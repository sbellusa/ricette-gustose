          }
        ]
      }
    },
    {
      "instruction": "<p>While the pepper is cooking, peel and finely slice (don't chop!) your <strong>garlic</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1707132530890-x200.jpg",
