          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>curry powder</strong>, <strong>ground paprika</strong>,<strong> tomato paste </strong>and <strong>ginger & garlic paste</strong> to the pan and cook for 1 min further until fragrant</p>",
      "order": 4,
      "media": {
