          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1644935069277-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>honey-lime chicken skewers </strong>over the<strong> charred veg rice </strong>with the<strong> smoky</strong> <strong>mayo </strong>to the side</p><p>Enjoy!</p>",
