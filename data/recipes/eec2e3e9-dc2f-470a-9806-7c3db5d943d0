          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1644935069277-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1644935069277-x1000.jpg",
