          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1644935066852-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken is cooked through, stir the <strong>vegetable stock mix</strong> and <strong>charred veg </strong>through the <strong>basmati rice </strong>– this is your <strong>charred veg rice</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1644935069277-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1644935069277-x400.jpg",
