          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1809.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add the <strong>diced chicken breast</strong> to the pan and cook for 30 secs</p><p>Add <strong>half </strong>of the <strong>red chilli</strong> (can't handle the heat? Go easy!) with the<strong> curry powder</strong>, <strong>ground allspice</strong> and <strong>ground coriander</strong> and cook for 1-2 min further</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1809.-step-3-x200.jpg",
