          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1689685518416-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Grate your <strong>cheddar cheese</strong></p><p>Peel and grate your <strong>garlic</strong></p><p>Combine the <strong>grated cheese</strong> and <strong>cornflour</strong> in a pot with a pinch of <strong>salt </strong>and <strong>pepper</strong> and mix until the cheese is fully coated</p><p>Add your <strong>Dijon mustard</strong>,<strong> soft cheese</strong> and <strong>half</strong> the <strong>grated garlic</strong> (you'll use the rest later!) to the pot with 125ml<span class=\"text-purple\"> [190ml]</span> <span class=\"text-danger\">[250ml] </span><strong>milk </strong>– this is your<strong> mornay base</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1689685522914-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1689685522914-x400.jpg",
            "width": 400
