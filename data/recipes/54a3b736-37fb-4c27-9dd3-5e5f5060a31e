          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1680079294414-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the gnocchi is cooking, peel and finely slice your <strong>red onion[s]</strong></p><p>Chop your <strong>cherry tomatoes </strong>in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1680079300757-x200.jpg",
            "width": 200
