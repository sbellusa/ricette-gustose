  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle, then heat a large, wide-based pan (preferably non-stick) with a generous drizzle of <strong>olive oil </strong>over a medium-high heat</p><p>Once hot, add your<strong> gnocchi</strong> and cook for 8-10 min or until beginning to crisp, then transfer to a plate, reserving the pan</p><p>Tip: Don’t stir too often as this will prevent the gnocchi from crisping!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1680079294414-x200.jpg",
            "width": 200
