  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel your<strong> potatoes</strong> and chop them into large, bite-sized pieces</p><p>Peel and chop your <strong>brown onion[s] </strong>into wedges</p><p>Combine your <strong>cornflour</strong>, <strong>soy sauce </strong>and <strong>sesame oil </strong>with 2 tsp <span class=\"text-purple\">[3 tsp] </span><span class=\"text-danger\">[4 tsp]</span> <strong>sugar </strong>and 50ml <span class=\"text-purple\">[75ml] </span><span class=\"text-danger\">[100ml]</span> <strong>cold water </strong>– this is your <strong>braising liquid</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1721742552828-x200.jpg",
            "width": 200
