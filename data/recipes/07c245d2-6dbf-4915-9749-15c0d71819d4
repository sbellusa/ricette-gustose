            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/912.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, remove the pan from the heat and carefully add your <strong>tomato paste</strong> and<strong> chopped spinach</strong></p><p>Return the pan to the heat and and cook for 1 min</p><p>Dissolve your <strong>vegetable stock mix</strong> in 250ml<span class=\"text-purple\"> [325ml]</span> <span class=\"text-danger\">[450ml]</span> <strong>boiled</strong> <strong>water</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/912.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/912.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/912.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/912.-step-6-x1000.jpg",
            "width": 1000
