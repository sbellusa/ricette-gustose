            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your<strong> parsley</strong> roughly, including the stalks</p><p>Chop the <strong>remaining lemon</strong> into 1 wedge per person</p>",
      "order": 7,
      "media": {
        "images": [
