  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the brown rice to a pot with plenty of water and bring it to a boil<br /><br /><strong>Once</strong> boiling, reduce the heat and simmer with a lid on for 15 min or until cooked through<br /><br /><strong>Drain</strong> well and set aside (used in step 6)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to large pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the fennel seeds and paprika to the pan</p>\r\n<p><strong>Cook</strong> for 30 sec, or until the spices are starting to brown</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the pork and break the mince apart with a wooden spoon, season to your taste with salt and pepper</p>\r\n<p><strong>Cook</strong> for 8-10 min, or until caramelised and still moist</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong>, remove the core of the apple<span class=\"text-danger\">(s)</span> and dice finely<br /><br /><strong>Peel</strong> and dice the red onion finely<br /><br /><strong>Chop</strong> the coriander finely</p>\r\n<p><strong>Grate</strong> the zest of the lime<span class=\"text-danger\">(s)</span> and cut into quarters</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the lime zest, apple, coriander and red onion in a bowl</p>\r\n<p><strong>Squeeze</strong> over half of the <span class=\"text-danger\">(whole) </span>lime and mix well</p>\r\n<p><strong>Add</strong> a pinch of sugar and salt to taste</p>\r\n<p><strong>Set</strong> aside for step 8</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the brown rice to the pork pan</p>\r\n<p><strong>Mix</strong> well and remove from the heat</p>\r\n<p><strong>Transfer</strong> the rice and pork to a bowl</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Wipe</strong> the pan carefully with a tea towel</p>\r\n<p><strong>Add</strong> a tortilla wrap to the pan on a medium heat</p>\r\n<p><strong>Cook</strong> for 1 min each side, or until slightly browned and puffed up</p>\r\n<p><strong>Transfer</strong> to a plate and repeat until all the tortilla wraps are warm</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Divide</strong> the rice and pork mixture between the tortillas </p>\r\n<p><strong>Wrap</strong> your tortilla with salsa on top and lime juice to taste</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
