            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1691579733702-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>remaining cornflour</strong> to a large bowl with the <strong>cracked black pepper</strong>, half <span class=\"text-danger\">[all] </span>of the <strong>five-spice mix</strong>, 1 tsp<span class=\"text-danger\"> [2 tsp]</span> <strong>sugar </strong>and<strong> </strong>1/2 tsp <span class=\"text-danger\">[1 tsp]<strong> </span>salt</strong></p><p>Mix until fully combined – this is your <strong>salt & pepper coating</strong></p><p>Tip: Cooking for 2? Save the rest of the five-spice for another recipe!</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1691579736444-x200.jpg",
