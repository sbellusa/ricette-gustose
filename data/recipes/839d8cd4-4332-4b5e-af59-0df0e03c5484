            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, strip your <strong>sage leaves</strong> from their stalks and chop them finely, discard the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1632.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1632.-step-3-x400.jpg",
