            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the meatballs are browning, boil half a kettle</p><p>Slice your <strong>white cup mushrooms</strong> finely</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1673367155580-x200.jpg",
