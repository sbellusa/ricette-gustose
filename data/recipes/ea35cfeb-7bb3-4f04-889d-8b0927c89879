    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1707212702843-x200.jpg",
