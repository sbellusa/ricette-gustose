            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1635.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, strip the <strong>mint leaves</strong> from their stems and&nbsp;chop them roughly</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1635.-step-6-x200.jpg",
