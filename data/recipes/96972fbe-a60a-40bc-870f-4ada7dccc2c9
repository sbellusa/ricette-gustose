          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1662397175236-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1662397175236-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Melt 15g <span class=\"text-danger\">[30g]</span> <strong>butter</strong> in a pot over a medium-low heat</p><p>Once melted, add 20g <span class=\"text-danger\">[40g] </span><strong>flour</strong> and stir with a wooden spoon for 1 min or until a sandy paste forms</p><p>Add 150ml <span class=\"text-danger\">[300ml]</span> <strong>milk </strong>gradually and whisk for 2-3 min or until a smooth, thick sauce remains – this is your <strong>white sauce</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1662397183064-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1662397183064-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1662397183064-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1662397183064-x1000.jpg",
