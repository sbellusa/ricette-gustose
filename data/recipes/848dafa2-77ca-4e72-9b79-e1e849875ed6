            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve your <strong>soft cheese</strong> in 150ml<span class=\"text-purple\"> [225ml]</span> <span class=\"text-danger\">[300ml]</span> <strong>boiled water</strong> and add 100ml <span class=\"text-purple\">[150ml]</span> <span class=\"text-danger\">[200ml]</span> <strong>milk </strong>– this is your<strong> creamy stock</strong></p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1676913898773-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1676913898773-x400.jpg",
