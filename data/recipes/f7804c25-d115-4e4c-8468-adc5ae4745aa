            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large pot (preferably non-stick) with a drizzle of <strong>olive oil </strong>over a high heat</p><p>Once hot, add the <strong>sliced mushrooms</strong> and<strong> chopped garlic</strong> and reduce the heat to medium</p><p>Cook for 3 min or until the mushrooms have softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1856.-step-2-x200.jpg",
