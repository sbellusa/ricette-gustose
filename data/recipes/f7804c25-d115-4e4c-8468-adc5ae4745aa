          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1856.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve your <strong>vegetable stock mix </strong>in 200ml<span class=\"text-purple\"> [300ml] </span><span class=\"text-danger\">[400ml]</span> <strong>boiled water</strong></p><p>Add your <strong>soft cheese</strong> and give everything a good mix up – this is your <strong>creamy vegetable stock</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1856.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1856.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1856.-step-3-x700.jpg",
