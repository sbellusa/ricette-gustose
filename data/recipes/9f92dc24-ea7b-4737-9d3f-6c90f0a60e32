            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium heat</p><p>Once hot, add the <strong>onion petals</strong> and <strong>sliced chilli </strong>(can't handle the heat? Go easy!) and cook for 3-4 min or until beginning to soften</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1687507580167-x200.jpg",
