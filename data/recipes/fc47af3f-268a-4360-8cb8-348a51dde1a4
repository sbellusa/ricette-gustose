    },
    {
      "instruction": "<p>Meanwhile, trim your <strong>green beans</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1674830688608-x200.jpg",
