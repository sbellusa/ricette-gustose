            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail and grate your <strong>carrot[s] </strong>(no need to peel!)</p><p>Trim, then slice your <strong>sugar snap peas</strong> finely on a diagonal</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1620663368894-x200.jpg",
