            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once golden, add the <strong>chopped pepper </strong>and<strong> remaining garlic </strong>to the pan<strong> </strong>and cook for 2-3 min or until the pepper is starting to soften</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1663691014137-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1663691014137-x400.jpg",
