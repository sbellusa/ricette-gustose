          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-10-1647971411904-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-10-1647971411904-x1000.jpg",
