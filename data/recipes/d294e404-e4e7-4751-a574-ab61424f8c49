            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-10-1647971411904-x200.jpg",
            "width": 200
          },
          {
