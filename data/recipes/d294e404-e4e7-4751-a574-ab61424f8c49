            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion and carrot are beginning to soften, add your <strong>lean beef mince</strong> to the pan and increase the heat to high</p><p>Cook for 3-4 min further or until browned all over, breaking it up with a wooden spoon as you go</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-8-1647971415602-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-8-1647971415602-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-8-1647971415602-x700.jpg",
