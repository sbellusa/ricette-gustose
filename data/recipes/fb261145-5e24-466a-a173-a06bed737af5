            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>grated carrot</strong> with the <strong>grated apple</strong>, <strong>grated cucumber</strong>, the juice of 1/2 <span class=\"text-danger\">[1]</span> <strong>lime</strong> and the <strong>mayo </strong>in a bowl – this is your <strong>tangy slaw</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1629798907612-x200.jpg",
