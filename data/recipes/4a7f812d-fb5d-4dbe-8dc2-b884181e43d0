          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1693829655129-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, drain your <strong>pineapple</strong>, (save the juice, you'll use it later!)</p><p>Peel and chop your <strong>brown onion[s]</strong> into wedges</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1693829660930-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1693829660930-x400.jpg",
