  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 2)</p>\r\n<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the cauliflower into similar size pieces - roughly the size of a ping pong ball</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Bring</strong> a large pot of water to the boil with salt (optional) and add the pasta</p>\r\n<p><strong>Cook</strong> for 8 min, adding the cauliflower halfway through the cooking time </p>\r\n<p><strong>Drain</strong> and reserve the pan</p>\r\n<p><strong>Cut</strong> the tallegio (including the rind) into 2cm pieces, ready for step 4</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pot to a medium heat and melt 30g <span class=\"text-danger\">(60g)</span> of butter</p>\r\n<p><strong>Once</strong> melted stir in 30g <span class=\"text-danger\">(60g)</span> of flour and cook for 2 min, stirring constantly with a wooden spoon</p>\r\n<p><strong>This</strong> is your roux</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Whisk</strong> 300ml <span class=\"text-danger\">(600ml)</span> of milk and 100ml <span class=\"text-danger\">(200ml)</span> of boiling water gradually into the roux</p>\r\n<p><strong>Cook</strong> for 5 min, stirring constantly, or until the sauce has the same consistency as double cream</p>\r\n<p><strong>Combine</strong> the dijon, half the taleggio, drained pasta and cauliflower and season generously</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> to the oven-proof dish, tuck the remaining half of taleggio in amongst the pasta and sprinkle with breadcrumbs </p>\r\n<p><strong>Cook</strong> in the oven for 5 min </p>\r\n<p><strong>Then</strong> grill on high for a further 5 min</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the tomato up finely</p>\r\n<p><strong>Chop</strong> the capers finely</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the tomatoes, capers, 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> olive oil, salt and pepper to taste </p>\r\n<p><strong>This</strong> is your salsa</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the dish straight from the oven with the salsa as a garnish</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
