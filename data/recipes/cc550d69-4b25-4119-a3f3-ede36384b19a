  "cooking_instructions": [
    {
      "instruction": "<p><strong>Chop</strong> the coriander coarsely</p>\r\n<p><strong>Slice</strong> the spring onion<span class=\"text-danger\">(s)</span> finely, discarding the root ends</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the sweetcorn and transfer half of the kernals to a blender</p>\r\n<p><strong>Blend</strong> to form a coarse pulp</p>\r\n<p><strong>Combine</strong> the pulp with the remaining kernels</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 75ml <span class=\"text-danger\">(150ml)</span> of milk and the eggs to a bowl, whisk well</p>\r\n<p><strong>Add</strong> 90g <span class=\"text-danger\">(180g)</span> self-raising flour (plain is fine too), paprika, salt and pepper to another bowl, mix well</p>\r\n<p><strong>Combine</strong> the eggy milk and seasoned flour together to form a batter</p>\r\n<p><strong>Mix</strong> in the corn mixture, spring onion and coriander to the batter</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> and discard the stem and seeds of the chilli<span class=\"text-danger\">(es)</span>, and slice finely</p>\r\n<p><strong>Chop</strong> the tomatoes into chunky dice</p>\r\n<p><strong>Grate</strong> the zest of the lime(s) then chop the limes in two, ready for juicing</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the juice and zest of the lime<span class=\"text-danger\">(s)</span>, 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar and 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil to a bowl and whisk well</p>\r\n<p><strong>Add</strong> the tomato and chilli to the bowl and mix well to make the salsa</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a large pan (preferably non stick) on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add a large dollop of corn mixture to the pan and cook for 2 min or until golden brown on each side then remove to a kitchen towel lined plate</p>\r\n<p>Tip - If you are feeling confident, you can make more than one fritter at once, otherwise do one at a time.</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the halloumi into 8 <span class=\"text-danger\">(16)</span> slices</p>\r\n<p><strong>Once</strong> all the fritters are cooked, add the halloumi to the pan or use a griddle plan if you have one <br /><br /><strong>Cook</strong> for 2 min on each side on a high heat, or until browned and charred on the outside</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the fritters with the halloumi, and the salsa to the side </p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
