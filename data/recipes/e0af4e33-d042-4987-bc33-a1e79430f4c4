          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1577.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>rested gammon</strong>&nbsp;finely and serve with the <strong>leek and potato gratin</strong> and <strong>wilted spring greens</strong> to the side&nbsp;</p>\r\n<p>Enjoy!</p>",
