  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas9</p>\r\n<p><strong>Cut</strong> all the potatoes to roughly equal size (approx. 2cm chunks)<br /><br /><strong>Cut</strong> the onions into quarters</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the potatoes, sausages and onions on an oven tray, coat well with 2-4 tbsp of olive oil and season to your taste with salt and pepper</p>\r\n<p>Tip: You may need to use more than one tray, you want the vegetables to have some space inbetween them!</p>\r\n<p><strong>Put</strong> in the oven for 25-35 min or until golden and crisp</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the apples</p>\r\n<p><strong>Cut </strong>them into similar sized chunks (approx. 3cm) cubes</p>\r\n<p><strong>Discard </strong>the core&nbsp;</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the apple to a pot with 200ml <span class=\"text-danger\">(300ml)</span> of cold water </p>\r\n<p><strong>Bring</strong> to the boil over a medium-high heat</p>\r\n<p><strong>Cook</strong> for 10-15 min until the apple is softened</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Separate</strong> the sage leaves</p>\r\n<p><strong>Heat</strong> a pan with 3-5 tbsp of sunflower oil on a medium heat for approx. 1-2 min, or until hot </p>\r\n<p><strong>Lay</strong> a few sheets of kitchen towel ready at the side of your pan, and grab a pair of tongs or a slotted spoon</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a pan with 3-5 tbsp of sunflower oil on a medium heat for approx. 1-2 min, or until hot </p>\r\n<p><strong>Lay</strong> a few sheets of kitchen towel ready at the side of your pan, and grab a pair of tongs or a slotted spoon</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Check</strong> the apples are softened</p>\r\n<p><strong>Once</strong> softened, remove from the heat and mash them thoroughly with a potato masher</p>\r\n<p><strong>You</strong> should end up with a coarse homemade apple sauce</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the sausage traybake is cooked, remove the skin from the onions by cutting the attached end off and separating the 'petals'</p>\r\n<p><strong>Serve</strong> the sausages, onion petals and potatoes with the apple sauce on the side and the crispy sage leaves scattered over</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
