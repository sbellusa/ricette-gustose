  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your<strong> chicken</strong> out of the fridge, open the packet and let it air</p><p>Add your <strong>ground</strong> <strong>smoked paprika</strong>, <strong>dried oregano</strong> and <strong>cayenne pepper</strong> (can't handle the heat? Go easy!) to a plate with a generous pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Give it a good mix up – this is your<strong> Cajun-style spice mix</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1690285130856-x200.jpg",
            "width": 200
