          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674487253845-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674487253845-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674487253845-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>ciabatta[s]</strong> in half</p><p>Add the<strong> sliced ciabatta</strong>,<strong> </strong>cut-side up, to a separate baking tray (or two!)</p><p>Put the tray[s] in the oven for 5-6 min or until toasted and lightly golden</p><p>Once toasted, remove the tray[s] from the oven</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1674487258518-x200.jpg",
            "width": 200
