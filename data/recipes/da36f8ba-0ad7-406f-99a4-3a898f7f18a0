  "cooking_instructions": [
    {
      "instruction": "<p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat</p><p>Once hot, add your <strong>coconut flakes</strong> and <strong>flaked almonds </strong>and cook for 2-3 min or until toasted and lightly golden</p><p>Tip: Watch them like a hawk so they don't burn!</p><p>Once toasted, transfer the <strong>toasted coconut &</strong> <strong>almonds</strong> to a plate and reserve the pan</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1679486305977-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1679486305977-x400.jpg",
