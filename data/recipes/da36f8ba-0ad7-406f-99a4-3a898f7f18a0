          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679486340528-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679486340528-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> spicy</strong> <strong>karahi-style paneer </strong>with the <strong>peshwari rice</strong> to the side</p><p>Tip: For fancy presentation, press the rice into a small bowl and turn out</p><p>Garnish with the <strong>reserved</strong> <strong>ginger matchsticks</strong></p><p>Enjoy!</p>",
      "order": 8,
