  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Combine the<strong> tomato paste</strong>, <strong>chopped garlic</strong> and <strong>dried oregano </strong>with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> <strong>water </strong>and a pinch of <strong>salt</strong> and <strong>pepper</strong> – this is your <strong>tomato sauce</strong></p>",
      "order": 1,
