  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Slice the <strong>waxy potatoes</strong> (skins on) into 1-2cm thick discs</p><p>Add the<strong> vegetable stock mix</strong> to a large pot of<strong> boiled water </strong>and bring to a boil over a high heat</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1610968954240-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1610968954240-x400.jpg",
            "width": 400
