            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped chives</strong>, the<strong> </strong>juice of <strong>half</strong> your <strong>lemon wedge[s]</strong><span class=\"text-danger\"> </span>and a pinch of <strong>salt</strong> and <strong>pepper</strong> to the <strong>béchamel sauce</strong></p><p>Give everything a good mix up</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4--1586957750091-x200.jpg",
