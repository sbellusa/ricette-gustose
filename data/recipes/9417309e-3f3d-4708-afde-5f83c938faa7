            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp] </span><span class=\"text-danger\">[2 tbsp]</span> <strong>vegetable oil</strong> and a pinch of <strong>salt</strong> to the <strong>drained potatoes</strong> and give everything a good mix up</p><p>Tip: Don't worry if the potatoes break up a bit!</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1586957754215-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1586957754215-x400.jpg",
