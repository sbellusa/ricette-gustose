          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1644330246644-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While everything's cooking, wash your<strong> lettuce</strong> and chop into wedges, then pat it dry with kitchen paper</p><p>Chop your <strong>chives </strong>finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1644330257988-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1644330257988-x400.jpg",
