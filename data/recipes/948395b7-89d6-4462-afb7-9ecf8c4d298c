  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Add your<strong> potato[es]</strong> to a large baking tray and prick a few times with a sharp knife</p><p>Drizzle with <strong>olive oil </strong>and season with a pinch of <strong>salt </strong>and<strong> pepper</strong></p><p>Put the tray in the oven and cook for 60 min or until cooked through and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1644330213512-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1644330213512-x400.jpg",
