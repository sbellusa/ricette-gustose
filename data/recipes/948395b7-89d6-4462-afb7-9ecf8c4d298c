          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1644330257988-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1644330257988-x1000.jpg",
