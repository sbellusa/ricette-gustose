  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat </strong>the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes into wedges, then cut each wedge in half in the opposite direction</p>\r\n<p><strong>Place</strong> on a baking tray, coat well with a 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of the chilli oil &amp; season to taste with salt and pepper</p>\r\n<p><strong>Put</strong> in the oven for 20 min or until golden &amp; crisp</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and slice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Cut</strong> the pepper<span class=\"text-danger\">(s)</span> into strips, discarding the pith and seeds</p>\r\n<p><strong>Soak</strong> the skewers in cold water until step 4</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil in a large pan</p>\r\n<p><strong>When</strong> hot, add the pepper and onion and a large pinch of salt</p>\r\n<p><strong>Cook</strong> for 5 min on a medium heat</p>\r\n<p><strong>Once</strong> softened, turn the heat down to low and cook for 20 min until caramelised and very soft</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Reserve</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of the chipotle paste for step 6 - Combine the remaining chipotle paste and 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> chilli oil with 1 tsp <span class=\"text-danger\">(2 tsp)</span> of salt and pepper in a large mixing bowl</p>\r\n<p><strong>Cut</strong> the chicken into strips (approx. 2cm thick) and coat them evenly in the marinade</p>\r\n<p><strong>Thread</strong> the chicken pieces onto your soaked skewers</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chicken skewers to a baking tray (use tin foil to avoid mess)</p>\r\n<p><strong>Once</strong> the potatoes are ready, heat the grill to high and leave the potatoes in the bottom of the oven to keep warm</p>\r\n<p><strong>Grill</strong> the chicken on a high heat for 20 min, turning once</p>\r\n<p>Tip: If you don't have a grill, use a frying pan on a high heat and cook as above</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Finely</strong> slice the spring onion</p>\r\n<p><strong>Combine</strong> the mayonnaise with the remaining chipotle paste, chopped spring onion, 1 tsp of the red wine vinegar and a drizzle of olive oil</p>\r\n<p><strong>Mix</strong> well to combine - this is your mayonnaise</p>\r\n<p><strong>Chop</strong> the coriander finely</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the remaining red wine vinegar to the pepper and onion mix with 1 tsp <span class=\"text-danger\">(1.5 tsp)</span> of sugar and 50ml <span class=\"text-danger\">(100ml)</span> of boiling water</p>\r\n<p><strong>Remove</strong> from the heat, stir in the coriander and season generously with salt</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the grilled skewers over the pepper salsa with the potatoes and mayo to the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
