            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1689669870246-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray[s] in the oven for 13-15 min or until the cheese has melted and the base is crisp – this is your <strong>margherita</strong> <strong>pizza</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1689669874797-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1689669874797-x400.jpg",
