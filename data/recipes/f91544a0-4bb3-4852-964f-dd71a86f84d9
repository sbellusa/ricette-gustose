  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your<strong> potatoes</strong> (skins on) into small bite-sized pieces</p><p>Add the <strong>chopped potatoes </strong>to a baking tray (or two!) with a drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Sprinkle your <strong>dried oregano</strong> all over, give everything a good mix up and put the tray[s] in the oven for an initial 10 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1649773655302-x200.jpg",
