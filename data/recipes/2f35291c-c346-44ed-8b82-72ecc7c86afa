          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1730.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>chicken stock</strong>, <strong>cherry tomatoes</strong> and <strong>chickpeas</strong> and cook, covered, for 15 min or until thickened slightly – this is your<strong> cherry tomato stew</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1730.-step-5-x200.jpg",
