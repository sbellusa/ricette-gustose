  "cooking_instructions": [
    {
      "instruction": "<p><strong>Pre-</strong>heat the oven to 230&deg;C/ 210&deg;C (fan)/ 450&deg;F/ Gas 8</p>\r\n<p><strong>Grease</strong> an oven tray with 1-2 tbsp of oil and add the sausages</p>\r\n<p><strong>Put</strong> in the oven for 25 min or until browned</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Rinse</strong> the lentils</p>\r\n<p>Tip: Watch out for any stones in the lentils that may occur naturally in the harvesting process</p>\r\n<p><strong>Add</strong> the lentils and rosemary sprig to a pot with 1L <span class=\"text-danger\">(1.5L)</span> of water and bring to a boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer for 25-30 min or until tender</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and chop the onion finely</p>\r\n<p><strong>Crush</strong> the garlic, peel and chop finely</p>\r\n<p><strong>Add</strong> 1/2-1 tbsp of olive oil to a pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the onion, garlic, 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar and salt to taste</p>\r\n<p><strong>Reduce</strong> the heat to low and cook for 20 min, or until caramalised</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the cherry tomatoes into halves</p>\r\n<p><strong>Chop</strong> the parsley finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cherry tomatoes and red wine vinegar to the onion pan</p>\r\n<p><strong>Cook</strong> for 10 min, then add 30ml <span class=\"text-danger\">(60ml)</span> of water to form a relish-like consistency</p>\r\n<p><strong>Break</strong> the mixture with a masher (alternatively with a slotted spoon) to form a relish</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the lentils are done, drain well<br /><br /><strong>Remove</strong> and discard the rosemary stalk</p>\r\n<p><strong>Add</strong> 1-2 tbsp of olive oil and chopped parsley to the lentils</p>\r\n<p><strong>Season</strong> generously with salt and black pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the sausages from the oven</p>\r\n<p><strong>Cut</strong> the sausages diagonally into bite size pieces</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the relish on top of the lentils, with the sliced sausages piled on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
