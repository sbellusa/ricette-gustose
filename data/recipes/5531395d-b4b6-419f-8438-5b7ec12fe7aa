          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1620664016377-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1620664016377-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>spicy lamb ragù pasta</strong> topped with your <strong>grated Italian hard cheese</strong></p><p>Tear your <strong>mint leaves</strong> over the top</p><p>Dig in!</p>",
      "order": 8,
