            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>lamb mince </strong>to the dish, breaking it up into rough, large chunks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1620663992479-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1620663992479-x400.jpg",
            "width": 400
