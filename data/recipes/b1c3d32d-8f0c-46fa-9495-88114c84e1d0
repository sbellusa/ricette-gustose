            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>brioche bun[s]</strong> in half</p><p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat and add the <strong>brioche halves</strong>, cut-side down</p><p>Cook for 2-3 min or until toasted and charred, then set aside until serving</p>",
      "order": 7,
      "media": {
        "images": [
