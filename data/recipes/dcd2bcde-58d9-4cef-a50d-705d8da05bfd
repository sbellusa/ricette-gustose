          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and chop the garlic roughly</p>\r\n<p><strong>Chop</strong> the parsley roughly, including the stalks</p>\r\n<p><strong>Drain</strong> and discard a little&nbsp;liquid from the chickpeas</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-3-x700.jpg",
