  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the sweet potatoes (skin on) into&nbsp;chips&nbsp;</p>\r\n<p><strong>Add</strong> the chips to&nbsp;a large bowl with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil and a generous pinch of salt and pepper and toss to coat evenly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cornflour to the bowl and toss to coat them evenly</p>\r\n<p><strong>Add</strong> the chips to a baking tray, skin-side down (use tin foil to avoid mess!)</p>\r\n<p><strong>Put</strong> the tray in the oven&nbsp;for 30-35 min or until the chips are tender and starting to crisp</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/625.-step-2-x400.jpg",
            "width": 400
          },
          {
