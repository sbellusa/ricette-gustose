          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1648027639819-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the beans are thickening, trim, then finely slice your <strong>spring onion[s]</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1648027643725-x200.jpg",
            "width": 200
