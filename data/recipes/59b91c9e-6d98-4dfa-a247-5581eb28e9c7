          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1648027643725-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1648027643725-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1648027643725-x1000.jpg",
            "width": 1000
