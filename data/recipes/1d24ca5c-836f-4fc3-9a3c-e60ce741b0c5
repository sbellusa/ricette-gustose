          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-1684227522332-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> vegetable oil</strong> over a high heat</p><p>Once hot, add your <strong>meat-free chick'n </strong>and cook for 5-6 min or until starting to brown</p>",
      "order": 4,
      "media": {
        "images": [
          {
