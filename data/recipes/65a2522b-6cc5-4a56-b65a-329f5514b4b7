            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the<strong> chicken stock mix</strong> in 400ml <span class=\"text-danger\">[800ml]</span> <strong>boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1411.-step-4-x200.jpg",
