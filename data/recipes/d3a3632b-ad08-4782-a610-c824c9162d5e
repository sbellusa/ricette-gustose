  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Boil half a kettle</p><p>Peel and finely chop the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Drain the <strong>jackfruit</strong> and tear (or chop!) into small, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1601311876741-x200.jpg",
            "width": 200
