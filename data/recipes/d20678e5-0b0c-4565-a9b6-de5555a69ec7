        ]
      }
    },
    {
      "instruction": "<p>Chop <strong>half</strong> your<span class=\"text-danger\"> </span><strong>tomato[es] </strong>roughly</p><p>Peel and chop (or grate) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1671539445549-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1671539445549-x400.jpg",
