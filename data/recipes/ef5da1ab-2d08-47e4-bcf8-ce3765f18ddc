            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>spinach</strong>, then pat it dry with kitchen paper</p><p>Chop any larger pieces of <strong>haddock</strong> into bite-sized pieces</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1666697034032-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1666697034032-x400.jpg",
