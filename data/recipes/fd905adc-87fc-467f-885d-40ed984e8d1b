          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1103.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1103.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1103.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, dry, wide-based pan (preferably non-stick with a matching lid) over a medium heat</p><p>Once hot, add your <strong>flaked almonds</strong> and cook for 2-3 min or until toasted and lightly golden, then set them aside and reserve the pan</p><p>Tip: Watch them like a hawk so they don't burn!</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1652344075434-x200.jpg",
            "width": 200
