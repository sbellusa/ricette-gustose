  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>potatoes</strong> (skins on) into <strong>chunky chips</strong>, then add them to a baking tray with a generous drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong> and<strong> pepper</strong></p><p>Sprinkle over <strong>half</strong> the <strong>dried sage</strong> (save the rest for later!) and give everything a good mix up</p><p>Put the tray in the oven for 30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2320.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2320.-step-1-x400.jpg",
            "width": 400
