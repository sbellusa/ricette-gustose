            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the fries are cooking, cut your <strong>halloumi</strong> into 4 slices per person</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1622541662841-x200.jpg",
