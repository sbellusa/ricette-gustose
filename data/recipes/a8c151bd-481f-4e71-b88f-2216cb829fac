  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Peel and cut your <strong>sweet potato[es]</strong> into fries</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1622541632717-x200.jpg",
