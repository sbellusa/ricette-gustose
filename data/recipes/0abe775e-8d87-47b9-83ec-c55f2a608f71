            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>hake fillet[s]</strong> into large, bite-sized pieces</p><p>Add the <strong>chopped hake</strong> to a large bowl with the <strong>remaining soy sauce</strong>, then set aside to marinate</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1697453777640-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1697453777640-x400.jpg",
