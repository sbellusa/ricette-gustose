            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the rice is cooled, roll into 3 balls per person (clean hands is the best way!) – these are your <strong>sushi rice balls</strong></p><p>Tip: Use wet hands to make it easier!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1697453764372-x200.jpg",
