            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and grate your <strong>garlic</strong></p><p>Combine <strong>half</strong> your <strong>soy sauce </strong>and the<strong> grated garlic </strong>in a bowl with your <strong>chilli flakes</strong> (can't handle the heat? Go easy!) and a pinch of <strong>sugar</strong> – this is your <strong>dipping sauce</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1697453781768-x200.jpg",
