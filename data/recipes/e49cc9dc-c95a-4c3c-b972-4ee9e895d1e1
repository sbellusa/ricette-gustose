  "cooking_instructions": [
    {
      "instruction": "<p>Rinse the <strong>sushi</strong> <strong>rice</strong> in a sieve under <strong>cold running water </strong>for 30 secs (use your hands to really wash the grains!), then set aside to drain fully</p><p>Add the <strong>drained</strong> <strong>rice</strong> with 200ml<span class=\"text-danger\"> [400ml]</span> <strong>cold</strong> <strong>water</strong> and a generous pinch of <strong>salt</strong> to a pot with a lid and bring to the boil over a high heat</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680047543937-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680047543937-x400.jpg",
