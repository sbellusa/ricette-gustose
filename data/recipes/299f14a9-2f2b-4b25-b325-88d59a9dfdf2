  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> occasionally and once done, set aside until ready to serve</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, boil a kettle (used in step 4)</p>\r\n<p><strong>Peel</strong>, top and tail the carrot<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Continue</strong> to peel lengths of carrot until you end up with a pile of carrot 'ribbons'</p>\r\n<p><strong>Once</strong> you've peeled as far as you can, grate the inner stem</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely dice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Heat</strong> 2-3 tbsp of vegetable oil in a large pan</p>\r\n<p><strong>Add</strong> the grated carrot, onion, curry powder and a pinch of salt</p>\r\n<p><strong>Cook</strong> on a medium heat for 5 min or until starting to colour</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the stock cube and 300ml <span class=\"text-danger\">(500ml)</span> of boiled water</p>\r\n<p><strong>Add</strong> 1 tbsp <span class=\"text-danger\">(1 1/2 tbsp)</span> of flour to the carrot mixture, cook for 1 min</p>\r\n<p><strong>Stir</strong> in the stock and 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> sugar, mixing well to combine</p>\r\n<p><strong>Continue</strong> to cook for 5-10 min or until thickened on a low heat</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the spring onions finely </p>\r\n<p><strong>Add</strong> the carrot ribbons, spring onion and coriander to a bowl</p>\r\n<p><strong>Add</strong> the rice vinegar - mix well</p>\r\n<p><strong>Set</strong> aside for step 8</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Crack</strong> the egg<span class=\"text-danger\">(s)</span> into a shallow bowl and beat well with a fork<br /><br /><strong>On</strong> another plate, add 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of plain flour and season generously with salt and pepper</p>\r\n<p><strong>On</strong> a third plate, add the breadcrumbs</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> each pork loin steak in half lengthways, to form 4 <span class=\"text-danger\">(8)</span> escalopes</p>\r\n<p>Tip: Lay your hand flat over the steaks and carefully saw through with a sharp knife</p>\r\n<p><strong>Coat</strong> one escalope with the seasoned flour, tapping off any excess</p>\r\n<p><strong>Dip</strong> it in the egg and coat well, then roll it in the breadcrumbs and coat evenly</p>\r\n<p><strong>Repeat</strong> with the remaining steaks</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a pan with 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> of vegetable oil and once hot add the pork</p>\r\n<p><strong>Cook</strong> on each side for 4 min, then season to your taste</p>\r\n<p><strong>Serve</strong> the rice, breaded pork, sauce and salad together</p>\r\n<p>Tip: For authentic presentation, press the rice into a small bowl and turn out</p>\r\n<p>Enjoy!</p>\r\n<p>&nbsp;</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
