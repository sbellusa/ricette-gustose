  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes into small wedges</p>\r\n<p><strong>Place</strong> on a baking tray, coat evenly with 1-2 tbsp of olive oil and season to your taste with salt and pepper</p>\r\n<p><strong>Put</strong> it in the oven for 30-40 min, checking halfway through</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Shred</strong> the little gem finely with a knife </p>\r\n<p><strong>Cut</strong> the radishes into thin slices</p>\r\n<p><strong>Combine</strong> in a bowl and set aside until step 7</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the white wine vinegar with 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> of olive oil to make a dressing </p>\r\n<p><strong>Use</strong> half in step 4 and the other half in step 7</p>\r\n<p><strong>Season</strong> with salt and pepper and mix well</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Finely</strong> slice the spring onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Combine</strong> half of the dressing (from step 3) with the mayonnaise sachets and chopped spring onion, mixing well</p>\r\n<p><strong>Set</strong> the remaining dressing aside for step 7</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the fish fillets in half widthways</p>\r\n<p><strong>Pour</strong> the breadcrumbs onto a plate, and season generously with salt and pepper, then press the fish into the breadcrumbs to coat evenly</p>\r\n<p><strong>Place</strong> the fillets on a separate baking tray (use tin foil to avoid mess)</p>\r\n<p><strong>Put</strong> the tray in the oven for 10-12 min or until the fish is cooked through</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the brioche buns in half </p>\r\n<p><strong>Heat</strong> a large wide based dry pan on a high heat (use a griddle pan if you have one!)</p>\r\n<p><strong>When</strong> hot, add the brioche buns, cut side down and toast them for 3 min or until coloured on one side only </p>\r\n<p><strong>Remove</strong> and set aside until serving</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potato wedges and fish are cooked, add the remaining dressing to the salad and toss</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the fish fillets piled onto the toasted brioche with the spring onion mayo on top</p>\r\n<p><strong>Serve</strong> the crispy wedges and salad on the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
