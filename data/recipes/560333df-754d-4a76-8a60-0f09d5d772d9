  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Score a cross very lightly in the base of your <strong>tomato[es] </strong>and add them to a large, heat-proof bowl</p><p>Cover them with <strong>boiled water </strong>until they’re fully submerged and set them aside for 5 min</p><p>Tip: The boiling water loosens the skins for easy peeling in step 4!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/767-Step-1-x200.jpg",
            "width": 200
