  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Peel and finely dice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Chop the <strong>potatoes</strong> (skins on) into small bite-sized pieces</p><p>Top, tail, peel and dice the <strong>carrot<span class=\"text-danger\">[s]</span> </strong>finely</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
