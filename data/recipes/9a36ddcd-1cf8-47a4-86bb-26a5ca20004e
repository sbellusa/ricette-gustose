            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>little gem lettuce</strong> into bite-size pieces</p>\r\n<p>&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
