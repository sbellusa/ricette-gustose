  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> the ginger and chop finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Remove</strong> the stem<span class=\"text-danger\">(s)</span> of the chilli<span class=\"text-danger\">(es)</span>, deseed and slice finely</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to a boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> occasionally to prevent over-cooking and once done, set aside until you are ready to serve</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a pot with a lid on a medium heat</p>\r\n<p><strong>Once</strong> hot, add the turmeric, kaffir lime leaves and fennel seeds and stir briefly</p>\r\n<p><strong>Add</strong> the garlic, ginger, and chilli (adjust the amount to your preferred hotness)</p>\r\n<p><strong>Cook</strong> for 1-2 min or until golden and fragrant and remove from the heat (until step 5)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the prawns and add to a bowl </p>\r\n<p><strong>Coat</strong> with the cumin and season with salt and pepper, and leave to marinade in a bowl until step 6</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the spice pot to a medium heat and add the canned tomatoes</p>\r\n<p><strong>Fill</strong> half <span class=\"text-danger\">(all)</span> the empty tomato can with water and add to the pot</p>\r\n<p><strong>Add</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar and season to your taste with salt</p>\r\n<p><strong>Mix</strong> well, cover, bring to a boil and then simmer gently for 4-5 min</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the prawns and cook for 2 min or until they are pink, opaque and cooked through</p>\r\n<p><strong>Chop</strong> the coriander coarsely</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> half of the the coriander to the pot, mix well and remove from the heat</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the curry leaves before serving</p>\r\n<p><strong>Serve</strong> the curry with the rice and a sprinkling of coriander on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
