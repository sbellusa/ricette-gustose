  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 160&deg;C/ 140&deg;C (fan)/ 325&deg;F/ Gas 3 and boil a kettle&nbsp;</p>\r\n<p>Add the&nbsp;<strong>shredded kale&nbsp;</strong>to a large baking tray with a generous pinch of&nbsp;<strong>salt</strong>, 1 tsp<span class=\"text-danger\">&nbsp;[2 tsp]</span>&nbsp;<strong>sugar&nbsp;</strong>and a drizzle of&nbsp;<strong>vegetable oil</strong></p>\r\n<p>Massage the&nbsp;<strong>kale&nbsp;</strong>with clean hands so that it<strong>&nbsp;</strong>is evenly coated in&nbsp;<strong>oil</strong></p>\r\n<p>Put the baking tray in the oven for 20-25 min or until it's crispy&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1164.-step-1-x200.jpg",
            "width": 200
