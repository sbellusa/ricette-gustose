            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat </strong>a pot (with a lid) with 1-2 tbsp vegetable oil over a medium heat</p>\r\n<p><strong>Once</strong>&nbsp;hot, add the spring onion and cinnamon and cook for 30 sec, or until fragrant, stirring constantly</p>\r\n<p><strong>Stir</strong> in<strong>&nbsp;</strong>the rice, then add the kidney beans</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong>&nbsp;350ml <span class=\"text-danger\">[700ml]</span> water to the pot with a lid and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p><strong>Once</strong> cooked, remove from the heat and keep covered until serving</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-x200.jpg",
