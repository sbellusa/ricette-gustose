            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and chop the shallots finely</p>\r\n<p><strong>Cut</strong> the tomato<span class=\"text-danger\">[es]</span>&nbsp;in half</p>",
      "order": 2,
      "media": {
