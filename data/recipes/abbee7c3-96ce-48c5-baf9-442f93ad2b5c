  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the potatoes (skin on) into thin chips and place on a wide baking tray</p>\r\n<p><strong>Drizzle</strong> with 1-2 tbsp vegetable oil and season with a pinch of salt</p>\r\n<p><strong>Oven</strong>-roast for 30 min, or until golden</p>",
      "order": 1,
      "media": {
        "images": [
