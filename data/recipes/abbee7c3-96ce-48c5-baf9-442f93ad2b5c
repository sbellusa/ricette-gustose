      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the pan from the heat and add 4 tbsp <span class=\"text-danger\">[8 tbsp]</span>&nbsp;sour cream</p>\r\n<p><strong>Whisk</strong> to combine- you should end up with a glossy sauce, the consistency of double cream</p>\r\n<p><strong>Tip:</strong> add 1-2 tbsp more sour cream or water if the sauce is too thick</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step7-x200.jpg",
