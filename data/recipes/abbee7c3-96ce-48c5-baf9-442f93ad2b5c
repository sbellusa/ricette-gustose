            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return </strong>the pan to&nbsp;a medium heat with a drizzle of olive oil&nbsp;</p>\r\n<p><strong>Once </strong>hot, add the shallot and cook for 1 min, or until starting to brown</p>\r\n<p><strong>Add</strong> 100ml <span class=\"text-danger\">[200ml]</span>&nbsp;boiled water to the pan</p>\r\n<p><strong>Scrape</strong> the bottom of the pan and mix well</p>",
      "order": 5,
      "media": {
        "images": [
          {
