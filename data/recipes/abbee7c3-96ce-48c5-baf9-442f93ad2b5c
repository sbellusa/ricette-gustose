            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> a large, wide-based pan over a medium-high heat for 2 min- you want it really hot for the steaks!</p>\r\n<p><strong>Boil</strong> a kettle</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.step3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.step3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.step3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.step3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.step3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Pat</strong> the steaks dry, then rub them&nbsp;with 1-2 tsp vegetable oil and season with a large pinch of salt</p>\r\n<p><strong>Place</strong> the steaks in the pan and cook on each side for 1 min</p>\r\n<p><strong>Transfer</strong> to a plate, cover&nbsp;with foil or a tea towel and reserve the pan</p>\r\n<p><strong>Add</strong> the tomatoes to the chip tray in the oven, cut side up</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step4-x200.jpg",
            "width": 200
