      }
    },
    {
      "instruction": "<p><strong>Crumble</strong> in half the <span class=\"text-danger\">[whole]</span>&nbsp;stock cube</p>\r\n<p><strong>Add</strong> 1 tsp <span class=\"text-danger\">[2 tsp]</span>&nbsp;black pepper</p>\r\n<p><strong>Add</strong> the dijon mustard and cook for 2 min</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step6-x700.jpg",
