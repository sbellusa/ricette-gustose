          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/285.-step7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the steak and spoon the sauce all over it</p>\r\n<p><strong>Serve</strong> the chips and the tomato half to the side</p>\r\n<p><strong>Enjoy!</strong></p>",
