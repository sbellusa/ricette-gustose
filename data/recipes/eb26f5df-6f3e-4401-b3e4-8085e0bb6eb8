    {
      "instruction": "<p>Peel the skin off your <strong>smoked mackerel fillet[s]<span class=\"text-danger\"> </span></strong>and discard the skin</p><p>Tear the <strong>smoked mackerel </strong>into rough pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-1718090484904-x200.jpg",
