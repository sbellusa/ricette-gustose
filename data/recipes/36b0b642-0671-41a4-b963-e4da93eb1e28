            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>tomato[es] </strong>into wedges</p><p>Slice your <strong>baby button mushrooms</strong> finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1714735922941-x200.jpg",
