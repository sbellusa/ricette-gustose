  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Bash your <strong>lemongrass</strong> with a <strong>rolling pin</strong></p><p>Remove the <strong>tough outer layers</strong> of the lemongrass<strong> </strong>and set aside for later</p><p>Chop the <strong>softer inner core[s]</strong> finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1714735808519-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1714735808519-x400.jpg",
