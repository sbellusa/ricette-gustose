            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice your <strong>spring onion[s]</strong></p><p>Dissolve your <strong>chicken stock mix</strong> in 200ml <span class=\"text-purple\">[275ml]</span><span class=\"text-danger\"> [350ml]</span> <strong>boiled water</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1673354033275-x200.jpg",
