            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your<strong> cucumber</strong> in half lengthways</p><p>Bash the <strong>halved cucumber</strong> with a <strong>rolling pin</strong> then slice into bite-sized chunks – this is your <strong>smashed cucumber</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1659890666693-x200.jpg",
            "width": 200
