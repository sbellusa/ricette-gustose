          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1659890670462-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a high heat</p><p>Once hot, add your <strong>lamb mince</strong> and<strong> cornflour</strong> to the pan and cook for 4-5 min or until beginning to brown, breaking it up with a wooden spoon as you go</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1659890674196-x200.jpg",
