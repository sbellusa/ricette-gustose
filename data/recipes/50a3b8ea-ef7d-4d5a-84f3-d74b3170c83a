            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1659890674196-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice your <strong>spring onion[s] </strong>in half lengthways, then chop roughly</p><p>Peel and chop (or grate) your <strong>garlic</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1659890678329-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1659890678329-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1659890678329-x700.jpg",
