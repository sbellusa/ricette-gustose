            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the mushrooms are beginning to soften, add your <strong>cracked black pepper</strong> and a pinch of <strong>salt </strong>to the pan and cook for 1-2 min further</p>",
      "order": 4,
      "media": {
        "images": [
