  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 4)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Drain</strong>, rinse and chop the olives into 'O's</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the tomatoes into wedges (approx. 3cm thick)</p>\r\n<p><strong>Crumble</strong> 100g <span class=\"text-danger\">(200g)</span> of the feta cheese</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span>, cut in half and slice finely</p>\r\n<p><strong>Chop</strong> the parsley coarsely</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the pasta in a pot of boiling water and salt (optional) for 8-10 min or until the pasta is cooked to your taste, stirring occasionaly</p>\r\n<p><strong>Drain</strong> and reserve 1 cup of pasta water for steps 7 and 8</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add 1-2 tbsp of olive oil to a large pan on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the tomato wedges skin-side down preferably</p>\r\n<p><strong>Cook</strong> for 2-3 minutes until blistered and releasing their juices</p>\r\n<p><strong>Sprinkle</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar to reduce the acidity and add sweetness</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the onion to the tomato pan and cook for 3 min or until soft</p>\r\n<p><strong>Add</strong> the garlic and cook for 1 min, stirring constantly</p>\r\n<p><strong>Allow</strong> to simmer for 2-3 min</p>\r\n<p>Tip: If the sauce becomes too dry, gradually add a few tbsp of the pasta water</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the olives, capers and chilli flakes (careful, adjust the amount to your preferred hotness) to the pan</p>\r\n<p><strong>Add</strong> the feta and cook for 2-3 min</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the pasta to the sauce</p>\r\n<p>Tip: Should you wish, thin the sauce with a little of the reserved pasta water, bringing to a simmer and reducing to desired consistency </p>\r\n<p><strong>Sprinkle</strong> with parsley</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
