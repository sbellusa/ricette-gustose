            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium-high heat with a drizzle of <strong>olive oil</strong></p><p>Once hot, add the <strong>sliced onion </strong>and <strong>sliced pepper </strong>with a pinch of <strong>salt </strong>and cook for 3-4 min or until starting to soften</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1711454203782-x200.jpg",
