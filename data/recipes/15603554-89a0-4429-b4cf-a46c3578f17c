            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add your <strong>tomato paste</strong>, <strong>ground cumin </strong>and <strong>sweet pepper relish</strong></p><p>Cook for 1-2 min or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1711454207266-x200.jpg",
            "width": 200
