          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1637925199740-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1637925199740-x1000.jpg",
