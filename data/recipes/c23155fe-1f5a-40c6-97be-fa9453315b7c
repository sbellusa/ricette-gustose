          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, cut the pepper<span class=\"text-danger\">(s)</span> into 1cm strips, scraping out the pith and seeds with a teaspoon and discarding</p>\r\n<p><strong>Cut</strong> each mushroom into wedges</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/466.-step-4-new-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/466.-step-4-new-x400.jpg",
