  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Chop your<strong> cherry tomatoes </strong>in half</p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Chop your <strong>pitted olives </strong>roughly</p>",
      "order": 1,
      "media": {
        "images": [
