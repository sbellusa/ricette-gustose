            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray[s]<span class=\"text-danger\"> </span>in the oven for 15 min or until the veg has softened and the fish is cooked through – this is your <strong>fiery coconut cod & vegetables</strong></p><p>Tip: Your fish is cooked once it turns opaque and flakes easily</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1637071318998-x200.jpg",
