  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>capers</strong> and cook for 3-4 min, stirring frequently, or until crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1644835711367-x200.jpg",
