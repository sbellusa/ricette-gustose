            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1644835711367-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the capers are cooking, peel and finely dice your <strong>brown onion[s]</strong></p><p>Peel and finely slice (don't chop) your <strong>garlic</strong></p><p>Chop your <strong>cherry tomatoes</strong> in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1644835715564-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1644835715564-x400.jpg",
