          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1663752120582-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dust a work surface with a small handful of <strong>flour</strong></p><p>Unwrap your <strong>puff pastry </strong>and roll it out to approx. 0.5cm thickness with a <strong>rolling pin</strong></p><p>Cut the <strong>puff pastry</strong> into 1 rectangle per person and add them to a <strong>non-stick baking paper</strong>-lined<strong> </strong>baking tray (or two!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1663752131121-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1663752131121-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1663752131121-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1663752131121-x1000.jpg",
