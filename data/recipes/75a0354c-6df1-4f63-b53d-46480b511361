            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray[s] in the oven for 17-20 min or until puffed up, golden and cooked through – this is your <strong>creamy pesto salmon pasty</strong></p>",
      "order": 6,
      "media": {
        "images": [
