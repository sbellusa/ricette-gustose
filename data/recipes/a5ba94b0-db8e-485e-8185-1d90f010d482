          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1664189134841-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1664189134841-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1664189134841-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Place your <strong>basa fillet[s]</strong> on top of the vegetables, drizzle with a little <strong>olive oil</strong> and top with the <strong>lemon breadcrumbs</strong></p><p>Return the tray[s] to the oven for a further 12-15 min or until the basa is cooked through, the vegetables are tender and the breadcrumbs are golden – this is your <strong>lemon crumbed basa tray bake</strong></p><p>Tip: Your fish is cooked once it turns opaque and flakes easily</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1664189141402-x200.jpg",
