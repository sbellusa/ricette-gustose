  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and finely chop your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1680278264719-x200.jpg",
