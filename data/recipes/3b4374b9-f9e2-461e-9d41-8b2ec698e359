            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1680278268530-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1680278268530-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion is beginning to soften, add the<strong> chopped cherry tomatoes</strong> and cook for 2-3 min or until the tomatoes start to blister</p>",
      "order": 3,
      "media": {
        "images": [
          {
