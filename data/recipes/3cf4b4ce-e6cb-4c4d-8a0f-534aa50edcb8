          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1578321230027-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Carefully slice your<strong> ciabatta[s]</strong> in half and spread with the <strong>cheddar pesto</strong></p><p>Top with the <strong>sliced tomato</strong>, <strong>meat-free sausages</strong> and a small handful of <strong>salad</strong> – this is your <strong>sausage & pesto sandwich</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1578321234962-x200.jpg",
