            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your<strong> tomato[es]</strong> finely</p><p>Wash your <strong>salad</strong>, then pat it dry with kitchen paper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1578321224064-x200.jpg",
