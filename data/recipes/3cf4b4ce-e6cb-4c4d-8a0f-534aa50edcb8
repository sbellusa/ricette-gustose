  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your <strong>potatoes</strong> (skins on) into wedges</p><p>Add the <strong>wedges</strong> to one side of a baking tray (or two!) with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1578321204286-x200.jpg",
            "width": 200
