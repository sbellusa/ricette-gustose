          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1578321204286-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>meat-free sausages</strong> to the other side of the tray[s]</p><p>Put the tray[s] in the oven for 20-25 min or until everything is cooked through and golden</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1578321209400-x200.jpg",
            "width": 200
