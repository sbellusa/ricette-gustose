          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1581614384328-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1581614384328-x1000.jpg",
            "width": 1000
