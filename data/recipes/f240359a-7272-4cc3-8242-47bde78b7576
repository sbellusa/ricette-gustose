          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1600417499866-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, slice the<strong> spring onion<span class=\"text-danger\">[s]</span></strong> finely</p><p>Remove the pan from the heat and add the<strong> beef strips</strong> and any<strong> resting juices</strong> to the pan</p><p>Give everything a good mix up – these are your <strong>beef & black pepper udon noodles</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
