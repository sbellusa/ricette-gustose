            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>gnocchi</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook the <strong>gnocchi</strong> for 3 min or until it begins to rise to the top of the pot</p><p>Once done, drain the <strong>gnocchi</strong>, reserving a cup of the <strong>starchy cooking water</strong></p>",
      "order": 5,
      "media": {
        "images": [
