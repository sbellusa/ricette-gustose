  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Boil a kettle&nbsp;</p>\r\n<p>Dissolve the <strong>chicken stock cube<span class=\"text-danger\">[s]</span></strong> in 150ml <span class=\"text-danger\">[300ml]</span> <strong>boiled water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1387.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1387.-step-1-x400.jpg",
            "width": 400
