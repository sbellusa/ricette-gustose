            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Squeeze any excess water out of the <strong>grated potatoes&nbsp;</strong></p>\r\n<p>Tip: wrap the grated potatoes in a clean tea towel and twist the cloth to remove as much water as possible</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1387.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1387.-step-5-x400.jpg",
