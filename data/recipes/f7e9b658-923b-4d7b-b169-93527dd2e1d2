  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel lengths off the<strong> courgette<span class=\"text-danger\">[s]</span></strong> with a peeler until you end up with a pile of <strong>courgette ribbons</strong></p><p>Dice the <strong>inner</strong> <strong>stem<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 1,
