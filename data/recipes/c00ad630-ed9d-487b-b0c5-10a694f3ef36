            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel your<strong> carrot[s]</strong>, then continue to peel lengths until you end up with a pile of carrot ribbons</p><p>Trim, then chop your <strong>green beans</strong> into bite-sized pieces</p><p>Wash your <strong>spinach</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1680014119270-x200.jpg",
