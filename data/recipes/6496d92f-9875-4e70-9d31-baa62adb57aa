            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the chicken is cooking, grate your <strong>cheddar cheese</strong></p><p>Dice your <strong>tomato[es]</strong> finely and season with a pinch of <strong>salt</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1-1599496794603-x200.jpg",
            "width": 200
          },
