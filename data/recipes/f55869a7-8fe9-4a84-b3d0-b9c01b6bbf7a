          }
        ]
      }
    },
    {
      "instruction": "<p>Pick the <strong>mint leaves</strong> from their stems, discard the stems&nbsp;</p>\r\n<p>Pick the <strong>coriander leaves</strong> from their stems</p>\r\n<p>Set the<strong> mint</strong> and<strong> coriander leaves</strong> aside for garnish</p>\r\n<p>Chop the <strong>coriander</strong> stems finely, and add them to the <strong>chilli-lime dressing</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1413.-step-5-x200.jpg",
