  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into thin strips</p><p>Peel and slice your <strong>shallot[s]</strong> finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Chop your <strong>sun-dried tomatoes</strong> into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1670928845164-x200.jpg",
