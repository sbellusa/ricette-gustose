  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil a full kettle</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Peel and finely dice 1/2 <span class=\"text-danger\">[1] </span><strong>brown</strong> <strong>onion</strong>, then finely slice the <strong>remaining onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1650990884344-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1650990884344-x400.jpg",
            "width": 400
