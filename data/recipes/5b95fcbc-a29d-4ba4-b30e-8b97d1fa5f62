            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has softened, add the <strong>chopped</strong> <strong>garlic</strong> and <strong>ground paprika</strong> to the pan and cook for 1-2 min or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1722941905455-x200.jpg",
