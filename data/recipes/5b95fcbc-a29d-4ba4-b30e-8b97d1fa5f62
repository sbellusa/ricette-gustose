            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add your<strong> red Thai curry paste</strong> and<strong> halved green beans</strong> to the pan and cook for 2-3 min further or until the green beans are slightly tender</p><p>Chop your <strong>cod fillet[s] </strong>into bite-sized pieces</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1722941908635-x200.jpg",
