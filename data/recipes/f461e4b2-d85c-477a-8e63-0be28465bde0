            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> caramelised, add the mushrooms to the processor (reserving the pan for step 5)</p>\r\n<p><strong>Season</strong> the mixture with 1/4 tsp <span class=\"text-danger\">(1/2 tsp)</span> of both salt and pepper</p>\r\n<p><strong>Add</strong> 4 tbsp<span class=\"text-danger\"> (8 tbsp)</span> of cold water</p>\r\n<p><strong>Blitz</strong> into a sticky mixture, similar to stuffing</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/445.-step3-x200.jpg",
            "width": 200
