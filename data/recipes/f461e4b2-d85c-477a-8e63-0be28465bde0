          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/445.-step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, strip the rosemary leaves, discard the woody stems, and chop finely</p>\r\n<p><strong>Grate</strong> the cheddar&nbsp;</p>\r\n<p><strong>Peel</strong> and finely chop or grate the garlic</p>\r\n<p><strong>Add</strong> the rosemary, cheddar, oats and 1/3 of the garlic (reserve the rest for step 5) in a food processor</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/445.-step2-x200.jpg",
            "width": 200
          },
          {
