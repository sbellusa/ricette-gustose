  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7 and slice the mushrooms thinly</p>\r\n<p><strong>Heat</strong> a wide based pan with a lid on a medium-high heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil and 15g <span class=\"text-danger\">(30g)</span> of butter</p>\r\n<p><strong>Cook</strong> for 8 min, or until browned and the water has evaporated</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/445.-step1-x200.jpg",
            "width": 200
          },
          {
