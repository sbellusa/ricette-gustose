          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-23-1697120799306-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-23-1697120799306-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat</p><p>Once hot, add your <strong>flaked almonds</strong> and cook for 2-3 min or until toasted and lightly golden, then set them aside and reserve the pan</p><p>Tip: Watch them like a hawk to make sure they don’t burn!</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-26-1697120803863-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-26-1697120803863-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-26-1697120803863-x700.jpg",
