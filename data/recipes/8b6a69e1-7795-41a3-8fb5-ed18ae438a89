  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil half a kettle</p><p>Add your <strong>couscous</strong> to a heatproof bowl with 200ml <span class=\"text-purple\">[300ml]</span><span class=\"text-danger\"> [400ml]</span> <strong>boiled water</strong>, cover and set aside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-23-1697120799306-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-23-1697120799306-x400.jpg",
