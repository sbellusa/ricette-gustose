      }
    },
    {
      "instruction": "<p>Pat your <strong>pork loin steaks</strong> dry with kitchen paper</p><p>Rub them with a little <strong>vegetable oil</strong> and season both sides with <strong>salt</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1644924622068-x200.jpg",
