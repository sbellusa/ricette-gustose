            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once browned, pour the <strong>barbecue sauce</strong> over the steaks, reduce the heat to low and cook, covered, for a final 2-3 min or until the steaks are cooked through and the sauce has slightly thickened (no pink meat!) – these are your <strong>BBQ pork steaks</strong></p><p>Transfer the <strong>BBQ pork</strong> <strong>steaks</strong> to a clean board and leave to rest for 2 min</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1644924629848-x200.jpg",
