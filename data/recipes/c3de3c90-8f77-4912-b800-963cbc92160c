  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Put a large baking tray (or two!) in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p><p>Drain your<strong> pineapple chunks</strong></p><p>Tip: Keep the pineapple juice for your smoothies, cakes or marinades!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-1-x400.jpg",
            "width": 400
