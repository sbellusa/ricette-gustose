          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>tomato paste</strong> to a bowl with the <strong>chopped garlic</strong> and a generous pinch of<strong> salt</strong>, <strong>pepper</strong> and <strong>sugar</strong></p><p>Add 5 tbsp <span class=\"text-purple\">[7 1/2 tbsp] </span><span class=\"text-danger\">[10 tbsp] </span><strong>cold water</strong> and give everything a good mix up – this is your <strong>tomato sauce</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1652.-step-2-x200.jpg",
