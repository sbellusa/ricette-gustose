          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-3-1657627897030-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-3-1657627897030-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>pulled duck</strong> to a large bowl with the <strong>remaining hoisin sauce</strong> and <strong>remaining five-spice mix</strong></p><p>Season with a pinch of <strong>salt </strong>and<strong> pepper </strong>and give everything a good mix up – this is your <strong>pulled hoisin duck</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-3-1657627907767-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-3-1657627907767-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-3-1657627907767-x700.jpg",
            "width": 700
          },
          {
