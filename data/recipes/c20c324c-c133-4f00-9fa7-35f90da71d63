            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once cooked, transfer the <strong>duck</strong> to a clean board and shred apart using two forks (watch out for any bones!) – this technique is known as 'pulling'</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-3-1657627897030-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-3-1657627897030-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-3-1657627897030-x700.jpg",
