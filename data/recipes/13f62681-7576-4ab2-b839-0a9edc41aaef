  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Add your <strong>burger patty[ies]</strong> to a <strong>baking paper</strong>-lined baking tray</p><p>Put the tray in the oven and cook for an initial 20 min</p><p>Tip: Cooking for 3 or more? Use 2 trays!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1715609677918-x200.jpg",
