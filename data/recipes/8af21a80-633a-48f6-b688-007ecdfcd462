  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and slice into thin strips</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624355490831-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624355490831-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624355490831-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624355490831-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624355490831-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> sliced pepper</strong> to a baking tray with a generous drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Put the tray in the oven for 12-15 min or until the pepper has softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1624355494624-x200.jpg",
            "width": 200
