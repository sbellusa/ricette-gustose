            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>pizza bases</strong> to a baking tray (or two!)</p><p>Divide the<strong> pizza sauce</strong> between the pizza bases and spread it evenly all over them with the back of a spoon</p><p>Top with the <strong>torn mozzarella</strong></p>",
      "order": 6,
      "media": {
