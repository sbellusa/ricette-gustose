  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Trim, then chop the <strong>spring onions</strong> into large pieces</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
