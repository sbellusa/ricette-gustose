            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the<strong> chopped spring onion</strong> and cook for 2-3 min or until it's softened slightly</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1117.-step-2-x200.jpg",
