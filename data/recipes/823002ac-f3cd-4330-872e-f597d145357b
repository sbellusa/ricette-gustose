            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve the <strong>vegetable stock mix</strong> in 700ml <span class=\"text-danger\">[1.4L]</span> <strong>boiled water</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1117.-step-3-x200.jpg",
            "width": 200
