            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely dice the <strong>onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
