          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Chop the <strong>tomatoes</strong> roughly</p><p>Peel and finely chop the <strong>shallot<span class=\"text-danger\">[s]</span></strong></p><p>Chop the <strong>coriander </strong>roughly, including the stalks</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1657641654805-x200.jpg",
