            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2428Step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, slice the<strong> ciabatta rolls</strong> finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2428Step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2428Step-5-x400.jpg",
            "width": 400
