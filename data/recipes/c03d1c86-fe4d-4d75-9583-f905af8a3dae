        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> browned, remove the potatoes from the oven and scatter the cheese and spring onions over</p>\r\n<p><strong>Return</strong> the tray to the oven for 1 min, or until the&nbsp;cheese has melted&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
