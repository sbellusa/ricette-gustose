            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the spring onion<span class=\"text-danger\">[s]</span> finely, discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Grate</strong> the cheese</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-5-x200.jpg",
