  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 230&deg;C/ 210&deg;C (fan)/ 450&deg;F/ Gas 8, then soak the skewers in water (to prevent them from burning)</p>\r\n<p><strong>Cut</strong> the potatoes (skins on) into bite-size pieces&nbsp;</p>\r\n<p><strong>Add</strong> the potatoes to a baking tray, drizzle with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> vegetable oil and season with salt and pepper</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Put</strong> the potatoes in the oven for 20-25 min or until the potatoes are nicely browned</p>\r\n<p><strong>Meanwhile</strong>, top and tail the&nbsp;courgette<span class=\"text-danger\">[s]</span> and slice into 8 <span class=\"text-danger\">[16]</span> discs</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Assemble</strong>&nbsp;the kebabs</p>\r\n<p><strong>Thread</strong> a sausage onto each skewer, add a tomato to each end of each skewer</p>\r\n<p><strong>Top</strong> and tail with a slice of courgette (see picture)</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the kebabs to a lightly oiled baking tray (use tin foil to avoid a mess!)</p>\r\n<p><strong>Add</strong> any leftover cherry tomatoes to the tray then season the vegetables (not the sausages) with a small pinch of salt and pepper</p>\r\n<p><strong>Put</strong> the tray in the oven&nbsp;for 20min or until the sausages are nicely browned and cooked through</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/667.-step-4-x400.jpg",
            "width": 400
          },
          {
