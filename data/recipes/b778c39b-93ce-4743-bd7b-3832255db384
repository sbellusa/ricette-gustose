  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Boil a kettle</p><p>Add the <strong>macaroni</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook for 7 min or until it's cooked with a slight bite</p><p>Once done, drain the macaroni, reserving 150ml <span class=\"text-danger\">[200ml]</span> of the <strong>starchy pasta water</strong></p>",
      "order": 1,
      "media": {
