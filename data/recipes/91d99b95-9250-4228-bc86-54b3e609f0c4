          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1175.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Separate 2 <span class=\"text-danger\">[4]</span> outer <strong>little gem lettuce</strong> <strong>leaves</strong> and slice the remaining <strong>inner core</strong>&nbsp;into 4 <span class=\"text-danger\">[8] </span><strong>wedges</strong></p>",
      "order": 3,
      "media": {
        "images": [
