            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, grate your <strong>cheddar cheese</strong></p><p>Dissolve your<strong> vegetable stock mix</strong> in 100ml <span class=\"text-purple\">[150ml]</span> <span class=\"text-danger\">[200ml]</span> <strong>boiled water</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1629467799673-x200.jpg",
            "width": 200
