  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Chop your <strong>parsley</strong> finely, including the stalks</p><p>Chop your <strong>cherry tomatoes</strong> in half</p><p>Peel and roughly chop your <strong>red onion[s]</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-5-1684497311217-x200.jpg",
