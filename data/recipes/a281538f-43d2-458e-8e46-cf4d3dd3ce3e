  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Cut the <strong>potatoes</strong> (skin on) into wedges</p>\r\n<p>Place them on a baking tray, drizzle with <strong>vegetable oil</strong> and season generously with <strong>salt</strong> and <strong>pepper</strong></p>\r\n<p>Put them in the oven for 25-30 min or until golden and crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/683.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/683.-step-1-x400.jpg",
            "width": 400
