    {
      "instruction": "<p>While the potatoes are cooking, peel and chop the <strong>garlic</strong> roughly</p><p>Chop the <strong>parsley</strong> roughly, including the stalks</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2087.-step-6-x200.jpg",
            "width": 200
          },
          {
