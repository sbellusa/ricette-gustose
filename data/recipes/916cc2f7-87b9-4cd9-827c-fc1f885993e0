  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Peel your <strong>potatoes</strong> and chop them into large, bite-sized pieces</p><p>Chop your<strong> leek[s]</strong><span class=\"text-danger\"> </span>in half lengthways, wash thoroughly to remove any grit then top, tail and chop into large chunks</p><p>Peel and finely slice (don't chop!) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1688739303590-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1688739303590-x400.jpg",
