            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the meatballs are browning, chop your <strong>basil</strong> roughly, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/03-01-24_09h30m46s-APIC-1704383682573-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/03-01-24_09h30m46s-APIC-1704383682573-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/03-01-24_09h30m46s-APIC-1704383682573-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/03-01-24_09h30m46s-APIC-1704383682573-x1000.jpg",
