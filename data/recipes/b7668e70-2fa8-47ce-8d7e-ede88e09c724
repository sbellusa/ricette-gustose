          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1-1643200941381-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1-1643200941381-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1-1643200941381-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Strip your<strong> mint leaves</strong> from their stems and chop them roughly, discard the stems</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1643200945937-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1643200945937-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1643200945937-x700.jpg",
            "width": 700
