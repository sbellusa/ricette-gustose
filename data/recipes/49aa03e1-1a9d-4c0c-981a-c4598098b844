  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Crush your <strong>cardamom</strong> <strong>pods</strong> open by squashing them with the side of a knife</p><p>Heat a pot (with a matching lid) with a large knob of <strong>butter </strong>over a medium heat</p><p>Once hot, add the <strong>crushed</strong> <strong>cardamom</strong> <strong>pods</strong> and cook for 30 secs or until they're fragrant</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1603211922527-x200.jpg",
            "width": 200
