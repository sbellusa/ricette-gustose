          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1689.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Prep the ingredients</strong></p>\n<p>Meanwhile, chop the <strong>parsley</strong> finely, including the stalks.</p>\n<p>Crumble the <strong>feta</strong>.</p>\n<p>Cut the<strong> lemon<span class=\"text-danger\">[s]</span> </strong>in half.</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1689.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1689.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1689.-step-5-x700.jpg",
            "width": 700
          },
          {
