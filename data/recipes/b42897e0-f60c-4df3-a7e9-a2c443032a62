  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and grate the ginger</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and grate it finely</p>\r\n<p><strong>Slice</strong> the tofu into 1cm strips and chop into 1cm cubes<br /><br /><strong>Boil</strong> a kettle for steps 5 and 6</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Discard</strong> the roots of the spring onions and slice diagonally</p>\r\n<p><strong>Slice</strong> the mangetout lengthwise as thin as possible</p>\r\n<p><strong>Transfer</strong> both to a sieve and set aside in the sink until step 6</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice, plenty of water (approx. 4x more) and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce to a simmer and cover for 15-20 min or until the rice is tender</p>\r\n<p><strong>Check</strong> to prevent over-cooking and once done, drain and set aside until serving</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> 1/2-1 tbsp of vegetable oil in a pot over medium heat </p>\r\n<p><strong>Once</strong> hot, add the ginger, garlic, and chilli (careful, adjust to your preferred&nbsp;hotness), and cook for 1 min, or until fragrant and sizzling, stirring frequently</p>\r\n<p><strong>Remove</strong> the pot from the hob while keeping the heat/gas on</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the black beans, liquid too, to the pot and return to the hob</p>\r\n<p><strong>Add</strong> the tofu and fold through, careful not to break the tofu</p>\r\n<p><strong>Pour</strong> in 300ml <span class=\"text-danger\">(500ml)</span> of boiled water and the soy sauce</p>\r\n<p><strong>Bring</strong> to a boil, then reduce to a simmer and cook uncovered for 8-10 min, or until reduced by 1/2</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, pour the remainder of the boiled water over the spring onion and mangetout</p>\r\n<p><strong>Rinse</strong> under running cold water until cold to the touch</p>\r\n<p><strong>Transfer</strong> them to a bowl and add the rice vinegar</p>\r\n<p><strong>Mix</strong> briefly and let sit in the vinegar until serving</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> of flour with 3 tsp <span class=\"text-danger\">(6 tsp)</span> of water and mix until smooth</p>\r\n<p><strong>When</strong> the bean sauce has reduced by 1/2, add 1 tsp of the flour and water mixture to the pot</p>\r\n<p><strong>Mix</strong> into the sauce before adding more</p>\r\n<p><strong>Continue</strong> until the tofu and bean sauce is glossy</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> the the tofu and black bean sauce around the brown rice </p>\r\n<p><strong>Serve</strong> alongside the pickled mangetout and spring onion</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
