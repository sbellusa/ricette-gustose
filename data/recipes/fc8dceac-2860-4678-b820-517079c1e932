          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1665486490913-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1665486490913-x700.jpg",
