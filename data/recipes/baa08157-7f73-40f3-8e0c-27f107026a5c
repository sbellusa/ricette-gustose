            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>brioche bun[s] </strong>in half</p><p>Add the <strong>brioche halves</strong> to a baking tray and put in the oven for 3-4 min or until warmed through</p><p>Once done, spread the <strong>warmed brioche buns</strong> with <strong>butter</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-6-x1000.jpg",
