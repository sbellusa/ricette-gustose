            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1832Step-7-x1000.jpg",
