          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1594054170150-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the<strong> remaining lime </strong>into 1 wedge per person</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1594054182073-x200.jpg",
            "width": 200
