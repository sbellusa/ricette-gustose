            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1667318723818-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1667318723818-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your<strong> meat-free mince</strong> (remove the paper if required!) with the <strong>chopped basil stalks</strong>, <strong>half </strong>the <strong>chopped garlic</strong> (you'll use the rest later!) and a pinch of<strong> salt</strong> and <strong>pepper</strong></p><p>Mix until combined (clean hands is the best way), then roll into 3 polpette per person</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1667318717881-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1667318717881-x400.jpg",
            "width": 400
