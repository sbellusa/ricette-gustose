            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1667318717881-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1667318717881-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a drizzle of <strong>olive oil</strong> over a high heat</p><p>Once hot, add the <strong>polpette</strong> and cook for 2-3 min, turning occasionally until browned on all sides</p><p>Once browned, set aside on a plate (reserve the pan) – these are your <strong>meat-free polpette</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1667318711001-x200.jpg",
            "width": 200
