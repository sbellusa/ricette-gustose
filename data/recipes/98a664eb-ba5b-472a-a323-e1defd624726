          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618432722-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618432722-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618432722-x1000.jpg",
