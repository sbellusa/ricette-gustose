  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and cut your <strong>red onion[s]</strong> into quarters, then separate the wedges so you end up with a pile of onion petals</p><p>Deseed your <strong>pepper[s] </strong>(scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Chop your<strong> tomato[es]</strong> roughly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708618428318-x200.jpg",
