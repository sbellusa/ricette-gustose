            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once browned, add the<strong> red onion petals </strong>and cook for 3-4 min or until softened</p><p>Once softened, add the <strong>chopped garlic </strong>and cook for 1 min or until fragrant</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1708618454906-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1708618454906-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1708618454906-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1708618454906-x1000.jpg",
