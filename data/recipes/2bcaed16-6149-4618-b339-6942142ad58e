  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> and finely dice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and finely dice the carrot<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and dice the potatoes into approx. 2cm cubes</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large pan (with a matching lid) with 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> olive oil</p>\r\n<p><strong>When</strong> hot, add the onion, carrot and potatoes with a pinch of salt</p>\r\n<p><strong>Cook</strong> on a high heat for 5 min or until starting to colour and caramelise</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 300ml <span class=\"text-danger\">(450ml)</span> of boiled water to a separate pot</p>\r\n<p><strong>Add</strong> 1/2 tbsp <span class=\"text-danger\">(1 tbsp)</span> of salt and the bay leaf<span class=\"text-danger\">(ves)</span></p>\r\n<p><strong>Bring</strong> to a simmer on a medium low heat and carefully add the smoked fish</p>\r\n<p><strong>Cover</strong> with a lid and cook for 4 min, or until cooked through (the fish is cooked once it appears opaque and flakes apart easily)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 2 tbsp <span class=\"text-danger\">(3 tbsp)</span> of flour to the caramelised vegetables and cook for 2 min further, stirring well to combine</p>\r\n<p><strong>Strain</strong> the fish, keeping the water (this is your fish stock)</p>\r\n<p><strong>Add</strong> the strained stock to the vegetables</p>\r\n<p><strong>Transfer</strong> the cooked fish to your serving bowls, ready for step 7</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Bring</strong> the vegetables and stock to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to a simmer, cover with a lid and cook for 8 min or until the potatoes are cooked through</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the parsley finely</p>\r\n<p><strong>Measure</strong> out 300ml <span class=\"text-danger\">(450ml)</span> of milk</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are cooked, remove the lid and add the sweetcorn (no need to drain) and the milk</p>\r\n<p><strong>Cook</strong> for 4 min on a very low heat, stirring constantly until warmed through and thickened </p>\r\n<p><strong>Remove</strong> from the heat, stir in 1/2 of the chopped parsley</p>\r\n<p>Tip: Add more water if the mixture becomes too thick</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Ladle</strong> the chowder over the fish </p>\r\n<p><strong>Finish</strong> with the remaining chopped parsley and a grind of black pepper</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
