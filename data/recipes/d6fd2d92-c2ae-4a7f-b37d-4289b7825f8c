          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1694605667123-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1694605667123-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a small dry pan over a medium heat</p><p>Once hot, add your <strong>walnuts</strong> and cook for 2-3 min or until toasted and lightly golden</p><p>Tip: Watch them like a hawk to make sure they don't burn!</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1694605670683-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1694605670683-x400.jpg",
            "width": 400
          },
          {
