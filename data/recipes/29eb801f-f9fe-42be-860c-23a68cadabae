          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/368.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>smoked basa</strong> over the<strong> cheesy spinach mash </strong>and top with a<strong> poached egg</strong> </p><p>Season with a good grind of <strong>pepper</strong></p><p>Enjoy!</p>",
