  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in steps 1 and 5)</p>\r\n<p><strong>Chop</strong> the potatoes, leaving the skin on, into 2cm wedges</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 15 min or until you can pierce them easily with a fork</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Season</strong> the pork with salt and pepper on both sides</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan on a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the pork and cook for 3-4 min each side, or until cooked to your preference</p>\r\n<p><strong>Remove</strong> the pork from the pan (reserving the pan for step 5) to a plate</p>\r\n<p><strong>Cover</strong> loosely with a tea towel to rest</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely dice the onion</p>\r\n<p><strong>Remove</strong> and discard the tough green tops and the root<span class=\"text-danger\">(s)</span> of the leek<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Slice</strong> the leeks diagonally into 2cm pieces</p>\r\n<p><strong>Cut</strong> the mushroom in half and slice finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pork pan to a medium heat</p>\r\n<p><strong>Once</strong> hot, add the onions and a pinch of salt and cook for 1 min</p>\r\n<p><strong>Add</strong> the mushroom<span class=\"text-danger\">(s)</span>, leek<span class=\"text-danger\">(s)</span>, 30g <span class=\"text-danger\">(60g)</span> of butter, and a few splashes of kettle water, stirring to coat</p>\r\n<p><strong>Cook</strong> for a further 2-3 min until the leek and mushroom have softened</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely chop the garlic </p>\r\n<p><strong>Add</strong> 30ml <span class=\"text-danger\">(60ml)</span> of milk, the mustard, and the garlic to the pan</p>\r\n<p><strong>Cook</strong> for 1 min, stirring to combine</p>\r\n<p><strong>Add</strong> any resting juices from the meat</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and return the potatoes to the pot</p>\r\n<p><strong>Crush</strong> the potatoes up slightly with the back of a wooden spoon</p>\r\n<p><strong>Season</strong> to taste with salt and pepper and 1/2 tbsp <span class=\"text-danger\">(1 tbsp)</span> of olive oil</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the rested pork to your preferred thickness</p>\r\n<p><strong>Serve</strong> the pork with the mushroom and leek mixture (leaving some of the sauce behind) and then the potatoes</p>\r\n<p><strong>Spoon</strong> the mushroom and leek sauce over the pork</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
