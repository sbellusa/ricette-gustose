          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1641914332799-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Peel and finely slice (don't chop!) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1641914342998-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1641914342998-x400.jpg",
