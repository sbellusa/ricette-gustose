            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>spinach</strong>, then add it to the curry and cook, covered, for 2 min or until the spinach has wilted – this is your <strong>sweet potato & spinach curry</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/755.step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/755.step-6-x400.jpg",
            "width": 400
          },
