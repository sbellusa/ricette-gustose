          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/755.step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Fluff the <strong>basmati</strong> <strong>rice</strong> with a fork and add a few squeezes of a <strong>lemon wedge</strong>, discard the <strong>lemon slices</strong></p><p>Season generously with<strong> salt</strong> and<strong> pepper</strong> – this is your <strong>saffron &</strong> <strong>lemon rice</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/755.step-7-x200.jpg",
