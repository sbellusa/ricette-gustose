  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Add 3 tbsp <span class=\"text-danger\">[6 tbsp]</span> <strong>soft</strong> <strong>butter</strong> to a bowl with the <strong>harissa paste </strong>(can't handle the heat? Go easy!) and <strong>half</strong> the <strong>ras el hanout </strong>(you'll use the rest later!) and mix with a fork – this is your <strong>butter mix</strong></p><p>Tip: If your butter is not soft then microwave for a few secs or until soft to the touch but not melted!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1643201296230-x200.jpg",
            "width": 200
