  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Peel and grate <strong>half</strong> your <strong>red onion[s]</strong>, then finely slice the <strong>remaining red onion</strong></p><p>Combine the <strong>sliced onion</strong> and <strong>red wine vinegar </strong>in a small bowl with a pinch of <strong>salt </strong>and <strong>sugar</strong></p><p>Add 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp]</span> <strong>boiled water</strong> – this is your <strong>quick-pickled onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1664895105027-x200.jpg",
            "width": 200
