            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>grated onion </strong>and <strong>beef mince</strong> to a bowl with your <strong>ground</strong> <strong>cumin </strong>and<strong> half</strong> your <strong>ground</strong> <strong>smoked paprika</strong> (you'll use the rest later!)</p><p>Add a pinch of <strong>salt</strong> and mix thoroughly until fully combined (clean hands is the best way!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1664895107858-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1664895107858-x400.jpg",
