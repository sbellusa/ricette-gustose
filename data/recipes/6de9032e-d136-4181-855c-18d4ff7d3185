  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the grill to medium and boil a full kettle</p><p>Add your <strong>conchiglie</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Cook the <strong>conchiglie</strong> for 8-10 min or until cooked with a slight bite</p><p>Once done, reserve 100ml <span class=\"text-purple\">[150ml]</span> <span class=\"text-danger\">[200ml]</span> of the <strong>starchy pasta water</strong> and drain the <strong>cooked conchiglie</strong></p>",
      "order": 1,
      "media": {
