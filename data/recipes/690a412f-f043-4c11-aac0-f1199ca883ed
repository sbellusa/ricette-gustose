    {
      "instruction": "<p>Pat your <strong>hake fillet[s] </strong>dry with kitchen paper</p><p>Season the <strong>hake</strong> with a generous pinch of <strong>salt</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1713871706745-x200.jpg",
            "width": 200
