  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your<strong> waxy potatoes </strong>into large, bite-sized pieces</p><p>Add the <strong>chopped potatoes</strong> to a baking tray with a generous drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Give everything a good mix up and put the tray in the oven for 30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1713871700180-x200.jpg",
            "width": 200
