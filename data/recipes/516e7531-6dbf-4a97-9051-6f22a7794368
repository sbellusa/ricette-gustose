            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wipe the reserved pot clean and return it to a medium heat with a drizzle of <strong>olive oil</strong></p><p>Once hot, add the <strong>diced onion</strong> and <strong>remaining chopped garlic </strong>with a pinch of <strong>salt </strong>and cook for 5-6 min or until softened and slightly caramelised</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1604418222498-x200.jpg",
