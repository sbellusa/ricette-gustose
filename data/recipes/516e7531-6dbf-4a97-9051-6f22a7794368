            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reduce the heat to medium-high, then top with the <strong>browned meatballs</strong></p><p>Cook for an initial 8-10 min, stirring occasionally to prevent the spaghetti from sticking to the pot, or until the spaghetti is cooked with a slight bite and the meatballs are cooked through (no pink meat!)</p><p>While the spaghetti is cooking, grate your <strong>cheddar cheese</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1604418247064-x200.jpg",
