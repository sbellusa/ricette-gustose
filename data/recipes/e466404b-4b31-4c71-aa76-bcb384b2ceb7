          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1681285405333-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a very generous drizzle of <strong>vegetable oil </strong>(enough to cover the base of the pan)<strong> </strong>over a high heat</p><p>Once hot, add the <strong>coated</strong> <strong>chicken</strong> and cook for 3 min on each side or until golden and crispy</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1681285408952-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1681285408952-x400.jpg",
