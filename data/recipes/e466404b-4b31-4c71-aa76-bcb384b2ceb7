            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1681285408952-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once crispy, remove the tray<span class=\"text-danger\">[s]</span> with the chips from the oven and add the <strong>browned chicken</strong></p><p>Return the tray<span class=\"text-danger\">[s] </span>to the oven for a final 12-14 min or until the chicken is cooked through (no pink meat!) – this is your <strong>masala chicken</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1681285413345-x200.jpg",
