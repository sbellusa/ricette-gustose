          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1692890536046-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1692890536046-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1692890536046-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>sticky</strong> <strong>rice</strong> with the <strong>Thai-style garlic pepper jumbo prawns</strong> and <strong>steamed</strong> <strong>greens </strong>to the side</p><p>Tip: For fancy presentation, press the rice into small bowls and turn out</p><p>Serve the <strong>chilli</strong> <strong>dipping sauce</strong> to the side and garnish with the <strong>chopped</strong> <strong>coriander</strong></p><p>Enjoy!</p>",
      "order": 8,
