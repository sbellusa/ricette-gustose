          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>arborio rice</strong> and cook for 2 min, stirring to coat the grains in the oil</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-4-x400.jpg",
