            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the <strong>leek<span class=\"text-danger\">[s]</span></strong> in half lengthways and wash carefully to remove any grit from between the leaves</p><p>Slice the<strong> leek<span class=\"text-danger\">[s]</span></strong> finely, discarding the tough tops, outer leaves and root end<span class=\"text-danger\">[s]</span></p><p>Boil a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-2-x200.jpg",
            "width": 200
