  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ 350°F/ Gas 4</p><p>Heat a large, wide-based pan with 1 tbsp <span class=\"text-danger\">[2 tbsp]<strong> </span>olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>bacon lardons</strong> and cook for 4-5 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-1-x700.jpg",
            "width": 700
          },
          {
