            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>bacon</strong> is crisp, add the<strong> sliced leek</strong> to the pan</p><p>Cook for 3-4 min or until starting to soften</p>",
      "order": 3,
      "media": {
        "images": [
