            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, strip the <strong>mint leaves</strong> from their stems and chop them finely</p><p>Trim and slice the <strong>spring onions</strong> finely</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/224.step-6-x1000.jpg",
