            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and slice (don't chop!) your <strong>garlic</strong></p><p>Once the sausage is starting to brown, add the <strong>sliced garlic</strong>, <strong>dried oregano</strong> and most<strong> </strong>of your <strong>chilli flakes </strong>(can't handle the heat? Go easy!) to the pan and cook for 1 min further or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-1644923890139-x200.jpg",
