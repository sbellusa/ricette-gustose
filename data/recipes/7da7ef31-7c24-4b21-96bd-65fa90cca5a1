            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add the <strong>sausage meatballs</strong> to the pan with a pinch of <strong>salt</strong> and cook for 3-4 min or until starting to brown</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-1644923883855-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-1644923883855-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-1644923883855-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-1644923883855-x1000.jpg",
