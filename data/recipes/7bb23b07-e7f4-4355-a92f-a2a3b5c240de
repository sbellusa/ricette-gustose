  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Peel and cut the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into quarters, then separate the wedges so you end up with a pile of onion petals</p><p>Chop the <strong>cherry tomatoes</strong> in half</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683717161457-x200.jpg",
            "width": 200
