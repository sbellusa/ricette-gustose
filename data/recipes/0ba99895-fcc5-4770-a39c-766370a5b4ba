          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1680597985886-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once tender, add the <strong>spinach</strong> and a very generous pinch of <strong>salt</strong> and <strong>pepper </strong>and cook for 1 min or until wilted</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-copy-1680597989671-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-copy-1680597989671-x400.jpg",
