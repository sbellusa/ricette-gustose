            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>halved mangetout</strong> and cook for 2-3 min or until tender</p><p>Wash your <strong>spinach </strong>and pat dry with kitchen paper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1680597985886-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1680597985886-x400.jpg",
