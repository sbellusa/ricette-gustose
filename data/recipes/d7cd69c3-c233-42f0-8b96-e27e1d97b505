            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, strip your <strong>mint leaves</strong> from their stems, discard the stems</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1673867340118-x200.jpg",
