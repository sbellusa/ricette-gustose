          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1714492561598-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1714492561598-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1714492561598-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the potato is cooking, chop your <strong>tomato[es] </strong>into wedges</p><p>Wash your<strong> lettuce</strong>, then pat it dry with kitchen paper</p><p>Tear the <strong>outer</strong> <strong>lettuce leaves </strong>into rough, bite-sized pieces and shred the<strong> inner core[s]</strong></p><p>Tear your <strong>ciabatta[s] </strong>into small, bite-sized pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1714492564523-x200.jpg",
            "width": 200
