            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>smoked streaky bacon</strong> to a <strong>tin foil</strong>-lined baking tray (or two!)</p><p>Put the tray[s] in the oven for 12-15 min or until golden and crispy</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1714492567540-x200.jpg",
