          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1662719405854-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1662719405854-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1662719405854-x1000.jpg",
