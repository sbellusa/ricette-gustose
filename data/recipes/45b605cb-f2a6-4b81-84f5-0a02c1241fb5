  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9 and boil a kettle</p><p>Cut your <strong>pepper[s]</strong> in half (scrape the seeds and pith out with a teaspoon)</p><p>Add the <strong>halved pepper</strong> to a baking tray (or two!) with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Put the tray[s] in the oven for 15 min or until the pepper has softened and browned</p>",
      "order": 1,
      "media": {
        "images": [
