  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a very high heat</p><p>Once very hot, add the <strong>beef strips</strong> with a generous pinch of<strong> salt</strong> and cook for 1-2 or until browned all over</p><p>Transfer the<strong> cooked beef strips</strong> to a plate and reserve the pan</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1602248243802-x200.jpg",
            "width": 200
