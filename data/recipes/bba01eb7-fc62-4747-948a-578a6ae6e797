            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely slice the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Return the reserved pan to a medium heat and once hot, add the <strong>sliced onion</strong> with a pinch of <strong>salt</strong></p><p>Cook for 6-7 min or until softened and caramelised</p>",
      "order": 2,
      "media": {
        "images": [
