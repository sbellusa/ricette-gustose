            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pepper has softened, drain your<strong> king prawns</strong>, then add to the pan and cook for 2-3 min further</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1657033394757-x200.jpg",
