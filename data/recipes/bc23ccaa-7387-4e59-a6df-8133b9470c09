            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>spring onion[s] </strong>finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Sliced-finely-spring-onions-1687848784498-x200.jpg",
            "width": 200
          },
          {
