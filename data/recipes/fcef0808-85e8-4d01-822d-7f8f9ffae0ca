            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>arborio rice</strong>, <strong>ground smoked paprika</strong>, <strong>saffron</strong> and <strong>half</strong> your <strong>roasted garlic paste</strong> (you'll use the rest later!) to the dish and stir everything together</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1686317991075-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1686317991075-x400.jpg",
