            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624294589973-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624294589973-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the potatoes are cooking, trim, then finely slice the<strong> spring onions</strong></p><p>Strip the <strong>mint</strong> <strong>leaves</strong> from their stems and chop them finely, discard the stems</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1624294596115-x200.jpg",
            "width": 200
