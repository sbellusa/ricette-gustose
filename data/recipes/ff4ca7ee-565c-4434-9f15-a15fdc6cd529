  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the grill to a medium-high heat</p>\r\n<p><strong>Boil</strong> a kettle</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Pat</strong> the fish dry with kitchen towel and place the fillets on a baking tray</p>\r\n<p><strong>Combine</strong> the miso and half of the mirin together to form a paste</p>\r\n<p><strong>Spread</strong> the paste evenly over each fish fillet and set them aside</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel </strong>the ginger (scrape the skin off with a teaspoon) and finely chop (or grate)</p>\r\n<p><strong>Bash</strong> the lemongrass&nbsp;with a rolling pin, cut&nbsp;down the middle lengthways, remove the tough outer layers (keep them for later!) and chop the softer inner stem<span class=\"text-danger\">[s]</span>&nbsp;finely</p>\r\n<p><strong>Slice</strong> the mangetout diagonally</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large pot with a drizzle of vegetable oil over a medium-high heat</p>\r\n<p><strong>Once</strong>&nbsp;hot, add the ginger, chopped lemongrass, chilli flakes (can't handle the heat? Go easy!) and cook for 30 seconds, stirring constantly</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1L <span class=\"text-danger\">[2L]</span>&nbsp;boiled water, the stock cube<span class=\"text-danger\">[s]</span>, outer lemongrass leaves and the remaining mirin to the pot</p>\r\n<p><strong>Season</strong> with&nbsp;1/2 tsp <span class=\"text-danger\">[1 tsp]</span>&nbsp;pepper and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to medium-low and cook for 5-7 min</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the fish under the grill and cook for 6-8 min or until cooked through&nbsp;</p>\r\n<p><strong>Tip:</strong> your fish is cooked when it turns opaque and flakes easily</p>\r\n<p>&nbsp;</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/322.-step--6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
