            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1598386194138-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the<strong> chicken breasts</strong> into large, bite-sized pieces</p><p>Combine the <strong>chopped</strong> <strong>chicken</strong> with the <strong>ground coriander</strong>, 1 tsp <span class=\"text-danger\">[2 tsp]</span> of the <strong>garam masala</strong> (save the rest for later!) and a generous pinch of<strong> salt</strong></p>",
      "order": 2,
      "media": {
        "images": [
