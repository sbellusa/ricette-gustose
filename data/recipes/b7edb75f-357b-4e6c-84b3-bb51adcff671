  "cooking_instructions": [
    {
      "instruction": "<p>Peel the <strong>butternut squash<span class=\"text-danger\">[es]</span></strong> and cut in half using a sharp knife</p><p>Scoop out the seeds with a spoon and discard</p><p>Chop the <strong>peeled butternut squash</strong> into bite-sized pieces</p><p>Peel and finely slice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Deseed the<strong> pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and chop into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1666708508570-x200.jpg",
            "width": 200
