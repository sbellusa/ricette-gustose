            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682186059836-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>gnocchi</strong> to an <strong>oven-proof dish</strong> with a drizzle of <strong>vegetable oil</strong></p><p>Give everything a good mix up and put the dish in the oven</p><p>Cook for 25 min or until the gnocchi is crispy – this is your <strong>crispy gnocchi</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1679405526377-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1679405526377-x400.jpg",
