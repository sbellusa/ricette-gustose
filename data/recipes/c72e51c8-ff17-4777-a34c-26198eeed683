  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely slice your <strong>brown onions</strong></p><p>Slice your<strong> chestnut mushrooms</strong> finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682186059836-x200.jpg",
            "width": 200
