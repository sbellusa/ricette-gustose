          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1604078412343-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pork mince has started to brown, add the <strong>ginger & garlic paste</strong> and <strong>remaining Marmite </strong>to the pan and cook for 1 min further or until caramelised</p><p>Wash the <strong>baby leaf spinach</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1604078416870-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1604078416870-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1604078416870-x700.jpg",
