  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Trim the green stalk[s] off your <strong>aubergine[s] </strong>and cut into bite-sized pieces</p><p>Top, tail and slice your <strong>courgette[s]</strong> into discs</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624886726326-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624886726326-x400.jpg",
            "width": 400
