        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the celery finely&nbsp;</p>\r\n<p><strong>Peel</strong>, halve the carrots lengthways and slice finely, discarding the root ends</p>\r\n<p><strong>Slice</strong> the sugar snap peas finely&nbsp;</p>\r\n<p><strong>Tip:</strong> you can gather and slice several peas at a time</p>",
      "order": 4,
      "media": {
