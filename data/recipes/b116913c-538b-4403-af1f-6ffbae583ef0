            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add 1L&nbsp;<span class=\"text-danger\">(2L)</span>&nbsp;boiled water to a pot over a medium-high heat</p>\r\n<p><strong>Add</strong> the beef stock cube<span class=\"text-danger\">(s)</span>, hoisin sauce, tomato paste and a big pinch of salt</p>\r\n<p><strong>Stir</strong> to combine - this is your broth</p>\r\n<p><strong>Keep</strong> the broth on a medium high heat until step 6&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-3-x200.jpg",
            "width": 200
