  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a full kettle</p>\r\n<p><strong>Peel</strong> the ginger (scrape the skin off with a teaspoon) and finely chop (or grate)</p>\r\n<p><strong>Combine</strong> the beef mince, Thai red curry paste and ginger in a bowl</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-1-x200.jpg",
            "width": 200
