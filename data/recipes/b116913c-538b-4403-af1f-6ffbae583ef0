            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) over a high heat</p>\r\n<p><strong>Once</strong> hot, add the beef mixture and cook for 4 min or until cooked through (it will no longer be pink)</p>\r\n<p><strong>Once</strong> cooked, remove from the heat</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/549.-step-2-x200.jpg",
            "width": 200
          },
          {
