  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, plenty of water (approx. 4x more) and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently with the lid on for 15-20 min or until tender</p>\r\n<p><strong>Check</strong> occasionally and once done, drain and set aside until serving</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Dice</strong> the sweet potato, with the skin on, into 1-2cm pieces</p>\r\n<p><strong>Heat</strong> 2 tbsp <span class=\"text-danger\">(3 tbsp)</span> of vegetable oil in a wide pot with a matching lid on a high heat</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> hot, toss in the cumin seeds, ground turmeric, and ground coriander and toast for 1 min</p>\r\n<p><strong>Toss</strong> in the sweet potatoes and cook for 2 min, stirring to coat</p>\r\n<p><strong>Cover</strong> with a lid until step 4</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, cut away the stem<span class=\"text-danger\">(s)</span> from the chilli<span class=\"text-danger\">(es)</span>, deseed and slice into half-moons</p>\r\n<p><strong>Crush</strong> the garlic with the side of the knife, peel, and chop finely</p>\r\n<p><strong>Add</strong> the garlic and chilli to the pot (careful, adjust the amount to your preferred hotness) and stir for 1 min, or until fragrant</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chopped tomatoes to the pot</p>\r\n<p><strong>Add</strong> the stock cube and 250ml <span class=\"text-danger\">(400ml)</span> of boiling water</p>\r\n<p><strong>Stir</strong> to combine, bring to a boil and then reduce to a rapid simmer</p>\r\n<p><strong>Cover</strong> with a lid and stir occasionally until adding the spring greens</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, rip the leaves off of the spring greens and discard the tough inner stalks</p>\r\n<p><strong>Bunch</strong> up the greens and chop or tear into 3-4cm thick strips</p>\r\n<p><strong>Add</strong> to the pot, mix well, and cook on a high heat for 7-9 min, or until the potatoes are tender</p>\r\n<p><strong>This</strong> is your sag aloo</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Crush</strong> the cashews in their bag using a rolling pin, taking care not to split the bag! </p>\r\n<p><strong>Set</strong> aside for step 8</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Season</strong> the sag aloo to your taste with salt and plenty of pepper</p>\r\n<p><strong>Spoon</strong> the sag aloo into bowls and serve the rice beside it</p>\r\n<p><strong>Garnish</strong> with the chopped cashew nuts</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
