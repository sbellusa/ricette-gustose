            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail and slice your <strong>leek[s]</strong> into chunky rounds</p><p>Wash to remove any grit from between the leaves</p><p>Chop your <strong>chives</strong> finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1634641446809-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1634641446809-x400.jpg",
