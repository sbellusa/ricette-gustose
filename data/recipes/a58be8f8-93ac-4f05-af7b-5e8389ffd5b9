  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and finely chop the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Heat a large, wide-based pan (preferably non-stick) with 1/2 tbsp <span class=\"text-danger\">[1 tbsp] </span><strong>olive oil </strong>over a medium heat</p><p>Once hot, add the <strong>chopped onion</strong> with a pinch of <strong>salt </strong>and cook for 6-7 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1625735946380-x200.jpg",
