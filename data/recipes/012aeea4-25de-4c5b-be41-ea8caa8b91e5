            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and roughly chop the <strong>garlic</strong></p><p>Chop the <strong>sun-dried tomatoes </strong>roughly</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1610383763062-x200.jpg",
