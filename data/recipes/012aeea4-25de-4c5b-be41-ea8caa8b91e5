          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped garlic </strong>and<strong> chopped sun-dried tomatoes</strong> to the pan with a knob of <strong>butter</strong> and cook for 1 min until fragrant and all the butter has melted</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1610383810208-x200.jpg",
