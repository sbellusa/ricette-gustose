          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1610383823213-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash the <strong>spinach</strong>, then pat it dry with <strong>kitchen paper</strong></p><p>Once the gnocchi has started to crisp, add the <strong>washed</strong> <strong>spinach </strong>to the pan and cook for 1-2 min until just starting to wilt – this is your <strong>spinach gnocchi</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1610383833963-x200.jpg",
