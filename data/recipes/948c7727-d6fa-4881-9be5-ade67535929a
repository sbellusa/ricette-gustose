          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1918.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>basa fillets</strong> to the plate and press them into the <strong>flour mixture</strong> until fully coated</p>\n<p> </p>",
      "order": 5,
      "media": {
        "images": [
          {
