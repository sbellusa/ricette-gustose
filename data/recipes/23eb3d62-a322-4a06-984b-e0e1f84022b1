            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>potatoes</strong> (skins on) into small bite-sized pieces</p><p>Top, tail, peel and chop your <strong>carrot[s]</strong> into thin rounds</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1724153671474-x200.jpg",
            "width": 200
