            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1724153671474-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1724153671474-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped carrot </strong>and<strong> chopped potato </strong>to a large baking tray (or two!) with the <strong>chopped garlic</strong>, <strong>onion wedges </strong>and <strong>dried thyme</strong></p><p>Add a drizzle of <strong>olive oil</strong>, season with a pinch of <strong>salt </strong>and <strong>pepper </strong>and give everything a good mix up</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1724153692032-x200.jpg",
