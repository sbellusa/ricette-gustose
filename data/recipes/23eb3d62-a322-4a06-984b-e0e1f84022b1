          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1724153692032-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top with your <strong>sausages </strong>and put the tray[s] in the oven for an initial 30 min or until the sausages are cooked through (no pink meat!) and the veg is tende</p>",
      "order": 4,
      "media": {
