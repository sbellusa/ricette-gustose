            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1664882946214-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the pork mince is cooking, dissolve your <strong>honey</strong>, <strong>mirin</strong>, <strong>rice vinegar</strong>,<strong> ginger & garlic paste</strong> and <strong>soy sauce</strong> in 100ml<span class=\"text-purple\"> [150ml] </span><span class=\"text-danger\">[200ml]</span><strong> boiled water </strong>– this is your<strong> soy stock</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1664882949651-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1664882949651-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1664882949651-x700.jpg",
