            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice your <strong>spring onion[s] </strong>finely, keeping the <strong>whites </strong>and <strong>greens </strong>separate</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1664882960156-x200.jpg",
