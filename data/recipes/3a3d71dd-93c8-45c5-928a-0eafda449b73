            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>cucumber</strong> into quarters lengthways, then slice into batons</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1708440256079-x200.jpg",
