        ]
      }
    },
    {
      "instruction": "<p>Give everything a good mix up – this is your <strong>curried potato salad</strong></p><p>Chop the<strong> crispy chicken</strong> into smaller pieces</p>",
      "order": 7,
      "media": {
        "images": [
