          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1627376629254-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>golden gnocchi</strong> to the pan and tear in the <strong>fresh basil</strong></p><p>Season with a pinch of <strong>salt</strong> and <strong>pepper</strong> – this is your <strong>plant-based creamy veg gnocchi</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627376633929-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627376633929-x400.jpg",
