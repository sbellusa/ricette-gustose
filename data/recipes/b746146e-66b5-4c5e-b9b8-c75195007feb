            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your<strong> tomato[es] </strong>into wedges</p><p>Peel and cut your <strong>red onion[s]</strong> into wedges</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1718713250411-x200.jpg",
