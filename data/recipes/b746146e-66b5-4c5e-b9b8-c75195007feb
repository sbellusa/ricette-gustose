  "cooking_instructions": [
    {
      "instruction": "<p><strong>Before you begin...</strong></p><p>This recipe takes around 5-10 min to prep, so get your baking tray and all your ingredients ready, then wash your fruit and veg</p><p>Take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1718713242007-x200.jpg",
            "width": 200
