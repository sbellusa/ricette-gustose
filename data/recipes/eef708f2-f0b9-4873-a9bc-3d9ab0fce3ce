        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>apple[s]</strong> finely, then chop into matchsticks (discard the core[s])</p><p>Chop your <strong>pumpkin seeds </strong>roughly</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1718100769841-x200.jpg",
