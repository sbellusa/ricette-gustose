            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, drain and rinse the <strong>black beans</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1641911104691-x200.jpg",
