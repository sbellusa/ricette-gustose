            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>beef mince</strong> to the pan and cook for 2 min, breaking it up with a wooden spoon as you go</p><p>Mix in the <strong>beef stock mix </strong>and <strong>tomato paste </strong>with a pinch<strong> </strong>of<strong> salt </strong>and cook for a further 2 min or until the mince<strong> </strong>has browned all over</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1641911086116-x200.jpg",
