      "instruction": "<p>Cut your <strong>cucumber </strong>into quarters lengthways, then slice into batons</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1656425439540-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1656425439540-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1656425439540-x700.jpg",
            "width": 700
