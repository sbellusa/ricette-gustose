  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p>\n<p>Boil a kettle</p>\n<p>Slice the<strong> potatoes</strong> into thin discs</p>\n<p>Add the <strong>potato discs</strong> to a pot of<strong> boiling water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 7-8 min or until almost tender</p>\n<p>Once done, drain, set aside to steam dry and reserve the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1846.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1846.-step-1-x400.jpg",
            "width": 400
