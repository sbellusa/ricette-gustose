            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>pork belly</strong> into thin strips</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1616514183272-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1616514183272-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1616514183272-x700.jpg",
            "width": 700
          },
          {
