          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1618223242669-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1618223242669-x700.jpg",
