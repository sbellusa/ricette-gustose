            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the onions are cooking, dissolve your <strong>vegetable stock mix</strong> and<strong> tomato paste</strong> in 250ml <span class=\"text-purple\">[375ml]</span> <span class=\"text-danger\">[500ml]</span> <strong>boiled water</strong> – this is your <strong>tomato stock</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1618223242669-x200.jpg",
            "width": 200
