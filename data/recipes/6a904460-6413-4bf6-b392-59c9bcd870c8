            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1684422213201-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>remaining cauliflower</strong> into small florets</p><p>Peel and chop the <strong>sweet potatoes</strong> into small bite-sized pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684422217258-x200.jpg",
