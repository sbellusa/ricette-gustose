            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Carefully add each piece of <strong>fish</strong> to the pan of <strong>poaching liquid</strong>, trying not to overlap them</p><p>Cook for 8 min, carefully flipping the fish halfway through for even cooking</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/555.-step-5-x200.jpg",
