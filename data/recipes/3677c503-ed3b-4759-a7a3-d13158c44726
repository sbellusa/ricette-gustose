  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p><p>Cut the <strong>paneer</strong> into bite-sized cubes</p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid), with a large drizzle of<strong> vegetable oil</strong> over a medium heat</p><p>Once hot, add the <strong>paneer</strong> and cook for 3-5 min until golden, turning occasionally for even colouring</p>",
      "order": 1,
      "media": {
        "images": [
          {
