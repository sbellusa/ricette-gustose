      }
    },
    {
      "instruction": "<p>Meanwhile, wash your <strong>spinach</strong>, then pat it dry with kitchen paper</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1678889696643-x200.jpg",
