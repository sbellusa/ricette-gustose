  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Cut the <strong>potatoes</strong> (skins on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
