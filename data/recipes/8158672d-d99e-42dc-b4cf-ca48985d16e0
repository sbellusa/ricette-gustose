            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your <strong>mayo</strong> with the <strong>remaining roasted garlic paste</strong>, 2 tsp <span class=\"text-purple\">[3 tsp]</span><span class=\"text-danger\"> [4 tsp]</span><strong> cold water</strong> and a pinch of <strong>pepper</strong> – this is your <strong>roasted garlic aioli</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1725535599697-x200.jpg",
            "width": 200
