          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1725535585637-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once starting to brown, add your <strong>tomato paste </strong>to the pot with the <strong>remaining</strong> <strong>smoked paprika</strong> and <strong>half</strong> your <strong>roasted garlic paste </strong>(you'll use the rest later!)</p><p>Cook for 30 secs or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1725535590162-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1725535590162-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1725535590162-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1725535590162-x1000.jpg",
