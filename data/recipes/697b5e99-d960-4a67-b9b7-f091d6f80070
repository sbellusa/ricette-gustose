            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1599207939926-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>lettuce</strong>, then pat it dry with kitchen paper</p><p>Remove the <strong>outer lettuce leaves </strong>for one per person<strong> </strong>and set them aside for serving</p><p>Tear the <strong>remaining lettuce</strong> into bite-sized pieces</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1599207956847-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1599207956847-x400.jpg",
