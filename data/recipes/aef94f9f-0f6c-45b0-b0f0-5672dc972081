  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Add the <strong>spinach</strong> to a colander and pour<strong> boiled water</strong> all over it so that it starts to wilt</p><p>Rinse the <strong>wilted spinach</strong> under<strong> cold running water</strong> until it's cool</p><p>Once cool, squeeze as much of the water out of the <strong>cooled spinach</strong> as you can, then chop it roughly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658224745051-x200.jpg",
            "width": 200
