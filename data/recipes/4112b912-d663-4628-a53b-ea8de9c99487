            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once slightly reduced, add the <strong>pulled mushrooms </strong>to the sauce<strong> </strong>and mix it all together</p><p>Cook for 1-2 min further or until the mushrooms are warmed through and well coated in the sauce – these are your <strong>BBQ pulled mushrooms</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1684236527493-x200.jpg",
