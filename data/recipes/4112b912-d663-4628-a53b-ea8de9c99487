          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1684236508674-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>Fable pulled mushrooms</strong> to the pan and cook for 5-6 min or until browned</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1684236512088-x200.jpg",
