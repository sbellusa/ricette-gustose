  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Deseed the <strong>pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut them into strips</p><p>Peel and cut the <strong>red onions</strong> into wedges</p><p>Chop your <strong>cherry tomatoes</strong> in half</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1327.-step-1-x200.jpg",
