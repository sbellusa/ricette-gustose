  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6 and boil half a kettle</p><p>Top, tail and cut your <strong>courgette[s]</strong> into bite-sized pieces</p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into bite-sized pieces</p><p>Dice your <strong>tomato[es]<span class=\"text-danger\"> </span></strong>finely</p>",
      "order": 1,
      "media": {
        "images": [
