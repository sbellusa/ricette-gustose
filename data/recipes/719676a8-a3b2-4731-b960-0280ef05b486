            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658234645129-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658234645129-x400.jpg",
