          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the <strong>halloumi</strong> into bite-sized pieces</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/644.-step-6-x200.jpg",
