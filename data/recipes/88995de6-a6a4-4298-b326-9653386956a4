          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1649848598202-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cover with the<strong> cheesy fennel béchamel </strong>and top with the <strong>remaining grated cheese</strong></p><p>Put the dish in the oven and cook for 30 min or until the pasta is cooked and the top is golden – this is your <strong>pork, fennel & leek lasagne</strong></p>",
      "order": 7,
      "media": {
