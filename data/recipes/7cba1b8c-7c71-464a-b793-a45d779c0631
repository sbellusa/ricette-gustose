            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>aubergine[s] </strong>in half lengthways (including the stalk)</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1652179980444-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1652179980444-x400.jpg",
