            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and chop your <strong>red</strong> <strong>onion[s]<span class=\"text-danger\"> </span></strong>into wedges</p><p>Chop your <strong>tomato[es]</strong> into wedges</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1652179976891-x200.jpg",
