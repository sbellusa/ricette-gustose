  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium heat</p><p>Once hot, add your <strong>bacon lardons</strong> and cook for 8 min, stirring frequently, or until golden and crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-1-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-1-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-1-2-x700.jpg",
