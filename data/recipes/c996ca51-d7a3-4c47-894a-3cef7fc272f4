            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the spaghetti is cooking, chop your <strong>basil</strong> finely, including the stalks</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2084.-step-6-x700.jpg",
