  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the freekeh, add to a pot of plenty of cold water and bring to a boil<br /><br /><strong>Boil</strong> for 20 min or until cooked through, but with a slight bite</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Discard</strong> the ends, peel and cut the carrots lengthwise into long strips, then into baton sized pieces </p>\r\n<p><strong>Peel</strong> and chop the shallots finely</p>\r\n<p><strong>Remove</strong> the woody tops from the sugar snap peas</p>\r\n<p><strong>Slice</strong> the goats' cheese in half to form circular patties (approx. 1cm thick)</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the shallot, red wine vinegar, 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar and 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil in a bowl</p>\r\n<p><strong>Season</strong> to your taste with salt</p>\r\n<p><strong>Mix</strong> well to form a dressing and set aside until step 7</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> one handful of flour to a shallow bowl or plate, and spread out</p>\r\n<p><strong>Add</strong> 50ml <span class=\"text-danger\">(100ml)</span> of milk to a shallow bowl</p>\r\n<p><strong>Spread</strong> the breadcrumbs onto another plate</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Coat</strong> one goats' cheese patty in the flour</p>\r\n<p><strong>Add</strong> to the milk and coat well</p>\r\n<p><strong>Roll</strong> in the breadcrumbs and coat well, including the sides</p>\r\n<p><strong>Repeat</strong> the process until all of the goats' cheese patties are well coated</p>\r\n<p><strong>Once</strong> the freekeh has been boiling for 12 min, add the carrot and cook for 8 min</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan over a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the goats' cheese and cook for 1-2 min on each side, or until golden brown</p>\r\n<p>Tip: To avoid over-colouring, remove the pan from the heat if necessary and continue to cook with the residual heat</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the carrot is almost done, add the sugar snap peas to the freekeh pot and cook for 2 min, or until tender</p>\r\n<p><strong>Drain</strong> well</p>\r\n<p><strong>Coat</strong> the freekeh and cooked vegetables with the dressing</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> up the dressed freekeh and vegetables</p>\r\n<p><strong>Serve</strong> with the browned goats' cheese on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
