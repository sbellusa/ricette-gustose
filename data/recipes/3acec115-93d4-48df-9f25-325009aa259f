          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1696239839065-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>BBQ pork loin</strong> with the <strong>garlic potatoes</strong>, <strong>crispy bacon corn</strong> and <strong>creamy slaw</strong> to the side</p><p>Sprinkle over any <strong>remaining crispy bacon crumb</strong> and garnish with the <strong>remaining</strong> <strong>sliced spring onion</strong></p><p>Enjoy!</p>",
      "order": 8,
