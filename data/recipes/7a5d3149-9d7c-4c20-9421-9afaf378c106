          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1674813154314-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1674813154314-x1000.jpg",
