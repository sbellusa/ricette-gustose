    {
      "instruction": "<p>Chop your<strong> cherry tomatoes</strong> in half</p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Cut your <strong>black olives </strong>in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2015.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2015.-step-2-x400.jpg",
            "width": 400
          },
          {
