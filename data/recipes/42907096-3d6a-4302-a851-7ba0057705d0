          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-2-1659433553626-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>coconut haddock curry</strong> with the <strong>cooked rice</strong> to the side</p><p>Garnish with your <strong>nigella seeds</strong></p><p>Enjoy!</p>",
      "order": 8,
