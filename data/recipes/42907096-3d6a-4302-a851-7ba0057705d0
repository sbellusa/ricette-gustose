          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-2-1659433540733-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Squeeze your pouch[es] of <strong>cooked brown long grain rice </strong>to separate the grains</p><p>Tear the top corner of the pouch[es] (just a little!) and put the pouch in the <strong>microwave</strong> for 2 min or until piping hot</p><p>Tip: If you're cooking two pouches, pop them in together but increase the microwave cook time accordingly</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-2-1659433553626-x200.jpg",
            "width": 200
