          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1651572357055-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the potatoes are boiling, peel and finely dice 1/2 <span class=\"text-danger\">[1]</span> <strong>shallot</strong></p><p>Peel and finely slice the <strong>remaining shallot</strong></p><p>Chop the <strong>dried cranberries</strong> roughly</p><p>Cut the <strong>orange<span class=\"text-danger\">[s]</span></strong> in half</p><p>Reboil half a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1651572359419-x200.jpg",
            "width": 200
