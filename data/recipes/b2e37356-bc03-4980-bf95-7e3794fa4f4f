      }
    },
    {
      "instruction": "<p>Peel and finely dice the<strong> red onion<span class=\"text-danger\">[s]</span></strong></p><p>Dissolve the <strong>vegetable stock mix</strong> in 600ml <span class=\"text-danger\">[1.2L]</span> <strong>boiled water</strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/369_step-2-x200.jpg",
            "width": 200
