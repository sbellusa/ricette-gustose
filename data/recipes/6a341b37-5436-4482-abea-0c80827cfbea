            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, transfer the <strong>peri peri steak[s]</strong> to a clean board and slice</p><p>Wash your <strong>salad</strong>, then pat it dry with kitchen paper</p><p>Slice the <strong>warmed ciabatta[s] </strong>in half</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1581515534700-x200.jpg",
