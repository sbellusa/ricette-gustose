            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chips are done, remove them from the oven and push into two piles</p><p>Top each pile with the <strong>grated cheese</strong></p><p>Add your <strong>ciabatta[s]</strong> to the other side of the tray[s] and return the tray[s] to the oven for 2-3 min until the cheese has melted and the ciabatta[s] is warmed through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1581515528189-x200.jpg",
