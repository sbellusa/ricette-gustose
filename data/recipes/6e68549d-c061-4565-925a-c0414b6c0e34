          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679566915000-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679566915000-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679566915000-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Toss the<strong> drained potatoes</strong> in the <strong>herby dressing </strong>– these are your <strong>herby potatoes</strong></p><p>Serve the<strong> sausage rolls</strong> with the<strong> chunky tomato & chilli chutney</strong>,<strong> apple salad </strong>and <strong>herby potatoes</strong> to the side</p><p>Enjoy!</p>",
      "order": 8,
