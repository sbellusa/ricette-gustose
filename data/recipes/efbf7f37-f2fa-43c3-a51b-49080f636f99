          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-2-1685028584302-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the prawns are cooking, peel and finely chop your <strong>shallot[s]</strong></p><p>Chop your <strong>dill</strong> finely, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-2-1685028596431-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-2-1685028596431-x400.jpg",
            "width": 400
          },
          {
