  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Cut the <strong>avocado<span class=\"text-danger\">[s]</span></strong> in half lengthways, around the <strong>stone<span class=\"text-danger\">[s]</span></strong></p><p>Remove the <strong>stone<span class=\"text-danger\">[s]</span></strong> using a spoon, then scoop out the avocado flesh and dice roughly</p><p>Chop the<strong> coriander </strong>finely, including the stalks</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1610451498219-x200.jpg",
            "width": 200
          },
          {
