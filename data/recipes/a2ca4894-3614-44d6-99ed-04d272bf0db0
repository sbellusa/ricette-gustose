          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1692971179379-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>chopped asparagus </strong>to the pan with a pinch of <strong>salt </strong>and cook for 2-3 min or until beginning to soften</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1692971183253-x200.jpg",
            "width": 200
