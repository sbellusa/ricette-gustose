  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ Gas 7</p><p>Boil a full kettle</p><p>Add the <strong>conchiglie</strong> to a pot of <strong>boiled water </strong>with a large pinch of<strong> salt </strong>and bring to the boil over a high heat</p><p>Cook the <strong>conchiglie</strong> for an initial 4-5 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1615470589538-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1615470589538-x400.jpg",
