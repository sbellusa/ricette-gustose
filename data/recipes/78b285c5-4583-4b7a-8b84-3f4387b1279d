        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and roughly chop the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and roughly chop the <strong>garlic</strong></p><p>Dissolve the <strong>veg stock mix</strong> in 250ml <span class=\"text-danger\">[450ml]</span> <strong>boiled water</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-1615470649987-x200.jpg",
