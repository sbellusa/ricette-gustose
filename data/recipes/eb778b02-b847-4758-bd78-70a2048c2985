  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Add your <strong>chicken thighs </strong>to a bowl with 2 tbsp <span class=\"text-purple\">[3 tbsp] </span><span class=\"text-danger\">[4 tbsp] </span><strong>flour </strong>and a pinch of <strong>salt </strong>and <strong>pepper </strong>and toss them to coat them evenly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1713264991241-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1713264991241-x400.jpg",
            "width": 400
