          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1713265014114-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Mozambican-style chicken & peanut stew </strong>with the <strong>coriander rice</strong></p><p>Garnish with the<strong> reserved chopped coriander & chopped peanuts</strong></p><p>Enjoy!</p>",
