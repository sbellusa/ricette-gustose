            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>cucumber</strong> into quarters lengthways, then into chunks</p><p>Remove 1 <strong>outer</strong> <strong>leaf </strong>per person from your<strong> lettuce</strong> and set aside, shred the <strong>inner core</strong></p><p>Slice your <strong>tomato[es]</strong> into rounds</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1653319942527-x200.jpg",
