      }
    },
    {
      "instruction": "<p>Dissolve the<strong> beef stock cube<span class=\"text-danger\">[s]</span></strong> in 50ml <span class=\"text-danger\">[75ml]</span> <strong>boiled water</strong></p>\r\n<p>Add the&nbsp;<strong>beef mince</strong>, <strong>beef stock</strong>,&nbsp;<strong>panko breadcrumbs</strong> and <strong>grated onion</strong></p>\r\n<p>Season with a generous grind of <strong>pepper</strong> and knead thoroughly with clean hands for 2-3 min until fully combined</p>",
      "order": 2,
