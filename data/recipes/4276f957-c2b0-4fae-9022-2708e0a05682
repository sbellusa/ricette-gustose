          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1627383713646-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the potatoes have had an initial 12-15 min, add the <strong>pepper strips </strong>and <strong>cherry tomatoes</strong> to the tray[s]</p><p>Sprinkle over the <strong>remaining curry powder </strong>and give everything a good mix up</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627383722177-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627383722177-x400.jpg",
