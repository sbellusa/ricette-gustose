    {
      "instruction": "<p>Put the tray in the oven for 10-15 min or until the feta is golden</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1632759509082-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1632759509082-x400.jpg",
            "width": 400
