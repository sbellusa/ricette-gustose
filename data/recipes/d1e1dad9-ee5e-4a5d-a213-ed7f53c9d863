          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1700038472113-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail, peel and grate your <strong>carrot[s]</strong></p><p>Wash your <strong>spinach</strong> and pat dry with kitchen paper</p><p>Drain your <strong>tofu </strong>and pat dry with kitchen paper</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1700038499449-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1700038499449-x400.jpg",
