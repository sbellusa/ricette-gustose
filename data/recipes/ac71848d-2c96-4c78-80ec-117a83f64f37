  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Tear the <strong>ciabatta</strong> into rough, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1655806803242-x200.jpg",
