          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1655806808198-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1655806808198-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1655806808198-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>avocado<span class=\"text-danger\">[s]</span> </strong>in half lengthways, around the <strong>stone<span class=\"text-danger\">[s]</span></strong></p><p>Remove the <strong>stone<span class=\"text-danger\">[s]</span></strong> using a spoon, then scoop out the <strong>avocado flesh</strong> and dice roughly</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1655806810431-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1655806810431-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1655806810431-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1655806810431-x1000.jpg",
