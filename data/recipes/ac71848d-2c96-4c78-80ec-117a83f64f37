          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1655806810431-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the<strong> tomato<span class=\"text-danger\">[es]</span></strong> into wedges</p><p>Chop the<strong> basil</strong> roughly, including the stalks</p><p>Peel and finely slice the <strong>garlic</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1655806815407-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1655806815407-x400.jpg",
            "width": 400
