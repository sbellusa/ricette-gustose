            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1655806803242-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1655806803242-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> torn ciabatta </strong>to a baking tray with a drizzle of<strong> olive oil </strong>and a pinch of<strong> salt</strong></p><p>Put the tray in the oven for 5 min or until golden and crisp – these are your <strong>croutons</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1655806808198-x200.jpg",
            "width": 200
