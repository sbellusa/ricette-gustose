  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil a kettle</p><p>Add your <strong>smoked streaky bacon</strong> to a <strong>tin foil</strong>-lined baking tray</p><p>Put the tray in the oven for 12-15 min or until golden and crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1585746815281-x200.jpg",
            "width": 200
