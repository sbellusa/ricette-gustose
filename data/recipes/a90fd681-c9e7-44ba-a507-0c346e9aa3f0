  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p><p>Boil half a kettle</p><p>Peel and finely slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Add the <strong>lamb mince</strong> to a bowl with a generous pinch of both <strong>salt </strong>and <strong>pepper</strong> and mix until combined (clean hands is the best way!)</p><p>Divide the <strong>mince</strong> into 6 <span class=\"text-danger\">[12] </span>and shape into <strong>meatballs</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1597834726622-x200.jpg",
