            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add your <strong>ginger & garlic paste </strong>and <strong>red</strong> <strong>Thai curry paste </strong>with 1 tsp <span class=\"text-purple\">[1 1/2 tsp] </span><span class=\"text-danger\">[2 tsp]</span> <strong>sugar </strong>and cook for 1-2 min or until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1725446960954-x200.jpg",
