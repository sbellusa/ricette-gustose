            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1934.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your<strong> tomato paste</strong> to a bowl with the <strong>chopped garlic</strong> and a generous pinch of <strong>salt</strong>, <strong>pepper </strong>and <strong>sugar</strong></p><p>Add 4 tbsp <span class=\"text-purple\">[6 tbsp]</span> <span class=\"text-danger\">[8 tbsp] </span><strong>cold water</strong> and stir it all together – this is your<strong> tomato sauce</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1934.-step-2-x200.jpg",
            "width": 200
