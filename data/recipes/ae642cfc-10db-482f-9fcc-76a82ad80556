            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1694438685094-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1694438685094-x700.jpg",
            "width": 700
          },
          {
