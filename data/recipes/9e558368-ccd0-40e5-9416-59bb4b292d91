  "cooking_instructions": [
    {
      "instruction": "<p>Add your <strong>white long grain rice</strong> to a pot with a lid with 225ml <span class=\"text-purple\">[300ml] </span><span class=\"text-danger\">[450ml]</span> <strong>cold</strong> <strong>water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 12-15 min or until all the water has absorbed and the rice is cooked, then once done, remove from the heat and set aside to cool</p>",
      "order": 1,
      "media": {
        "images": [
