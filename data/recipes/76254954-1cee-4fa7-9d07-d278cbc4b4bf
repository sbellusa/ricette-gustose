  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6 and boil a full kettle</p><p>Chop your <strong>chestnut mushrooms</strong> very finely</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a high heat</p><p>Once hot, add the <strong>chopped mushrooms</strong> and cook for 3-4 min or until golden</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1608572340788-x200.jpg",
