          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1687782639188-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve your <strong>miso</strong> <strong>paste</strong> in 750ml <span class=\"text-purple\">[975ml]</span> <span class=\"text-danger\">[1.4L]</span> <strong>boiled</strong> <strong>water</strong> – this is your <strong>miso stock</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1687782642769-x200.jpg",
