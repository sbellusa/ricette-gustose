            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once beginning to soften, add your <strong>arborio rice</strong> to the pan with your <strong>lime leaf[ves]</strong> and <strong>mirin </strong>and cook for 1 min or until evaporated</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1687782646269-x200.jpg",
