  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Rinse your <strong>quinoa</strong> in a sieve under <strong>cold running water</strong></p><p>Add the <strong>quinoa</strong> to a large pot with plenty of <strong>boiled water </strong>and your <strong>vegetable stock mix </strong>and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 6-8 min or until all the water has absorbed and the quinoa is tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1679675184066-x200.jpg",
