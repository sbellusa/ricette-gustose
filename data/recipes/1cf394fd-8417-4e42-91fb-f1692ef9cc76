            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the quinoa is cooking, peel and chop your <strong>sweet potato[es]</strong> into rounds</p><p>Peel and chop your <strong>red onion[s]</strong> into wedges</p>",
      "order": 2,
      "media": {
