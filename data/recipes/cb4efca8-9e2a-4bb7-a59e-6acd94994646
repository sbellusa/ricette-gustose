            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>nectarines</strong> in half lengthways, around the <strong>stone[s]</strong></p><p>Remove the <strong>stone[s]</strong> using a spoon</p><p>Chop half your <strong>nectarine[s] </strong>into 6 wedges per person and set the <strong>remaining nectarine </strong>aside</p>",
      "order": 2,
      "media": {
        "images": [
          {
