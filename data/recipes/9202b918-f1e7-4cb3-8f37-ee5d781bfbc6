          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2469Step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>meat-free mince meatballs </strong>and cook for 3 min, turning occasionally, until browned all over</p><p>Once browned, transfer the <strong>browned</strong> <strong>meat-free mince meatballs </strong>to a plate and set aside</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2469Step-3-x200.jpg",
            "width": 200
          },
          {
