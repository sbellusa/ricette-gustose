            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Top, tail, peel and grate the<strong> carrot<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2469Step-2-x200.jpg",
            "width": 200
          },
