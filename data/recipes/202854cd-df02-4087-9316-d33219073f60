            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>meat-free mince</strong> (remove the paper if required!) to the dish<strong> </strong>with<strong> </strong>1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span> <span class=\"text-danger\">[2 tbsp]</span><strong> flour</strong> and cook for 1-2 min or until very lightly browned all over, breaking it up into rough, large chunks</p>",
      "order": 3,
      "media": {
        "images": [
