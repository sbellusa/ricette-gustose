            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While everything is cooking, chop the <strong>tomatoes</strong> roughly, until they resemble a salsa-like consistency</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1626797382367-x200.jpg",
            "width": 200
          },
          {
