  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the sweet potatoes and chop into 5cm pieces</p>\r\n<p><strong>Once</strong> the water in the rice pot is boiling, add the sweet potatoes and put a lid on</p>\r\n<p><strong>Reduce</strong> the heat to medium and cook for 10 min, or until the potatoes are softened and rice cooked</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> each chicken breast in half lengthwise, to form 4 <span class=\"text-danger\">(8)</span> escalopes</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Reserve</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of curry powder (used in step 7)</p>\r\n<p><strong>Coat</strong> the chicken with the remaining curry powder</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 2-4 tbsp of olive oil to a large pan </p>\r\n<p><strong>Once</strong> the oil is hot, add the chicken </p>\r\n<p><strong>Cook</strong> on each side for 4 min or until cooked through</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the coriander coarsely (including the stalks)</p>\r\n<p><strong>Grate</strong> the zest of the lime<span class=\"text-danger\">(s)</span></p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the coriander, lime zest, juice of the lime<span class=\"text-danger\">(s)</span>, 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of olive oil, the remaining curry powder, and a pinch of each salt and sugar in a processor or blender</p>\r\n<p><strong>Combine</strong> until you get a green fresh tasting chutney/salsa</p>\r\n<p>Tip: Pour any remaining pan juices from the chicken into the dressing</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> up the rice and sweet potato with the chicken </p>\r\n<p><strong>Spoon</strong> the coriander and lime dressing over the plates</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
