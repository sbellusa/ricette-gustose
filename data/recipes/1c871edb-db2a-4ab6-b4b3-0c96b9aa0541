  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and chop the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into wedges</p><p>Heat a large, wide-based pan with a generous drizzle of<strong> vegetable oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>red onion wedges</strong> with a generous pinch of<strong> salt</strong> and cook for 4-5 min or until starting to soften</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1593430059385-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1593430059385-x400.jpg",
            "width": 400
