            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Pierce your <strong>bao bun</strong> <strong>packet[s] </strong>with a few holes and <strong>microwave </strong>for 1-2 min</p><p>Chop the <strong>remaining lime</strong> into 1 wedge per person</p>",
      "order": 7,
