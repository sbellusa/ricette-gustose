            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, top, tail, peel and grate your <strong>carrot[s]</strong></p><p>Slice your <strong>cucumber</strong> into discs on the diagonal</p><p>Slice each individual <strong>cucumber disc</strong> into matchsticks</p><p>Chop your <strong>coriander </strong>finely, including the stalks (save some leaves for a garnish!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-3-1678455550756-x200.jpg",
