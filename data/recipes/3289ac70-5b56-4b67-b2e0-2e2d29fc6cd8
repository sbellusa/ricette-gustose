            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil </strong>over a medium-high heat</p><p>Once hot, add the<strong> bashed Fable pulled mushrooms</strong> and cook for 8-10 min or until browned</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-2-1678455585479-x200.jpg",
