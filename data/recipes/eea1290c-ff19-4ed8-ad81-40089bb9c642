  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Strip the <strong>mint leaves</strong> from their stems and chop them finely, discard the stems</p><p>Tip: Hold the top of the herb sprigs firmly and slide your fingers down their lengths to easily remove the leaves</p><p>Cut the <strong>red chilli<span class=\"text-danger\">[es]</span> </strong>in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1583491076153-x200.jpg",
            "width": 200
