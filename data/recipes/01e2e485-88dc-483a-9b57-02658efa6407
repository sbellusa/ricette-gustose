  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Top, tail, peel and dice your <strong>carrot[s]</strong> finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Chop your <strong>parsley</strong> finely, including the stalks</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1693405438029-x200.jpg",
