  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Heat a pot with a matching lid, with a knob of <strong>butter</strong> over a medium heat</p><p>Add the <strong>white long grain rice</strong> to the pot with a pinch or <strong>salt</strong> and cook for 2 min or until the rice has darkened slightly in colour</p>",
      "order": 1,
      "media": {
        "images": [
