            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Finely chop your<strong> sun-dried tomatoes</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1661184256747-x200.jpg",
