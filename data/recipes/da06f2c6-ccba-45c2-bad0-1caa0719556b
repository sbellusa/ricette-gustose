          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1619787072180-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>remaining</strong> <strong>Henderson's Relish </strong>and <strong>mayo</strong> in a bowl – this is your <strong>Henderson's mayo</strong></p><p>Wash your<strong> lettuce</strong>, then pat dry with kitchen paper and shred</p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1619787122803-x200.jpg",
