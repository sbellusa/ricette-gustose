            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>coriander</strong> finely, including the stalks</p><p>Drain your <strong>sweetcorn</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1722521964635-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1722521964635-x400.jpg",
