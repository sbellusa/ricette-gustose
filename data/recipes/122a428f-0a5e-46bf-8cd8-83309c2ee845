          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1722521949311-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add your <strong>chicken breast portion[s] </strong>to the dish with a generous knob of<strong> butter</strong> and cook for 3 min or until very lightly browned</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1722521959616-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1722521959616-x400.jpg",
