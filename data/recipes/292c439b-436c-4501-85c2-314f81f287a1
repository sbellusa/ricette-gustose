  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 400°F/ Gas 6</p>\n<p>Peel and finely slice the <strong>shallot<span class=\"text-danger\">[s]</span></strong></p>\n<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive</strong><strong> oil</strong> over a medium heat</p>\n<p>Once hot, add the <strong>sliced</strong> <strong>shallot</strong> with a generous pinch of <strong>salt</strong> and cook for 4 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
