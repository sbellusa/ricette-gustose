            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1683028172998-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1683028172998-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>one-pot tomato spaghetti & lean meatballs </strong>with the <strong>remaining</strong> <strong>grated cheese </strong>sprinkled on top</p><p>Serve the<strong> salad</strong> to the side and top with a drizzle of <strong>olive oil </strong>and a crack of <strong>black pepper</strong></p><p>Garnish with the <strong>remaining basil</strong></p><p>Enjoy!</p>",
      "order": 8,
