          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1708419844601-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add <strong>half </strong>of the <strong>chopped garlic</strong> and <strong>half </strong>of your <strong>shichimi togarashi </strong>(can't handle the heat? Go easy!)</p><p>Cook for 1-2 min or until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1708419853988-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1708419853988-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1708419853988-x700.jpg",
            "width": 700
