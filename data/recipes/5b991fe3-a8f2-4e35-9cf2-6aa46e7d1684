          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/55_step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop the <strong>beef tomato<span class=\"text-danger\">[es]</span></strong> into large bite-size pieces</p>\r\n<p>Dissolve the <strong>chicken stock cube<span class=\"text-danger\">[s]</span></strong> in 100ml <span class=\"text-danger\">[200ml]</span> <strong>boiled water&nbsp;</strong></p>\r\n<p>Drain and rinse the <strong>butter beans</strong></p>\r\n<p>&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/55_step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/55_step-5-x400.jpg",
