          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1634721221773-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> Greek cheese</strong> to a <strong>tin foil</strong>-lined baking tray</p><p>Drizzle with <strong>olive oil</strong> and<strong> </strong>season with<strong> </strong>a grind of <strong>black pepper </strong>and put in the oven for 10-15 min or until golden and softened</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1634721229255-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1634721229255-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1634721229255-x700.jpg",
