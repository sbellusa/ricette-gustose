  "cooking_instructions": [
    {
      "instruction": "<p>Cut your <strong>red chilli[es]</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p><p>Cut your<strong> lemon[s]</strong> in half</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1637082368726-x200.jpg",
