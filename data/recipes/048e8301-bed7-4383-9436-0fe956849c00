          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1608551803728-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1608551803728-x1000.jpg",
