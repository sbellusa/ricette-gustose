  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely dice your <strong>shallot[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690275043784-x200.jpg",
