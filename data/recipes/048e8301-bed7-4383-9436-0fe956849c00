            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>spaghetti</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook the<strong> </strong> for 8-10 min or until cooked with a slight bite</p><p>Once done, drain the <strong>spaghetti</strong>, reserving a cup of the <strong>starchy pasta water</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1608551803728-x200.jpg",
            "width": 200
