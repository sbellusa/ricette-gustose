          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1608551715413-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, combine <strong>half</strong> of your<strong> cider vinegar </strong>(save the rest for later!) with 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp]</span> <strong>olive oil </strong>in a bowl and give it a good mix up – this is your <strong>dressing</strong></p><p>Dice your <strong>tomato[es]</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1608551733131-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1608551733131-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1608551733131-x700.jpg",
