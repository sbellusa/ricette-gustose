  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil a kettle</p><p>Add the<strong> diced chicken thigh</strong> to a bowl with your <strong>cornflour</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Mix it all together until fully coated – this is your <strong>coated chicken</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1342.-step-1-x200.jpg",
            "width": 200
          },
          {
