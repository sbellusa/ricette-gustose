          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-5-1710854461645-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the pasta is cooking, peel and finely slice your<strong> red onion[s]</strong></p><p>Chop your<strong> free range chicken breast portion[s]</strong> into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-5-1710854466258-x200.jpg",
            "width": 200
          },
          {
