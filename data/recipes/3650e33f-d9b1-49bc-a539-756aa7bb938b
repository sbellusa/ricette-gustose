  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken </strong>out of the fridge, open the packet and let it air, then boil a kettle</p><p>Add your <strong>farfalle</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 8-12 min or until cooked with a slight bite</p><p>Once done, drain and reserve about 200ml<span class=\"text-purple\"> [300ml] </span><span class=\"text-danger\">[400ml] </span><strong>starchy pasta water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-5-1710854461645-x200.jpg",
            "width": 200
