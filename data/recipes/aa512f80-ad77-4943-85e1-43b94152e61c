      }
    },
    {
      "instruction": "<p>Dissolve your <strong>chicken stock mix</strong> in 100ml <span class=\"text-purple\">[150ml]</span> <span class=\"text-danger\">[200ml] </span><strong>boiled water</strong></p>",
      "order": 5,
