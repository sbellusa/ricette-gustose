          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1679659430749-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1679659430749-x1000.jpg",
