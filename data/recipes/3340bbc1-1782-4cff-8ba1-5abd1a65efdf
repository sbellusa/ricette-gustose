  "cooking_instructions": [
    {
      "instruction": "<p><strong>Before you begin...</strong></p>\n<p>Get all your ingredients and equipment ready</p>\n<p>Skim through these steps</p>\n<p>Wash your fruit and veg</p>\n<p>Note: Equipment and pan sizes vary. <span class=\"text-highlight\">Make sure</span> you cook food thoroughly (even if it takes you a little longer than 10 mins)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1971.-step-1-x200.jpg",
            "width": 200
