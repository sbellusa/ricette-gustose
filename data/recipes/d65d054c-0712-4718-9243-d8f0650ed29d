      }
    },
    {
      "instruction": "<p>Mix the <strong>chipotle paste</strong> with <strong>half</strong> the <strong>mayo</strong> (save the rest for later!) – this is your <strong>chipotle mayo</strong></p>",
      "order": 6,
      "media": {
