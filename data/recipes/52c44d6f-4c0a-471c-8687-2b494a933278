          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2110.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2110.-step-5-x1000.jpg",
            "width": 1000
