  "cooking_instructions": [
    {
      "instruction": "<p>Add the <strong>white long grain rice</strong> to a pot with a lid with 225ml <span class=\"text-danger\">[450ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 12-15 min or until all the water has absorbed and the rice is cooked</p><p>Once done, remove from the heat and set aside (lid on) to steam until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1644338353604-x200.jpg",
