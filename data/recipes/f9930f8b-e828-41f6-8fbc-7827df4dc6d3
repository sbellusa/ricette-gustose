  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 7</p><p>Cut your <strong>potato[es] </strong>(skins on) into wedges</p><p>Add the <strong>wedges</strong> to a baking tray (or two!) with a drizzle of<strong> vegetable oil </strong>and a pinch of <strong>salt</strong> and<strong> pepper </strong>and give everything a good mix up</p><p>Put the tray[s] in the oven for 20-25 min or until the wedges are tender and starting to crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2129.-step-1-x200.jpg",
            "width": 200
