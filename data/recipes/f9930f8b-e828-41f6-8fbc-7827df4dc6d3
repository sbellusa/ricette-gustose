            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut your <strong>halloumi</strong> into 2 equal sized slices per person</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2129.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2129.-step-2-x400.jpg",
            "width": 400
