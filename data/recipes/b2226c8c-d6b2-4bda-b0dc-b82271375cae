            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>sliced</strong> <strong>cucumber</strong> and <strong>sliced</strong> <strong>spring onion</strong> to a mixing bowl with your <strong>rice vinegar </strong>and a large pinch of <strong>salt</strong></p><p>Mix well and set aside – this is your <strong>quick-pickled cucumber</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1637067321732-x200.jpg",
