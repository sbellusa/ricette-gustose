  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Soak your <strong>skewers</strong> in <strong>cold water</strong> (this prevents them from burning whilst cooking)</p><p>Chop your <strong>tofu</strong> into 6 large cubes per person by dividing the block into 3 lengthways and then cutting each slice into quarters</p><p>Chop your <strong>creamed coconut</strong> roughly (if required!) and combine with 200ml <span class=\"text-purple\">[300ml]</span> <span class=\"text-danger\">[400ml] </span><strong>boiled water</strong> – this is your<strong> coconut stock</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
