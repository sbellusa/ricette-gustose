            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>green chilli<span class=\"text-danger\">[es]</strong> </span>into rounds</p><p>Strip the <strong>coriander leaves </strong>from the stems, discard the stems</p><p>Wash the <strong>spinach</strong>, then pat it dry with kitchen paper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1650992317709-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1650992317709-x400.jpg",
            "width": 400
