            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1650992311422-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, combine the <strong>ginger & garlic paste</strong> with 1 tsp <span class=\"text-danger\">[2 tsp] </span><strong>sugar</strong>, the <strong>soy sauce</strong> and <strong>Chinese rice wine</strong> in a small bowl – this is your<strong> seasoned soy sauce</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1650992314784-x200.jpg",
