  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut the<strong> pepper<span class=\"text-danger\">[s]</span></strong> in half (scrape the seeds and pith out with a teaspoon)</p><p>Top, tail and chop the <strong>courgette<span class=\"text-danger\">[s]</strong> </span>into bite-sized pieces</p><p>Cut the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into quarters, keeping the skin on and root attached</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1618227799566-x200.jpg",
            "width": 200
