            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> meat-free sausages</strong> to the opposite side of the tray</p><p>Put the tray in the oven for 25-30 min until the sausages are golden and cooked through and the veg is starting to brown</p><p>Tip: Cooking for 4? Use to 2 trays!</p><p>Meanwhile, boil a kettle</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1618227810075-x200.jpg",
