      }
    },
    {
      "instruction": "<p>Whilst everything is cooking, chop your <strong>black</strong> <strong>olives</strong> in half</p><p>Crumble your <strong>feta</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1706622809851-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1706622809851-x400.jpg",
