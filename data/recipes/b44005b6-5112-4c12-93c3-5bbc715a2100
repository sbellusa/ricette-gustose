  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Chop your <strong>potatoes</strong> (skins on) into bite-sized pieces</p><p>Peel and chop your <strong>red onion[s] </strong>into wedges</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1706622773960-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1706622773960-x400.jpg",
            "width": 400
          },
          {
