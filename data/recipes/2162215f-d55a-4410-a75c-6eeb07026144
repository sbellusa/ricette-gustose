          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1632227346034-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the rice is cooking, add your <strong>free</strong> <strong>range</strong> <strong>chicken breast portion[s]</strong> to a chopping board and cover with a sheet of <strong>cling film</strong></p><p>Bash the<strong> chicken</strong> with a <strong>rolling pin</strong> until evenly flattened – this is your<strong> chicken escalope</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1632227354732-x200.jpg",
