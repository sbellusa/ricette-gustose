  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice your<strong> potatoes</strong> (skins on) into discs and add them to a baking tray (or two!) with a generous drizzle of <strong>vegetable oil</strong> and a small pinch of<strong> salt </strong>and<strong> pepper</strong></p><p>Give everything a good mix up and put the tray[s] in the oven for 15-20 min or until beginning to soften</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1672756500983-x200.jpg",
