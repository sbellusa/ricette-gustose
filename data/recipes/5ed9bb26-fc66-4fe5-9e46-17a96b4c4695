  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ gas 4, then take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Peel and finely slice your<strong> brown onion[s]</strong></p><p>Trim, then chop your <strong>green beans </strong>in half</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Zest your<strong> lemon[s] </strong>and cut into wedges</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1661516350004-x200.jpg",
            "width": 200
