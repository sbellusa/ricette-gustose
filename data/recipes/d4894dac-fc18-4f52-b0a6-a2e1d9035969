  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Peel</strong> and chop the onion<span class=\"text-danger\">[s]</span> finely</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) over a medium-low heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the onions and the garlic and cook for 10 min or until softened</p>\r\n<p><strong>Once</strong> done, transfer the onion and garlic to a bowl (reserve the pan for a later step!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the rice, 175ml <span class=\"text-danger\">[350ml]</span> water and a pinch of salt to a pot with a lid over a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/612.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile,</strong> return&nbsp;the pan to a medium heat</p>\r\n<p><strong>Once</strong> hot, add the beef mince and cook for 5 min or until starting to brown, breaking it up as you go</p>\r\n<p><strong>Meanwhile</strong>, drain and rinse the kidney beans</p>",
      "order": 4,
      "media": {
