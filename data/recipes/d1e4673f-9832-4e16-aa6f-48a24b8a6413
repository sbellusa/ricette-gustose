            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the fish fingers are cooking, add the juice<strong> </strong>of<strong> </strong>1/2<span class=\"text-danger\"> [1]</span><strong> lemon </strong>(not a fan of citrus? Use a little less!), a drizzle of<strong> olive oil</strong> and a pinch of<strong> salt </strong>to the <strong>drained potatoes</strong> – these are your <strong>lemony potatoes</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1640100118116-x200.jpg",
