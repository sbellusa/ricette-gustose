  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>chopped cauliflower </strong>and<strong> chopped pepper & red onion </strong>with a pinch of <strong>salt </strong>and cook for 2-3 min until starting to soften and brown</p>",
      "order": 1,
      "media": {
        "images": [
