          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/525.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, quarter the <strong>apple<span class=\"text-danger\">[s]</span></strong>&nbsp;(skin on) and discard the core<span class=\"text-danger\">[s]</span></p>\r\n<p>Chop into small, bite-size pieces</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 4,
