  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Take 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span> <span class=\"text-danger\">[2 tbsp]</span><strong> butter </strong>out of the fridge and set aside to soften, then chop your <strong>potatoes</strong> into small bite-sized pieces</p><p>Chop your <strong>leek[s]</strong> in half lengthways, wash thoroughly to remove any grit then top, tail and slice finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
