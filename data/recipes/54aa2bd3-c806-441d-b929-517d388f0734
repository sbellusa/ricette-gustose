            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Grate your <strong>cheddar cheese</strong> finely</p><p>Chop your <strong>parsley</strong> as finely as you can, including the stalks</p>",
      "order": 2,
      "media": {
