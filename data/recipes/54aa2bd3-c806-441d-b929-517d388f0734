          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1698922558778-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your <strong>panko breadcrumbs</strong> and <strong>grated cheese</strong> in a small bowl with a pinch of<strong> salt</strong> – these are your <strong>cheesy breadcrumbs</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1698922561598-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1698922561598-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1698922561598-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1698922561598-x1000.jpg",
            "width": 1000
