            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 500ml <span class=\"text-danger\">[800ml]</span>&nbsp;boiled water to a wide pot and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, carefully add the halloumi slices and boil for 4-5 min</p>\r\n<p><strong>Drain</strong> the boiled halloumi and carefully pat the slices dry with a clean tea towel or kitchen paper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/326-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/326-step-5-x400.jpg",
