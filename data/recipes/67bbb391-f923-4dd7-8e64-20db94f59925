  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Add</strong> the bulgur to a pot with plenty of salted boiled water over a high heat and cook&nbsp;for 10-15 min or until tender with a slight bite, then drain and return to the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/326-step-1-x200.jpg",
            "width": 200
          },
          {
