          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Using</strong> a rolling pin, flatten and roll out the stretchy halloumi until it's approx. 1cm thick</p>\r\n<p><strong>These</strong> are your halloumi steaks</p>",
      "order": 6,
      "media": {
