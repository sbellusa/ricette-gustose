  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil half a kettle</p><p>Top, tail and slice the <strong>aubergines</strong> lengthways into roughly 1cm thick slices</p><p>Chop any leftover pieces of<strong> aubergine </strong>roughly</p>",
      "order": 1,
      "media": {
        "images": [
