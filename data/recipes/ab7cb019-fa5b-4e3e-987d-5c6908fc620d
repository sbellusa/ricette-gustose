          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1690285282199-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the <strong>cherry tomatoes</strong> in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-1690285288416-x200.jpg",
