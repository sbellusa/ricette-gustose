  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ gas 4 and boil a kettle</p><p>Peel and cut the <strong>waxy potatoes</strong> into small, bite-sized pieces</p><p>Add them to a pot, cover with<strong> boiled water</strong> and a pinch of <strong>salt</strong> and bring back to the boil over a high heat</p><p>Once boiling, cook for 10-15 min until the potatoes are fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1690285282199-x200.jpg",
            "width": 200
