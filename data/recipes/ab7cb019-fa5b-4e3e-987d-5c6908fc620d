            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-copy-1690285312123-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the <strong>drained</strong> <strong>potatoes</strong> to the pot with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> <strong>lemon juice</strong>, a<strong> </strong>knob of<strong> butter </strong>and a drizzle of <strong>olive oil</strong></p><p>Mash until smooth, then season with a pinch of <strong>salt</strong> and <strong>pepper</strong> – this is your <strong>lemon mash</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-copy-1690285317913-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-copy-1690285317913-x400.jpg",
