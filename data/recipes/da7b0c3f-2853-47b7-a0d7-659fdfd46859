            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has softened, add the <strong>chopped leek</strong>, <strong>carrot discs</strong> and <strong>chopped potatoes </strong>to the pot</p><p>Cook for a further 4-5 min or until the leek has softened</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1670347700071-x200.jpg",
