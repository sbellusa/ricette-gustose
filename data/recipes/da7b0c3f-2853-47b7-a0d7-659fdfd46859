        ]
      }
    },
    {
      "instruction": "<p>Preheat the grill to medium-high</p><p>Drain the <strong>sweetcorn</strong></p><p>Add the <strong>drained sweetcorn</strong> to a <strong>tin foil</strong>-lined baking tray</p><p>Put the tray under the grill and cook for 8-10 min or until the corn is lightly charred – this is your <strong>charred corn</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1670347716981-x200.jpg",
