  "cooking_instructions": [
    {
      "instruction": "<p>Rinse your <strong>quinoa</strong> in a sieve under <strong>cold running water</strong></p><p>Add the<strong> quinoa</strong> to a pot with a lid with 180ml <span class=\"text-purple\">[270ml]</span> <span class=\"text-danger\">[360ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to low and cook, covered, for 18-20 min or until all the water has absorbed and the quinoa is tender</p><p>Once cooked, remove from the heat and leave to steam-dry, uncovered, until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1580125301371-x200.jpg",
