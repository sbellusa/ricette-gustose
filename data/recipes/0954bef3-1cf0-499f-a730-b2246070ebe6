          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708618348524-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708618348524-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708618348524-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708618348524-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the fries are cooking, cut your <strong>cucumber</strong> into batons</p><p>Wash your <strong>lettuce</strong>, then pat dry with kitchen paper and shred finely</p><p>Slice your <strong>brioche</strong> <strong>bun[s]</strong> in half</p><p>Boil half a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618352097-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618352097-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1708618352097-x700.jpg",
            "width": 700
