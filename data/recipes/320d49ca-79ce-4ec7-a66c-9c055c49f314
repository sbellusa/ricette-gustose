          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/505.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the couscous to a shallow bowl with 200ml <span class=\"text-danger\">(400ml)</span> boiled water and cover with a tea towel</p>\r\n<p><strong>Set</strong> aside for 10 min or until the water is absorbed and the couscous tender</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/505.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/505.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/505.-step-5-x700.jpg",
