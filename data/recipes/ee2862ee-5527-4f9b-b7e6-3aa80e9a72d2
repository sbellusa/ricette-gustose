          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-3-1716392983136-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-3-1716392983136-x700.jpg",
            "width": 700
