          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1715615768401-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1715615768401-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1715615768401-x1000.jpg",
