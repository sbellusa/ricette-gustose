            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>spring onion<span class=\"text-danger\">[s]</span></strong> finely discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p>Set aside a small pinch of chopped spring onions for garnish</p>",
