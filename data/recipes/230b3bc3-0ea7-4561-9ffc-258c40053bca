          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1617709499881-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>beluga lentils</strong> to the onion and cook for 3-4 min</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1617709849659-x200.jpg",
