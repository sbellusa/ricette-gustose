  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Put a large baking tray (or two!) in the oven to heat up (this will stop the <strong>pizza bottoms</strong> from going soggy!)</p><p>Add the <strong>tomato paste </strong>to a bowl with the <strong>dried oregano</strong> and a generous pinch of<strong> salt</strong>, <strong>pepper</strong> and <strong>sugar</strong></p><p>Add 5 tbsp<span class=\"text-danger\"> [10 tbsp]</span> <strong>cold water </strong>and stir it all together – this is your <strong>tomato base</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690215657530-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690215657530-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690215657530-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690215657530-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1690215657530-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>soft cheese</strong> to a separate bowl with 2 tbsp <span class=\"text-danger\">[4 tbsp] </span><strong>cold water</strong></p><p>Mix<strong> </strong>it all together<strong> </strong>until smooth – this is your <strong>creamy base</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1690215660664-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1690215660664-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1690215660664-x700.jpg",
            "width": 700
