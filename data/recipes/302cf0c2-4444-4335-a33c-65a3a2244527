            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1627381230507-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the onion is softening, peel and finely chop (or grate) your<strong> garlic</strong></p><p>Slice your <strong>chestnut mushrooms</strong> finely</p><p>Boil half a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1627381241266-x200.jpg",
            "width": 200
