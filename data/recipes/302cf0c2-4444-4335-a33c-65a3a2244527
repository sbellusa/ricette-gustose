            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve your <strong>vegetable stock mix</strong>, <strong>tomato paste</strong> and <strong>soy sauce</strong> in 250ml <span class=\"text-purple\">[325ml]</span> <span class=\"text-danger\">[450ml]</span> <strong>boiled water</strong> – this is your <strong>vegetable</strong> <strong>stock</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627381258992-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627381258992-x400.jpg",
