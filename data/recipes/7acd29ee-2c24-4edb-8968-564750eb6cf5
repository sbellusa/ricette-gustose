            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1688113195939-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely dice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Top, tail, peel and finely dice the <strong>carrot<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely dice the <strong>potatoes</strong></p><p>Peel and finely slice (don't chop!) the <strong>garlic</strong></p><p>Drain and rinse the <strong>cannellini beans</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1688113199321-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1688113199321-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1688113199321-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1688113199321-x1000.jpg",
