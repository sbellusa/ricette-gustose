  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 225&deg;C/ 200&deg;C (fan)/ 450&deg;F/ Gas 7</p>\r\n<p><strong>Boil</strong> a kettle (used in step 3)</p>\r\n<p><strong>Cut</strong> the potatoes, with skin on, into approx. 4cm chunks</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 7 min and drain</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, crush the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Grind</strong> the fennel seeds, 1/4 tsp <span class=\"text-danger\">(1/2 tsp)</span> salt, 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> pepper and the chilli ﬂakes (careful, adjust the amount to your preferred hotness) in a pestle and mortar</p>\r\n<p><strong>Add</strong> half of the garlic and 2-4 tbsp of olive oil for a thick paste</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely slice the onion(s) and place in the middle of an oven-proof tray</p>\r\n<p><strong>Drain</strong> the potatoes and coat with a pinch of salt, 1-2 tbsp of olive oil and arrange around the edges of the tray</p>\r\n<p><strong>Put</strong> in the oven for an initial 10 min</p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 80ml <span class=\"text-danger\">(140ml)</span> of boiled water</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the pork steaks on one side of a large sheet of clingfilm (approx. A3 size)</p>\r\n<p><strong>Spread</strong> the spice paste onto the tops and bottoms of each steak </p>\r\n<p><strong>Cover</strong> the tops of the steaks with the clingfilm and tenderise with a rolling pin to 1cm thickness</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>After</strong> the initial 10 min, remove the potato tray from the oven</p>\r\n<p><strong>Place</strong> the steaks on top of the onions in the middle of the tray<br /><br /><strong>Return</strong> the tray to the oven for 15-20 min or until the pork is cooked through to your taste</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, drain the butter beans and tomato through a sieve, shaking it until you're just left with the tomato chunks</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pot on a high heat 10 min before the pork is ready</p>\r\n<p><strong>Once</strong> the oil is hot, add the remaining garlic and cook for 30 sec</p>\r\n<p><strong>Add</strong> the butter beans and tomato and cook for 2 min, then add the stock</p>\r\n<p><strong>Bring</strong> to a boil then reduce the heat and simmer uncovered for 5-7 min, or until thickened and combined, stirring often</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Season</strong> the beans to your taste with salt and pepper and cover to keep warm</p>\r\n<p><strong>Remove</strong> the pork tray from the oven, cover well and leave to rest for 5 min</p>\r\n<p><strong>Serve</strong> the pork with all the trimmings</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
