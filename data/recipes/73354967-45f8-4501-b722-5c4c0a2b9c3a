  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Wash your<strong> leek[s]</strong> thoroughly to remove any grit from between the leaves, then top, tail and slice finely</p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1849.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1849.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1849.-step-1-x700.jpg",
            "width": 700
          },
          {
