    },
    {
      "instruction": "<p><strong>Cut</strong> the pepper<span class=\"text-danger\">(s)</span> in half and discard the pith and seeds</p>\r\n<p><strong>Dice</strong> the tomato<span class=\"text-danger\">(es)</span> and place inside the pepper halves</p>",
      "order": 2,
