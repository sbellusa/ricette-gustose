          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the potatoes into thin slices (approx. 1/2cm)</p>\r\n<p><strong>Place</strong> on an oven-proof tray</p>\r\n<p><strong>Coat</strong> well with 1-2 tbsp of olive oil and season generously with salt and pepper</p>\r\n<p><strong>Put</strong>&nbsp;them in the oven for 20 min or until golden, turning once</p>",
      "order": 4,
