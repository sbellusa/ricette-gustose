        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the stuffed peppers in an oven-proof dish</p>\r\n<p><strong>Drizzle</strong> the tomato with the red wine vinegar, 1/2-1 tbsp of olive oil and season generously with salt and pepper</p>\r\n<p><strong>Put</strong>&nbsp;them in the oven for 30 min or until tender</p>",
      "order": 3,
