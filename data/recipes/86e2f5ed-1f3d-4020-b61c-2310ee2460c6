    },
    {
      "instruction": "<p>While the duck is cooking, combine your <strong>cornflour</strong> with 50ml <span class=\"text-purple\">[65ml]</span> <span class=\"text-danger\">[85ml]</span> <strong>warm water</strong> in a small bowl - this is your <strong>cornflour mixture</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1701688290083-x200.jpg",
