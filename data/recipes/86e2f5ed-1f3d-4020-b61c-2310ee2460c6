  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Separate your <strong>duck leg[s]</strong> from the <strong>white duck fat</strong> and <strong>duck jelly</strong> (you'll use these later!)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1701688280629-x200.jpg",
            "width": 200
