            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>duck leg[s]</strong> to a <strong>baking paper</strong>-lined baking tray (or two!)</p><p>Put the tray[s] in the oven for 28-30 min or until the duck is golden and crispy – this is your <strong>roast duck</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1701688285020-x200.jpg",
