  "cooking_instructions": [
    {
      "instruction": "<p>Peel and slice the <strong>brown</strong>&nbsp;<strong>onion</strong><span class=\"text-danger\"><strong>[s]</strong></span></p>\r\n<p>Heat a large, wide-based pan (preferably non-stick) with a matching lid over a medium heat with a drizzle of <strong>vegetable oil</strong></p>\r\n<p>Once hot, add the<strong> sliced onion</strong>&nbsp;with a pinch of <strong>salt</strong> and cook for 5 min or until starting to soften</p>",
      "order": 1,
      "media": {
