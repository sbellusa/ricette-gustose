  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Combine</strong> the honey and wholegrain mustard in a large bowl - this is your marinade</p>\r\n<p><strong>Add</strong> the pork steaks and mix well to coat them fully</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper and set aside until step 5</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and chop the carrot<span class=\"text-danger\">(s)</span> into small dice</p>\r\n<p><strong>Peel</strong> and finely chop the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Finely</strong> chop the celery</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pot with a matching lid on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the carrot, onion and celery and cook for 5 min with a pinch of salt, until the onion is soft</p>\r\n<p><strong>Peel</strong> and finely chop the garlic clove<span class=\"text-danger\">(s)</span> in the meantime</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the bay leaf<span class=\"text-danger\">(ves)</span> &amp; garlic to the pot - cook for 1 min further before adding the lentils, stock cube<span class=\"text-danger\">(s)</span> &amp; 500ml <span class=\"text-danger\">(1L)</span> of boiling water, stir well &amp; reduce the heat</p>\r\n<p><strong>Simmer</strong> with the lid on over a high heat and cook the lentils for 15-20 min before step 5 (add more water if necessary)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/327.-step4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the lentils have cooked for 15-20 minutes, place another pan on a medium high heat</p>\r\n<p><strong>Shake</strong> the excess honey mustard mix off the steaks (but reserve the excess for step 7)</p>\r\n<p><strong>Add</strong> the steaks to the hot pan and cook for 5 min on each side, or until slightly charred on the outside and cooked through</p>",
      "order": 5,
