    {
      "instruction": "<p>Cut the <strong>remaining</strong> <strong>lime</strong> into 1 wedge per person</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 7,
      "media": {
        "images": [
