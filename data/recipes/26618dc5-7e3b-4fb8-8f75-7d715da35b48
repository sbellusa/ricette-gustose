  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and slice the <strong>red onions</strong></p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with 1/2 tbsp<span class=\"text-danger\"> [1 tbsp]</span> <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the <strong>sliced onions</strong> with a pinch of <strong>salt</strong> and 1 tsp<span class=\"text-danger\"> [2 tsp]</span> <strong>sugar</strong> and cook for 10-12 min or until softened and caramelised</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1629813997349-x200.jpg",
            "width": 200
          },
          {
