  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Boil</strong> a kettle (used in step 4)</p>\r\n<p><strong>Cut</strong> the leeks in half lengthwise and wash carefully to remove any dirt from between the leaves</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span> and chop finely</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the potatoes</p>\r\n<p><strong>Slice</strong> the leeks and potatoes to the thickness of a pound coin</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the leek and potatoes to a pot of boiling salted water and cook for 10 min without a lid, or until the potatoes are almost cooked</p>\r\n<p><strong>Drain</strong> and leave to steam dry in the colander </p>\r\n<p><strong>Season</strong> the vegetables to your taste</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1/2-1 tbsp of oil to a wide pan over a medium-high heat</p>\r\n<p><strong>Once</strong> hot, add the lamb, onion and garlic </p>\r\n<p><strong>Brown</strong> the lamb for 5 min, then add the stock cube<span class=\"text-danger\">(s)</span> and 2-4 tbsp of water, enough to dissolve the tasty bits stuck to the pan</p>\r\n<p><strong>Remove</strong> from the heat</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the tarragon coarsely</p>\r\n<p><strong>Add</strong> the lamb mixture to an oven-proof dish </p>\r\n<p><strong>Add</strong> 2/3 of the tarragon and save the rest to serve</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Layer</strong> the leek and potato on top of the mince, spread over the yoghurt and sprinkle with breadcrumbs </p>\r\n<p><strong>Put</strong> in the oven for 10 min, then switch the oven to the grill setting for 5-10 min or until the pie is browned and hot through</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Sprinkle</strong> the pie with the remaining tarragon and serve</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
