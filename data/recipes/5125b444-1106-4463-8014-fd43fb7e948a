            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add the <strong>garlic</strong> and<strong> diced chicken</strong> to the<span class=\"text-highlight\"><strong> onion</strong>&nbsp;and</span> cook for 4-5 min or until the<strong> chicken</strong> is cooked through</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-5-x200.jpg",
            "width": 200
          },
          {
