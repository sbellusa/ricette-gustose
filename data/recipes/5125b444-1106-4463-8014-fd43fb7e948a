            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped cherry tomatoes</strong> to the pan and cook for 2 min, stirring gently until warmed through</p>\r\n<p>Meanwhile, grate the<strong> Italian hard cheese&nbsp;</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-6-x400.jpg",
            "width": 400
          },
          {
