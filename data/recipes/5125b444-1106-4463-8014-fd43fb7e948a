  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Add the<strong>&nbsp;fusilloni</strong>&nbsp;<strong>pasta</strong> to a pot of <strong>boiled water</strong> with a large pinch of<strong> salt</strong> and bring to the boil over a high heat</p>\r\n<p>Cook the <strong>fusilloni</strong> for 12-14 min or until cooked with a slight bite</p>\r\n<p>Once done, drain the <strong>fusilloni</strong>, reserving a cup of the <strong>starchy pasta water&nbsp;</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely slice the<strong>&nbsp;brown onion<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Peel and finely chop (or grate) the <strong>garlic</strong>&nbsp;</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> olive oil</strong> over a medium heat</p>\r\n<p>Once hot, add the<strong>&nbsp;sliced onion</strong> with a pinch of <strong>salt</strong> and cook for 5-6 min or until softened</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1060.-step-3-x1000.jpg",
