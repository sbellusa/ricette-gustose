          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1635254964756-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and grate (don't chop!) your <strong>garlic</strong></p><p>Peel (scrape the skin off with a teaspoon) and grate (don't chop!) your <strong>ginger</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1635254969505-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1635254969505-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1635254969505-x700.jpg",
            "width": 700
