          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1635255015624-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>sticky rice</strong> topped with the <strong>Vietnamese-style pork</strong> and the <strong>crunchy salad</strong> to the side</p><p>Sprinkle over your <strong>toasted sesame seeds</strong></p><p>Garnish with the <strong>chopped mint</strong></p><p>Enjoy!</p>",
      "order": 8,
