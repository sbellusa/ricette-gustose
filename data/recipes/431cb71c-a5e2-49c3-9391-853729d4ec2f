            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Use this time to clear up, set the table, have a cup of tea or simply chill!</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1705422658161-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1705422658161-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1705422658161-x700.jpg",
            "width": 700
