            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1660041112131-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the vegetables are cooking, dissolve the <strong>vegetable stock mix </strong>in 700ml <span class=\"text-danger\">[1.4L] </span><strong>boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1660041114198-x200.jpg",
