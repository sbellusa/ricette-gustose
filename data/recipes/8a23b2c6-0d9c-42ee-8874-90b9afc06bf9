            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your<strong> red onion[s]</strong> into quarters</p><p>Drain and rinse your <strong>black beans</strong></p><p>Crush your<strong> garlic</strong> open by squashing it with the side of a knife and discard the skin</p><p>Slice your <strong>green chilli[es]</strong> roughly</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-12-1691498295947-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-12-1691498295947-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-12-1691498295947-x700.jpg",
