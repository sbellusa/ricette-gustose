            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add your <strong>diced</strong> <strong>beef </strong>to the dish with a generous pinch of <strong>salt</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-13-1691498290743-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-13-1691498290743-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-13-1691498290743-x700.jpg",
