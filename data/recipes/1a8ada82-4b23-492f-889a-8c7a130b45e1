          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1580806767666-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1580806767666-x700.jpg",
