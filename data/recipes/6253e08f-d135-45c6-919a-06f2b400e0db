            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>cucumber</strong> into thin batons, then dice finely</p><p>Chop your <strong>tomato[es]</strong> finely</p><p>Chop your <strong>coriander </strong>roughly, including the stalks (save some leaves for a garnish!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1712064272751-x200.jpg",
