            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and slice (don't chop!) your <strong>garlic</strong></p><p>Chop your <strong>basil</strong> roughly, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1663669616058-x200.jpg",
            "width": 200
