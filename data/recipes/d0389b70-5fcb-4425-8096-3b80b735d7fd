            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the wedges have started to soften, add the<strong> turkey burgers</strong> to the tray</p><p>Tip: Cooking for 4? Use a separate tray!</p><p>Put the tray<span class=\"text-danger\">[s]</span> in the oven for a further 12-14 min or until everything is cooked through (no pink meat!)</p>",
      "order": 5,
      "media": {
        "images": [
