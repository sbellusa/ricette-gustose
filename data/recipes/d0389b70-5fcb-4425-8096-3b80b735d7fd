            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1654612881697-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Shape the <strong>herby turkey mixture</strong> into 2<span class=\"text-danger\"> [4]</span> <strong>burger patties </strong>– these are your <strong>turkey burgers</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1654612885005-x200.jpg",
            "width": 200
          },
          {
