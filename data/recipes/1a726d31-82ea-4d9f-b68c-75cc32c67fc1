          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1684417332398-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1684417332398-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1684417332398-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reboil half a kettle</p><p>Peel and finely dice your <strong>shallot[s]</strong></p><p>Chop your <strong>parsley</strong> finely, including the stalks</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Slice your <strong>red chilli[es]</strong> finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684417333845-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684417333845-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684417333845-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684417333845-x1000.jpg",
            "width": 1000
