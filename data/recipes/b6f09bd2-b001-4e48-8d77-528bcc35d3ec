  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Crumble the <strong>drained tofu</strong> very finely</p><p>Combine the <strong>crumbled tofu </strong>and <strong>five-spice mix </strong>in a bowl with your<strong> umami seasoning </strong>and <strong>half </strong>your<strong> soy sauce </strong>(you'll use the rest later!) and a pinch of <strong>salt</strong>  – this is your <strong>umami tofu</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1692958865214-x200.jpg",
            "width": 200
