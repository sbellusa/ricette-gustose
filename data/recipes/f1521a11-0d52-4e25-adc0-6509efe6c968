  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Crush your <strong>cardamom</strong> <strong>pods</strong> open by squashing them with a knife</p><p>Heat a pot, with a matching lid, with a large knob of <strong>butter </strong>over a medium heat, once hot, add the <strong>crushed</strong> <strong>cardamom</strong> <strong>pods</strong> and cook for 30 secs or until fragrant</p><p>Tip: Watch them like a hawk to make sure they don’t burn!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1648566700739-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1648566700739-x400.jpg",
