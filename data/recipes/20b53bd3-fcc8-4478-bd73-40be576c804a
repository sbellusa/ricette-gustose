          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1679660035302-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1679660035302-x700.jpg",
            "width": 700
