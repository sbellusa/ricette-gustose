            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>brioche bun[s]</strong> in half</p><p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat and add your <strong>brioche halves</strong>, cut-side down, and cook for 2-3 min or until toasted and charred</p><p>Set aside until serving, reserve the pan</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1707215355822-x200.jpg",
            "width": 200
