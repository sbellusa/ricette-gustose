  "cooking_instructions": [
    {
      "instruction": "<p>Peel and dice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) the <strong>ginger</strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2473Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2473Step-1-x400.jpg",
            "width": 400
