            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2473Step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with 1 tbsp<span class=\"text-danger\"> [2 tbsp]</span> <strong>vegetable oil </strong>over a high heat</p><p>Once hot, add the <strong>diced onion</strong>,<strong> chopped ginger</strong>, <strong>chopped garlic </strong>and<strong> curry powder </strong>with a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Cook for 4-5 min or until starting to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2473Step-2-x200.jpg",
            "width": 200
