  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Take 30g<span class=\"text-purple\"> [45g]</span><span class=\"text-danger\"> [60g]</span> <strong>butter </strong>out of the fridge and set aside to soften</p><p>Cover your <strong>chicken breast portion[s]</strong> with <strong>cling film</strong> and bash with a <strong>rolling pin</strong> until evenly flattened – this is your <strong>chicken escalope</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1715603363321-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1715603363321-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1715603363321-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1715603363321-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1715603363321-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and chop your <strong>sweet potato[es] </strong>into small bite-sized pieces</p><p>Slice your <strong>spring onion[s]</strong> finely</p><p>Slice <strong>half</strong> your <strong>green chilli[es]</strong> into rounds and set aside for garnish, then chop the <strong>remaining chilli </strong>finely, removing the seeds</p><p>Trim your <strong>green beans</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1715603366728-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1715603366728-x400.jpg",
            "width": 400
          },
          {
