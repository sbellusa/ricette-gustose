          }
        ]
      }
    },
    {
      "instruction": "<p>Drain and rinse the<strong> canned lentils </strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1719.-step-5-x200.jpg",
            "width": 200
          },
          {
