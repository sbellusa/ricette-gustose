            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>chicken</strong> is almost done, add the <strong>pumpkin seeds</strong> to the tray and cook for 2-3 min or until toasted</p>",
      "order": 6,
      "media": {
        "images": [
          {
