            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1684845471153-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once done, remove the lime leaves and give the <strong>red Thai-style beef meatball bake</strong> a good mix up in case the sauce has separated a little</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1684845474492-x200.jpg",
