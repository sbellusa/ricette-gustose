          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1641306754252-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1641306754252-x700.jpg",
            "width": 700
