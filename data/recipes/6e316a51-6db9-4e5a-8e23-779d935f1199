          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1641306754252-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Place the <strong>marinated basa fillets </strong>on a separate <strong>tin foil</strong>-lined<strong> </strong>baking tray</p><p>Put the tray in the oven for 12-15 min or until the fish is cooked through – this is your <strong>Indian-style fish</strong></p><p>Tip: Your fish is cooked when it turns opaque and flakes easily</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1641306759751-x200.jpg",
