            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chicken thighs</strong> to an <strong>oven-proof dish</strong> and cover them with the <strong>BBQ hoisin sauce</strong></p><p>Put the dish in the oven for 30-35 min or until the chicken is cooked through (no pink meat!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-2-1651598837211-x200.jpg",
