  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the <strong>air fryer</strong> to 200°C</p><p>Chop the <strong>cherry tomatoes</strong> in half</p><p>Transfer the <strong>halved tomatoes </strong>to a heatproof bowl with a spray of <strong>vegetable oil </strong>and a generous pinch of <strong>salt</strong></p><p>Transfer the bowl to the air fryer basket and cook for 5 min or until the tomatoes are charred and starting to break down, then set aside</p>",
      "order": 1,
      "media": {
        "images": [
