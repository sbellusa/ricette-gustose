          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1513.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop the <strong>parsley</strong>&nbsp;roughly, including the stalks</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1513.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1513.-step-7-x400.jpg",
