            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve your <strong>chicken stock mix</strong> in 300ml <span class=\"text-purple\">[400ml]</span> <span class=\"text-danger\">[500ml]</span><strong> boiled water </strong>and stir in your <strong>tomato paste </strong>and <strong>half</strong> your <strong>balsamic vinegar </strong>(save the rest for later!) – this is your <strong>tomato stock</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1-1592234204026-x200.jpg",
