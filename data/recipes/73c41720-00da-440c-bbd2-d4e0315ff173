        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>coriander</strong> finely, including the stalks</p>\r\n<p>Slice the<strong> blackened</strong>&nbsp;<strong>chicken</strong></p>",
      "order": 6,
      "media": {
        "images": [
