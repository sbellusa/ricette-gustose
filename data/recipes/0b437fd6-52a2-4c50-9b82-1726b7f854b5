            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/253_step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>black olives</strong>, <strong>chopped tomatoes</strong> and <strong>caper buds</strong> to the pan</p>\r\n<p>Cook for a further 10 min, stirring occasionally to prevent the bottom from sticking</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/253_step-6-x200.jpg",
