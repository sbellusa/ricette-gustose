          }
        ]
      }
    },
    {
      "instruction": "<p>Peel the skin off your <strong>smoked mackerel fillet[s]<span class=\"text-danger\"> </span></strong>and discard</p><p>Tear the <strong>smoked mackerel </strong>into rough pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1717669213524-x200.jpg",
            "width": 200
          },
          {
