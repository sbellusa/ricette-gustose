            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once everything is starting to soften, remove the tray[s] from the oven and add<strong> </strong>your<strong> meat-free sausages </strong>on top of the vegetables</p>",
      "order": 5,
      "media": {
        "images": [
