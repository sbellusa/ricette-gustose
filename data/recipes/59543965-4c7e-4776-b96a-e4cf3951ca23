        ]
      }
    },
    {
      "instruction": "<p>While the prawns are cooking, cut your <strong>lemon[s]</strong> in half</p><p>Chop your<strong> parsley</strong> finely, including the stalks</p><p>Chop your <strong>cherry tomatoes</strong> in half</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1599558432077-x200.jpg",
