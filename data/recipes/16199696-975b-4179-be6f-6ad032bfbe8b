            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once beginning to soften, add your <strong>roasted garlic paste</strong> and <strong>baharat</strong> to the pan and cook for 1 min or until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1720777132864-x200.jpg",
            "width": 200
