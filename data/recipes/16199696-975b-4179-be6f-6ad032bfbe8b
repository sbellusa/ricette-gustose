  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Add your <strong>beef mince </strong>to a large bowl with a generous pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Give everything a good mix up until thoroughly combined (clean hands is the best way!)</p><p>Divide the <strong>seasoned mince</strong> and shape into meatballs (5 per person!)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1720777105184-x200.jpg",
            "width": 200
