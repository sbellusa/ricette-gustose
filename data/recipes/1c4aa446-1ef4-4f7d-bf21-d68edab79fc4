            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>rump steaks</strong> to the <strong>carne asada marinade </strong>and set aside until later</p><p>Tip: Turn the steaks every few minutes to get them evenly coated!</p>",
      "order": 2,
      "media": {
