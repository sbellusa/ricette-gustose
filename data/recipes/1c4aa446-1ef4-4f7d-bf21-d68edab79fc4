  "cooking_instructions": [
    {
      "instruction": "<p>Cut the <strong>green chilli<span class=\"text-danger\">[es]</span></strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop ﬁnely</p><p>Tip: Keep the seeds in if you like it spicy!</p><p>Combine the <strong>juice</strong> of the <strong>orange<span class=\"text-danger\">[s] </span></strong>with the <strong>juice</strong> of <strong>1/2</strong> <span class=\"text-danger\">[1]</span> <strong>lime</strong>, <strong>chopped green chilli </strong>(can't handle the heat? Go easy!), <strong>ground cumin </strong>and <strong>soy sauce</strong> and give everything a good mix up – this is your <strong>carne asada marinade</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1592909379489-x200.jpg",
            "width": 200
