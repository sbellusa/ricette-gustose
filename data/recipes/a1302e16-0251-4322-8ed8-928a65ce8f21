  "cooking_instructions": [
    {
      "instruction": "<p><strong>Before you begin...</strong></p>\n<p>Get all your ingredients and equipment ready</p>\n<p>Skim through these steps</p>\n<p>Wash your fruit and veg</p>\n<p>Note: Please make sure you cook your chicken thoroughly (until there’s no pink meat and it’s piping hot!) as cooking equipment varies</p>",
      "order": 1,
      "media": {
        "images": [
