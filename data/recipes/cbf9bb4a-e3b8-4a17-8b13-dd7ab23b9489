  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your<strong> potatoes</strong> (skins on) into thin chips</p><p>Add the <strong>chips</strong> to a baking tray (or two!) with a drizzle of<strong> vegetable oil</strong> and a pinch of <strong>pepper</strong></p><p>Give everything a good mix up and put the tray[s] in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682354222238-x200.jpg",
