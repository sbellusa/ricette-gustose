          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682354222238-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chips are cooking, peel and roughly chop <strong>half </strong>your <strong>red onion[s]</strong></p><p>Finely slice the <strong>remaining red onion</strong> and set aside for later</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1682354226377-x200.jpg",
