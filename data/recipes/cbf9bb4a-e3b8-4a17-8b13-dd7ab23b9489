            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and roughly chop<strong> half </strong>your <strong>garlic </strong>(you'll use the rest later!)</p><p>Chop your <strong>parsley</strong> roughly, including the stalks</p><p>Drain and rinse your<strong> chickpeas</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1682354229942-x200.jpg",
            "width": 200
