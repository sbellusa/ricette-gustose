  "cooking_instructions": [
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7&nbsp;</span></p>\r\n<p><strong>Cut</strong> the potatoes into wedges (skins on)</p>\r\n<p><strong>Add</strong> them to a baking tray, drizzle with vegetable oil and season generously with salt&nbsp;</p>\r\n<p><strong>Put</strong> the tray in the oven until step 4</p>",
