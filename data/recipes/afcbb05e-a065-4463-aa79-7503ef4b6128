          }
        ]
      }
    },
    {
      "instruction": "<p>Strip the <strong>coriander leaves</strong> from their stalks and chop the stalks finely (save the leaves for garnish!)</p><p>Drain and rinse the <strong>black beans</strong></p>",
      "order": 6,
      "media": {
        "images": [
