  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Squeeze the <strong>sausage meat</strong> out of the sausage skins and roll into bite-sized meatballs</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1640091471373-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1640091471373-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1640091471373-x700.jpg",
            "width": 700
