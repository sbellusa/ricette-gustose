          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1-1640091479390-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1-1640091479390-x1000.jpg",
