  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice 1<span class=\"text-danger\"> [2]</span> <strong>brown onion<span class=\"text-danger\">[s]</span></strong>, peel and chop the <strong>remaining onion</strong> into wedges</p><p>Heat a pot with a matching lid with 4 tbsp <span class=\"text-danger\">[8 tbsp]</span> <strong>vegetable oil </strong>over a high heat</p><p>Once hot, add the<strong> sliced onion</strong> with a pinch of<strong> salt</strong> and cook for 4-5 min, stirring regularly until golden and crispy</p><p>Once done, set the<strong> fried onions</strong> aside on <strong>kitchen paper</strong>, reserve the pot</p>",
      "order": 1,
