  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p><p>Peel and finely chop 1/4 <span class=\"text-danger\">[1/2]</span> <strong>red onion</strong></p><p>Chop the <strong>cherry tomatoes</strong> finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1585754216281-x200.jpg",
