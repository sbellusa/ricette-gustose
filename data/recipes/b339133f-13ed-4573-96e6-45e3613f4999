          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1585754216281-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped onion</strong> and <strong>tomato </strong>to a bowl with a generous drizzle of <strong>olive oil </strong>and a pinch of<strong> salt</strong> and <strong>pepper </strong>– this is your<strong> tomato & onion salad</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1585754224717-x200.jpg",
            "width": 200
