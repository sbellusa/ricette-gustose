  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Add the <strong>aubergines </strong>(no prep needed!) to a baking tray with a drizzle of <strong>vegetable oil</strong></p><p>Put the tray in the oven for 30-35 min or until the aubergines are soft inside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1621936824239-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1621936824239-x400.jpg",
