  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Top, tail and slice the<strong> courgette<span class=\"text-danger\">[s]</span></strong> on a diagonal into discs</p><p>Cut the<strong> red onion<span class=\"text-danger\">[s]</span></strong> into wedges, removing the skins</p>",
      "order": 1,
      "media": {
        "images": [
