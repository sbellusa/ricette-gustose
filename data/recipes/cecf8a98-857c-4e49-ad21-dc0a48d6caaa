  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice your <strong>potatoes</strong> (skins on) into thin discs</p><p>Add the<strong> potato discs</strong> to a baking tray with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until golden and crisp – these are your <strong>crispy</strong> <strong>potatoes</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1665139010447-x200.jpg",
            "width": 200
