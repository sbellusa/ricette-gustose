          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the remaining stock to the rice gradually, allowing each measure to be absorbed before adding the next</p>\r\n<p><strong>Stir</strong> constantly until the rice is tender</p>\r\n<p>Tip: if you run out of stock, use a little hot water</p>\r\n<p><strong>Taste</strong> the risotto and season accordingly&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-7-x700.jpg",
