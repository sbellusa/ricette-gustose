          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>\r\n<p><strong>Add</strong> the tomatoes, courgette, pepper and garlic to an oven-proof tray and arrange in a single layer</p>\r\n<p><strong>Drizzle</strong> with olive oil</p>\r\n<p><strong>Season</strong>&nbsp;generously with salt and pepper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/3-step-5-x200.jpg",
            "width": 200
          },
          {
