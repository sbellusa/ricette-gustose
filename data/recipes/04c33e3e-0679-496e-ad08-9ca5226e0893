          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1624273167506-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>ginger & garlic paste</strong> with 1 tsp<span class=\"text-danger\"> [2 tsp]</span> <strong>sugar</strong>, the <strong>soy sauce</strong> and <strong>Chinese rice wine</strong> in a small bowl – this is your<strong> seasoned soy sauce</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1624273171938-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1624273171938-x400.jpg",
