          }
        ]
      }
    },
    {
      "instruction": "<p>Spread the <strong>pizza sauce</strong> over the chicken</p><p>Top with the <strong>torn mozzarella </strong>and <strong>torn basil leaves</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
