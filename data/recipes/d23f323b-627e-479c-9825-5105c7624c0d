  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely slice your <strong>brown onion[s]<span class=\"text-danger\"> </span></strong>and <strong>garlic</strong></p><p>Slice your <strong>chestnut mushrooms </strong>finely</p><p>Wash your <strong>spinach</strong>, then pat it dry with kitchen paper</p><p>Drain your <strong>mozzarella</strong>, then pat and squeeze as much liquid out as you can with kitchen paper and tear into rough, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1678802263677-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1678802263677-x400.jpg",
