  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Cut the <strong>Brussels sprouts </strong>in half</p><p>Peel and chop the <strong>red onion<span class=\"text-danger\">[s]</strong> </span>into wedges</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1606140093451-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1606140093451-x400.jpg",
            "width": 400
