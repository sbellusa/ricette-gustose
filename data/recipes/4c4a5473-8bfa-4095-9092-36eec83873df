          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add the remaining ingredients</strong> </p>\n<p>Add the <strong>pine nuts</strong>, <strong>capers</strong> and <strong>sultanas</strong> to the <strong>chopped herbs</strong> and chop everything together as finely as you can.</p>\n<p> </p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-2-x400.jpg",
