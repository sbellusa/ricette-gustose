  "cooking_instructions": [
    {
      "instruction": "<p><strong>Start the salsa verde</strong></p>\n<p>Boil a kettle.</p>\n<p>Chop the <strong>parsley</strong> and <strong>basil</strong> finely (including the stalks).</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-1-x200.jpg",
            "width": 200
