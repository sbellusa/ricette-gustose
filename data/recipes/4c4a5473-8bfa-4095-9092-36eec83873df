          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Finish the salsa verde</strong></p>\n<p>Add the mix to a bowl with the juice of 1/4 <span class=\"text-danger\">[1/2]</span> <strong>lemon</strong> and 3 tbsp <span class=\"text-danger\">[6 tbsp]</span><strong> olive oil</strong>.</p>\n<p>Season with a pinch of <strong>salt</strong> and give everything a good mix up – this is your <strong>salsa verde</strong>.</p>\n<p> </p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-3-x200.jpg",
            "width": 200
