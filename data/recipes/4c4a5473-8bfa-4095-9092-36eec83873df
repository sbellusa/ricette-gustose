            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1630.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Start the butter bean purée</strong></p>\n<p>Dissolve 1/2<span class=\"text-danger\"> [1]</span> <strong>Knorr</strong> <strong>vegetable stock cube</strong> in 50ml <span class=\"text-danger\">[100ml]</span> <strong>boiled water</strong>.</p>\n<p>Peel and chop the <strong>garlic</strong> roughly.</p>",
      "order": 4,
      "media": {
