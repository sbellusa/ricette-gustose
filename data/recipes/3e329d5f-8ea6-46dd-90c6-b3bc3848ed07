            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> tortillas</strong> to a plate and pop in the<strong> microwave</strong> for 20 secs on high or until warmed through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Plain-tortillas-on-a-plate-1663680102418-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Plain-tortillas-on-a-plate-1663680102418-x400.jpg",
            "width": 400
          },
          {
