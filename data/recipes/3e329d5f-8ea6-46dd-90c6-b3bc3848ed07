            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain the <strong>quick-pickled onion rings</strong> and discard the liquid</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624887972352-x200.jpg",
            "width": 200
