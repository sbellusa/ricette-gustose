          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624887972352-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624887972352-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624887972352-x1000.jpg",
