  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle ready for step 5</p>\r\n<p><strong>De-seed</strong> and roughly chop the green pepper<span class=\"text-danger\">(s)</span> into chunky strips</p>\r\n<p><strong>Peel</strong> and slice the red onion<span class=\"text-danger\">(s)</span> into 8<span class=\"text-danger\">(16)</span> wedges </p>\r\n<p><strong>Drain</strong> the pineapple rings (reserve the juice for step 3) and cut 2(all) of them into small bite-size pieces (approx 1 cm)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a small pot on a medium-low heat</p>\r\n<p><strong>Add</strong> the curry powder, chilli flakes (careful, adjust the amount to your preferred heat level) and 1 tsp <span class=\"text-danger\">(1.5 tsp)</span> flour</p>\r\n<p><strong>Cook</strong> on a medium heat for 30 seconds - 1 min</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the coconut milk to the pot and whisk to fully combine</p>\r\n<p><strong>Add</strong> a pinch of salt, a couple of spoonfuls of the reserved pineapple juice and the soy sauce- increase the heat to medium </p>\r\n<p><strong>Reduce</strong> by half until the sauce is the same consistency as double cream, then set aside until serving</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large wide-based pan with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil</p>\r\n<p><strong>When</strong> hot, add the onion and green pepper</p>\r\n<p><strong>Stir-fry</strong> on a medium-high heat for 4-8 min or until starting to colour, then add the pineapple and stir-fry for a further minute</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the cooked vegetables to a plate, reserving the pan for the next step</p>\r\n<p><strong>Add</strong> plenty of boiling water to the pan for your noodles</p>\r\n<p><strong>Add</strong> the wheat noodles and cook on a medium heat for 4-5 min or until cooked but with a slight bite</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, finely slice the spring onion<span class=\"text-danger\">(s)</span> discarding the root ends</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the noodles and add them to the vegetables (off the heat)</p>\r\n<p><strong>Add</strong> half of the coconut sauce and mix well</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Dish</strong> up the noodles and drizzle the remaining sauce over </p>\r\n<p><strong>Sprinkle</strong> the spring onion and sesame seeds over to garnish</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
