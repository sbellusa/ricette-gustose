            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the onion is softening, peel and finely chop (or grate) the<strong> garlic</strong></p><p>Slice the <strong>chestnut mushrooms</strong> finely</p><p>Boil half a kettle</p>",
      "order": 2,
      "media": {
        "images": [
