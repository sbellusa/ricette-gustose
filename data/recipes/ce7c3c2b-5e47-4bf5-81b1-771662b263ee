  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely chop the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> olive oil</strong> over a medium heat</p><p>Once hot, add the<strong> chopped onion</strong> with a pinch of <strong>salt</strong> and cook for 4 min or until beginning to soften</p>",
      "order": 1,
      "media": {
