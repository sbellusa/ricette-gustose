  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then chop the <strong>creamed coconut</strong> roughly (if required!)</p><p>Rinse the <strong>sushi rice</strong> in a sieve under <strong>cold running water</strong> for 30 secs (use your hands to really wash the grains!), then set aside to drain fully</p><p>Add the <strong>drained rice</strong> with 200ml <span class=\"text-danger\">[400ml]</span> <strong>cold water</strong>, a generous pinch of<strong> salt </strong>and<strong> half </strong>the <strong>chopped creamed coconut</strong> (you'll use the rest later!) to a pot with a lid and bring to the boil over a high heat</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683203253917-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683203253917-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683203253917-x700.jpg",
            "width": 700
