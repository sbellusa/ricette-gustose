            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add your <strong>free range chicken thighs </strong>to the dish and cook for 3 min or until lightly browned</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1699439446001-x200.jpg",
