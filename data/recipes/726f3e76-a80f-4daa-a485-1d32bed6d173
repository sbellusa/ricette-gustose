  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>diced chicken breast</strong>,<strong> cherry tomatoes </strong>and<strong> sun-dried tomatoes </strong>with a pinch of <strong>salt </strong>and cook for 4 min until the chicken has started to brown</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1614341107721-x200.jpg",
            "width": 200
