            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1614341107721-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1614341107721-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add the <strong>broccoli brown rice</strong> to a large, heatproof bowl and put the bowl in the <strong>microwave</strong> for 2-3 min or until piping hot</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1-1614341136480-x200.jpg",
            "width": 200
          },
          {
