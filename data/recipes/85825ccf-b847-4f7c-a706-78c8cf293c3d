  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Chop the<strong> tomatoes </strong>roughly</p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) over a medium-high heat with a generous drizzle of <strong>olive oil</strong></p><p>Once hot, add the <strong>chopped tomatoes </strong>with a pinch of<strong> salt </strong>and cook for 4-5 min or until beginning to break down</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1690290203861-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1690290203861-x400.jpg",
            "width": 400
