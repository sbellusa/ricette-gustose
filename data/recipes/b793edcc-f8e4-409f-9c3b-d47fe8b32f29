            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>aubergine<span class=\"text-danger\">[s]</span></strong>&nbsp;in half lengthways, then chop into thick slices</p>\r\n<p>Cut the <strong>tomato<span class=\"text-danger\">[es]</span></strong>&nbsp;into wedges</p>\r\n<p>Peel and cut the <strong>red onion<span class=\"text-danger\">[s]</span></strong>&nbsp;into quarters</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/375__step-2-x200.jpg",
