  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Boil a kettle</p>\r\n<p>Cut the <strong>mozzarella</strong> in half (like you would a burger bun)&nbsp;</p>\r\n<p>Pat dry with kitchen paper, then set aside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/375__step-1-x200.jpg",
            "width": 200
