  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p><p>Boil half a kettle</p><p>Add the <strong>walnuts </strong>to a <strong>pestle & mortar</strong> and bash into a coarse powder (or pulse in a <strong>food</strong> <strong>processor</strong>)</p><p>Rub the<strong> chicken breasts </strong>with 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>olive oil</strong> and a pinch of <strong>salt </strong>and <strong>pepper</strong> and add them to a baking tray</p><p>Top the chicken<strong> </strong>with<strong> half</strong> the <strong>bashed walnuts</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1598435052468-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1598435052468-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1598435052468-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1598435052468-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1598435052468-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray in the oven for 15-18 min or until the chicken is cooked through (no pink meat!) and the walnut crust is golden</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1598435079541-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1598435079541-x400.jpg",
            "width": 400
