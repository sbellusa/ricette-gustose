            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1696842213673-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add your <strong>chicken breast portion[s] </strong>with a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Cook for 1-2 min on each side or until lightly browned, then set the <strong>browned chicken</strong> aside</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1696842218333-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1696842218333-x400.jpg",
