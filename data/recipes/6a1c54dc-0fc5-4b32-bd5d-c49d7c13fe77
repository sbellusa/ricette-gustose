            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, slice your <strong>spring onion[s]</strong></p><p>Grate your <strong>cheddar</strong> <strong>cheese</strong></p><p>Wash your <strong>salad</strong> and pat dry with kitchen paper</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1670924146766-x200.jpg",
