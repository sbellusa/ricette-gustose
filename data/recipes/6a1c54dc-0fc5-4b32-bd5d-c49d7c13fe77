            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add<strong> half </strong>your <strong>ginger paste</strong> (you'll use the rest later!) to a large bowl with 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp]</span> <strong>olive oil</strong> and a pinch of <strong>sugar</strong></p><p>Add the <strong>salad</strong> and give everything a gentle mix up – this is your<strong> ginger salad</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1670924153940-x200.jpg",
