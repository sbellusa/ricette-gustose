  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Slice</strong> the courgette<span class=\"text-danger\">(s)</span> into quarters lengthways, then into chunks (approx. 2-3cm)</p>\r\n<p><strong>Quarter</strong> the mushrooms</p>\r\n<p><strong>Chop</strong> the aubergine<span class=\"text-danger\">(s)</span> into cubes (approx. 2cm)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the vegetables on an oven-proof tray</p>\r\n<p><strong>Coat</strong> well with 2-3 tbsp of olive oil and season to your taste with salt and pepper</p>\r\n<p><strong>Put</strong> in the oven for 20 min or until soft and lightly browned</p>\r\n<p><strong>Meanwhile</strong>, boil a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong> Dissolve</strong> 1/2<span class=\"text-danger\"> (1)</span> stock cube (save the rest for step 5) in 400ml <span class=\"text-danger\">(800ml)</span> of boiled water</p>\r\n<p><strong>Add</strong> the millet and stock to a medium size pot</p>\r\n<p><strong>Bring</strong> to a boil with a lid, then reduce to a simmer, and cook for 20 min, or until the water is absorbed and there are holes on the surface</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span> and chop coarsely</p>\r\n<p><strong>Grate</strong> the parmesan (used in step 7)</p>\r\n<p>&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 2-4 tbsp of olive oil to a large pan on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the onion and cook for 3 min then add the garlic and cook for another 2 min</p>\r\n<p><strong>Crumble</strong> in the remaining stock cube</p>\r\n<p><strong>Add</strong> the tomatoes, balsamic vinegar, dried oregano and 100ml <span class=\"text-danger\">(150ml)</span> of boiled water then mix well</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/92-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the vegetables from the oven to the sauce and bring to a low boil</p>\r\n<p><strong>Lower</strong> the heat and simmer for 3 min</p>\r\n<p><strong>Mix</strong> well, season to your taste with salt and pepper and set aside</p>",
      "order": 6,
      "media": {
