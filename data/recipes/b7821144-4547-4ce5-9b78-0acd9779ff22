            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pepper is beginning to soften, drain the <strong>king prawns</strong>, then add them to the pan with the <strong>mangetout </strong>and cook for 3-4 min further</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-1600445090368-x200.jpg",
