          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1699372396427-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>smoky chutney chicken breast & rice traybake </strong>with the <strong>carrot salad</strong> to the side</p><p>Garnish with the <strong>reserved ground smoked paprika</strong></p><p>Enjoy!</p>",
      "order": 8,
