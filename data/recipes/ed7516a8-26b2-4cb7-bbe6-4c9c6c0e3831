            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the curry is cooking, add your <strong>mini</strong> <strong>garlic & coriander naan[s]</strong> to a <strong>toaster </strong>for 1-2 min or until warmed through</p><p>Tip: For a little extra indulgence, add a little butter alternative to the warmed naan once it's out of the toaster</p>",
      "order": 7,
      "media": {
        "images": [
          {
