          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1670340577863-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>drained chickpeas</strong>, <strong>coconut stock</strong> and <strong>spinach</strong> to the pan</p><p>Cook, covered, for 4-5 min or until the spinach has wilted and the sauce has reduced to a curry-like consistency – this is your <strong>creamy chickpea & spinach curry</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670340582235-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670340582235-x400.jpg",
            "width": 400
