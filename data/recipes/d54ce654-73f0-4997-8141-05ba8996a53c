  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely slice (don't chop!) the <strong>garlic</strong></p><p>Heat a large, wide-based pan (preferably non-stick) over a medium-low heat with 2 tbsp <span class=\"text-danger\">[4 tbsp] </span><strong>olive oil </strong>and <strong>half</strong><span class=\"text-danger\"> </span>of the<strong> truffle oil</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1604489763265-x200.jpg",
            "width": 200
