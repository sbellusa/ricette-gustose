            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the tray in the oven for 25-30 min or until the chips are golden, turning once halfway</p>\r\n<p><strong>Meanwhile</strong>, add the mayonnaise, cider vinegar, 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> olive oil and a generous pinch of salt and pepper to a large mixing bowl and mix well</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and grate the carrots, discarding the root ends</p>\r\n<p><strong>Grate</strong> the celery, discarding any tough fibrous bits</p>\r\n<p><strong>Grate</strong> the pear, discarding the inner core</p>\r\n<p><strong>Slice</strong> the spring onion<span class=\"text-danger\">(s)</span> finely, discarding the root ends</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong>&nbsp;the grated carrot, celery, pear and spring onion with the mayonnaise dressing and nigella seeds&nbsp;</p>\r\n<p><strong>Set</strong> aside until serving&nbsp;</p>",
      "order": 4,
      "media": {
