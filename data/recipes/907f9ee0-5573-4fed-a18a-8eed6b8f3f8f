  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the potatoes (skins on) lengthways into chunky chips</p>\r\n<p><strong>Place</strong> them on a baking tray, drizzle with vegetable oil and season generously with salt</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/487.-step-1-x400.jpg",
            "width": 400
          },
