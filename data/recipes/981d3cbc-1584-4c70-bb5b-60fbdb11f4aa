          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1671611790813-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>coated chicken</strong> to a <strong>tin foil</strong>-lined baking tray</p><p>Put the tray under the grill for 10-12 min or until the chicken is cooked through and starting to char (no pink meat!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1671611795699-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1671611795699-x400.jpg",
