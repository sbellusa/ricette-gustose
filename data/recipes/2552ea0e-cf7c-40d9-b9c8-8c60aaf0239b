            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Increase the heat to high, add the your <strong>lean pork mince</strong> (remove the paper if required!) to the pan and cook for 5-6 min or until beginning to brown, breaking it up with a wooden spoon as you go</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1677167564138-x200.jpg",
