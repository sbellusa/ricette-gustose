            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the kidney beans are in the oven, dissolve your<strong> beef stock mix</strong> in 350ml <span class=\"text-purple\">[455ml]</span> <span class=\"text-danger\">[600ml]</span> <strong>boiled water</strong></p><p>Add your<strong> ground cinnamon</strong> to the red onion and cook for 1 min</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1677167560503-x200.jpg",
