          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1694441273944-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1694441273944-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable</strong> <strong>oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>beef</strong> <strong>mince</strong> with a pinch of <strong>salt</strong> and cook for 3-4 min or until beginning to brown, breaking it up with a wooden spoon as you go</p><p>Once browned, add the <strong>diced</strong> <strong>onion</strong> and <strong>chopped</strong> <strong>garlic</strong> and cook for a further 3-4 min or until softened</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1694441277539-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1694441277539-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1694441277539-x700.jpg",
            "width": 700
