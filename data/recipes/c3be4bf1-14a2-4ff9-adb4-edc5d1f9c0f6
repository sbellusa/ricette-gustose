  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7<strong> </strong>and boil a kettle</p><p>Add your<strong> tortiglioni</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook the tortiglioni for 8-10 min or until cooked with a slight bite then drain</p><p>Tip: It doesn't need to be fully cooked, as it will go in the oven later!</p>",
      "order": 1,
      "media": {
        "images": [
