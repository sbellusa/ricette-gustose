            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Roll the <strong>lemon<span class=\"text-danger\">[s]</span></strong> with your hand on a hard surface (to release more juice!) and cut in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1595941523518-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1595941523518-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1595941523518-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1595941523518-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1595941523518-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>courgette discs</strong>, <strong>chopped pepper</strong>,<strong> cherry tomatoes </strong>and <strong>drained</strong> <strong>chickpeas</strong> to a baking tray and sprinkle over the <strong>grated garlic</strong></p><p>Squeeze over the juice of 1/2<strong><span class=\"text-danger\"> </strong>[1] </span><strong>lemon</strong>, add a generous drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper </strong>and put the tray in the oven for 10-12 min or until the veg is lightly charred and juicy – these are your<strong> Mediterranean-style vegetables</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1595941538033-x200.jpg",
