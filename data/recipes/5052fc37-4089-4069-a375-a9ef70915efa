  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Top, tail and slice the <strong>courgette<span class=\"text-danger\">[s]</span></strong> into discs</p><p>Deseed the<strong> pepper<span class=\"text-danger\">[s]</strong> </span>(scrape the seeds and pith out with a teaspoon) and cut into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1595941496850-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1595941496850-x400.jpg",
            "width": 400
