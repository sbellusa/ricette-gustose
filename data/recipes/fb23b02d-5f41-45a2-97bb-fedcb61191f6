          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice the<strong> spring onion<span class=\"text-danger\">[s]</span></strong> finely</p><p>Chop half <span class=\"text-danger\">[all]</span> the <strong>capers</strong> finely</p><p>Tip: Cooking for 2? Save the remaining capers for another recipe!</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1650378605560-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1650378605560-x400.jpg",
            "width": 400
