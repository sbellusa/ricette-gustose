      }
    },
    {
      "instruction": "<p>Whisk your <strong>egg[s]</strong> and a splash of<strong> milk</strong> in a jug with a pinch of <strong>pepper </strong>– this is your <strong>omelette mix</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1681807093392-x200.jpg",
