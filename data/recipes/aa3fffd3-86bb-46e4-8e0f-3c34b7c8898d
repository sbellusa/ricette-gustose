            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1351.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the<strong> </strong>onion has softened, add the<strong> diced chicken thigh</strong> with the <strong>chopped thyme</strong> and <strong>chopped garlic</strong> and cook for 1-2 min</p><p>Add the <strong>chicken stock</strong> and bring to the boil over a high heat</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1351.-step-4-x200.jpg",
