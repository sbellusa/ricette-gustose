          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1653317580155-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1653317580155-x1000.jpg",
