  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your<strong> chicken</strong> out of the fridge, open the packet and let it air, then preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut the<strong> potatoes</strong> (skins on) into fries</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Cut the <strong>lemon<span class=\"text-danger\">[s]</span> </strong>in half</p><p>Cut 1 <span class=\"text-danger\">[2]<strong> </span>lemon half<span class=\"text-danger\">[ves]</span></strong> into slices</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1653317580155-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1653317580155-x400.jpg",
            "width": 400
