            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>basa fillets</strong> in half lengthways, then slice each half into 3 until you end up with 12 <span class=\"text-danger\">[24]</span><strong> </strong>fish fingers</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/987.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/987.-step-4-x400.jpg",
