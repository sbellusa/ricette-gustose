  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Add</strong> the rice and plenty of salted water to a pot on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer for 20 min or until cooked<br />Drain the rice (used in step 7)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, crush the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Add</strong> 1/2-1 tbsp of vegetable oil to a pan on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot add the cumin, garlic and half of the chipotle paste (keeping the rest for step 6) to the pan and cook for 1 min, until it releases its aroma</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the beef to the pan and break the mince apart</p>\r\n<p><strong>Cook</strong> for 5-10 min, or until cooked through and caramelised</p>\r\n<p><strong>Remove</strong> from the heat and leave covered until serving</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> grate the zest of the lime(s)</p>\r\n<p><strong>Slice</strong> the spring onion<span class=\"text-danger\">(s)</span> finely, discarding the root end<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Dice</strong> the cucumber finely <br /><br /><strong>Chop</strong> the coriander finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Wrap</strong> the tortillas in tin foil </p>\r\n<p><strong>Put</strong> in the oven to warm through for 5 min</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> the cucumber with the coriander in a bowl</p>\r\n<p><strong>Add</strong> the remaining chipotle paste, juice of half the <span class=\"text-danger\">(whole)</span> lime, and the sachets of mayonnaise and mix well</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the brown rice is ready, mix with the spring onion, lime zest and the juice of the remaining half <span class=\"text-danger\">(whole)</span> lime</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> the wraps and all the fillings on the table with serving spoons</p>\r\n<p><strong>Make</strong> your own wraps</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
