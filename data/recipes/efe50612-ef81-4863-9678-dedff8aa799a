  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Chop the <strong>potatoes</strong> (skins on) into bite-sized pieces</p><p>Add the <strong>chopped potatoes</strong> to a pot with plenty of <strong>boiled water </strong>and a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 8-10 min or until fork-tender, then drain and return to the pot to steam dry</p>",
      "order": 1,
      "media": {
        "images": [
