            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) over a medium-high heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the pork mince with a pinch of salt, sugar and pepper and cook for 3 min or until starting to brown, breaking it up as you go</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/613.-step-2-x200.jpg",
            "width": 200
