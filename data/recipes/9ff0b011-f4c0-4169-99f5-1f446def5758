  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong>&nbsp;a kettle</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 1,
      "media": {
        "images": [
