            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/613.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the noodles to a pot and cover with boiled water until fully submerged</p>\r\n<p><strong>Bring </strong>to the boil over a high heat and cook for 5-7min until tender with a slight bite</p>\r\n<p><strong>Once</strong> cooked, drain, return to the pot and set aside</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/613.-step-3-x200.jpg",
