  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely chop (or grate) <strong>half </strong>your <strong>garlic </strong>(you'll use the rest later!)</p><p>Heat a pot with a matching lid over a low heat and add a knob of<strong> butter</strong></p><p>Once melted, add the<strong> chopped garlic</strong> with a pinch of<strong> salt </strong>and cook for 1 min or until fragrant</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685604988499-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685604988499-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685604988499-x700.jpg",
            "width": 700
