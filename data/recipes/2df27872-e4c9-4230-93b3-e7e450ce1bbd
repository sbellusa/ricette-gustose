  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Line a baking tray with <strong>non-stick baking paper</strong></p><p>Cut the <strong>potatoes</strong> (skins on) into wedges</p>",
