          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1716459736768-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>red chilli[es]</strong> finely</p><p>Grate your <strong>cheddar cheese</strong> finely</p><p>Wash then remove <strong>leaves</strong> (1 per person!) from your<strong> lettuce</strong> and set aside, then cut the <strong>inner core </strong>into wedges</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1716459745132-x200.jpg",
