          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1716460085903-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>brioche bun[s]</strong> in half</p><p>Remove the tray[s] with the wedges from the oven and place the<strong> brioche halves </strong>(cut side up!) on top of the wedges</p><p>Return the tray[s] to the oven for 2-3 min or until warmed through</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1716460108504-x200.jpg",
