          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1630512523635-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1630512523635-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1630512523635-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the pan to a medium heat with a drizzle of <strong>olive oil</strong></p><p>Once hot, add the <strong>chopped onion</strong> and <strong>diced carrot</strong> with a pinch of <strong>salt</strong> and cook for 3-4 min or until beginning to soften</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-3-x200.jpg",
