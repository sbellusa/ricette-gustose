            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>lamb mince</strong> and <strong>ground</strong> <strong>cinnamon</strong> (don't like cinnamon? Go easy!) to the pan and cook for 4 min or until starting to crisp, breaking it up with a wooden spoon as you go</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-5-x700.jpg",
