            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely chop (or grate) your <strong>garlic</strong></p><p>Dissolve your <strong>chicken stock mix</strong> in 500ml <span class=\"text-purple\">[750ml]</span> <span class=\"text-danger\">[1L]</span><strong> boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1168.-step-4-x200.jpg",
