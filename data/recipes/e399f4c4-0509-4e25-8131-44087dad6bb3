  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely chop your <strong>red onion[s]</strong></p><p>Top, tail, peel and finely dice your<strong> carrot[s]</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-22-1624013943958-x200.jpg",
