            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1621258103552-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>meat-free mince </strong>(remove the paper if required!), <strong>diced onion</strong>, <strong>chopped garlic</strong>, <strong>chopped parsley</strong>, <strong>dried</strong> <strong>oregano</strong> and <strong>half</strong> your <strong>chilli flakes</strong> (can't handle the heat? Go easy!) to a bowl with a very generous pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Give everything a good mix up until fully combined (clean hands is the best way!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1621258145968-x200.jpg",
