  "cooking_instructions": [
    {
      "instruction": "<p>Chop your <strong>leek[s]</strong> in half lengthways, wash thoroughly to remove any grit then top, tail and chop into large chunks</p><p>Crush your <strong>garlic</strong> open by squashing them with the side of a knife and discard the skin</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674830955107-x200.jpg",
