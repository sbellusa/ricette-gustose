          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1629462017198-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1629462017198-x1000.jpg",
