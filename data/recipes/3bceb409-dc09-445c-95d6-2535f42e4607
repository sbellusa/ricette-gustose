          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1676987918379-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1676987918379-x1000.jpg",
