          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1676987918379-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a high heat</p><p>Once hot, add the <strong>paprika lean pork patties </strong>and cook, covered, for 6-7 min on each side or until cooked through (no pink meat!)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1676987936830-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1676987936830-x400.jpg",
