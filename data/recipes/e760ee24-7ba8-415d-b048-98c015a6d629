          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1689771379871-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1689771379871-x1000.jpg",
            "width": 1000
