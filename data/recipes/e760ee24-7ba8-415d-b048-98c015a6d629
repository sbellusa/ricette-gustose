            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the leek is cooking, add your <strong>orzo</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook the <strong>orzo</strong> for 6-8 min or until cooked with a slight bite</p><p>Once done, drain the <strong>orzo</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-1689771387914-x200.jpg",
