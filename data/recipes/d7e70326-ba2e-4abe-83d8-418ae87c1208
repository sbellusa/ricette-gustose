            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a high heat</p><p>Once hot, add the <strong>chopped shallot</strong> with a pinch of <strong>salt</strong> and cook for 1 min</p><p>Once the shallot has softened, add the <strong>chopped chicken</strong> and cook for 5-7 min or until starting to brown</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1706614064445-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1706614064445-x400.jpg",
