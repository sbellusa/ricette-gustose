  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and finely chop your<strong> red onion[s]</strong></p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and dice</p><p>Peel and chop your <strong>sweet potato[es]</strong> into small bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1706628515077-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1706628515077-x400.jpg",
