  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>carrots</strong> (skins on) lengthways into quarters</p><p>Cut the <strong>potato<span class=\"text-danger\">[es] </span></strong>and<strong> sweet potato<span class=\"text-danger\">[s] </span></strong>(skin on) into chips</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R1900Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R1900Step-1-x400.jpg",
            "width": 400
