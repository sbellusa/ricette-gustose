            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>spring onions</strong> finely</p><p>Wash and shred your<strong> lettuce</strong>, then pat it dry with<strong> </strong>kitchen paper</p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-4-1649169519996-x200.jpg",
            "width": 200
          },
          {
