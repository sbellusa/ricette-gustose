  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>potatoes</strong> (skins on) into bite-sized pieces</p><p>Add the <strong>chopped potatoes</strong> to a baking tray with a drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683041036023-x200.jpg",
