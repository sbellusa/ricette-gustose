  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>\r\n<p><strong>Cut</strong> the aubergine<span class=\"text-danger\">(s)</span> in half lengthways</p>\r\n<p><strong>Score</strong> the flesh quite deeply (in a diamond pattern), taking care not to cut through the skin</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and dice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Heat</strong> a medium-sized pot (with matching lid) with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil on a medium heat</p>\r\n<p><strong>When</strong> hot, add the onion, curry powder, sultanas and a pinch of salt</p>\r\n<p><strong>Cook</strong> for 3 min or until the onion is softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the basmati rice and stir briefly to coat the grains in the spices</p>\r\n<p><strong>Add</strong> 360ml <span class=\"text-danger\">(750ml)</span> water and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to low and simmer, covered, for 20 min or until the water is absorbed</p>\r\n<p><strong>Check</strong> to prevent over-cooking and, once done, set aside until serving</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/477.-step-3-x200.jpg",
            "width": 200
          },
