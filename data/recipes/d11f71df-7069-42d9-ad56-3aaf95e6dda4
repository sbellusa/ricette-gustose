  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p>Boil a kettle</p>\r\n<p>Add the <strong>tricoloured pasta twists</strong> to a pot of <strong>boiled water</strong> with a large pinch of <strong>salt</strong> and bring to the boil over a high heat</p>\r\n<p>Cook the pasta for 8-10 min or until cooked with a slight bite</p>",
      "order": 1,
      "media": {
        "images": [
