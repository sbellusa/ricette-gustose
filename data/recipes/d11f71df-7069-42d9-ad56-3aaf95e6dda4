            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>pasta</strong> is cooked, drain it and set aside</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1479.-step-5-x200.jpg",
            "width": 200
