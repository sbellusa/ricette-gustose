            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1627992802325-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped ginger</strong>, <strong>chopped garlic</strong> and <strong>soy sauce</strong> to a medium bowl – this is your <strong>marinade</strong></p><p>Add the <strong>cauliflower florets</strong> and give everything a good mix up, then set aside until later</p>",
      "order": 2,
      "media": {
        "images": [
