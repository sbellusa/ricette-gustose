            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>creamed coconut</strong> roughly (if required!)</p><p>Dissolve your <strong>vegetable stock mix </strong>in 250ml <span class=\"text-purple\">[325ml] </span><span class=\"text-danger\">[425ml] </span><strong>boiled water </strong>with your <strong>creamed coconut </strong>and <strong>cornflour </strong>– this is your <strong>coconut stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724830795120-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724830795120-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724830795120-x700.jpg",
