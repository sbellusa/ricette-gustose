            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Take a knob of<strong> butter</strong> out of the fridge and set it aside to soften</p><p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Chop your <strong>potato[es]</strong> (skins on) into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1671537084088-x200.jpg",
            "width": 200
