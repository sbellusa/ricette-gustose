  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Peel</strong> and finely slice half the <span class=\"text-danger\">[whole]</span> onion</p>\r\n<p><strong>Finely</strong> dice the remaining (see picture)&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/581.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/581.-step-1-x400.jpg",
            "width": 400
