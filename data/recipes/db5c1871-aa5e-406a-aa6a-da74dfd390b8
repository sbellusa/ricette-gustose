            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray<span class=\"text-danger\">[s] </span>in the oven for 15 min or until the cheese has melted and the pizza bases are crispy – these are your <strong>Calabrese pizzas with 'Nduja</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2080.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2080.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2080.-step-6-x700.jpg",
