          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1680277600081-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail, peel and grate your <strong>carrot[s]</strong></p><p>Strip your <strong>mint leaves</strong> from their stems and chop them finely, discard the stems</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1680277603994-x200.jpg",
            "width": 200
