          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1584989562424-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>chicken breasts</strong> into small bite-sized pieces</p><p>Return the reserved pan to a high heat with 1/2 tbsp <span class=\"text-danger\">[1 tbsp]</span> <strong>olive oil</strong></p><p>Once hot, add the <strong>chopped chicken</strong> with a pinch of <strong>salt </strong>and<strong> pepper</strong> and cook for 3-4 min or until browned all over</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1584989565592-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1584989565592-x400.jpg",
