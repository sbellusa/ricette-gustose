          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1672754305289-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1672754305289-x1000.jpg",
