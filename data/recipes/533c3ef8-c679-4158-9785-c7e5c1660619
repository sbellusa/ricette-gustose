  "cooking_instructions": [
    {
      "instruction": "<p>Cut the <strong>halloumi</strong> into bite-size cubes, then add them to a bowl with the <strong>ground paprika</strong>, <strong>ground</strong> <strong>cumin</strong> and the juice of 1/2 <span class=\"text-danger\">[1]</span> <strong>lemon</strong></p><p>Season with <strong>pepper</strong> and give everything a good mix up, then set aside to marinate</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1636109946261-x200.jpg",
