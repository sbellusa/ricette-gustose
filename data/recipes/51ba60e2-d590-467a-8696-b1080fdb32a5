          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1688736790408-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once tender, remove the pan from the heat and add the juice of <strong>half</strong> your <strong>lime[s] </strong>– this is your<strong> pho</strong></p><p>Slice the <strong>rested steak</strong> finely on a clean board</p><p>Cut the<strong> remaining lime </strong>into 1 wedge per person</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1688736792949-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1688736792949-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1688736792949-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1688736792949-x1000.jpg",
