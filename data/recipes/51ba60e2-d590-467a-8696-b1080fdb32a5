            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the <strong>sliced onion </strong>with a pinch of <strong>salt </strong>and cook for 4-5 min or until softened</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1688736785007-x200.jpg",
