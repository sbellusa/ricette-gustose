          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1718793692374-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1718793692374-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1718793692374-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add 2 tbsp <span class=\"text-purple\">[3 tbsp] </span><span class=\"text-danger\">[4 tbsp]</span><strong> flour </strong>to a plate with a pinch of <strong>salt</strong></p><p>Press the <strong>chopped hake</strong> into the flour firmly to evenly coat all over</p><p>Meanwhile, peel and dice<strong> half </strong>your <strong>shallot[s]</strong></p><p>Finely slice the <strong>remaining shallot</strong></p>",
      "order": 3,
      "media": {
        "images": [
