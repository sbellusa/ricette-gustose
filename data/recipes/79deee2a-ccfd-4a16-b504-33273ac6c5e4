  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>potatoes</strong> (skins on) into fries and add them to a large baking tray</p><p>Add a drizzle of<strong> vegetable oil</strong> and a pinch of <strong>salt </strong>and <strong>pepper </strong>and give everything a good mix up</p><p>Put the tray in the oven for 25-30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1718793688772-x200.jpg",
