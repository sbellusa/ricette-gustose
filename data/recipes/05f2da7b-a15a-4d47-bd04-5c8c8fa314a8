            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely slice your <strong>red onion[s]</strong></p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and dice</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1688738563338-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1688738563338-x400.jpg",
