            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1 tbsp<span class=\"text-danger\"> [2 tbsp] </span><strong>vegetable oil</strong> over a low heat</p><p>Once hot, add the <strong>diced</strong> <strong>onion</strong> with a pinch of <strong>salt</strong> and cook for 7-8 min min or until softened</p>",
      "order": 2,
      "media": {
