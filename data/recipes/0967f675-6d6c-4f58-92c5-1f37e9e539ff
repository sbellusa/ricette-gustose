  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Peel and finely dice the <strong>red</strong> <strong>onion<span class=\"text-danger\">[s]</span></strong></p><p>Chop the <strong>basil</strong> finely, including the stalks (save some leaves for garnish!)</p><p>Peel and finely chop (or grate) the<strong> garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
