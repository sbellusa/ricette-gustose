  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your <strong>potatoes</strong> (skins on) into chips</p><p>Add the<strong> chips</strong> to a baking tray (or two!) with a drizzle of<strong> vegetable oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Put the tray[s] in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1691741583354-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1691741583354-x400.jpg",
            "width": 400
