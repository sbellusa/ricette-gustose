          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-copy-3-1716894584525-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>spicy peanut chicken noodles </strong>and garnish with the <strong>crushed peanuts</strong> and <strong>sliced spring onion</strong></p><p>Enjoy!</p>",
      "order": 8,
