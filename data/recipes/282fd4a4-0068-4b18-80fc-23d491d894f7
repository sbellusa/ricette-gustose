  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> the ginger (scrape the skin off with a teaspoon) and finely chop (or grate)</p>\r\n<p><strong>Bash</strong> the lemongrass stem<span class=\"text-danger\">[s]</span> with a rolling pin, cut it <span class=\"text-danger\">[them]</span> down the middle lengthways, remove the tough outer layers (keep them for later!) and chop the softer inner stem<span class=\"text-danger\">[s]</span> finely</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the pork mince, ginger, garlic, inner lemongrass stems, cornflour, soy sauce and sesame oil in a large mixing bowl with clean hands</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> combined, pick up the mixture and slam it down forcefully back into the bowl (this gets rid of any air pockets and brings the mixture together so it holds its shape when cooking)</p>\r\n<p><strong>Repeat</strong> until the mixture comes together and becomes sticky and dense</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/548.-step--3-x200.jpg",
            "width": 200
