  "cooking_instructions": [
    {
      "instruction": "<p>Rinse the <strong>brown rice</strong>, add it to a pot with plenty of <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 15-20 min or until it's tender with a slight bite</p><p>Once cooked, drain, return it to the pot and keep covered until serving</p><p>Boil half a kettle</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1621864535765-x200.jpg",
