  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Chop your <strong>sweet potato[es]</strong> (skin on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1673365589730-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1673365589730-x400.jpg",
