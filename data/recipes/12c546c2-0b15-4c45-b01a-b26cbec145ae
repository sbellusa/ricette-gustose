            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1673365594510-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve <strong>half</strong> your <strong>vegetable stock mix </strong>(you'll use the rest later!) in 225ml <span class=\"text-purple\">[300ml]</span> <span class=\"text-danger\">[390ml] </span><strong>boiled water</strong></p><p>Drain and rinse your <strong>chickpeas</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1673365597396-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1673365597396-x400.jpg",
