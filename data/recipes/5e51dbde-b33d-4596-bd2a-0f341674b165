          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1650380338639-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>harissa chickpea & apricot tagine </strong>over the <strong>couscous</strong></p><p>Garnish with your <strong>flaked almonds</strong>, <strong>spring onion greens</strong> and<strong> tahini yoghurt</strong></p><p>Enjoy!</p>",
      "order": 8,
