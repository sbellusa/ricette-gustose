          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, finely chop or grate your<strong> garlic</strong></p><p>Wash your <strong>spinach</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1683890944402-x200.jpg",
