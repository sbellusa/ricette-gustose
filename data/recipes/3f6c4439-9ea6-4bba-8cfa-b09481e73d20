  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and finely chop the <strong>onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
