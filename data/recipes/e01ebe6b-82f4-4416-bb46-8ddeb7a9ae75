        ]
      }
    },
    {
      "instruction": "<p>Crush your<strong> cardamom pods</strong> open by squashing them with the side of a knife</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1680107589693-x200.jpg",
