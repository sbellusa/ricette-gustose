            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> crushed cardamom pods</strong> and<strong> ginger paste</strong> to your dish with your <strong>ground turmeric</strong>,<strong> curry powder</strong> and<strong> bay leaf[ves]</strong><span class=\"text-danger\"> </span>and give everything a good stir</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1680107597432-x200.jpg",
