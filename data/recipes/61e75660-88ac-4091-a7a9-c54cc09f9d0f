        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>mayo</strong>, <strong>wholegrain mustard</strong>,<strong> chopped dill </strong>and <strong>apple matchsticks</strong> with a pinch of<strong> pepper </strong>– this is your<strong> apple remoulade</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1765.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1765.-step-6-x400.jpg",
