          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1765.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1765.-step-4-x1000.jpg",
