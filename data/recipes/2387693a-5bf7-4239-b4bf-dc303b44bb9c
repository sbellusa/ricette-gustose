  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice the <strong>green chilli<span class=\"text-danger\">[es]</span></strong> finely</p><p>Add the <strong>sliced chilli </strong>(can't handle the heat? Remove the seeds!)<strong> </strong>to a small bowl with <strong>half </strong>the <strong>cider vinegar </strong>(you'll use the rest later!), a small pinch of <strong>salt</strong> and 1/2 tsp <span class=\"text-danger\">[1 tsp]</span> <strong>sugar</strong></p><p>Mix everything together and set aside – this is your <strong>quick-pickled chilli</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1651056788013-x200.jpg",
