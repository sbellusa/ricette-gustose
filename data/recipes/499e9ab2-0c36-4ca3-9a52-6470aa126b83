  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle for steps 1 and 4</p>\r\n<p><strong>Add</strong> the rice noodles to a pot with plenty of boiling water</p>\r\n<p><strong>Cook</strong> on a medium heat for 5 min, or until starting to soften</p>\r\n<p><strong>Remove</strong> from the heat and rinse under cold water</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and slice the ginger finely into matchsticks</p>\r\n<p>Tip: Use a teaspoon to scrape the skin off the ginger for easy peeling!</p>\r\n<p><strong>Peel</strong> and slice the shallots finely</p>\r\n<p><strong>Set</strong> both aside for step 4</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Rub</strong> the steaks with 1-2 tbsp of olive oil, 1 tsp <span class=\"text-danger\">(2 tsp)</span> of salt, and 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> of pepper and mix well</p>\r\n<p><strong>Place</strong> a large pan on a high heat</p>\r\n<p><strong>Once</strong> hot, add the steaks and cook for 1 min on each side</p>\r\n<p><strong>Transfer</strong> the steaks to a plate and cover with a tea towel, reserving the pan</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the steak pan to a medium-high heat and once hot, fry the chilli flakes, ginger, shallot, and star anise<span class=\"text-danger\">(s)</span> for 2 mins, stirring constantly (add more oil if needed)</p>\r\n<p><strong>Pour</strong> 750ml <span class=\"text-danger\">(1.5L)</span> of boiling water into the pan and crumble in the stock cube(s)</p>\r\n<p><strong>Add</strong> the hoisin and stir- this is your broth</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> any resting juice from the steaks to the broth and mix well</p>\r\n<p><strong>Bring</strong> the broth to a boil, then simmer for 6 min on a low heat</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the steak thinly on a clean chopping board</p>\r\n<p><strong>Transfer</strong> the sliced steak and its juices to the plate from step 3</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the broth has simmered for 6 min, add the mange tout and cook for a further 2 min, or until starting to soften</p>\r\n<p><strong>Season</strong> to your taste with with salt and pepper</p>\r\n<p><strong>Pour</strong> just the steak juices, directly into the broth</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Divide</strong> the noodles between bowls</p>\r\n<p><strong>Ladle</strong> in the broth (removing the star anise) and top with the sliced steak</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
