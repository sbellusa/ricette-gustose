      }
    },
    {
      "instruction": "<p>Divide and shape the <strong>pork mixture</strong> into 2 patties per person<strong> </strong>– these are your <strong>Thai-style pork patties</strong></p>",
      "order": 4,
      "media": {
        "images": [
