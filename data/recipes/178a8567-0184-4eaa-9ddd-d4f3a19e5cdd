          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1678294440431-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1678294440431-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1678294440431-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1678294440431-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>chicken stock</strong>, <strong>spelt</strong> and <strong>bay leaf[ves]</strong><span class=\"text-danger\"> </span>to the pan and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook, covered, for an initial 13 min</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1678294463731-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1678294463731-x400.jpg",
            "width": 400
