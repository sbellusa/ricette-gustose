            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Chop the<strong> walnuts </strong>roughly</p><p>Trim the <strong>green beans</strong></p>",
      "order": 2,
      "media": {
        "images": [
