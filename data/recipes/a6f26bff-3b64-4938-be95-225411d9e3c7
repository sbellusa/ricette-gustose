            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>spring greens</strong>, then rip the leaves off, discard the tough stalks, and layer the leaves over each other, roll them up and slice into thin strips</p><p>Trim, then slice your <strong>spring onions</strong> finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1681808889084-x200.jpg",
