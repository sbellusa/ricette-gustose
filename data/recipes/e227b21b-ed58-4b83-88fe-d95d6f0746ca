            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chestnut mushrooms soften, chop the <strong>basil</strong> finely, including the stalks</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1625.-step-5-x200.jpg",
            "width": 200
