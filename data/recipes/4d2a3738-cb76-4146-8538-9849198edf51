          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely dice the <strong>brown</strong>&nbsp;<strong>onion<span class=\"text-danger\">[s]</span></strong><br /><br />Once the <strong>bacon</strong> is crisp, reduce the heat to medium and add the <strong>diced onion</strong> and cook for 4-5 min further or until the <strong>onion</strong> has softened</p>",
      "order": 3,
      "media": {
