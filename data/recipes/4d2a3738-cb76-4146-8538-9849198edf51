  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Boil a kettle</p>\r\n<p>Add the<strong> tortiglioni</strong>&nbsp;to a pot of <strong>boiled water</strong> with a large pinch of <strong>salt</strong> and bring to the boil over a high heat, then cook&nbsp;for 10-12 min or until cooked with a slight bite</p>\r\n<p>Once done, drain the<strong> tortiglioni</strong>, reserving 150ml <span class=\"text-danger\">[250ml]</span> of the <strong>starchy pasta water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-1-x400.jpg",
            "width": 400
