          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop the&nbsp;<strong>smoked streaky bacon </strong>finely<strong>&nbsp;</strong></p>\r\n<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a high heat</p>\r\n<p>Once hot, add the<strong>&nbsp;chopped bacon</strong> and cook for 5-6 min or until starting to crisp</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1192.-step-2-x400.jpg",
            "width": 400
          },
