  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, wide-based pot with a drizzle of <strong>olive oil </strong>over a medium-high heat</p><p>Once hot, add your <strong>bacon lardons</strong> and cook for<span class=\"text-danger\"> </span>5-6 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1693827084784-x200.jpg",
