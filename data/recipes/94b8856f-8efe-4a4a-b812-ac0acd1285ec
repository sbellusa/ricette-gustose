            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> diced cucumber</strong> and the <strong>remaining chopped onion</strong> to a bowl with a drizzle of <strong>olive oil</strong></p><p>Season with a pinch of <strong>salt </strong>and a generous grind of <strong>pepper </strong>and give everything a good mix up – this is your<strong> cucumber salad</strong></p>",
      "order": 7,
      "media": {
        "images": [
