  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9 and take your <strong>chicken</strong> out of the fridge, open the packet and let it air, then boil half a kettle</p><p>Add your <strong>cashew nuts</strong> to a bowl, cover with 200ml <span class=\"text-purple\">[260ml]</span> <span class=\"text-danger\">[350ml]</span> <strong>boiled water</strong>, then cover with a plate and set aside</p><p>Chop your<strong> free range</strong> <strong>chicken breast portion[s]</strong> into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1699364006160-x200.jpg",
            "width": 200
