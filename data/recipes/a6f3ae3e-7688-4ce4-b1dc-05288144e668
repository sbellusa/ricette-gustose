          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685529987982-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the duck is cooking, cut your<strong> pak choi </strong>in half lengthways</p><p>Top, tail and slice your<strong> carrots</strong> into batons</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1685529993663-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1685529993663-x400.jpg",
            "width": 400
