          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1685529993663-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1685529993663-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1685529993663-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>pak choi halves </strong>and <strong>carrot batons</strong> to a large piece of <strong>tin foil</strong> with a generous pinch of <strong>salt</strong></p><p>Scrunch the foil around the vegetables to form a tightly sealed parcel and add to a baking tray</p><p>Put the tray in the oven for an initial 15 min</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1685529997837-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1685529997837-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1685529997837-x700.jpg",
            "width": 700
