  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Separate your <strong>duck legs</strong> and add to a <strong>tin foil</strong>-lined baking tray</p><p>Put the tray in the oven for an initial 15 min or until starting to brown</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685529987982-x200.jpg",
