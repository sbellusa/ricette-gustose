          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-7-x700.jpg",
