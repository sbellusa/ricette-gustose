          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the<strong> crème fraîche </strong>in 150ml <span class=\"text-danger\">[250ml]</span> <strong>boiled water </strong>– this is your<strong> creamy stock</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-4-x700.jpg",
