            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pan is hot, add the <strong>sliced</strong> <strong>spring onion</strong> and <strong>roasted garlic paste</strong> and cook for 30 sec or until fragrant</p>\n<p>Add the <strong>gnocchi</strong> and cook for 2-3 min or until starting to brown</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-3-x400.jpg",
            "width": 400
          },
