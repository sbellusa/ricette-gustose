            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>creamy ham hock gnocchi </strong>with the <strong>baby leaf salad</strong> to the side</p>\n<p>Drizzle the <strong>balsamic dressing</strong> over the salad and sprinkle the gnocchi with the <strong>remaining cheese</strong></p>\n<p>Enjoy!</p>",
      "order": 8,
