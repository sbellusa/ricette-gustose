          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the gnocchi has browned, add the <strong>creamy stock</strong> and cook, covered, for 2-3 min further or until the gnocchi has softened</p>\n<p>Tip: Don't worry if your sauce looks a bit thin, the cheese and ham will thicken it later!</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2029.-step-5-x200.jpg",
            "width": 200
