  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p>Boil a kettle (used in step 3)</p>\r\n<p>Cut the <strong>sweet potatoes</strong> into roughly equal size (approx. 2cm chunks)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Heat a large pan with 1 tbsp <strong>olive oil</strong></p>\r\n<p>When hot, add the <strong>sweet potatoes</strong> and <strong>curry powder</strong></p>\r\n<p>Cook on a medium heat for 4 min</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Add the<strong> lentils</strong>, <strong>tomato paste</strong> and 700ml <span class=\"text-danger\">[1L]</span> <strong>boiling water</strong></p>\r\n<p>Bring to the boil, stir well and cover with a lid</p>\r\n<p>Cook for 5 min then remove the lid and reduce by 2/3 </p>\r\n<p>You should end up with a mix that's the same consistancy as thick chunky soup</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Meanwhile, heat a pan with 2-3 tbsp <strong>olive oil</strong></p>\r\n<p>When hot, add the<strong> oats</strong>, <strong>breadcrumbs</strong> and <strong>pumpkin seeds</strong></p>\r\n<p>Cook on a medium heat for 4 min, stirring continously until crunchy</p>\r\n<p>Season to your taste with <strong>salt</strong> and <strong>pepper</strong>- this is your crumble topping</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Cut the <strong>feta</strong> roughly into 1cm cubes</p>\r\n<p>Add the <strong>sweet potato mixture</strong> to an ovenproof dish</p>\r\n<p>Evenly distribute the <strong>feta cubes</strong> in amongst the filling</p>\r\n<p>Sprinkle the <strong>oat mixture</strong> on top and bake for 5- 10 min, until bubbling</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Discard the woody end of the <strong>leek<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Cut the <strong>leek<span class=\"text-danger\">[s]</span></strong>&nbsp;in half lengthways</p>\r\n<p>Cut each half into 3 pieces</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Heat a small pan (with a lid) with 1-2 tbsp <strong>olive oil</strong></p>\r\n<p>When hot add the<strong> leek</strong> and season to your taste</p>\r\n<p>Cook for 1 min until starting to colour</p>\r\n<p>Add 100ml <span class=\"text-danger\">[150ml]</span> <strong>water</strong> and the lid</p>\r\n<p>Cook for 4 min or until tender</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Serve the crumble straight from the dish with the leeks as a side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
