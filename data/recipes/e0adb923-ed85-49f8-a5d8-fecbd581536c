  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Slice</strong> your aubergine<span class=\"text-danger\">[s]</span>&nbsp;lengthways into 4 equally thick slices, discard the green stalk<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Season</strong> both sides with salt</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide-based pan (preferably non-stick with a matching lid), with 2 tbsp<span class=\"text-danger\"> [4 tbsp]</span>&nbsp;vegetable oil over a medium-high heat</p>\r\n<p><strong>Once</strong> hot,&nbsp;add the aubergine and cook, covered, for 3-4 min each side or until nicely browned</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice your tomatoes in half and season them lightly with salt and pepper</p>\r\n<p><strong>Transfer</strong> the coloured aubergine to the baking tray (use tin foil to avoid mess!)</p>\r\n<p><strong>Reserve</strong> the pan for later</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the bulgur to a pot with plenty of salted boiled water over a high heat</p>\r\n<p><strong>Cook</strong> for 10-12 min or until tender with a slight bite, then drain and return to the pot</p>\r\n<p><strong>Meanwhile</strong>, mix the pomegranate molasses and the honey together - this is your glaze</p>\r\n<p>&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the reserved pan to a medium-high heat and add the tomatoes, cut-side-down</p>\r\n<p><strong>Cover</strong> and cook for 3-4 min or until nicely charred and blackened in colour</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Spread</strong> the glaze evenly&nbsp;over the cooked aubergine then top with the breadcrumbs</p>\r\n<p><strong>Tip:</strong> Working one at a time prevents the glaze from running off the aubergine and the breadcrumbs will help hold it in place</p>\r\n<p><strong>Place</strong> the baking tray on the top rack of your oven and cook for 5-7 min or until the breadcrumbs are golden brown in colour</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> the dill, 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;olive oil and a pinch of salt and pepper through the drained bulgur</p>\r\n<p>&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/572.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the crispy glazed aubergine over the bulgur, crumble the Rosary goats' cheese over and serve the tomatoes alongside</p>\r\n<p><strong>Enjoy!</strong></p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
