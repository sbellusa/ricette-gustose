            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the rice is cooking, trim, then roughly chop 1 <span class=\"text-danger\">[2] </span><strong>spring onion<span class=\"text-danger\">[s]</span></strong></p><p>Roughly chop the <strong>remaining ginger</strong></p>",
      "order": 3,
