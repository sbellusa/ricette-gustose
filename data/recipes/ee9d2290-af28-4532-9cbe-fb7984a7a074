            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1 tbsp<span class=\"text-danger\"> [2 tbsp]</span><strong> olive oil</strong> over a medium heat</p><p>Once hot, add the <strong>chopped onion </strong>and<strong> garlic</strong> with a pinch of <strong>salt</strong> and cook for 6-8 min or until softened</p>",
      "order": 3,
      "media": {
