            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the rice is coated, add your <strong>blanched</strong> <strong>peas</strong> and <strong>grated carrot </strong>to the pan<strong> </strong>and cook for 3-4 min further or until the rice is piping hot and the pork is cooked through (no pink meat!)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1606132815758-x200.jpg",
