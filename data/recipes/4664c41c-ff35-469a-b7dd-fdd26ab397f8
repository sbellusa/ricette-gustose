            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan to a medium heat, add the Thai red curry paste and cook for 1 min</p>\r\n<p><strong>Add</strong> the lime leaves, 300ml <span class=\"text-danger\">[600ml]</span>&nbsp;boiled water and the soy sauce</p>\r\n<p><strong>Stir</strong> to dissolve the curry paste&nbsp;</p>\r\n<p><strong>Reduce</strong> the heat to low&nbsp;</p>",
      "order": 3,
      "media": {
