            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, place<strong>&nbsp;</strong>the coconut cream sachet<span class=\"text-danger\">[s]</span> in a mug and cover with boiled water (this softens the naturally hard cream)</p>\r\n<p><strong>Add</strong> the rice noodles to a pot and cover with boiled water, then cook for 6 min over a high heat</p>\r\n<p><strong>Once</strong>&nbsp;cooked, drain, rinse with cold water and return them to the pot</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-1-x700.jpg",
            "width": 700
          },
          {
