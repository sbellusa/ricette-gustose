  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle and cut the paneer into bite-size cubes</p>\r\n<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) over a medium-high heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the paneer and cook for 3-5 min or until golden on all sides, then transfer it to a plate and set aside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/594.-step-2-x400.jpg",
