            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the veg is cooking, cut your <strong>potatoes</strong> (skins on) into wedges</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1672755982027-x200.jpg",
            "width": 200
