  "cooking_instructions": [
    {
      "instruction": "<p><strong>Before you begin...</strong></p><p>Get all your ingredients and equipment ready</p><p>Skim through these steps, then wash your fruit and veg</p><p>Note: Please make sure you cook your salmon thoroughly (until piping hot!) as cooking equipment varies</p>",
      "order": 1,
      "media": {
        "images": [
