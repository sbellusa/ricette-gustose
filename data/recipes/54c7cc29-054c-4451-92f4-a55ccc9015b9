          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/384_step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the veg is roasting, boil a kettle</p><p>Slice your <strong>ciabatta[s] </strong>in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/384_step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/384_step-3-x400.jpg",
            "width": 400
          },
