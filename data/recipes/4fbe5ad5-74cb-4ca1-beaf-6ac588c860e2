            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>avocado[s]</strong> in half lengthways, around the stone</p><p>Remove the <strong>stone[s]</strong> using a spoon, then scoop out the <strong>avocado flesh </strong>and slice finely lengthways</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1580126091334-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1580126091334-x400.jpg",
