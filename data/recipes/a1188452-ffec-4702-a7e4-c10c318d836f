  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Chop the <strong>waxy potatoes</strong> in half</p><p>Add the <strong>chopped potatoes</strong> to a pot of plenty of <strong>boiled water</strong> with a generous pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Once boiling, cook for an initial 10 min</p>",
      "order": 1,
      "media": {
        "images": [
