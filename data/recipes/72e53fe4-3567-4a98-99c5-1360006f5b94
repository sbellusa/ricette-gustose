            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>smoked streaky bacon</strong> to a separate<strong> tin foil</strong>-lined baking tray (or two!)</p><p>Put the tray[s] in the oven for 12-15 min further or until golden and crispy</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1699376205642-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1699376205642-x400.jpg",
