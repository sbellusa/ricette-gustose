  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Put a large baking tray (or two) in the oven to heat up (this will stop the <strong>pizza bottoms</strong> from going soggy!)</p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Peel and finely slice your<strong> red onion[s]</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684910606380-x200.jpg",
