          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684910606380-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Drain and rinse your <strong>sweetcorn</strong></p>",
      "order": 2,
      "media": {
        "images": [
