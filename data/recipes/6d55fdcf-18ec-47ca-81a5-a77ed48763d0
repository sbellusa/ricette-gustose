            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1702404357766-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1702404357766-x1000.jpg",
            "width": 1000
