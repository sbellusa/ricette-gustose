          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1702404335148-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1702404335148-x1000.jpg",
