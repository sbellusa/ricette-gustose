  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air then preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>red onion[s]</strong> into wedges, removing the skins</p><p>Chop your<strong> tomato[es] </strong>into wedges</p><p>Top, tail and chop your<strong> courgette[s]</strong> in half lengthways, then slice into half moons</p>",
      "order": 1,
      "media": {
        "images": [
