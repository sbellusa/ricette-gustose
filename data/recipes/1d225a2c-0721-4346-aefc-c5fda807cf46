          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2366Step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>coriander</strong> roughly, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2366Step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2366Step-3-x400.jpg",
            "width": 400
          },
          {
