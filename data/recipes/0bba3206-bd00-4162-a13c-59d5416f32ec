  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9, then put a large baking tray (or two!) in the oven to heat up</p><p>Tip: This will stop the<strong> </strong>pizza bottom from going soggy!</p><p>Add your <strong>dried yeast</strong><span class=\"text-danger\"> </span>to a large bowl with 100ml <span class=\"text-purple\">[150ml]</span> <span class=\"text-danger\">[200ml]</span> <strong>warm water </strong>and 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp] </span><strong>sugar</strong></p><p>Give it a good mix up and set aside for 5-10 min for the yeast to develop</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1595495140301-x200.jpg",
