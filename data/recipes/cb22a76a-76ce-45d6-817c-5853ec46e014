  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of<strong> vegetable oil </strong>over a medium heat</p><p>Once hot, add the <strong>chopped onion</strong> with a pinch of <strong>salt</strong> and cook for 3-4 min or until beginning to soften</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1721725757472-x200.jpg",
