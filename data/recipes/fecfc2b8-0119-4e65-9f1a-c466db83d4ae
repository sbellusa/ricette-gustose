  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Boil</strong> a kettle (used in step 4)</p>\r\n<p><strong>Peel</strong> and finely dice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and roughly chop the garlic<br />Cut the broccoli into florets</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the broccoli florets to a baking tray, drizzle with a little olive oil and season with salt and pepper</p>\r\n<p><strong>Put</strong> it in the oven for 20-25 min or until the broccoli is crispy on the outside</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, heat a large wide-based pan with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil</p>\r\n<p><strong>When</strong> hot, add the chopped onion with a pinch of salt</p>\r\n<p><strong>Cook</strong> on a medium heat for 8 min or until softened, then add the garlic and cook for a further 2 min</p>\r\n<p><strong>Once</strong> the onion is cooked,&nbsp;set aside in a bowl for step 7</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the pasta to a large pot of boiling water with a large pinch of salt</p>\r\n<p><strong>Cook</strong> for 8 min, or until al-dente</p>\r\n<p><strong>Once</strong> cooked, drain and allow to steam dry in the colander</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, break up the stilton into small pieces</p>\r\n<p><strong>Bash</strong> up the walnuts (whilst still in the bag) with a rolling pin or other suitable implement until you have fine crumbs</p>\r\n<p>Tip: Alternatively, use a food processor or pestle and mortar to break up the walnuts</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the onion&nbsp;pan to a medium heat and melt 30g <span class=\"text-danger\">(60g)</span> of butter</p>\r\n<p><strong>Once</strong> melted, gradually stir in 30g <span class=\"text-danger\">(60g)</span> of flour and cook for 2 min, stirring constantly</p>\r\n<p><strong>You</strong> should end up with a sandy textured, honey coloured paste</p>\r\n<p><strong>This</strong> is your roux</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Whisk</strong> 400ml <span class=\"text-danger\">(800ml)</span> of milk gradually into the roux</p>\r\n<p><strong>Cook</strong> for 5 min, stirring continously, until a smooth fairly loose sauce forms, then remove it from the heat</p>\r\n<p><strong>Add</strong> the stilton and onion-garlic mix to the sauce</p>\r\n<p><strong>Stir</strong> in the pasta and season with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the pasta mix to an oven-proof dish<span class=\"text-danger\">(es)</span> and sprinkle with the bashed walnuts</p>\r\n<p><strong>Cook</strong> in the oven for 5-10 min, or until the walnuts are golden brown</p>\r\n<p><strong>Serve</strong> the broccoli to the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
