            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1630426525037-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray<span class=\"text-danger\">[s]</span> in the oven for 15-20 min or until everything is cooked through and tender – this is your <strong>roasted veg</strong></p><p>Meanwhile, wash the <strong>gem lettuce</strong>, then pat it dry with kitchen paper and roughly shred</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1630426530122-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1630426530122-x400.jpg",
            "width": 400
          },
          {
