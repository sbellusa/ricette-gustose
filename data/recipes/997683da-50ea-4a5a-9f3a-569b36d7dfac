  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Toast</strong> the millet in a pot for 2-3 min, until starting to pop and slightly browned </p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 700ml <span class=\"text-danger\">(1.4L)</span> of boiled water</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 600ml <span class=\"text-danger\">(1.2L)</span> of stock to the millet pot (reserve the remainder for step 4)</p>\r\n<p><strong>Bring</strong> to a boil with a lid on</p>\r\n<p><strong>Once</strong> boiling, reduce to a simmer and cook for 20-25 min, or until all the water is absorbed and the millet is tender</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, preheat the grill to high</p>\r\n<p><strong>Chop</strong> the aubergine<span class=\"text-danger\">(s)</span> into quarters lengthwise and slice into bite size chunks</p>\r\n<p><strong>Cut</strong> the mushrooms in half and chop into 1cm pieces</p>\r\n<p><strong>Peel</strong> and slice the shallots finely and grate the zest of the lemon<span class=\"text-danger\">(s)</span></p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil and 15g <span class=\"text-danger\">(30g)</span> of butter to a pan on a medium-high heat</p>\r\n<p><strong>Once</strong> melted, cook the aubergine for 5 min, without turning</p>\r\n<p><strong>Add</strong> the shallot and mushroom, turn the aubergine and reduce the heat to a simmer</p>\r\n<p><strong>Add</strong> the remaining stock in batches and cook for 12-15 min</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the parsley and lemon zest together finely</p>\r\n<p><strong>This</strong> is your gremolata! </p>\r\n<p><strong>Cut</strong> the lemon<span class=\"text-danger\">(s)</span> into quarters</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> the lemon wedges on an oven proof tray and place under the grill </p>\r\n<p><strong>Grill</strong> for 8-10 min or until caramelised </p>\r\n<p><strong>Remove</strong> and set aside for serving</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the millet is tender, grate 3/4 of the parmesan directly into the pot</p>\r\n<p><strong>Add</strong> 15g <span class=\"text-danger\">(30g)</span> of butter and stir well with a fork to combine</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper, and set aside </p>\r\n<p>Tip: Add a few tbsp of water or milk to thin out if desired</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> up a big spoonful of millet topped with the earthy veg, season to taste with salt and pepper</p>\r\n<p><strong>Serve</strong> with the remaining lemon wedges, a big pinch of gremolata and a big drizzle of olive oil </p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
