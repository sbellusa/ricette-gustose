  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p><p>Add the <strong>chicken breasts </strong>to a baking tray</p><p>Drizzle the <strong>chicken breasts</strong> with <strong>olive oil</strong> and sprinkle over the <strong>smoked paprika</strong>, <strong>cayenne pepper</strong> (can't handle the heat? Go easy!) and a pinch of <strong>salt</strong> and <strong>pepper</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1595957343583-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1595957343583-x400.jpg",
            "width": 400
