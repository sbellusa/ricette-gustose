          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1595957343583-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1595957343583-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1595957343583-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray in the oven for 15-20 min or until the chicken is cooked through</p><p>Whilst the chicken is cooking, peel and finely dice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Boil a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1595957347892-x200.jpg",
