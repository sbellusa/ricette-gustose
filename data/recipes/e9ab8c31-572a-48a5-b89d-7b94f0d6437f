            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice the <strong>spring onions</strong> finely</p>\n<p>Drain and roughly chop the<strong> pineapple slices</strong></p>\n<p>Chop the <strong>cherry tomatoes</strong> into quarters </p>\n<p>Cut the <strong>lime<span class=\"text-danger\">[s]</span></strong> in half</p>\n<p>Chop the <strong>coriander</strong> finely, including the stalks </p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2076.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2076.-step-5-x400.jpg",
