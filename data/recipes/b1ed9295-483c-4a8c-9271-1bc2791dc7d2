  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Peel</strong> the carrots, cut into batons and add them to a baking tray lined with tin foil</p>\r\n<p><strong>Drizzle</strong> them with olive oil and season generously with salt</p>\r\n<p><strong>Put</strong> the tray in the oven for 20 min, turning once</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/498.-step-1-x200.jpg",
            "width": 200
