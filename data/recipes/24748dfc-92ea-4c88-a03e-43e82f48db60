            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, top and tail the <strong>courgette<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Peel lengths of <strong>courgette</strong> until you end up with a pile of courgette 'ribbons'</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-4-x400.jpg",
            "width": 400
          },
          {
