            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) the <strong>garlic</strong></p>\r\n<p>Cut the<strong>&nbsp;red chilli<span class=\"text-danger\">[es]</span></strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop ﬁnely</p>\r\n<p>Strip the <strong>mint leaves</strong> and chop them finely, discarding the stems&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1439.-step-5-x700.jpg",
            "width": 700
          },
