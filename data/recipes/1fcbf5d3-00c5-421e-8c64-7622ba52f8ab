          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Admin10mm-Step-1-2-1672852957739-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Admin10mm-Step-1-2-1672852957739-x1000.jpg",
