          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2338v2Step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2338v2Step-3-x1000.jpg",
