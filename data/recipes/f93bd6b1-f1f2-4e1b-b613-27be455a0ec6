  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Combine the <strong>baharat</strong>, <strong>cumin seeds </strong>and <strong>ground</strong> <strong>cinnamon</strong> with 2 tbsp<span class=\"text-danger\"> [4 tbsp] </span><strong>olive oil</strong> and a generous pinch of <strong>salt</strong> and <strong>pepper </strong>in a small bowl – this is your <strong>spice rub</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1637085548879-x200.jpg",
            "width": 200
