  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and grate <strong>half</strong> your <strong>red onion[s]<span class=\"text-danger\"> </span></strong>(you'll use the rest later!)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-33-1704989605029-x200.jpg",
