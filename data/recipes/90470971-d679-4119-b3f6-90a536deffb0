            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1676304354984-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1676304354984-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Grate the <strong>apple<span class=\"text-danger\">[s]</strong> </span>(skin on) and discard the core</p><p>Top, tail and grate the<strong> carrot<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1676304364634-x200.jpg",
            "width": 200
