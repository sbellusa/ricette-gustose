            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>grated apple </strong>and<strong> carrot</strong> in a small bowl with the<strong> mayo</strong>, <strong>white wine vinegar </strong>and<strong> soy sauce </strong>– this is your<strong> carrot & apple slaw</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
