            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>chicken breast portion[s]</strong> in half across the middle – these are your <strong>chicken pieces</strong></p><p>Peel and finely chop (or grate) your <strong>garlic </strong>and cut your <strong>lemon[s]</strong> in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2012.-step-3-x200.jpg",
            "width": 200
