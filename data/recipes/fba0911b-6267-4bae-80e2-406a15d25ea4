            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>potatoes</strong> to a pot of<strong> boiling water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for an initial 10-15 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1752.-step-2-x200.jpg",
            "width": 200
          },
          {
