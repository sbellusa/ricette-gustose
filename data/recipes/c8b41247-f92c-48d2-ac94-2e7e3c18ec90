          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-2-1677077850564-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the burger patties are cooking, trim, then slice the <strong>spring onion[s]</strong><span class=\"text-danger\"> </span>lengthways into thin strips</p><p>Chop the<strong> cucumber</strong> into discs</p><p>Slice each <strong>cucumber disc</strong> into matchsticks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1678109197365-x200.jpg",
