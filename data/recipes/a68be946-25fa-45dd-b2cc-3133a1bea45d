            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Peel and finely slice your<strong> red onion[s]</strong></p><p>Trim, then chop your <strong>green beans </strong>in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2329-Step-2-x200.jpg",
