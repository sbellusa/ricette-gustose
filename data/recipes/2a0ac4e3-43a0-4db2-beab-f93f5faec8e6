          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1454.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>potatoes</strong> (skins on) into small, bite-sized pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1454.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1454.-step-3-x400.jpg",
