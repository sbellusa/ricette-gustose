  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Chop your <strong>leek[s] </strong>in half lengthways, wash thoroughly then top, tail and slice finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1454.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1454.-step-1-x400.jpg",
            "width": 400
