            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1681892893093-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1681892893093-x700.jpg",
            "width": 700
