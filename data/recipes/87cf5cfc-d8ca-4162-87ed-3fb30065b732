            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1725365143203-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1725365143203-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain and rinse your <strong>butter beans</strong></p><p>Add the<strong> carrot rounds</strong> to the dish with the<strong> drained butter beans</strong>, <strong>baby button mushrooms </strong>and 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp] </span><span class=\"text-danger\">[2 tbsp]</span><strong> flour </strong>and stir everything together</p>",
      "order": 3,
