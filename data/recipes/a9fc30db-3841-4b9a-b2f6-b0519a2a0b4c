  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Cut the <strong>waxy potatoes</strong> (skins on) in half</p>\r\n<p>Chop the <strong>green beans</strong> in half</p>\r\n<p>Add the <strong>potatoes</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 15 min or until almost fork-tender&nbsp;</p>\r\n<p>Once almost tender, add the <strong>green beans</strong> and cook for 3-4 min or until cooked with a slight bite</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1303.-step-1-x200.jpg",
