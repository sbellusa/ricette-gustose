            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reboil half a kettle</p><p>Top, tail, peel and grate the <strong>carrot<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Tear the <strong>chestnut mushrooms </strong>into rough, bite-sized pieces</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1615218102245-x200.jpg",
            "width": 200
