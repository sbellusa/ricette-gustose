  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Boil a kettle</p>\r\n<p>Cut the <strong>potatoes</strong>&nbsp;(skins on) into thick chips and add them to a lightly oiled baking tray</p>\r\n<p>Drizzle with <strong>vegetable</strong>&nbsp;<strong>oil</strong> and season with <strong>salt</strong> and <strong>pepper&nbsp;</strong></p>\r\n<p>Put the tray in the oven for 20-25 min or until golden and crisp&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop 1/2 <span class=\"text-danger\">[1]</span> of the<strong> shallot<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Chop the <strong>capers</strong> finely</p>\r\n<p>Cut the <strong>lemon<span class=\"text-danger\">[s]</span></strong> in half&nbsp;</p>\r\n<p>Add the chopped <strong>shallot</strong>,&nbsp;<strong>capers</strong> and&nbsp;<strong>mayonnaise</strong> to a small bowl with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;<strong>lemon juice&nbsp;</strong></p>\r\n<p>Mix to combine - this is your <strong>tartare sauce&nbsp;</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Roughly chop the <strong>green beans&nbsp;</strong></p>\r\n<p>Add them to a pot of<strong> salted</strong> <strong>boiled water</strong> and cook for 3-4 min or until tender with a slight bite</p>\r\n<p>Once cooked, drain and rinse them under cold water and set aside and keep the pan for later&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849_step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849_step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/849_step-3-x700.jpg",
