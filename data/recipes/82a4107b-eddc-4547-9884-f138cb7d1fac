  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and chop the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Heat</strong> a wide-based pan (preferably non-stick) with a matching lid on a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil</p>\r\n<p><strong>When</strong> hot, add the onion &amp; cinnamon with a pinch of salt</p>\r\n<p><strong>Cook</strong> for 8 min, or until softened and brown at the edges, stirring often</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely chop (or grate) the garlic</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the ginger (scrape the skin off with a teaspoon)</p>\r\n<p><strong>Chop</strong> the chilli<span class=\"text-danger\">(es)</span> and seeds (optional) finely for step 4</p>\r\n<p><strong>Chop</strong> the chicken into 3cm cubes also for step 4</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> half a kettle for step 5</p>\r\n<p><strong>Add</strong> the garlic and ginger to the onion pan and cook for a further 30 sec-1 min, or until fragrant without taking on too much colour, stirring constantly</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the red chilli and seeds to your preferred heat, with the turmeric, ground coriander, 2 tsp <span class=\"text-danger\">(4 tsp)</span> of sugar and 1 tsp <span class=\"text-danger\">(2 tsp)</span> of salt to the pan and mix well</p>\r\n<p><strong>Add</strong> the chicken &amp; cook for approx. 3-4 min, or until the chicken is slightly coloured and no longer translucent, stirring occasionally</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, dissolve the coconut cream in 150ml <span class=\"text-danger\">(300ml)</span> of boiled water and stir to combine</p>\r\n<p><strong>Once</strong> the chicken has coloured slightly, add the tamarind paste and stir through the dissolved coconut cream</p>\r\n<p><strong>Cover</strong> with a lid, reduce the heat to medium-low and simmer for 15-20 min, or until the chicken is tender and cooked through and the sauce is creamy</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--5-x1000.jpg",
