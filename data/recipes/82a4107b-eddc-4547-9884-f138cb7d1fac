          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the rice to a separate pot with 375ml <span class=\"text-danger\">(750ml)</span> of cold water and salt (optional) on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce to a simmer and cover for 15-20 min or until the water is absorbed</p>\r\n<p><strong>Check</strong> to prevent over-cooking and once done, set aside until serving</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/439.-step--6-x200.jpg",
