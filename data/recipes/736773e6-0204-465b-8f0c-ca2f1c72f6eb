            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1673977450538-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chicken is cooking, wash the <strong>gem lettuce</strong>,<strong> </strong>then pat dry with kitchen paper</p><p>Remove 2<span class=\"text-danger\"> [4] </span><strong>leaves</strong> from the <strong>gem lettuce</strong> and set aside, then cut the <strong>inner core<span class=\"text-danger\">[s]</span></strong> into 4 <span class=\"text-danger\">[8]</span> wedges</p>",
      "order": 6,
      "media": {
        "images": [
