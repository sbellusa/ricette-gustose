            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the sauce is cooking, grate the <strong>cheddar flavour block</strong></p><p>Trim, then finely slice the<strong> spring onion<span class=\"text-danger\">[s]</span></strong></p><p>Drain and rinse the<strong> black beans</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1682596198519-x200.jpg",
