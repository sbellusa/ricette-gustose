            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion is beginning to soften, add the <strong>sliced courgette </strong>and <strong>sliced garlic </strong>to the pan</p><p>Cook for 10-12 min or until the courgette is beginning to soften, stirring occasionally</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1680016326948-x200.jpg",
