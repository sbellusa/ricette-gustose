          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1618924565802-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1618924565802-x700.jpg",
