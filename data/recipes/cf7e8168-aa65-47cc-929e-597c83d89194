            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Peel and finely chop your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Slice your <strong>cherry tomatoes </strong>roughly</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1618924565802-x200.jpg",
            "width": 200
