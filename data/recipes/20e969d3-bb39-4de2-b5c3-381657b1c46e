  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Drain</strong> the artichokes and pat dry</p>\r\n<p><strong>Place</strong> the artichokes on an oven-proof tray, coat well with 1-2 tbsp olive oil and sprinkle with the pumpkin seeds</p>\r\n<p><strong>Put</strong> in the oven for 15 min or until brown</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Add</strong> the bulgar wheat, stock cube<span class=\"text-danger\">(s)</span> and cranberries to a pot, add 135ml <span class=\"text-danger\">(270ml)</span> of boiling water, cover with a lid and place on a medium-low heat</p>\r\n<p><strong>Simmer</strong> for 5 min or until almost all the water is absorbed</p>\r\n<p><strong>Remove</strong> from the heat and allow to rest with the lid on for 10 min or until all the water has been absorbed</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and dice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Remove</strong> the thyme's leaves and discard the stems</p>\r\n<p><strong>Grate</strong> the zest of the orange<span class=\"text-danger\">(s)</span> and slice the celery (approx. 1cm)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the onion, thyme and orange zest and cook for 5 min or until the onion is soft</p>\r\n<p><strong>Cut</strong> the orange<span class=\"text-danger\">(s)</span> in half</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the celery to the pan</p>\r\n<p><strong>Cook</strong> for 3 min or until the celery is warm through, stirring constantly</p>\r\n<p><strong>Check</strong> the artichokes and remove from the oven if the pumpkin seeds are beginning to burn</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, drain and rinse the butter beans</p>\r\n<p><strong>Add</strong> the butter beans to the pan</p>\r\n<p><strong>Cook</strong> for 2 min or until the beans are warm through, stirring occasionally</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Squeeze</strong> the juice of the orange<span class=\"text-danger\">(s)</span> over the pan and mix well</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>\r\n<p><strong>Remove</strong> the artichokes from the oven if you haven't already</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the butter bean mixture to the bulgar wheat, mix well and serve with the roasted artichokes</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
