  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 350ml <span class=\"text-danger\">(650ml)</span> of boiling water </p>\r\n<p><strong>Add</strong> the couscous to a bowl with 200ml <span class=\"text-danger\">(400ml)</span> of the stock (save the rest for step 5), cover well and set aside (used in step 7)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel the onion<span class=\"text-danger\">(s)</span> and slice finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Remove</strong> the mint's leaves and chop coarsely, discarding the stems</p>\r\n<p><strong>Slice</strong> the olives thinly into 'O's'</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> a large wide-base pan on a medium-high heat</p>\r\n<p><strong>Once</strong> the pan is hot, add the almonds and dry toast for 3 min</p>\r\n<p><strong>Remove</strong> the almonds for step 6 and reserve the pan for the next step</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the almond pan to a medium-high heat and add 1/2-1 tbsp of vegetable oil </p>\r\n<p><strong>Add</strong> the tumeric, cumin, and lamb mince and cook for 2-3 min or until browned, breaking it up with a spoon</p>\r\n<p><strong>Add</strong> the onion and garlic and cook for a further 2-3 min or until translucent</p>\r\n<p><strong>Add</strong> the garlic and cook for 1 min</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the sliced olives and the remaining stock</p>\r\n<p><strong>Reduce</strong> the heat and simmer for 4-6 min or until the lamb is cooked through and the sauce has reduced, stirring occasionally</p>\r\n<p>Tip: The sauce is ready when a trail is left by a wooden spoon at the bottom of the pan</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, crush the almonds coarsley with a pestle and mortar or chop with a knife</p>\r\n<p>Tip: Check the lamb and if the water has evaporated too quickly or the lamb is too dry, gradually add a few tbsp of water</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the yoghurt and mint </p>\r\n<p><strong>Season</strong> the mint yoghurt to your taste with salt and pepper</p>\r\n<p><strong>Fluff</strong> the couscous with a fork</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Arrange</strong> the lamb and couscous on plates</p>\r\n<p><strong>Drizzle</strong> the couscous with the mint yoghurt</p>\r\n<p><strong>Sprinkle</strong> the almonds on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
