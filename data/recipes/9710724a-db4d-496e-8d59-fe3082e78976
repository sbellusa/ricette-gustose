          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the bulgur wheat to the reserved chicken pan with 180ml <span class=\"text-danger\">(360ml)</span>&nbsp;boiled water, cover with a lid and place on a medium-low heat</p>\r\n<p><strong>Simmer</strong> for 5 min or until almost all the water is absorbed</p>\r\n<p><strong>Remove</strong> from the heat and leave covered for 10 min or until all water has absorbed &nbsp; &nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-7-x1000.jpg",
