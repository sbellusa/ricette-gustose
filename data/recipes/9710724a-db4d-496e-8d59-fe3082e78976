          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Tip</strong> the dressed tomatoes over the chicken, pushing them down well with a spoon so that everything is well mixed together</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-4-x200.jpg",
