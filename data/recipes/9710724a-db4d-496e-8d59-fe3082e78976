            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>De-link</strong> the chorizo and slice each one in half lengthways</p>\r\n<p><strong>Peel</strong> and cut the onion<span class=\"text-danger\">(s)</span> into 8 wedges through the root</p>\r\n<p>Tip: This ensures that the onion layers stay together whilst cooking</p>\r\n<p><strong>Lay</strong> the salami and onion wedges over the chicken</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Tear</strong> the mozzarella over the top</p>\r\n<p><strong>Bake</strong> for 30-35min, or until the chicken is cooked through, the onions are charred around the edges and the cheese is bubbling and melted</p>\r\n<p><strong>Once</strong> the chicken has been cooking for 15 min, boil a kettle</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-6-x1000.jpg",
