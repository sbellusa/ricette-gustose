            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> golden, transfer the chicken, skin-side up, into an ovenproof dish</p>\r\n<p><strong>Discard</strong> the oil from the chicken pan but leave behind any bits at the bottom for step 7 (to lend extra flavour to the bulgur)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-2-x400.jpg",
