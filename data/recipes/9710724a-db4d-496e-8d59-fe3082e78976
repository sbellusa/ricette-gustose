          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the dish from the oven</p>\r\n<p><strong>Serve</strong> the chicken over the bulgur with a couple of spoonfuls of the sauce over the top</p>\r\n<p><strong>Season</strong> to your taste with salt and plenty of pepper and enjoy!</p>",
      "order": 8,
