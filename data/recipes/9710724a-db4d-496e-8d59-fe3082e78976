  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 200&deg;C (fan)/ 425F/ Gas 7</p>\r\n<p><strong>Lightly</strong> season the chicken with salt</p>\r\n<p><strong>Place</strong> a dry, wide-base pan (with a matching lid) over a medium-high heat and, once hot, add the chicken (skin-side down) and cook for 5 min or until golden and crispy, without turning</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/473.-step-1-x200.jpg",
            "width": 200
