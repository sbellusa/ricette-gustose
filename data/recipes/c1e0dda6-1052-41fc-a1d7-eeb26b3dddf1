  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Tip: This is just to warm your naans (alternatively, just pop them in the toaster)</p><p>Heat a pot with a matching lid with a knob of <strong>butter</strong> over a medium heat</p><p>Once melted, add the<strong> nigella seeds</strong> and <strong>basmati rice</strong> and cook for 1 min or until fragrant and lightly toasted</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1627379712957-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1627379712957-x400.jpg",
            "width": 400
