  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Finely dice your <strong>tomato[es]</strong></p><p>Peel and finely chop your <strong>shallot[s]</strong></p><p>Chop your <strong>coriander </strong>finely, including the stalks</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1657006086644-x200.jpg",
            "width": 200
