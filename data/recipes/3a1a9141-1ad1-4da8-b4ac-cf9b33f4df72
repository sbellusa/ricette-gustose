    },
    {
      "instruction": "<p>While the meat-free chick'n is cooking, cut your <strong>cucumber[s]</strong> in half lengthways and then slice finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1636107533618-x200.jpg",
