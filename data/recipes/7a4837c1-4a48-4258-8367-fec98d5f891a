  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the sweet potatoes in half lengthways and sit them skin-side up</p>\r\n<p><strong>Cut</strong> narrow slices into the skin (a little thicker than a pound coin), making sure not to cut all the way down to the base</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> the cumin with 2 tbsp <span class=\"text-danger\">[3 tbsp]</span>&nbsp;olive oil in the bottom of an oven-proof dish</p>\r\n<p><strong>Rub</strong> the potatoes into the cumin oil and season them lightly with salt and pepper</p>\r\n<p><strong>Put</strong> the dish in the oven and cook for an initial 35 min</p>\r\n<p><strong>Meanwhile</strong>, peel and finely chop (or grate) the garlic</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> (scrape the skin off with a teaspoon) and finely chop (or grate) the ginger</p>\r\n<p><strong>Cut</strong> the lemon<span class=\"text-danger\">[s]</span>&nbsp;in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> the harissa, garlic, ginger, juice of 1/2 <span class=\"text-danger\">[1]</span>&nbsp;lemon (reserve the rest for later) with 1/2 tbsp <span class=\"text-danger\">[1 tbsp]</span>&nbsp;olive oil in large mixing bowl</p>\r\n<p><strong>Season</strong> lightly with salt and pepper - this is your harissa marinade</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> your hand onto your large chicken breast</p>\r\n<p><strong>Slice</strong> in half as if you were cutting a burger bun, leaving you with two thinner pieces</p>\r\n<p><strong>Add</strong> the escalopes to the harissa, coat completely and leave to marinate for 15 min</p>\r\n<p><strong>Wait</strong> until the sweet potatoes have had their 35 min before moving on to the next step!</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>A</strong><strong>dd</strong> the chicken to the dish with the sweet potatoes</p>\r\n<p><strong>Pour</strong> the marinade over the chicken and run a fork across the potatoes to fan them out</p>\r\n<p><strong>Return</strong> to the oven for 10-15 min or until the chicken is cooked through</p>\r\n<p><strong>Meanwhile</strong>, boil half a kettle</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the couscous to a bowl with 200ml <span class=\"text-danger\">[400ml]</span>&nbsp;boiled water, cover and set aside for 10 min</p>\r\n<p><strong>Cut</strong> the remaining lemon into wedges</p>\r\n<p><strong>Slice</strong> the spring onion<span class=\"text-danger\">[s]</span>&nbsp;finely, discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Fluff</strong> the cooked couscous with a fork, drizzle with olive oil and season lightly with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/520.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the cooked chicken and potatoes over the couscous and pour any roasting juices over the top</p>\r\n<p><strong>Garnish </strong>with spring onion&nbsp;and the remaining lemon wedges&nbsp;</p>\r\n<p><strong>Enjoy!</strong></p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
