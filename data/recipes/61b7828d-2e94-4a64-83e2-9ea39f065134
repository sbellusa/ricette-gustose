  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a drizzle of <strong>vegetable oil </strong>over a medium-high heat</p><p>Once hot, add your <strong>smoked streaky bacon </strong>to the pan and cook for 2-3 min on each side or until golden and crisp</p><p>Once crisp, transfer the bacon to kitchen paper (reserve the pan)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1682613737487-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1682613737487-x400.jpg",
            "width": 400
