        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Finely slice <strong>half</strong> your<strong> red chilli[es]</strong> into rounds and set aside for garnish</p><p>Chop the <strong>remaining</strong> <strong>chilli</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1715598722702-x200.jpg",
