            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Strip the <strong>mint</strong> <strong>leaves</strong> from their stalks, discard of the stalks</p><p>Finely chop the <strong>mint</strong> <strong>leaves</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1602152575224-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1602152575224-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1602152575224-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1602152575224-x1000.jpg",
