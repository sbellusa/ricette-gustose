            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1602152557274-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the <strong>cucumber</strong><span class=\"text-danger\"> </span>in half lengthways</p><p>Scrape out the seeds with a teaspoon and discard</p><p>Dice the <strong>halved</strong> <strong>cucumber</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1602152570306-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1602152570306-x400.jpg",
            "width": 400
          },
          {
