  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Deseed the <strong>yellow</strong> <strong>pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Trim the green stalks off the <strong>aubergine<span class=\"text-danger\">[s]</span> </strong>and <strong>courgette<span class=\"text-danger\">[s]</span></strong> and chop them into bite-sized pieces</p>",
      "order": 1,
      "media": {
