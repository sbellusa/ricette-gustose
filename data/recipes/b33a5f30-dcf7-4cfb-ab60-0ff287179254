  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil half a kettle</p><p>Chop your <strong>dried ancho chilli[es] </strong>roughly and discard the stem[s]</p><p>Add your <strong>chopped ancho chilli</strong> to a bowl, cover with 100ml<span class=\"text-purple\"> [150ml]</span> <span class=\"text-danger\">[200ml]</span> <strong>boiled water </strong>and set aside to soak</p>",
      "order": 1,
      "media": {
