        ]
      }
    },
    {
      "instruction": "<p><strong>Soak</strong> the skewers in cold water until step 3 (this stops them burning whilst cooking)</p>\r\n<p><strong>Peel</strong> and cut the onion<span class=\"text-danger\">(s)</span> into&nbsp;chunky pieces</p>\r\n<p><strong>Trim</strong> the fat off the pork steaks and cut each steak into 4 pieces, lengthways</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/391.-step-2-x200.jpg",
