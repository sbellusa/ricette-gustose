          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the Thai green curry paste, fish sauce and juice of half the&nbsp;<span class=\"text-danger\">(whole)</span> lime</p>\r\n<p><strong>Add</strong> 1 tbsp <span class=\"text-danger\">(2 tbsp)</span>&nbsp;olive oil and season generously with salt and pepper</p>\r\n<p><strong>Add</strong> the pork strips to the Thai paste mixture and mix thoroughly</p>\r\n<p><strong>Thread</strong> two pieces of pork per skewer with a piece of onion on either side (see picture)</p>",
      "order": 3,
      "media": {
