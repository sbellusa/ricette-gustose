  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the rice, add it to a pot with plenty of cold water and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to low and cook for 15-20 min or until tender with a slight bite</p>\r\n<p><strong>Once</strong> cooked, drain and return to the pot and cover until serving&nbsp;</p>",
      "order": 1,
      "media": {
