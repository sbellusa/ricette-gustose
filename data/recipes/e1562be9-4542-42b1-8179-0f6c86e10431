            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>carrot & cabbage slaw mix</strong> to a large bowl with your <strong>mayo</strong> and a generous pinch of <strong>pepper</strong></p><p>Give everything a good mix up – this is your <strong>creamy slaw</strong></p>",
      "order": 5,
      "media": {
        "images": [
