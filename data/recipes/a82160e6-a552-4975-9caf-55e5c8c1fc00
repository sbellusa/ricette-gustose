  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Crush the<strong> cardamom pods</strong> open by squashing them with the side of a knife</p><p>Melt a knob of<strong> butter</strong> in a pot with a lid over a medium heat</p><p>Once melted, add the <strong>crushed cardamom pods </strong>and cook for 1 min or until fragrant</p>",
      "order": 1,
      "media": {
