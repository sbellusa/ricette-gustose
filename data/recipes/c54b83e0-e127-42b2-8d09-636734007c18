  "cooking_instructions": [
    {
      "instruction": "<p>Slice the <strong>chestnut mushrooms</strong></p>\n<p>Deseed the<strong> red pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p>\n<p>Peel and finely slice the<strong> red onion<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2256-Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2256-Step-1-x400.jpg",
            "width": 400
