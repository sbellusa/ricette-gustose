            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2256-Step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) the <strong>ginger</strong></p>\n<p>Trim, then slice the <strong>spring onions</strong> into large, bite-sized pieces</p>\n<p>Tip: Bunch them together for speed!</p>",
      "order": 2,
      "media": {
