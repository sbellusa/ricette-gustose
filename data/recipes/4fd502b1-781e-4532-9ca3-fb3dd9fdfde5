  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil half a kettle</p><p>Chop the <strong>chicken breast portions<span class=\"text-danger\"> </span></strong>into small, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1585746174054-x200.jpg",
            "width": 200
