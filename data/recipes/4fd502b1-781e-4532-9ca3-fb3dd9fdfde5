            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken is browned, add the <strong>chopped</strong> <strong>cherry tomatoes</strong> and<strong> harissa stock </strong>to the pan</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1585746201706-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1585746201706-x400.jpg",
