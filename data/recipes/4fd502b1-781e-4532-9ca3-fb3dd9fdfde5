            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>remaining chicken stock mix </strong>in 100ml <span class=\"text-danger\">[175ml]</span><strong> boiled water</strong></p><p>Stir in the <strong>tomato paste </strong>and <strong>harissa paste</strong> (can't handle the heat? Go easy!) – this is your <strong>harissa stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1585746196004-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1585746196004-x400.jpg",
