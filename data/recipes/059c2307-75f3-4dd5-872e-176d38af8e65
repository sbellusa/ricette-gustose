            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p><p>Slice the<strong> black olives </strong>finely</p><p>Grate the <strong>Italian hard cheese</strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416__.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416__.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416__.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416__.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416__.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add 500ml <span class=\"text-danger\">[1L]</span> <strong>boiled water</strong> to the softened onions and stir in the <strong>veg stock mix</strong></p><p>Increase the heat to high and bring to the boil</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the stock is boiling, reduce the heat to medium and add the<strong> linguine</strong> (you can break it in half if it doesn't fit)</p><p>Add the<strong> chopped tomatoes</strong>, <strong>chopped garlic</strong>, <strong>capers</strong>, <strong>sliced olives</strong> and<strong> chilli flakes</strong> (can't handle the heat? Go easy!)</p><p>Tip: Push the pasta into the liquid fully, so it cooks!</p>",
      "order": 4,
      "media": {
