  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice the<strong> red onion<span class=\"text-danger\">[s]</span></strong></p><p>Heat a large pot (big enough to fit all your ingredients inside and with a matching lid) with a drizzle of <strong>olive oil </strong>over a medium heat</p><p>Once hot, add the <strong>sliced red onion</strong>, 1 tsp <span class=\"text-danger\">[2 tsp]</span> of <strong>sugar </strong>and a pinch of <strong>salt</strong> and cook for 3-5 min or until softened but not coloured</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/416-1-x200.jpg",
            "width": 200
          },
          {
