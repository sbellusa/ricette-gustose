          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1600360685592-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>aubergine slices </strong>to a large baking tray with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong></p><p>Give it a good mix up then put the tray in the oven for 12-15 min or until the aubergine is soft and golden</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1600360692302-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1600360692302-x400.jpg",
