            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your<strong> green chilli[es]</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p><p>Roughly chop your <strong>coriander</strong>, including the stalks</p><p>Cut your <strong>paneer</strong> into bite-sized cubes</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1629109738612-x200.jpg",
