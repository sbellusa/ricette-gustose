  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and dice <strong>half </strong>the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Finely slice the<strong> remaining red onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Roll the <strong>lime<span class=\"text-danger\">[s]</span></strong> with your hand on a hard surface (to release more juice) and cut in half</p>",
      "order": 1,
      "media": {
        "images": [
