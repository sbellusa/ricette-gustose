  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>sweet potatoes</strong> (skins on) into wedges</p><p>Add the <strong>sweet potato wedges</strong> to a baking tray with a drizzle of<strong> vegetable oil</strong> and a pinch of <strong>salt</strong></p><p>Put the tray in the oven and cook for 20-25 min or until cooked through</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2325-Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2325-Step-1-x400.jpg",
            "width": 400
          },
          {
