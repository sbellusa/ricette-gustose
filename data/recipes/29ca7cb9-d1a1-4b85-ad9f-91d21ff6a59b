  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Deseed your<strong> pepper[s]</strong><span class=\"text-danger\"> </span>(scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Trim, then slice your <strong>spring onion[s]</strong></p><p>Chop your<strong> broccoli</strong> into small florets, discard the stem[s] and leaves</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1688483151917-x200.jpg",
