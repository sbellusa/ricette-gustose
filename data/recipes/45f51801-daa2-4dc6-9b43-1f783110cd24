  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil a full kettle</p><p>Peel and roughly chop the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Cut the <strong>carrot<span class=\"text-danger\">[s]</span></strong> (no need to peel) and <strong>green beans</strong> roughly</p><p>Peel and finely chop the <strong>garlic</strong> and <strong>ginger</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1629302996729-x200.jpg",
            "width": 200
