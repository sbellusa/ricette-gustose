          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1642089864416-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1642089864416-x1000.jpg",
