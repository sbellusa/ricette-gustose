            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> chicken escalopes</strong> to the the bowl of cheesy breadcrumb mix<strong> </strong>and press them into the mix until nicely coated</p><p>Add the <strong>coated chicken </strong>to the other side of the baking tray with the potatoes</p><p>Tip: Cooking for 4? Use 2 trays!</p><p>Put the tray<span class=\"text-danger\">[s]</span> in the oven for 20 min further or until the chicken is cooked through (no pink meat!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1642089874686-x200.jpg",
