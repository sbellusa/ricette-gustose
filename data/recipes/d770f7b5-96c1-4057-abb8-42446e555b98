  "cooking_instructions": [
    {
      "instruction": "<p>Peel and chop your <strong>red onion[s] </strong>into thick slices</p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into strips</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1673366922532-x200.jpg",
