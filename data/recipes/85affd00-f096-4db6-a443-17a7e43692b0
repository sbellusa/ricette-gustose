            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1711640061243-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1711640061243-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>sliced</strong> <strong>shallot</strong> to a bowl with your <strong>cider</strong> <strong>vinegar</strong> and a pinch of <strong>salt</strong> and <strong>sugar</strong> and set aside to pickle – this is your <strong>quick-pickled shallot</strong></p>",
      "order": 3,
      "media": {
        "images": [
