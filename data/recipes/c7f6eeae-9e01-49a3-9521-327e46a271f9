            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1584988252049-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium-high heat</p><p>Once hot, add the <strong>sliced halloumi</strong> and cook for 2-3 min on each side until golden and crisp</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1584988255966-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1584988255966-x400.jpg",
            "width": 400
