          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> 1 tbsp<span class=\"text-danger\"> (2 tbsp)</span> sugar with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> boiled water and stir to fully dissolve</p>\r\n<p><strong>Add</strong> the tamarind paste and mix well until smooth - this is your glaze</p>\r\n<p><strong>Place</strong> the coconut cream sachet<span class=\"text-danger\">(s)</span> in a mug and cover with boiled water until fully submerged (this softens the naturally hard cream)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step2-x700.jpg",
            "width": 700
          },
          {
