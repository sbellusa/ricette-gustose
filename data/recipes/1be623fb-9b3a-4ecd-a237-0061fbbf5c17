            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large pot (with a matching lid) with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil over a medium heat</p>\r\n<p><strong>Once</strong>&nbsp;hot, add the spring onion and half the coriander</p>\r\n<p><strong>Cook</strong> for 1 min, then add 800ml <span class=\"text-danger\">(1.6L)</span> salted boiled water and the noodles</p>\r\n<p><strong>Cover</strong> and cook for 6 min or until the noodles are tender with a slight bite</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.-step-3-x200.jpg",
