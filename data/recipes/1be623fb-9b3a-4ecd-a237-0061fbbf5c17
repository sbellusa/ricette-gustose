  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Preheat</strong> the oven to 200&deg;C/ 190&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Chop</strong> the spring onion<span class=\"text-danger\">(s)</span> finely, discarding the root ends</p>\r\n<p><strong>Chop</strong> the coriander finely (stalks too)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/495.step1-x400.jpg",
