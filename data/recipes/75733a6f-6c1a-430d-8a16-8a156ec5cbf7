  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722950674705-x200.jpg",
            "width": 200
