        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>pulled chicken</strong> and <strong>homemade pesto </strong>in a bowl with a grind of<strong> black pepper</strong> and give everything a good mix up – this is your <strong>pesto chicken</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1650979226404-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1650979226404-x400.jpg",
