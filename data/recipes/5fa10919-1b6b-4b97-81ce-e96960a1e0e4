            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, combine your <strong>mayo</strong> with the juice of your <strong>lime[s] </strong>in a small bowl<strong> </strong>– this is your <strong>lime mayo</strong></p><p>Cut the <strong>remaining lime </strong>into wedges</p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-2-1679389595794-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-2-1679389595794-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-2-1679389595794-x700.jpg",
