          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1627991858370-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1627991858370-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then finely slice your<strong> spring onion[s]</strong> on the diagonal</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1627991869817-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1627991869817-x400.jpg",
