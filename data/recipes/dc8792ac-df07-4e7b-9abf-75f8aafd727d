  "cooking_instructions": [
    {
      "instruction": "<p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into large bite-sized pieces</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1713535033892-x200.jpg",
