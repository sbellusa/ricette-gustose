            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, drain and rinse the <strong>cannellini beans</strong></p><p>Dissolve the <strong>vegetable stock mix</strong> in 150ml <span class=\"text-danger\">[250ml]</span><strong> boiled water</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2010.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2010.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2010.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2010.-step-6-x1000.jpg",
