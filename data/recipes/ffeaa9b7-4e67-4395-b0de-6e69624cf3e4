          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-3-1715249253177-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>parsley </strong>roughly, including the stalks</p><p>Chop your <strong>capers</strong> roughly</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-3-1715249256321-x200.jpg",
            "width": 200
          },
          {
