  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Drain</strong> the beetroot and cut into wedges</p>\r\n<p><strong>Remove</strong> the halloumi from its package and press it firmly between kitchen roll or a tea towel to remove the liquid</p>\r\n<p><strong>Slice</strong> the halloumi into thick sticks</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the beetroot on a large, non-stick oven tray (or use foil to avoid mess)</p>\r\n<p><strong>Drizzle</strong>&nbsp;with 1/2 tbsp <span class=\"text-danger\">(1 tbsp)</span> olive oil and season generously with salt and pepper</p>\r\n<p><strong>Push</strong> to one side of the tray and set aside until step 5</p>\r\n<p><strong>Preheat</strong> the grill to medium-high</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the giant couscous to a pot with 500ml <span class=\"text-danger\">(800ml)</span>&nbsp;boiling water and return to the boil over a high heat</p>\r\n<p><strong>Boil</strong> for 5-7 min or until tender but with a slight bite</p>\r\n<p><strong>Drain</strong> and rinse briefly under cool water (to remove the excess starch which can make it stick together)</p>\r\n<p><strong>Set</strong> aside until step 7</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-3-x700.jpg",
