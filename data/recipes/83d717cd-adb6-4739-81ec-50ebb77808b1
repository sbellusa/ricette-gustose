          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, bash (in a bag with a rolling pin) or chop the almonds coarsely</p>\r\n<p><strong>Peel</strong>,&nbsp;halve and slice the shallots finely</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/484.-step-4-x1000.jpg",
