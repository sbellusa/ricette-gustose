  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 395&deg;F/ Gas 6</p>\r\n<p>Boil a full kettle</p>\r\n<p><span class=\"text-highlight\">Cut the <strong>leek<span class=\"text-danger\">[s]</span></strong> in half lengthways and wash carefully to remove any grit from between the leaves</span></p>\r\n<p><span class=\"text-highlight\">Slice the <strong>leek<span class=\"text-danger\">[s]</span></strong> finely, discarding the tough tops, outer leaves and root end<span class=\"text-danger\">[s]</span></span></p>\r\n<p>Peel and slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a medium-sized pot over a low heat with a drizzle of <strong>olive oil</strong></p>\r\n<p>Once hot, add the <strong>sliced leek</strong>&nbsp;and <strong>onion</strong> with a pinch of <strong>salt</strong> and cook for 8-10 min or until softened&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548._step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548._step-2-x400.jpg",
            "width": 400
