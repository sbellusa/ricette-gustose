          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-6-x400.jpg",
