          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>leek</strong>&nbsp;and <strong>onion</strong> has softened, add the <strong>chopped garlic&nbsp;</strong>and cook for 1-2 min or until fragrant</p>\r\n<p>Once fragrant, add the <strong>vegetable stock</strong> and cook for 5 min</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1548.-step-5.emergency-x200.jpg",
            "width": 200
