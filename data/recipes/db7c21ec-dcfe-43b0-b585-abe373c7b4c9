          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the spring onion finely, discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Stir</strong> the spring onion into the cr&egrave;me fra&icirc;che&nbsp;</p>",
      "order": 5,
      "media": {
