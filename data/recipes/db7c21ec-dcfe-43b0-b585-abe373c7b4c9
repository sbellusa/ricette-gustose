  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Deseed</strong> the pepper<span class=\"text-danger\">[s]</span> (scrape the seeds out with a teaspoon) and cut into thin strips</p>\r\n<p><strong>Cut</strong> the broccoli into small florets</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan with a matching lid (preferably non-stick) over a high heat with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the peppers and broccoli with a pinch of sugar, salt and pepper</p>\r\n<p><strong>Cover</strong> and cook for approx 4-6 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, dissolve the stock cube<span class=\"text-danger\">[s]</span> in&nbsp;3 tbsp <span class=\"text-danger\">[6 tbsp]</span> of hot water to make a concentrated stock</p>\r\n<p><strong>Add</strong> the concentrated stock to the pan with the vegetables with a knob of butter&nbsp;</p>\r\n<p><strong>Reduce</strong>&nbsp;the heat to medium-low and cook, uncovered, for&nbsp;a further 3-4 min</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the gnocchi to a pot of salted boiling water over a high heat</p>\r\n<p><strong>Cook</strong>&nbsp;for 3-4 min&nbsp;</p>\r\n<p><strong>Once</strong> cooked, drain the gnocchi and return it to the pot&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/616.-step--4-x400.jpg",
            "width": 400
