  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your<strong> chicken </strong>out of the fridge, open the packet and let it air</p><p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>potatoes </strong>(skins on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
