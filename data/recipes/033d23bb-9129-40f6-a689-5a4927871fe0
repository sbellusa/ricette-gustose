            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>red onion[s]</strong> into wedges, leaving the skins on (this helps them cook quicker!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2327-Step-2-x200.jpg",
            "width": 200
