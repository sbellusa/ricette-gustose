  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Add your <strong>Cumberland sausages</strong> to a baking tray (use <strong>tin foil</strong> to avoid mess!)</p><p>Put the tray in the oven for 20-25 min or until the sausages are golden and cooked through</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1147.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1147.-step-1-x400.jpg",
            "width": 400
