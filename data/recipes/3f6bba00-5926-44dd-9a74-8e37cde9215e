            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut your <strong>cucumber</strong> in half lengthways</p><p>Scrape out the seeds with a teaspoon and discard</p><p>Dice the <strong>halved</strong> <strong>cucumber</strong></p>",
      "order": 5,
      "media": {
        "images": [
