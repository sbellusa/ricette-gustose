            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>natural yoghurt</strong> to a bowl with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Chop the <strong>toasted cashew nuts</strong> coarsely (careful they may be hot!)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1633341352578-x200.jpg",
            "width": 200
          },
          {
