  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Slice the <strong>ciabatta<span class=\"text-danger\">[s]</span> </strong>into 8 <span class=\"text-danger\">[16]</span> slices</p><p>Add the <strong>sliced ciabatta</strong> to a baking tray lined with<strong> tin foil </strong>with a drizzle of <strong>olive oil </strong>and a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Put the tray in the oven for 5-6 min or until lightly toasted</p>",
      "order": 1,
      "media": {
        "images": [
