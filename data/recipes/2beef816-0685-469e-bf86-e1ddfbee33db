        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop the <strong>crispy bacon </strong>roughly</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1712068221231-x200.jpg",
            "width": 200
