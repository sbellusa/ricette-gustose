  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Slice your <strong>potatoes</strong> (skins on) into thin discs</p><p>Add the<strong> sliced potatoes</strong> to a heatproof bowl, then cover the bowl with <strong>cling film</strong> and pierce a few holes in the top with a fork</p><p>Put the bowl in the <strong>microwave </strong>for 6-8 min or until the potatoes are fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1708528238398-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1708528238398-x400.jpg",
