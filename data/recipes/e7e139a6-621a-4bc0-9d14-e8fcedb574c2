            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pepper has softened, add the <strong>courgette ribbons </strong>and <strong>sliced</strong> <strong>garlic </strong>to the pan and cook for 1-2 min until fragrant, then remove from the heat</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1585752853110-x200.jpg",
