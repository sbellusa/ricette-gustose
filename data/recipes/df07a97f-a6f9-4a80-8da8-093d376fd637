          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1599559911615-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1599559911615-x1000.jpg",
            "width": 1000
