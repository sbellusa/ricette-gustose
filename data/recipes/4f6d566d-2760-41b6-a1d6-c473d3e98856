  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil a kettle</p><p>Peel and finely chop your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1634032664521-x200.jpg",
