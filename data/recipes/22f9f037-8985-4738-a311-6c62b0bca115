            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your<strong> tomato[es] </strong>finely</p><p>Trim, then slice your <strong>spring onion[s]</strong></p><p>Drain your <strong>sweetcorn</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1718632058974-x200.jpg",
            "width": 200
