            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1718632051163-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1718632051163-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, zest <strong>half </strong>your <strong>lime[s]</strong> (try to grate lightly with a micro-plane or sharp box grater and avoid grating the white pith, as this is very bitter)</p><p>Roll the<strong> lime[s] </strong>with your hand on a hard surface (to release more juice) and cut in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1718632054803-x200.jpg",
