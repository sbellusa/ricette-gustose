  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your<strong> chicken</strong> out of the fridge, open the packet and let it air</p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into chunks</p>",
      "order": 1,
      "media": {
        "images": [
