            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1688126486400-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of <strong>vegetable oil</strong> over a high heat</p><p>Once hot, add the <strong>coated</strong> <strong>tofu</strong> to the pan with a pinch of <strong>salt </strong>and cook for 10-15 min or until golden and crispy – this is your <strong>crispy tofu</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1688126489733-x200.jpg",
