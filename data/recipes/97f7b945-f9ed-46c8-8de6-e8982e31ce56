  "cooking_instructions": [
    {
      "instruction": "<p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Grate the<strong> tofu</strong></p><p>Combine your <strong>cornflour </strong>and <strong>grated tofu</strong> in a bowl</p><p>Give everything a good mix up – this is your <strong>coated</strong> <strong>tofu</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1688126486400-x200.jpg",
            "width": 200
          },
          {
