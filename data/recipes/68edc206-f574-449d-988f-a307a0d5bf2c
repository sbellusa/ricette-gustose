  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Break your <strong>meat-free sausages</strong> into rough pieces</p><p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of <strong>olive oil </strong>over a medium-high heat</p>",
      "order": 1,
      "media": {
