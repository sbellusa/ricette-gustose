            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>creamed coconut </strong>roughly (if required!)</p><p>Add the<strong> chopped creamed coconut</strong> and 500ml<span class=\"text-danger\"> [1L]<strong> </span>boiled water</strong> to the dish<strong> </strong>and bring to the boil over a high heat</p><p>Once boiling, cover with a lid and put the dish in the oven for 20 min</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1597676318019-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1597676318019-x400.jpg",
