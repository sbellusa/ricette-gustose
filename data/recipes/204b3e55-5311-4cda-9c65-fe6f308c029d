          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1597676311078-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Rinse the<strong> brown rice </strong>under <strong>cold running water</strong></p><p>Add the<strong> rinsed brown rice</strong>, <strong>curry powder</strong>,<strong> ground turmeric </strong>and<strong> lime leaves </strong>to the dish</p><p>Add in the<strong> vegetable stock mix</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1597676314673-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1597676314673-x400.jpg",
