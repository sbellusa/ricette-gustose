          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain and pat the <strong>mozzarella</strong> dry with <strong>kitchen paper</strong> (squeeze as much liquid out as you can!)</p>\n<p>Tear the <strong>drained mozzarella</strong> into rough, bite-sized pieces</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-3-x700.jpg",
            "width": 700
