  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 390°F/ Gas 6</p>\n<p>Put a large baking tray (or two) in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p>\n<p>Add the <strong>tomato paste</strong> and <strong>dried oregano</strong> to a bowl with a generous pinch of <strong>salt</strong>, <strong>pepper</strong> and <strong>sugar</strong></p>\n<p>Add 5 tbsp <span class=\"text-danger\">[10 tbsp]</span><strong> cold water</strong> and give everything a good mix up – this is your <strong>tomato sauce</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim the ends from the <strong>Brussels sprouts</strong>, then finely slice</p>\n<p>Chop the <strong>smoked bacon</strong> into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-2-x1000.jpg",
