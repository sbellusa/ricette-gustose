          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2423Step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> pizza bases</strong> to a baking tray (or two)</p>\n<p>Divide the <strong>tomato sauce </strong>between the <strong>pizza bases </strong>and spread it evenly all over them with the back of a spoon</p>\n<p>Top with the<strong> torn mozzarella </strong>and dot the<strong> onion marmalade </strong>all over</p>",
      "order": 4,
      "media": {
