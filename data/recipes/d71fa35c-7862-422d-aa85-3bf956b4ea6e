            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>spring onions</strong> finely</p><p>Wash your<strong> lettuce</strong>, then pat it dry with kitchen paper and roughly shred</p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/944.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/944.-step-4-x400.jpg",
