            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken has browned, add the <strong>tinga paste</strong> and the<strong> sliced spring onion</strong> to the pan</p><p>Add 150ml <span class=\"text-purple\">[225ml] </span><span class=\"text-danger\">[300ml]</span> <strong>boiled water</strong> and season with a pinch of <strong>salt</strong></p><p>Cover with a lid and cook for 12-15 min or until the chicken is cooked through (no pink meat!)</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1623767915664-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1623767915664-x400.jpg",
