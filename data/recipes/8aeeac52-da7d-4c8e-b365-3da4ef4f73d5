  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Heat a large, wide-based pan (preferably non-stick)<strong> </strong>over a medium-high heat with a drizzle of <strong>olive oil</strong></p><p>Once hot, add the<strong> ginger & garlic paste </strong>and <strong>half </strong>the<strong> chilli flakes</strong> (can't handle the heat? Go easy!)<strong> </strong>and cook for 2 min until fragrant</p>",
      "order": 1,
      "media": {
        "images": [
