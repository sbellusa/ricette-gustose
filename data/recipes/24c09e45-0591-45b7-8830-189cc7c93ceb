  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>potatoes</strong> (skins on) into quarters</p><p>Add the <strong>chopped potatoes</strong> to a <strong>baking paper</strong>-lined baking tray with a drizzle of <strong>vegetable oil</strong> and a generous pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Give everything a good mix up and put the tray in the oven for an initial 10 min</p>",
      "order": 1,
      "media": {
        "images": [
