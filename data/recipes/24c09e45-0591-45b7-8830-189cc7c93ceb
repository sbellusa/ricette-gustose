          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>remaining lemon </strong>into wedges</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-copy-5-1688139509052-x200.jpg",
