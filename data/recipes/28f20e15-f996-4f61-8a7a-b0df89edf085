            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Divide the<strong> cheesy chicken mix</strong> between your <strong>tortillas</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724716450146-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724716450146-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1724716450146-x700.jpg",
            "width": 700
          },
