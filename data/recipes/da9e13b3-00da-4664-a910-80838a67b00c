            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1708093485226-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1708093485226-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1708093485226-x1000.jpg",
            "width": 1000
