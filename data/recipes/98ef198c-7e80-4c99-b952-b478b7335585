            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>creamy stock </strong>to the pan with your<strong> salmon flakes </strong>and a pinch of <strong>salt </strong>and cook for 2-3 min or until the sauce has slightly thickened</p>",
      "order": 6,
      "media": {
        "images": [
          {
