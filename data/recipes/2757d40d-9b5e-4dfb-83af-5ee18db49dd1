      }
    },
    {
      "instruction": "<p>Trim, then slice your<strong> spring onion[s]</strong></p><p>Top, tail (no need to peel) and grate your <strong>carrot[s]</strong></p><p>Cut your<strong> apple[s]</strong> (skin on) into matchsticks</p>",
      "order": 5,
      "media": {
        "images": [
