            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/197.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely chop the onion<span class=\"text-danger\">(s)</span>, carrot<span class=\"text-danger\">(s)</span> and garlic</p>",
      "order": 3,
      "media": {
