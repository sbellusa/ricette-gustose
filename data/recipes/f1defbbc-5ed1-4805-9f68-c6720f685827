      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the pie filling to an oven-proof dish (or individual ones)</p>\r\n<p><strong>Top</strong> with mash and grate over the Cheddar cheese</p>\r\n<p><strong>Cook</strong> in the oven for 20 min or until piping hot through and golden brown on top</p>",
      "order": 6,
      "media": {
