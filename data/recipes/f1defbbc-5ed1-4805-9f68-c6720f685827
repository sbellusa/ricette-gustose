  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle and preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Peel</strong> and cut the potatoes into approx. 4cm chunks, add to a pot of salted, boiling water and cook for approx. 15 min or until you can pierce them easily with a fork</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/197.-step-1-x200.jpg",
            "width": 200
