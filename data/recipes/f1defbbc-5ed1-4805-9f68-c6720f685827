            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/197.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/197.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are cooked, mash with a splash of milk and a knob of butter, season generously with salt and pepper and set aside with the lid on</p>\r\n<p><strong>Meanwhile</strong>, dissolve the stock cube<span class=\"text-danger\">(s)</span> in 250ml <span class=\"text-danger\">(500ml)</span> boiled water&nbsp;</p>\r\n<p><strong>Add</strong> the stock and allspice to the mince to soak</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/197.-step-2-x200.jpg",
            "width": 200
