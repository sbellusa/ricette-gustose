            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken is cooked, add the <strong>chopped ginger</strong>, <strong>garlic</strong> and<strong> basil stalks</strong> to the pan with your <strong>chilli flakes</strong> (can't handle the heat? Go easy!) and cook for 1 min until fragrant</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1585745865763-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1585745865763-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1585745865763-x700.jpg",
            "width": 700
          },
