            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add 1 tbsp<span class=\"text-purple\"> [1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp]</span> <strong>flour </strong>to a bowl</p><p>Add your <strong>diced</strong> <strong>chicken thigh </strong>to the bowl and coat evenly in the flour</p><p>Tap off any excess</p><p>Tip: The chicken should just have a light flour coating!</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1585745852708-x200.jpg",
