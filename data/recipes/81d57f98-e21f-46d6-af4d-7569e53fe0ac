  "cooking_instructions": [
    {
      "instruction": "<p><strong>Before you begin...</strong></p>\n<p>Get all your ingredients and equipment ready</p>\n<p>Skim through these steps</p>\n<p>Wash your fruit and veg</p>\n<p>Note: equipment and pan sizes vary. Ensure you cook food thoroughly (even if it takes you a little longer than 10 mins)</p>",
      "order": 1,
      "media": {
