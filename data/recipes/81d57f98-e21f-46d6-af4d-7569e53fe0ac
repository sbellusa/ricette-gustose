            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the<strong> lemon</strong> into 2 <span class=\"text-danger\">[4]</span> wedges</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1604.-step-5.n-x200.jpg",
            "width": 200
