  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and cut the <strong>onion<span class=\"text-danger\">[s]</span></strong> in half</p><p>Push the <strong>cloves</strong> into 1 <span class=\"text-danger\">[2]</span> <strong>onion half<span class=\"text-danger\">[ves] </span></strong>–<strong><span class=\"text-danger\"> </span></strong>this is your <strong>studded onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
