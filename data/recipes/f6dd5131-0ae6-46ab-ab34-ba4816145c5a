            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add <strong>half</strong> of the <strong>sliced spring onion</strong> (save the rest for garnish!) to the pan with your <strong>sugar snap peas</strong> and <strong>ginger paste</strong> and cook for 2 min further or until the lean beef mince has started to brown</p>",
      "order": 5,
      "media": {
        "images": [
