            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the noodles are soaking, slice your <strong>red chilli[es] </strong>finely</p><p>Tip: Not a fan of spice? Remove the seeds!</p><p>Trim, then slice your <strong>spring onion[s]</strong> roughly</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1614009325916-x200.jpg",
