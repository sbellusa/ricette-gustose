  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Add the <strong>curry powder</strong> to a plate with a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Add the<strong> chicken thighs</strong> to the <strong>curry powder </strong>and turn them several times until they're fully coated in the curry powder – these are your<strong> curried chicken thighs</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-2-1657623481868-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-2-1657623481868-x400.jpg",
            "width": 400
