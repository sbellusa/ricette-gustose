          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1718618802393-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>cherry tomatoes</strong> in half</p><p>Add them to one side of a <strong>tin foil</strong>-lined baking tray (or two!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1718618808797-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1718618808797-x400.jpg",
