            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the onion softens, chop the <strong>green beans</strong> in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1629197775631-x200.jpg",
            "width": 200
