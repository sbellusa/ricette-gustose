            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reheat the<strong> enchilada topping</strong> over a high heat for 2-3 min or until the sauce has thickened to a double cream consistency</p><p>Meanwhile, tear your <strong>cheese flavour slices</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1682597565073-x200.jpg",
            "width": 200
