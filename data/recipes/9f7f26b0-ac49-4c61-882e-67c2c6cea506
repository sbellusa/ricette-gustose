            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1682597565073-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1682597565073-x700.jpg",
