          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1682597548155-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium heat with a small drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the <strong>sliced onion</strong> and<strong> chopped garlic </strong>and cook for 4-5 min or until softened</p><p>Boil a kettle</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1682597552372-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1682597552372-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1682597552372-x700.jpg",
