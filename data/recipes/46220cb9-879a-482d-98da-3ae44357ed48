          }
        ]
      }
    },
    {
      "instruction": "<p>Top the <strong>spiced lamb sausage rolls</strong> with the <strong>cumin seeds</strong></p><p>Put the tray in the oven for 15-20 min or until the lamb is cooked through and the pastry is puffed up and golden</p>",
      "order": 5,
