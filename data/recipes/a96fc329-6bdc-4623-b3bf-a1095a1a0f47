            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, grate your <strong>cheddar cheese</strong></p><p>Slice your <strong>ciabatta[s] </strong>in half</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1684507389308-x200.jpg",
