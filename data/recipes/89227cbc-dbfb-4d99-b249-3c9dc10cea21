  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a full kettle and chop your <strong>potatoes</strong> (skins on) into large bite-sized pieces</p><p>Add the<strong> chopped potatoes</strong> to a pot with plenty of <strong>boiled water</strong> and a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Cook for 12-15 min or until fork-tender, then drain and return to the pot to steam dry</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1632822570211-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1632822570211-x400.jpg",
