          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/261.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and rinse the cannellini and kidney beans under the tap</p>\r\n<p><strong>Add</strong> them to the pan and cook for 2 min, or until the liquid has evaporated</p>\r\n<p><strong>Add</strong> 250ml (500ml) of water and cook for 5 min, or until half of the liquid has evaporated</p>",
      "order": 4,
      "media": {
