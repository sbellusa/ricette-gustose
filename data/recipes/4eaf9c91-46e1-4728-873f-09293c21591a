          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/983.-step4-new-x1500.png",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and chop your <strong>shallot[s]<span class=\"text-danger\"> </span></strong>as finely as you can</p>",
      "order": 5,
      "media": {
        "images": [
