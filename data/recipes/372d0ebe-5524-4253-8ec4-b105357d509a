  "cooking_instructions": [
    {
      "instruction": "<p>Add your <strong>white long grain rice</strong> to a pot with a lid with 225ml<span class=\"text-purple\"> [300ml] </span><span class=\"text-danger\">[450ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 12-15 min or until the rice is cooked, then remove from the heat and set aside (lid on) to steam until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1676978838153-x200.jpg",
