  "cooking_instructions": [
    {
      "instruction": "<p><span class=\"text-highlight\">Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</span></p>\n<p><span class=\"text-highlight\">Boil a full kettle</span></p>\n<p><span class=\"text-highlight\">Peel and roughly chop the<strong> potatoes</strong> and<strong> carrots </strong>then add them to a pot of <strong>boiled water</strong> with a pinch of <strong>salt </strong>and bring to the boil over a high heat and cook for 12-15 min or until fork-tender</span></p>\n<p><span class=\"text-highlight\">Once cooked, drain and return to the pot, cover with a lid and set aside to steam dry</span></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Re-boil half a kettle</span></p>\n<p><span class=\"text-highlight\">Add the <strong>green beans</strong> to a pot with a pinch of <strong>salt</strong> and cover them with <strong>boiled</strong> <strong>water</strong> until fully submerged</span></p>\n<p><span class=\"text-highlight\">Bring to the boil over a high heat and cook for 3-4 min or until tender</span></p>\n<p><span class=\"text-highlight\">Once done, drain and rinse the <strong>green beans</strong> under <strong>cold water</strong> until cooled </span></p>\n<p><span class=\"text-highlight\">Return to the pot and set aside for later</span></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Once the green beans are cooled, add the<strong> shredded </strong><strong>h</strong><strong>am hock</strong> to a baking tray and put the tray in the oven for 6-8 min or until beginning to lightly crisp</span></p>\n<p><span class=\"text-highlight\">Tip: Add a couple of splashes of cold water to the tray to stop the<strong> </strong>from drying out!</span></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Return the<strong> drained potato</strong> and <strong>carrot </strong>to a low heat with a splash of <strong>milk</strong>, a large knob of <strong>butter</strong> and a generous pinch of <strong>salt </strong>and <strong>pepper</strong></span></p>\n<p><span class=\"text-highlight\">Mash until smooth – this is your <strong>carrot &amp; potato mash</strong></span></p>\n<p> </p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Return the <strong>cooled beans</strong> to a medium heat with a large knob of <strong>butter</strong></span></p>\n<p><span class=\"text-highlight\">Once melted, add the <strong>roasted garlic paste</strong> and cook for 30 sec or until fragrant</span></p>\n<p><span class=\"text-highlight\">Add the <strong>baby leaf spinach </strong>and a pinch of <strong>salt </strong>and<strong> pepper </strong>and cook for 2-3 min or until the spinach has wilted and the beans are warmed through – these are your <strong>garlicky greens</strong></span></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC1008Step-5pg-x200.jpg",
