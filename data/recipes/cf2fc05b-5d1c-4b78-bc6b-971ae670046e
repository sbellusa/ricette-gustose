        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Add the <strong>crème fraîche</strong> and <strong>wholegrain mustard</strong> to a small pot and stir it all together </span></p>",
      "order": 6,
      "media": {
