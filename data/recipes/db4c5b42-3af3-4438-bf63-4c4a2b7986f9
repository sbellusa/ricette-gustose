            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the pan to a medium heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the<strong> burger patty[ies]</strong> to the pan and cook for 4-5 min on each side or until cooked through and charred (no pink meat!)</p><p>Tip: Push the patties down with a spatula so they cook evenly</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1676.-step-5-x200.jpg",
