  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 4)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop coarsely</p>\r\n<p><strong>Chop</strong> the basil finely</p>\r\n<p><strong>Cut</strong> away the stem<span class=\"text-danger\">(s)</span> of the chilli<span class=\"text-danger\">(es)</span> and deseed</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the tomatoes, garlic, chilli (careful, adjust the amount to your preferred hotness), 100g <span class=\"text-danger\">(all)</span> of the feta and 1-2 tbsp of olive oil with a (stick) blender for a smooth sauce</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>\r\n<p>Tip: Add a few tbsp of olive oil or water if you don't have enough volume to blend</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the pasta in a pot of boiling water and salt (optional) for 8-10 min or until the pasta is cooked to your taste, stirring occasionally, then drain</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> a small pan on a medium heat</p>\r\n<p><strong>Once</strong> the pan is hot, add the pine nuts and toast for 3 min or until golden brown </p>\r\n<p><strong>Set</strong> aside (used in step 8)</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the artichokes and cut into quarters</p>\r\n<p><strong>Slice</strong> the olives into thin 'O's</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> a large pan on a medium heat and add the sauce</p>\r\n<p><strong>Heat</strong> the sauce for 2 min then add the oregano, basil and artichoke </p>\r\n<p><strong>Add</strong> the pasta and mix well</p>\r\n<p><strong>Remove</strong> the pan from the heat and set aside for 1 min</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> up the pasta</p>\r\n<p><strong>Sprinkle</strong> the pine nuts and olives on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
