            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and chop your<strong> brown onion[s] </strong>into wedges</p><p>Chop your <strong>tomato[es]</strong> into wedges</p><p>Add the <strong>wedged tomato[es]</strong> and <strong>onion </strong>to the dish with a pinch of <strong>salt</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1605095734261-x200.jpg",
