  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Add each <strong>sweetcorn cobette</strong> to a piece of <strong>tin foil </strong>with a small knob of <strong>butter</strong> and wrap up tightly until fully sealed</p><p>Put the<strong> sweetcorn cobettes </strong>in the oven for 25 min or until tender and cooked through</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1625647034838-x200.jpg",
            "width": 200
          },
          {
