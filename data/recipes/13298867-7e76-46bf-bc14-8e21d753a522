  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Rinse your <strong>brown rice</strong>, add it to a pot with plenty of <strong>cold water </strong>and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 15-20 min or until it's tender with a slight bite</p><p>Once cooked, drain, return it to the pot and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1700644955793-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1700644955793-x400.jpg",
