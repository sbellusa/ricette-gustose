  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Peel</strong> and chop the garlic coarsely</p>\r\n<p><strong>Remove</strong> the stem<span class=\"text-danger\">(s)</span> from the chilli<span class=\"text-danger\">(es)</span>, deseed and slice into half-moons</p>\r\n<p><strong>Add</strong> the garlic and chilli (careful, adjust the amount to your preferred hotness) to a large bowl</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Seperate</strong> the florets of broccoli from the stalk<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Cut</strong> the florets and stalk<span class=\"text-danger\">(s)</span> into bite size pieces</p>\r\n<p><strong>Add</strong> to the bowl of garlic and chilli</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 2 tbsp <span class=\"text-danger\">(3 tbsp)</span> of vegetable oil to the bowl </p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>\r\n<p><strong>Mix</strong> well and transfer the broccoli mixture to a large baking tray</p>\r\n<p><strong>Roast</strong> in the oven for 20 min, or until the edges are brown and crispy, then remove to cool until step 8</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, boil a kettle (used in step 5)</p>\r\n<p><strong>Chop</strong> the peanuts coarsely</p>\r\n<p>Tip: You can crush the peanuts in their bag using a rolling pin!</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the noodles in a large pot of boiling water and salt (optional) for 4-7 min or until the noodles are tender, loosening with a fork</p>\r\n<p><strong>Drain</strong> and rinse thoroughly under cold water</p>\r\n<p><strong>Return</strong> the drained noodles to their cooking pot until step 8</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> a small pot on a medium heat</p>\r\n<p><strong>Once</strong> the pot is hot, add the sesame seeds and peanuts and toast for 2 min or until lightly browned</p>\r\n<p><strong>Tip</strong> out the seeds and nuts and set aside to cool</p>\r\n<p><strong>Wipe</strong> down the pot for the next step</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the tahini, honey, rice vinegar, and sesame oil in the pot </p>\r\n<p><strong>Whisk</strong> to form a thick dressing, then warm over a low heat</p>\r\n<p><strong>Add</strong> 100ml <span class=\"text-danger\">(135ml)</span> of boiled water to the pot and whisk to combine</p>\r\n<p><strong>Once</strong> it reaches the thickness of double cream, remove from the heat</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the dressing and soy sauce to the noodles and coat well</p>\r\n<p><strong>Plate</strong> the noodles and top with the roasted broccoli, garlic and chilli as desired</p>\r\n<p><strong>Sprinkle</strong> on the peanuts and sesame seeds</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
