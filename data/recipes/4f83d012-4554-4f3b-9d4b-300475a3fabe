            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599055014170-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, sprinkle each <strong>chicken breast</strong> with the <strong>dried oregano</strong> and a pinch of <strong>salt</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1599555646605-x200.jpg",
