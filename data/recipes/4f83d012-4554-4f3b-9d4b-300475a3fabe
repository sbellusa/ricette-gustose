  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 425°F/ Gas 7</p><p>Cut the<strong> potatoes</strong> (skins on) into chips</p><p>Add the chips to a baking tray with a generous drizzle of<strong> vegetable oil</strong> and a pinch of<strong> salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599055014170-x200.jpg",
