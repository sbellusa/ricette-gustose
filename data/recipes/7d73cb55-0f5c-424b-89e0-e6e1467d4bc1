            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1634028567385-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> vegetable oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>meat-free chick'n </strong>with a pinch of <strong>salt</strong> and<strong> pepper</strong> and cook for 3-4 min on each side, or until warmed through</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1634028571344-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1634028571344-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1634028571344-x700.jpg",
