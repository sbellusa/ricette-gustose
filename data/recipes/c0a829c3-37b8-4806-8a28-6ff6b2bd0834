    {
      "instruction": "<p>Peel and finely slice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Strip the <strong>mint leaves</strong> from their stems and chop them roughly, discard the stems</p><p>Chop the <strong>coriander</strong> finely, including the stalks</p><p>Cut the <strong>halloumi</strong> into thick slices</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/25_step-3-x200.jpg",
