            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the creamy cauliflower pasta is baking, chop the<strong> chives</strong> finely </p>\n<p>Use the rest of this time to clear up, set the table, have a cup of tea or simply chill!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2186.-step-7-x200.jpg",
