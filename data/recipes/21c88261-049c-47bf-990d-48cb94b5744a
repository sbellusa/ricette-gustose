        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> meaty pizza[s]</strong> with the <strong>chicken dippers</strong>,<strong> wedges </strong>and <strong>garlic & herb dip</strong> to the side</p><p>Enjoy!</p>",
      "order": 8,
