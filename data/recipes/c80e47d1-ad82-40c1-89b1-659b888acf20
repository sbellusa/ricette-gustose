            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>fragrant sauce </strong>to the pan and cook for 30 secs</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1705677393409-x200.jpg",
            "width": 200
