            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add your<strong> lean</strong> <strong>pork mince</strong> (remove the paper if required!) and<strong> chopped green beans</strong> to the pan and cook for 3-4 min, breaking the mince up with a wooden spoon as you go</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1705677378822-x200.jpg",
            "width": 200
