  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the lentils in a sieve under cold running water, then add them to a pot with plenty of cold&nbsp;water and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, add the bay leaf<span class=\"text-danger\">(ves)</span>, reduce to a medium heat and cook for 20-30 min or until tender</p>",
      "order": 1,
      "media": {
