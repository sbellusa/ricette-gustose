          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/76.-step7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/76.-step7-x1000.jpg",
