            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/76.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Grate</strong> the beetroot and parmesan</p>\r\n<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 800ml <span class=\"text-danger\">(1.6L)</span> of boiled water</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/76.-step-2-x200.jpg",
            "width": 200
