  "cooking_instructions": [
    {
      "instruction": "<p><strong>Chop</strong> the walnuts coarsely</p>\r\n<p><strong>Cut</strong> the leeks in half lengthways, discard the root ends and wash between the leaves</p>\r\n<p><strong>Cut</strong> into 1cm slices</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/76.-step-1-x200.jpg",
            "width": 200
