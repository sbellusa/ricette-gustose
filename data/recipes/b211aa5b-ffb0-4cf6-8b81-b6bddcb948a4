            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the pork is cooking, trim, then slice your <strong>spring onion[s]</strong></p><p>Grate your <strong>cheddar cheese </strong>finely</p><p>Drain your <strong>sweetcorn</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1669727808319-x200.jpg",
