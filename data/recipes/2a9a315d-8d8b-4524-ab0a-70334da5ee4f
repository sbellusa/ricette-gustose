  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel, then chop your <strong>potatoes </strong>into small bite-sized pieces</p><p>Add the <strong>chopped potatoes </strong>to a large heat-proof bowl covered with<strong> cling film</strong></p><p>Put the bowl in the <strong>microwave</strong> for 6-8 min or until slightly tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1716201313074-x200.jpg",
