  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel your <strong>red onion[s]</strong> and slice<strong> half </strong>very finely</p><p>Finely dice (or grate) the<strong> remaining red onion</strong></p><p>Chop <strong>half</strong> the <strong>parsley</strong> finely, including the stalks (you'll use the rest later!)</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1621257968276-x200.jpg",
            "width": 200
          },
