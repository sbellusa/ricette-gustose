            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pork mince has browned, add the <strong>sliced pepper</strong> with a pinch of <strong>salt</strong> to the pan and cook for 2-3 min or until the pepper has started to soften</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1646765430583-x200.jpg",
