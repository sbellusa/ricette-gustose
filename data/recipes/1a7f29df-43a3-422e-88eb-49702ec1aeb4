            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1757.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Top, tail, peel and finely dice the <strong>carrot<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1757.-step-2-x200.jpg",
            "width": 200
          },
