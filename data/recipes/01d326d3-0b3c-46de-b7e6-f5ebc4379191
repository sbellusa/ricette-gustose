  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice the <strong>chestnut mushrooms</strong> finely and strip the <strong>thyme leaves</strong> from their stems</p><p>Add the<strong> sliced mushrooms </strong>to a <strong>tin foil</strong>-lined baking tray with the <strong>thyme leaves</strong>, a drizzle of <strong>olive</strong> <strong>oil</strong> and pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 15-20 min or until the mushrooms are crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1648553931587-x200.jpg",
            "width": 200
