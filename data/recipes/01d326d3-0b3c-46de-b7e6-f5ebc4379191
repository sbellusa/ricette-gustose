            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>leek<span class=\"text-danger\">[s]</span> </strong>in half lengthways, wash thoroughly to remove any grit then top, tail and slice finely</p><p>Top, tail, peel and finely dice the <strong>carrot<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1648553933765-x200.jpg",
