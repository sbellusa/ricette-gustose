          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1723544726415-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst everything is cooking, pick your<strong> coriander leaves</strong> from their stalks</p><p>Chop your <strong>coriander stalks</strong> finely</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-kha-soup-1637665057748-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-kha-soup-1637665057748-x400.jpg",
            "width": 400
