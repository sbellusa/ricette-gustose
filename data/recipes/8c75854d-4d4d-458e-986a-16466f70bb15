  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Bash your<strong> lemongrass</strong> with a<strong> rolling pin</strong>, remove the <strong>tough outer layer[s]</strong> and set aside for later, then chop the <strong>softer inner core[s]</strong> finely</p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your <strong>ginger</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1---Kha-soup-1637665013649-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1---Kha-soup-1637665013649-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1---Kha-soup-1637665013649-x700.jpg",
            "width": 700
