  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Add the <strong>waxy potatoes</strong> to a heatproof bowl, then cover the bowl with <strong>cling film</strong> and pierce a few holes in the top with a fork</p><p>Put the bowl in the <strong>microwave </strong>for 5-6 min <span class=\"text-danger\">[7-9 min]</span> or until the potatoes are fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1673977565672-x200.jpg",
            "width": 200
