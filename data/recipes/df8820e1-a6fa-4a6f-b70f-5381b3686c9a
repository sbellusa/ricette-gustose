            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the basa is cooking, wash your<strong> lettuce</strong>, then pat it dry with kitchen<strong> </strong>paper and shred</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1596551888865-x200.jpg",
