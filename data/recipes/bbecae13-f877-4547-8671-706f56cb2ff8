            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add the <strong>green beans</strong> to a pot of <strong>boiling water</strong> with a generous pinch of <strong>salt</strong> and cook for 3-4 min or until tender with a bite</p>\n<p>Cut the <strong>remaining lemon</strong> into wedges </p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-7-x400.jpg",
