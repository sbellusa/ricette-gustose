            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cut the <strong>lemon<span class=\"text-danger\">[s]</span></strong> in half </p>\n<p>Combine the <strong>juice</strong> of <strong>1/2</strong><span class=\"text-danger\"> [1]</span> <strong>lemon</strong> with the <strong>mayonnaise</strong> in a small bowl with a pinch of <strong>salt</strong> – this is your <strong>lemon mayo</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-4-x400.jpg",
            "width": 400
