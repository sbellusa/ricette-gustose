            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p>\n<p>Once hot, add the <strong>smoked basa fillets</strong> and cook for 3-4 min on each side or until the fish is cooked through</p>\n<p>Tip: your fish is cooked when it turns opaque and flakes easily</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1726.-step-3-x400.jpg",
