            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and slice (don't chop!) your <strong>garlic</strong></p><p>Chop your <strong>basil</strong> finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
