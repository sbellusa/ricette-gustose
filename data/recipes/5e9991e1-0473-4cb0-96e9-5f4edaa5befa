            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Chop your<strong> free range chicken breast portion[s]</strong> into bite-sized pieces</p>",
      "order": 3,
      "media": {
