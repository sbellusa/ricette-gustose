  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat</p><p>Once hot, add the <strong>flaked almonds</strong> and cook for 2-3 min or until toasted and lightly golden</p><p>Tip: Watch them like a hawk to make sure they don’t burn!</p><p>Once golden, set aside and reserve the pan</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1679396337260-x200.jpg",
