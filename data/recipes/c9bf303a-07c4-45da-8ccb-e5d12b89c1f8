          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1255.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the beef mince is cooking, boil half a kettle</p><p>Grate your <strong>cheddar cheese</strong></p><p>Add your <strong>natural yoghurt</strong> to a bowl with your <strong>chipotle paste</strong> (can't handle the heat? Go easy!) and give it a good mix up – this is your <strong>chipotle yoghurt</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1255.-step-4-x200.jpg",
            "width": 200
