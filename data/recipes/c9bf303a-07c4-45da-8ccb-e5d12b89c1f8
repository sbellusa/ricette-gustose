  "cooking_instructions": [
    {
      "instruction": "<p>Add your <strong>white long grain rice</strong> to a pot with a lid with 175ml [230ml] <span class=\"text-danger\">[350ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 12-15 min or until all the water has absorbed and the rice is cooked</p><p>Once done, remove from the heat and set aside (lid on) to steam until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1255.-step-1-x200.jpg",
            "width": 200
