            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once browned, turn down to medium-high heat, then add the <strong>sliced onion </strong>with<strong> </strong>a splash of <strong>boiled water</strong> to the pan and cook, covered, for an initial 6 min or until the kofte are golden brown and cooked through (no pink meat!)</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-28-1712749523519-x200.jpg",
