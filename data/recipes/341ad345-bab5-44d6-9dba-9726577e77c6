  "cooking_instructions": [
    {
      "instruction": "<p><span class=\"text-highlight\">Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6 and boil a kettle, then peel and slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong> </span></p>\n<p><span class=\"text-highlight\">Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium heat</span></p>\n<p><span class=\"text-highlight\">Once hot, add the <strong>sliced onion</strong> with a pinch of <strong>salt</strong> and cook for 6-7 min or until softened</span></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2060.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2060.-step-1-x400.jpg",
