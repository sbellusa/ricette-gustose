          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2060.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">While the onion is cooking, cut</span> the <strong>chicken breast<span class=\"text-danger\">[s]</span></strong> into large, bite-sized pieces</p>\n<p>Strip the <strong>thyme leaves</strong> and chop finely, discarding the stems </p>\n<p>Dissolve 1/2 <span class=\"text-danger\">[1]</span> <strong>Knorr</strong> <strong>chicken stock cube</strong> in 150ml <span class=\"text-danger\">[250ml]</span> <strong>boiled water</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2060.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2060.-step-2-x400.jpg",
            "width": 400
          },
          {
