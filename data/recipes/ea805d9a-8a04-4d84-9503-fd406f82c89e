            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the vegetables have had an initial 25-30 min, remove the tray from the oven and add your <strong>meat-free bacon lardons</strong> and the <strong>sliced spring greens </strong>and<strong> </strong>stir it all together</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1689588925672-x200.jpg",
