            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>spring greens</strong> then pat dry with kitchen paper</p><p>Rip the leaves off the <strong>spring greens</strong>, discard the tough stalks, then layer the leaves over each other, roll them up and slice into thin strips</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1689588897075-x200.jpg",
            "width": 200
