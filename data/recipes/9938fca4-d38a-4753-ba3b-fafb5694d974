  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and finely slice <strong>half</strong> your <strong>red onion[s]</strong></p><p>Dice your <strong>remaining onion</strong> finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
