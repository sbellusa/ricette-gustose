    },
    {
      "instruction": "<p>While the orzo is cooking, chop the <strong>parsley</strong> finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2208.-step-4-x200.jpg",
