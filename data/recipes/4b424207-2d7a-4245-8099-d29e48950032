            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>flat white mushrooms </strong>into bite-sized chunks</p><p>Add the <strong>chopped</strong> <strong>mushrooms</strong> and <strong>butternut squash cubes</strong> to the dish and season generously with<strong> salt </strong>and<strong> pepper</strong></p><p>Cook for 2-3 min or until very lightly browned</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1632393631044-x200.jpg",
