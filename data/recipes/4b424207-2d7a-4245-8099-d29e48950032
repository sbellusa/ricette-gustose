          }
        ]
      }
    },
    {
      "instruction": "<p>Use this time to clear up, set the table, have a cup of tea or simply chill!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1632393645760-x200.jpg",
