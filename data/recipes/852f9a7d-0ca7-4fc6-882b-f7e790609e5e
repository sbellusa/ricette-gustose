      }
    },
    {
      "instruction": "<p>While the smoky beans are cooking, add your<strong> tortillas</strong> to a plate</p><p>Put the plate in the <strong>microwave</strong> and cook for 20 secs on high or until warmed through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Plain-tortillas-on-a-plate-1714123119766-x200.jpg",
