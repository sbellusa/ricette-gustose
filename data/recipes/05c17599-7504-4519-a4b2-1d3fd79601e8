  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Add your <strong>wholewheat noodles</strong> to a large bowl, cover them with <strong>boiled water</strong> and stir for 10 secs to separate the noodles</p><p>Set aside to soak for 4 min</p><p>Drain the <strong>soaked noodles </strong>and set aside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1685525305250-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1685525305250-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1685525305250-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1685525305250-x1000.jpg",
            "width": 1000
          },
          {
