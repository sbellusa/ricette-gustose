            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1685525315808-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the pork is cooking, wash your<strong> lettuce</strong>, then pat it dry with kitchen paper and shred finely</p><p>Top, tail and finely slice your <strong>radishes</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1685525319342-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1685525319342-x400.jpg",
