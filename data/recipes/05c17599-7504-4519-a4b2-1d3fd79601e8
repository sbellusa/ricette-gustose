            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Roughly chop your <strong>roasted peanuts</strong></p><p>Pick your <strong>mint leaves</strong> from their stems and roughly chop, discarding the stems</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1685525322969-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1685525322969-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1685525322969-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1685525322969-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1685525322969-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>shredded lettuce</strong>,<strong> sliced radishes</strong>, <strong>chopped peanuts</strong>,<strong> chopped mint</strong>, <strong>drained noodles</strong> and<strong> lean pork mince</strong>, including any <strong>pan juices</strong>, to a large bowl and give everything a good mix up</p><p>Season generously with <strong>salt</strong> and <strong>pepper</strong> – this is your <strong>larb salad</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1685525325697-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1685525325697-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1685525325697-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1685525325697-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1685525325697-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>larb</strong> <strong>salad</strong> and garnish with a<strong> lime wedge</strong></p><p>Enjoy!</p>",
