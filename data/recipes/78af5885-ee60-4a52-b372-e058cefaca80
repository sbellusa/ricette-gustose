  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>shallot[s]</strong></p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your <strong>ginger</strong></p><p>Cut your <strong>cucumber</strong> in half lengthways, then into batons</p><p>Add the <strong>cucumber batons </strong>to a small bowl with your <strong>rice vinegar </strong>– this is your <strong>quick-pickled cucumber</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1582200203726-x200.jpg",
            "width": 200
