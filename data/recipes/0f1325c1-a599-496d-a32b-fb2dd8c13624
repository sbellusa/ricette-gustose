  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 190°C/ 170°C (fan)/ 375°F/ Gas 5</p><p>Peel and finely slice <strong>1/2</strong> <span class=\"text-danger\">[1]</span> <strong>brown onion</strong></p><p>Grate the <strong>remaining onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1614004043952-x200.jpg",
            "width": 200
          },
          {
