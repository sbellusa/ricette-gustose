          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1689940725790-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>fish pie loaded jacket potatoes </strong>with the <strong>buttery leeks & peas</strong> to the side</p><p>Enjoy!</p>",
