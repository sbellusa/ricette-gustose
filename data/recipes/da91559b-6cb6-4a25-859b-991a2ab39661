  "cooking_instructions": [
    {
      "instruction": "<p>Trim the green stalk[s] off your <strong>aubergine[s]</strong> and discard, then chop into small bite-sized cubes</p><p>Heat a pot (with a matching lid) with a generous drizzle of <strong>vegetable oil </strong>over a medium-high heat</p><p>Add the <strong>chopped aubergine </strong>and cook for 5-6 min or until lightly browned</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1707822772561-x200.jpg",
            "width": 200
