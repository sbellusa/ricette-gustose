  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a full kettle</p><p>Peel your <strong>potatoes</strong>, then slice into thick discs</p><p>Add the <strong>sliced potatoes</strong> and <strong>bay leaf[ves] </strong>to a pot with plenty of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 12-15 min or until very tender</p>",
      "order": 1,
      "media": {
        "images": [
