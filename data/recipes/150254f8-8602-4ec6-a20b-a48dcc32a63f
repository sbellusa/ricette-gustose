      }
    },
    {
      "instruction": "<p>Trim, then slice the <strong>spring onion<span class=\"text-danger\">[s] </span></strong>finely</p><p>Cut 1/2 <span class=\"text-danger\">[1]</span> <strong>lime </strong>into wedges</p><p>Pick the <strong>coriander leaves</strong> from the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2251-Step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2251-Step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2251-Step-4-x700.jpg",
