          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2251-Step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chicken is cooking, peel and slice the <strong>red onion<span class=\"text-danger\">[s] </span></strong>(as finely as you can!)</p><p>Slice the <strong>red chilli<span class=\"text-danger\">[es]</span></strong> finely</p><p>Tip: Deseed them if you can't handle the heat!</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2251-Step-3-x200.jpg",
            "width": 200
          },
          {
