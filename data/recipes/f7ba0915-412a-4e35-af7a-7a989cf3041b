            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>chips</strong> are almost cooked, pat the <strong>basa fillets</strong> dry with kitchen paper</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add a handful of <strong>flour</strong> to a plate with a generous pinch of <strong>salt</strong> and<strong> pepper</strong></p>\n<p>Crack the <strong>egg<span class=\"text-danger\">[s]</span></strong> into a shallow bowl and beat with a fork</p>\n<p>Add the <strong>panko breadcrumbs</strong> to another plate</p>\n<p>Coat the <strong>fish fillets</strong> in the <strong>flour</strong>, tap off the excess, then add them into the <strong>beaten egg </strong>and finally press them into the <strong>breadcrumbs</strong> firmly to evenly coat all over</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-4-x700.jpg",
