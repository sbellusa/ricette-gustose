  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Cut the <strong>potatoes</strong> (skins on) into chips </p>\n<p>Add the <strong>chips</strong> to a baking tray with a very generous drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt </strong>and<strong> pepper</strong> and give everything a good mix up</p>\n<p>Put the tray in the oven for 25-30 min or until golden and crisp</p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-1-x200.jpg",
            "width": 200
