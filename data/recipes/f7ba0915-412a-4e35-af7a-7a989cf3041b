            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p>\n<p>Combine the <strong>mayonnaise</strong> with the <strong>dried dill</strong>, the <span class=\"text-highlight\"><strong>juice</strong></span> of 1/2 <span class=\"text-danger\">[1]</span> <strong>lemon</strong> and a pinch of <strong>salt</strong> – this is your <strong>dill mayonnaise</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1793.-step-2-x200.jpg",
            "width": 200
