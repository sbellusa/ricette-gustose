            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Peel and finely chop your <strong>shallot[s]</strong></p><p>Trim, then chop your<strong> green beans</strong> into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-2-1717410128774-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-2-1717410128774-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-2-1717410128774-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-2-1717410128774-x1000.jpg",
