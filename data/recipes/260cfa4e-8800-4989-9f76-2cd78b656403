  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the rice and lentils and add them to a pot with plenty of cold water and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to medium and cook for 20-25 min or until tender with a slight bite</p>\r\n<p><strong>Once</strong> cooked, drain and return to the pot and cover until serving</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and slice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Add</strong> 1-2 tbsp vegetable oil and 1-2 tsp butter to a wide-based pan over a medium heat</p>\r\n<p><strong>Once</strong>&nbsp;melted, add the onion with a large pinch of salt and sugar</p>\r\n<p><strong>Cook</strong> on a medium-low heat for 20 min until softened and caramelised</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the cumin, cinnamon, 1 tsp <span class=\"text-danger\">(2 tsp)</span>&nbsp;salt and 2 tbsp <span class=\"text-danger\">(4 tbsp)</span>&nbsp;vegetable oil to make a marinade</p>\r\n<p><strong>Combine&nbsp;</strong>the chicken thighs and the marinade&nbsp;</p>\r\n<p><strong>Mix</strong> well, making sure the thighs are evenly coated all over&nbsp;</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat </strong>a wide-based pan (preferably non-stick)&nbsp;over a high heat</p>\r\n<p><strong>Once</strong> hot, add the chicken, skin-side down</p>\r\n<p><strong>Cook</strong> for 7 min on the skin side only, or until the skin of very crisp</p>\r\n<p>chicken over and cook for a further 4 min, or until cooked through</p>\r\n<p>Tip: Set the chicken over a wire rack to drain off excess oil</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the mint leaves finely, discarding the stalks&nbsp;</p>\r\n<p><strong>Mix </strong>the chopped mint through the yoghurt with a drizzle of olive oil and a pinch of salt and pepper</p>\r\n<p><strong>This</strong> is your minty yoghurt&nbsp;</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong>&nbsp;the courgette into a pile of ribbons with a vegetable peeler</p>\r\n<p><strong>Add </strong>the courgette ribbons to the onions<strong>&nbsp;</strong></p>\r\n<p><strong>Cook</strong> for 3 min, or until the courgette is cooked through and wilted</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the rice and lentils are tender, drain and add them to the onion pan</p>\r\n<p><strong>Taste</strong> for seasoning, adding more salt and pepper if needed - this is your mujaddara</p>\r\n<p><strong>Transfer </strong>the cooked chicken to a&nbsp;chopping board</p>\r\n<p><strong>Leave</strong> to cool for a few min, then slice finely</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the chicken over the mujaddara with a big dollop of minty yoghurt</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
