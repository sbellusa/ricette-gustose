  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and slice the<strong> red onion<span class=\"text-danger\">[s]</span></strong> finely</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium heat</p><p>Once hot, add the <strong>sliced onion </strong>with a pinch of <strong>salt </strong>and cook for 8-10 min or until softened and starting to caramelise</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1629301966574-x200.jpg",
            "width": 200
