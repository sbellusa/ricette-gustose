            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once starting to soften, add your <strong>ginger & garlic paste</strong>, <strong>curry powder </strong>and <strong>ground turmeric </strong>to the pan and cook for 1 min or until fragrant</p><p>Once fragrant, add the <strong>coconut stock </strong>and bring to the boil over a high heat</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1682419420259-x200.jpg",
