  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle and dissolve 1/2 <span class=\"text-danger\">(1)</span> stock cube in 275ml <span class=\"text-danger\">(550ml)</span> of boiling water in a pot</p>\r\n<p><strong>Add</strong> the bulgur and simmer for 5 min or until almost all the water is absorbed</p>\r\n<p><strong>Remove</strong> from the heat and allow to rest with the lid on for 10 min or until the rest of the water has been absorbed</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/272.-step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/272.-step1-x400.jpg",
            "width": 400
