            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/272.-step1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/272.-step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, put a pan with a matching lid on a medium-high heat</p>\r\n<p><strong>Rub</strong> 1-2 tbsp of olive oil on each steak and season generously with salt</p>\r\n<p><strong>Once</strong> the pan is hot, add the steaks and cook on each side for 4-5 min, or until cooked through</p>\r\n<p><strong>Remove</strong> and transfer to a plate, cover with a tea towel or foil to rest for 5 min</p>",
      "order": 2,
      "media": {
        "images": [
