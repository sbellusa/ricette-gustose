            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, combine your <strong>mayo</strong>, <strong>chopped garlic </strong>(not a big garlic fan? Try using less!),<strong> </strong>1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp]</span><strong> cold water </strong>and a pinch of <strong>salt</strong> in a small bowl – this is your <strong>aioli</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1707825313508-x200.jpg",
