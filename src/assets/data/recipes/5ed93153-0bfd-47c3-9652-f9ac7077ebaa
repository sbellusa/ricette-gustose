          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1647942036268-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your<strong> lettuce</strong>, then pat it dry with kitchen paper and remove 1 of the <strong>outer leaves </strong>per person, then chop the <strong>remaining lettuce</strong> into quarters</p><p>Slice your <strong>brioche bun[s]</strong> in half, then add to a baking tray, cut side up, and put the tray in the oven for 4-5 min or until warmed through</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1647942042360-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1647942042360-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1647942042360-x700.jpg",
