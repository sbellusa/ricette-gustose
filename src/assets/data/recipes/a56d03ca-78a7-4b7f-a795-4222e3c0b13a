          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-1-x1000.jpg",
