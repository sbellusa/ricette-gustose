  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ 350°F/ Gas 4</p>\n<p>Add the <strong>basmati rice, </strong>a pinch of <strong>salt </strong>and 300ml <span class=\"text-danger\">[600ml]</span> <strong>cold water</strong> to a pot with a lid and bring to the boil over a high heat</p>\n<p>Once boiling, reduce the heat to very low and cook, covered, for 10-15 min or until the water has absorbed and the rice is cooked</p>\n<p>Once cooked, remove from the heat and keep covered until serving</p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-1-x200.jpg",
            "width": 200
