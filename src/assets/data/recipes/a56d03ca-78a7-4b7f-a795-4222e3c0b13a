          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice the <strong>spring onion<span class=\"text-danger\">[s]</span></strong> finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-3-x200.jpg",
