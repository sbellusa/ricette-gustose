          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>Tenderstem broccoli</strong> to a baking tray with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong></p>\n<p>Give everything a good mix up and put the tray in the oven for 10-15 min or until crispy</p>",
      "order": 2,
      "media": {
