          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1441.-step-3-x700.jpg",
            "width": 700
