            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Increase the heat to high and add the<strong> smoky chicken</strong> with <strong>half </strong>the <strong>chopped parsley </strong>to the pan (save the rest for garnish!)</p><p>Cook for a further 4-5 min or until the chicken is beginning to brown</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1599838994807-x200.jpg",
