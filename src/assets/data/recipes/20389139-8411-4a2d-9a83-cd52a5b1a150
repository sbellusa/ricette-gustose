  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Peel your <strong>potato[es]</strong> and chop into very small pieces</p><p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1627993711730-x200.jpg",
