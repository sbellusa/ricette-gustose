            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the potatoes are fork-tender, add your <strong>mint leaves</strong> and <strong>blanched peas</strong> to the pot and cook for 2-3 min further</p>",
      "order": 6,
      "media": {
        "images": [
