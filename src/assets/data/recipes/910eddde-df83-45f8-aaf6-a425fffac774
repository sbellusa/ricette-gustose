          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1712074968687-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail and chop your <strong>radishes</strong> into quarters</p><p>Wash your <strong>lettuce</strong>, then pat it dry with kitchen paper and roughly shred</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1712074972660-x200.jpg",
            "width": 200
          },
          {
