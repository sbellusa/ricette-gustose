  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air, then boil half a kettle</p><p>Combine the <strong>creamed coconut</strong> and <strong>half</strong> the <strong>turmeric</strong> in a medium bowl with 50ml<span class=\"text-danger\"> [80ml]</span> <strong>boiled water </strong>and<strong> </strong>a generous pinch of <strong>salt</strong> and <strong>pepper</strong>, then stir until the coconut cream has fully dissolved – this is your <strong>coconut marinade</strong></p><p>Once dissolved, add the <strong>chicken thighs </strong>to the marinade and give everything a good mix up until fully coated</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1669137062352-x200.jpg",
