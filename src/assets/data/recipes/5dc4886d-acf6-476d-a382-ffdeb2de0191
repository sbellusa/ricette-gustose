            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the sausage meat has begun to brown, add your <strong>roasted</strong> <strong>garlic paste</strong> with your <strong>dried thyme</strong> and 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp]</span> <strong>flour</strong></p><p>Cook for 1 min or until fragrant</p>",
      "order": 5,
      "media": {
