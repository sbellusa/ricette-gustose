            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> vegetable oil</strong> over a high heat</p><p>Once hot, add your <strong>lean</strong> <strong>beef mince</strong> with a generous pinch of <strong>salt</strong> and cook for 3-4 min or until browned, breaking it up with a wooden spoon as you go</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1612882780684-x200.jpg",
            "width": 200
