  "cooking_instructions": [
    {
      "instruction": "<p>Add the<strong> basmati rice</strong> and 300ml <span class=\"text-danger\">[600ml]</span> <strong>water</strong> to a pot with a lid and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to low and cook, covered, for 12-15 min or until all the water has absorbed and the rice is cooked</p><p>Once cooked, remove from the heat and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/600.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/600.-step-1-x400.jpg",
            "width": 400
