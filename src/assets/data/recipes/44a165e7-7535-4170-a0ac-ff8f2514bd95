  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9</p><p>Boil a kettle</p><p>Peel and finely slice your <strong>red onion[s]</strong></p><p>Deseed your <strong>pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1940.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1940.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1940.-step-1-x700.jpg",
            "width": 700
          },
          {
