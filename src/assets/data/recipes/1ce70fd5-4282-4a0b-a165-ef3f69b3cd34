          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1715687139523-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped chicken </strong>to the pan and cook for 2 min</p><p>Tip: Add a drizzle more oil if the pan looks a little dry</p><p>Sprinkle your<strong> chicken stock mix</strong> into the pan and add your <strong>tomato paste</strong></p>",
      "order": 4,
      "media": {
        "images": [
