            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the butternut squash is in the microwave, peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1612277912705-x200.jpg",
