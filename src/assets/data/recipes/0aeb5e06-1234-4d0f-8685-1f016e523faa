            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium-high heat with any remaining oil</p><p>Once hot, add the <strong>sliced onion</strong> and <strong>carrot discs</strong> and cook for 4-5 min or until the onion has softened and is starting to brown</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-43-1717076509410-x200.jpg",
