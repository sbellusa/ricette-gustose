            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely slice your <strong>brown onion[s]</strong></p><p>Top, tail, peel and slice your <strong>carrot[s]</strong> into discs on the diagonal (peeling is optional)</p><p>Slice your<strong> red chilli[es] </strong>finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-42-1717076500862-x200.jpg",
