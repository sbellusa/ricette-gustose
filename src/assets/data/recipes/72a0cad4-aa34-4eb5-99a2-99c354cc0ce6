  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil half a kettle</p><p>Pat your <strong>pork belly </strong>dry with kitchen paper, then<strong> </strong>score the<strong> fatty side </strong>in a criss-cross pattern by drawing a sharp knife through the skin, deep enough to reach the meat below</p><p>Season with<strong> </strong>a generous pinch of<strong> salt</strong> and rub it deep into the criss-cross pattern</p>",
      "order": 1,
      "media": {
        "images": [
