  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> and chop the carrot<span class=\"text-danger\">[s]</span> into bite-size pieces, discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Cut</strong> the broccoli into small florets and cut the stem<span class=\"text-danger\">[s]</span> into bite-size pieces</p>\r\n<p><strong>Slice</strong> the mushrooms finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide-based pan with a matching lid (preferably non-stick) over a medium-high heat with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span>&nbsp;vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the carrots and broccoli stems (leave the florets for later), cover and leave to cook for approx. 5-8 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the rice and 350ml <span class=\"text-danger\">[700ml]</span> water to a pot with a lid and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p><strong>Once</strong> cooked, remove from the heat and keep covered</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/618.-step--3-x200.jpg",
            "width": 200
