          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1657621781027-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dust your work surface with a generous sprinkling of <strong>flour</strong></p><p>Unwrap the <strong>puff pastry</strong> and roll it out to approx. 0.5cm thickness with a <strong>rolling pin </strong>and cut into 2 <span class=\"text-danger\">[4]</span> rectangles</p><p>Line a baking tray with <strong>non-stick baking paper</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1657621813164-x200.jpg",
            "width": 200
