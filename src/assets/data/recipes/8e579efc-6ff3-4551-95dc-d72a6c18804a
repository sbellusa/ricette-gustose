  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7 </p>\r\n<p><strong>Boil</strong> a kettle (used in step 3)<br /><br /><strong>Place</strong> the pork on an oven-proof tray and season with salt</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> in the oven for 15-20 min or until cooked through to your preference</p>\r\n<p><strong>Once</strong> done, remove from the oven and cover well to rest until serving</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the parsnips, remove and discard the root ends</p>\r\n<p><strong>Dice</strong> into 1cm cubes and transfer to a medium pot</p>\r\n<p><strong>Add</strong> just enough boiling water to cover the parsnip and return to a boil on a high heat with the lid on</p>\r\n<p><strong>Boil</strong> for 10-12 min, or until easily pierced with a fork</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, cut the leeks in half lengthwise and wash carefully to remove any grit from between the leaves, discarding the tough tops</p>\r\n<p><strong>Discard</strong> the root ends and slice into thin half-moons</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a small pot with a matching lid on a medium heat</p>\r\n<p><strong>Once</strong> hot, add the garlic and leek and cook for 1 min</p>\r\n<p><strong>Add</strong> 1/2 <span class=\"text-danger\">(1)</span> stock cube (reserve the rest for step 7) and 120ml <span class=\"text-danger\">(240ml)</span> of boiling water<br />Cover, lower to a simmer and cook for 4-6 min, or until the leeks are tender</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and rinse the beans</p>\r\n<p><strong>Add</strong> them to the parsnip pot and cook for 1 min, or until starting to break apart</p>\r\n<p><strong>Drain</strong> the parsnips and beans, reserving a little cooking water from the pot</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the parnsip and beans to the pot and place on the hob on a simmer</p>\r\n<p><strong>Add</strong> the cumin, a dash of milk, 15g <span class=\"text-danger\">(30g)</span> of butter, and the remaining 1/2 <span class=\"text-danger\">(1)</span> stock cube</p>\r\n<p><strong>Mash</strong> with a masher or fork until smooth</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the pork into 0.5cm thick medallions</p>\r\n<p><strong>Serve</strong> the mash and leeks with the pork medallions on top</p>\r\n<p><strong>Drizzle</strong> over any leftover meat juices from the tray </p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
