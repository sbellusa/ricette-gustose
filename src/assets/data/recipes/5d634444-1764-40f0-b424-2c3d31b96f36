  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Pat the <strong>pork belly </strong>dry with <strong>kitchen paper</strong></p><p>Score the fatty side of the <strong>pork belly</strong> in a criss-cross pattern by drawing a sharp knife through the skin</p><p>Season with a very generous pinch of<strong> salt</strong> and rub it deep into the criss-cross pattern</p>",
      "order": 1,
      "media": {
