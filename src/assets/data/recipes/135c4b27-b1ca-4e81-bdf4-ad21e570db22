  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Transfer your <strong>BBQ pulled pork </strong>to an <strong>oven-proof dish</strong>,<strong> </strong>draining away <strong>half </strong>of the juices</p><p>Sprinkle over your <strong>ground smoked paprika</strong>, <strong>dried oregano</strong>, <strong>ground coriander</strong>, <strong>cayenne pepper </strong>(can't handle the heat? Go easy!) and a pinch of <strong>salt</strong> and rub it into the pork, using the back of a spoon, then cover with <strong>tin foil</strong> and put the dish in the oven for an initial 30 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-2-1683104673745-x200.jpg",
            "width": 200
