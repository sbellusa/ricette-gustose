          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1695721348545-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>medium egg noodles</strong> to a pot and cover them with <strong>boiled water</strong> until they're fully submerged</p><p>Bring to the boil over a high heat and cook for 5-6 min or until cooked with a slight bite</p><p>Once done, drain the <strong>noodles</strong> and set aside</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1695721353781-x200.jpg",
