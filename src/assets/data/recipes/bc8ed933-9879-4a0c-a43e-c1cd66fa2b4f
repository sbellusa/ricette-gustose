            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>tomato[es]</strong><span class=\"text-danger\"> </span>into wedges</p><p>Combine your<strong> cider vinegar </strong>with 2 tbsp<span class=\"text-danger\"> <span class=\"text-purple\">[3 tbsp]</span> [4 tbsp]<strong> </span>olive oil </strong>and a pinch of <strong>salt </strong>in a small bowl – this is your<strong> dressing</strong></p><p>Slice your<strong> spring onion[s]</strong> finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-1626261726865-x200.jpg",
