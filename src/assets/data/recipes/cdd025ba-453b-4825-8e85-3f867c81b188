  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to <span class=\"text-highlight\">220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7&nbsp;</span></p>\r\n<p>Tip: this is to warm your tortillas later! Alternatively, you can just heat them in a microwave</p>\r\n<p>Boil a kettle (you'll only need 50ml <span class=\"text-danger\">[100ml]</span>!)</p>\r\n<p>Dice the <strong>tomato<span class=\"text-danger\">[es]</span></strong></p>\r\n<p>Add the <strong>diced tomato</strong> to a bowl with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt </strong>and set aside</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1385.-step-1-x200.jpg",
