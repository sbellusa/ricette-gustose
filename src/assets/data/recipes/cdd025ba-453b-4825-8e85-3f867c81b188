            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve <span class=\"text-highlight\">1/2&nbsp;<span class=\"text-danger\">[1]</span>&nbsp;</span><strong><span class=\"text-highlight\">beef</span> stock cube</strong>&nbsp;in 50ml <span class=\"text-danger\">[100ml]</span> <strong>boiled water</strong></p>",
      "order": 3,
