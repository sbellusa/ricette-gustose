            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p><p>Chop your <strong>creamed coconut</strong> roughly (if required!)</p><p>Slice your <strong>red chilli[es] </strong>finely</p><p>Rinse your<strong> red lentils </strong>under <strong>cold running water</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1684497857456-x200.jpg",
