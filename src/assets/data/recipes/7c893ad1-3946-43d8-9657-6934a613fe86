  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely dice your <strong>brown</strong> <strong>onion[s]</strong></p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a small drizzle of <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the <strong>diced onion</strong> with a pinch of <strong>salt </strong>and cook for 5-6 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
