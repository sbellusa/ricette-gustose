          }
        ]
      }
    },
    {
      "instruction": "<p>While the rice is cooking, cut the<strong> lemon<span class=\"text-danger\">[s]</span></strong> in half</p>\n<p>Grate the <strong>cheddar cheese</strong></p>\n<p>Pat the <strong>hake</strong> <strong>fillets</strong> dry with kitchen paper and season both sides with a pinch of <strong>salt</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2064.-step-5-x200.jpg",
            "width": 200
          },
          {
