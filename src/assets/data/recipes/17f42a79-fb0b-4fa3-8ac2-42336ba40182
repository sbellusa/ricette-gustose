  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop the <strong>potato<span class=\"text-danger\">[es]</span></strong> (skins on) into bite-sized pieces</p><p>Add the<strong> chopped potato </strong>to a heatproof bowl, then cover the bowl with <strong>cling film</strong> and pierce a few holes in the top with a fork</p><p>Put the bowl in the <strong>microwave</strong> for 3-4 min or until the potato is fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1678180636527-x200.jpg",
