            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop your<strong> brown onion[s]</strong></p><p>Heat a pot with a drizzle of<strong> vegetable oil</strong> and a knob of <strong>butter</strong> over a medium heat</p><p>Once hot, add the <strong>chopped onion</strong> with a pinch of <strong>salt</strong> and cook for 4-5 min or until softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1713277372994-x200.jpg",
