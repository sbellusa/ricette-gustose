          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1713277448915-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1713277448915-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Brazilian-style black beans</strong> over the<strong> brown rice</strong> and top with the<strong> zesty lime hake</strong></p><p>Garnish with your <strong>chopped</strong> <strong>coriander</strong> and <strong>lime wedge</strong></p><p>Enjoy!</p>",
      "order": 8,
