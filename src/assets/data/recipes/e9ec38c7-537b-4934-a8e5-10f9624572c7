  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>potatoes</strong> (skins on) into fries</p><p>Add the <strong>fries</strong> to a <strong>baking paper</strong>-lined baking tray with a drizzle of <strong>vegetable oil</strong></p><p>Give everything a good mix up and put the tray in the oven for an initial 25-30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1666964968031-x200.jpg",
