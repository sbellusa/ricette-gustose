            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice your <strong>brioche bun[s]</strong> in half</p><p>Return the reserved pan to a medium heat and add the <strong>brioche halves</strong>, cut-side down, and cook for 2-3 min or until toasted</p><p>Set aside until serving</p>",
      "order": 6,
      "media": {
        "images": [
