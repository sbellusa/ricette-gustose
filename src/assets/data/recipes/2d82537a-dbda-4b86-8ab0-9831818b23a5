            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped potatoes</strong> and <strong>peeled garlic</strong> to a pot with plenty of <strong>boiled water </strong>with a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Once boiling, cook for 12-15 min or until fork-tender</p>",
      "order": 2,
      "media": {
        "images": [
