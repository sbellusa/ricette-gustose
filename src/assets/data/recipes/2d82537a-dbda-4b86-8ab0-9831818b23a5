  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Cut your<strong> potatoes</strong> (skins on) into large, bite-sized pieces</p><p>Peel your <strong>garlic cloves</strong></p>",
      "order": 1,
      "media": {
        "images": [
