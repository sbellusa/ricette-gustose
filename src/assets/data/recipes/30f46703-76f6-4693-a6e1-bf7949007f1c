  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and grate <strong>half</strong> the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Finely dice the <strong>remaining onion</strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1691681113066-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1691681113066-x400.jpg",
            "width": 400
