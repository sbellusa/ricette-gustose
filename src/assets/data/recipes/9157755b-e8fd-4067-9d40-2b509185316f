  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 6, then take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Cut your <strong>red chilli[es]</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p><p>Roll your<strong> lemon[s] </strong>with your hand on a hard surface (to release more juice) and cut in half</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1713869513998-x200.jpg",
