            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a drizzle of <strong>vegetable oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>diced onion</strong> and <strong>diced</strong> <strong>pepper </strong>and cook for 3-4 min or until they've softened slightly</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1713869545877-x200.jpg",
