  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Wash</strong> and cut the white potatoes into 3cm cubes</p>\r\n<p><strong>Add</strong> them to a large pot with a matching lid on a high heat with enough (salted) boiled water to cover by 2 inches</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Bring</strong> the water to a boil on a high heat and boil the potatoes with a lid on for 8 min</p>\r\n<p><strong>Meanwhile</strong>, wash and cut the sweet potatoes into 3cm cubes</p>\r\n<p><strong>Set</strong> aside a mixing bowl large enough to fit both the white and sweet potatoes for step 4</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the sweet potatoes to the pot after 8 min and boil both uncovered for a further 5 min, to soften slightly</p>\r\n<p><strong>Meanwhile</strong>, crumble the blue cheese into a bowl with the vinegar and mash together into a rough paste</p>\r\n<p><strong>Mix</strong> in the mayonnaise, 1 tbsp<span class=\"text-danger\"> (2 tbsp)</span> of milk and pepper to taste</p>\r\n<p><strong>This</strong> is your blue cheese dressing</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the white and sweet potatoes in a sieve and rinse under cold water until cool enough to handle, then shake dry</p>\r\n<p><strong>Add</strong> both to the mixing bowl and coat them in the chipotle paste and then in 4 tbsp <span class=\"text-danger\">(8 tbsp)</span> of flour, before crushing them gently with a potato masher</p>\r\n<p><strong>Season</strong> with salt and pepper, shape into 4 <span class=\"text-danger\">(8)</span> patties &amp; dust in flour to seal</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large non-stick frying pan with 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> of vegetable oil on a high heat</p>\r\n<p><strong>When</strong> hot, add the cakes and cook on each side for 3 min until golden brown</p>\r\n<p>Tip: Press the cakes down slightly with a spatula (or similar) after turning to flatten them into an even shape&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> browned, transfer the cakes to a baking tray (use tin foil to avoid mess) and season with salt and pepper to your taste</p>\r\n<p><strong>Put</strong> it in the oven for 10-15 min, or until the cakes are crispy&nbsp;</p>\r\n<p><strong>Add</strong> the pecans to a separate baking dish and put them in the oven for 5 min, or until darkened slightly in colour&nbsp;</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, wash and shred the little gem lettuce<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Roughly</strong> chop the tomato<span class=\"text-danger\">(es)&nbsp;</span></p>\r\n<p><strong>Roughly</strong> chop (or bash up in a bowl with a rolling pin) the cooled pecans&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/426.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the crispy cakes over the lettuce and tomato with the blue cheese dressing drizzled over</p>\r\n<p><strong>Scatter</strong> with toasted pecans&nbsp;</p>\r\n<p>Enjoy!</p>",
      "order": 8,
