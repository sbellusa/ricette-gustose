          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>cherry</strong> <strong>tomatoes</strong> in half</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1684511515571-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1684511515571-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1684511515571-x700.jpg",
