            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1684511509989-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1684511509989-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve your <strong>vegetable stock mix</strong> in 350ml <span class=\"text-purple\">[455ml]</span> <span class=\"text-danger\">[650ml]</span> <strong>boiled water</strong></p>",
      "order": 2,
      "media": {
