  "cooking_instructions": [
    {
      "instruction": "<p><strong>Soak</strong> the skewers in cold water until step 2 (this prevents burning whilst cooking)<br /><br /><strong>Peel</strong> and very finely chop (or grate) the garlic</p>\r\n<p><strong>Add</strong> the garlic to a large mixing bowl with the turkey mince, breadcrumbs and ground cumin - season generously with salt and plenty of pepper</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> the mince well with clean hands</p>\r\n<p><strong>Divide</strong> the mixture into 4 <span class=\"text-danger\">(8)</span> equal portions and shape into hotdogs (using wet hands helps shape the mixture)</p>\r\n<p><strong>Carefully</strong> pierce the skewer through each hotdog, then squeeze the meat tightly around the skewers, so it covers 2/3rd of the skewer</p>\r\n<p><strong>These</strong> are your koftas for step 4</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a very large wide based pan (preferably non-stick) on a medium heat</p>\r\n<p><strong>Add</strong> the walnuts and toast for 5-6 min or until starting to turn a darker colour, then remove from the heat (set them aside until step 6) whilst reserving the pan for the next step</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle for step 5</p>\r\n<p><strong>Place</strong> the pan over a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil, and when hot, add the koftas </p>\r\n<p><strong>Cook</strong> on all sides (total time approx. 13-16 min), or until browned and cooked through</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the couscous and sultanas to a large bowl with 200ml <span class=\"text-danger\">(400ml)</span> of boiled water and cover</p>\r\n<p><strong>Set</strong> aside for 10 min then fluff with a fork</p>\r\n<p><strong>Once</strong> fluffed, add the juice of 1/2 <span class=\"text-danger\">(1)</span> lemon with the spring onion, 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of olive oil and salt and pepper to your taste</p>\r\n<p><strong>Set</strong> aside for step 8</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the carrots, discarding the root ends, and grate them into the couscous bowl</p>\r\n<p><strong>Chop</strong> the coriander finely (including the stalks), and add it to the bowl</p>\r\n<p><strong>Chop</strong> the toasted walnuts roughly, and add them to the bowl</p>\r\n<p><strong>Mix</strong> well with a fork and season with salt and pepper to your taste</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the tahini with 50ml <span class=\"text-danger\">(100ml)</span> of boiled water and mix until smooth</p>\r\n<p><strong>Add</strong> the remaining lemon juice, 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of olive oil and season with salt and pepper to your taste - this is your tahini dressing</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the koftas over the couscous with the tahini sauce drizzled over or to the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
