  "cooking_instructions": [
    {
      "instruction": "<p>Peel (scrape the skin off with a teaspoon) and roughly chop your <strong>ginger</strong></p><p>Peel and roughly chop your <strong>garlic</strong></p><p>Slice half your <strong>green chilli[es]</strong> into rounds and set aside for garnish</p><p>Chop the <strong>remaining green chilli</strong> roughly</p>",
      "order": 1,
