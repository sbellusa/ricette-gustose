            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>basa fillets</strong> into strips</p><p>Season the <strong>chopped basa</strong> with a generous pinch of <strong>salt</strong></p><p>Add the<strong> seasoned basa </strong>to a bowl with the<strong> Hariyali-style marinade</strong> and give everything a good mix up – this is your <strong>marinated</strong> <strong>basa</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1600417182899-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1600417182899-x400.jpg",
