            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>When the peppers are almost ready, remove the tray[s] with the cobettes from the oven and add your <strong>tortillas</strong></p><p>Return the tray[s] to the oven for 2-3 min or until the tortillas are warmed through (alternatively, add them to a plate and microwave for 20 secs on high!)</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-2-1688642933348-x200.jpg",
