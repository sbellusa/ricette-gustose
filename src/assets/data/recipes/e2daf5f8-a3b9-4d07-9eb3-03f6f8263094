            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a small drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the<strong> onion wedges </strong>to the pan and cook for 2-3 min or<strong> </strong>until slightly softened</p><p>Boil half a kettle</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-2-1688642920416-x200.jpg",
