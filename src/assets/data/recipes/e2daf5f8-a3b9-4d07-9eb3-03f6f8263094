            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once slightly softened, add the <strong>sliced peppers</strong> and <strong>chopped garlic</strong> to the pan with a generous pinch of <strong>salt</strong> and cook for a further 5-6 min or until beginning to soften</p><p>Once beginning to soften, add your <strong>ground coriander</strong>, <strong>ground smoked paprika</strong> and <strong>tomato paste</strong> and cook for 1 min or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-2-1688642924610-x200.jpg",
