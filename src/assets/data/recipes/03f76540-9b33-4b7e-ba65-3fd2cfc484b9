  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Cut</strong> the potatoes into bite-size pieces, keeping the skins on</p>\r\n<p><strong>Add</strong> them to a pot of salted boiled water over a high heat</p>\r\n<p><strong>Bring</strong> to the boil and cook for 10-15 min or until fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, pat the steaks dry with kitchen towel</p>\r\n<p><strong>Rub</strong> them with a little vegetable oil and season generously with salt</p>\r\n<p><strong>Heat</strong> a dry, wide-based pan (preferably non-stick) over a medium-high heat for 1 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the pan is very hot, add the steaks and cook for 1 min on each side</p>\r\n<p><strong>Transfer</strong> the cooked steaks to a plate, cover with a clean teatowel and leave to rest</p>\r\n<p><strong>Reserve</strong> the pan for the next step</p>\r\n<p><strong>Peel</strong> and slice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Cut</strong> the mushrooms into thick slices</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan to a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil and a knob of butter (optional)</p>\r\n<p><strong>Add</strong> the onion and mushrooms with a big pinch of salt (to draw out the moisture)</p>\r\n<p><strong>Cook</strong> for 8 min over a medium heat until both have softened and caramelised</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are cooked, drain and return them to the pot</p>\r\n<p><strong>Chop</strong> the parsley finely, including the stalks</p>\r\n<p><strong>Add</strong> the parsley to the drained potatoes with a splash of milk, a knob of butter and plenty of salt and pepper</p>\r\n<p><strong>Mash</strong> thoroughly, then set aside, covered, until serving</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the steak and pour any resting juices into the mushroom pan with the Henderson's relish</p>\r\n<p><strong>Add</strong> 1 tbsp <span class=\"text-danger\">(1.5 tbsp)</span> butter and 1 tbsp <span class=\"text-danger\">(1.5 tbsp)</span> flour to the mushrooms and stir to combine</p>\r\n<p><strong>Cook</strong> for a further 2 min, then add 200ml <span class=\"text-danger\">(400ml)</span> milk and stir again</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> until the sauce is creamy and thickened, then remove the pan from the heat</p>\r\n<p><strong>Add</strong> the steak and crumble in half <span class=\"text-danger\">(all)</span> the blue cheese</p>\r\n<p><strong>Taste</strong> for seasoning and add more salt and pepper if desired</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/504.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the cheesy steak and onions over the parsley mash</p>\r\n<p>Enjoy!</p>",
      "order": 8,
