            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has started to brown, drain, then add your <strong>king prawns</strong> and <strong>spice paste</strong> and cook for 2 min</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1527.-step-6-x200.jpg",
            "width": 200
