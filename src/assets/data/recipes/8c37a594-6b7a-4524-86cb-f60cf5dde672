            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1907.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your <strong>ginger</strong></p><p>Peel your <strong>shallot[s] </strong>and finely slice into rings</p><p>Top, tail, peel and grate your<strong> carrot[s]</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1907.-step-4.new-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1907.-step-4.new-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1907.-step-4.new-x700.jpg",
            "width": 700
