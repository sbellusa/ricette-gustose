  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Peel</strong> and chop the onion<span class=\"text-danger\">(s)</span> into quarters</p>\r\n<p><strong>Coat</strong> well with 1-2 tbsp of olive oil and salt to taste on an oven tray</p>\r\n<p><strong>Put</strong> in the oven for 20 min, or until starting to caramelise (used in step 3)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the fennel seeds, lamb mince, salt and pepper to your taste</p>\r\n<p><strong>Form</strong> 4 <span class=\"text-danger\">(8)</span> oblong koftas, similar to a sausage shape</p>\r\n<p><strong>Cook</strong> in a pan on a high heat for 2 min or until brown all over, then add to the onion tray and cook for 8 min or until cooked through</p>\r\n<p><strong>Set</strong> aside for step 7</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Reserve</strong> the lamb pan (used in step 5)</p>\r\n<p><strong>Meanwhile</strong>, add the couscous and sultanas to a bowl with 200ml <span class=\"text-danger\">(400ml)</span> of boiling water- cover well and set aside for 10 min (used in step 6)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the mint finely, including the soft stems (used in step 6)</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and mince very finely</p>\r\n<p><strong>Add</strong> the garlic to the yoghurt, season to your taste with salt and pepper and mix well</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Wipe</strong> off any leftover grease from the lamb pan</p>\r\n<p><strong>Add</strong> the pine nuts to the pan and cook for 2-3 min on a medium heat, or until lightly browned and aromatic</p>\r\n<p><strong>Bash</strong> the pine nuts in a pestle and mortar to form a crumb (alternatively, chop finely) and set aside (used in step 7)</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> apart the onion layers with your fingers (or a fork if too hot to handle) into petals</p>\r\n<p><strong>Add</strong> the onion petals, mint and 1-2 tsp of olive oil to the couscous bowl</p>\r\n<p><strong>Mix</strong> well and season to your taste with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and discard the fat from the koftas</p>\r\n<p><strong>Add</strong> the pomegranate molasses to a flat plate and gently roll the koftas in it</p>\r\n<p><strong>Coat</strong> the glazed koftas with the pine nuts</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> all the elements on the table and fill your bowl with these amazing flavours</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
