            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>remaining</strong> <strong>lime</strong> into wedges</p><p>Wash the<strong> lettuce</strong>, then pat it dry with kitchen paper<strong> </strong>and roughly shred</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/991.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/991.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/991.-step-4-x700.jpg",
