            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your<strong> pak choi </strong>in half lengthways</p><p>Top, tail and slice your<strong> carrots</strong> into strips</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1646746910252-x200.jpg",
            "width": 200
