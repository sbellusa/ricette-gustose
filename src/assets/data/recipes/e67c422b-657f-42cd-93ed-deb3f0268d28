  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Combine your <strong>soy sauce</strong>, <strong>five-spice mix</strong>, <strong>rice vinegar </strong>and 1 tbsp<span class=\"text-danger\"> <span class=\"text-purple\">[1 1/2 tbsp] </span>[2 tbsp]</span> <strong>vegetable oil</strong> in a medium bowl with a pinch of<strong> salt</strong> and <strong>pepper </strong>– this is your <strong>five-spice marinade</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1646746886069-x200.jpg",
            "width": 200
