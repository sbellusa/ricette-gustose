          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1653320247919-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and slice (don't chop!) the <strong>garlic</strong></p><p>Chop the <strong>parsley</strong> finely, including the stalks</p><p>Dissolve the <strong>chicken stock mix </strong>and <strong>tomato paste </strong>in 200ml <span class=\"text-danger\">[300ml] </span><strong>boiled water </strong>– this is your <strong>tomato stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1653320260039-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1653320260039-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1653320260039-x700.jpg",
