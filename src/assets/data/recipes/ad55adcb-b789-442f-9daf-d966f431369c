          }
        ]
      }
    },
    {
      "instruction": "<p>While the pork is browning, cut the <strong>potatoes</strong> (skins on) into small bite-sized cubes</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1661880920949-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1661880920949-x400.jpg",
