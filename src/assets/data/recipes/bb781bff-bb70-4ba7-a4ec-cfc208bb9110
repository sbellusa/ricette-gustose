    {
      "instruction": "<p>Dissolve your<strong> beef stock mix</strong> in 400ml <span class=\"text-purple\">[520ml]</span> <span class=\"text-danger\">[700ml]</span> <strong>boiled water</strong></p>",
      "order": 5,
      "media": {
        "images": [
