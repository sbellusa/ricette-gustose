    {
      "instruction": "<p><strong>Meanwhile</strong>, crack the egg<span class=\"text-danger\">(s)</span> onto a shallow bowl and beat well</p>\r\n<p><span class=\"text-highlight\"><strong>Add</strong> 3 tbsp <span class=\"text-danger\">(5 tbsp)</span> of plain four to another shallow bowl and season with salt and pepper</span></p>\r\n<p><span class=\"text-highlight\"><strong>Add</strong> the breadcrumbs to a third bowl</span></p>",
      "order": 2,
      "media": {
