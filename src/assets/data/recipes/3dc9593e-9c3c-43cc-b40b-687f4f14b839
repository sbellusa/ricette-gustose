            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your <strong>gochujang paste</strong> (can't handle the heat? Go easy!) and 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp]</span> <strong>cold water</strong> in a large bowl with a pinch of <strong>sugar </strong>– this is your <strong>gochujang dressing</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1653319777789-x200.jpg",
