            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a generous drizzle of<strong> olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>diced onion</strong> with a very generous pinch of <strong>salt</strong> and <strong>pepper</strong> and cook for 3-4 min or until starting to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1670343947398-x200.jpg",
            "width": 200
