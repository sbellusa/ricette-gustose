  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 400°F/ Gas 6</p>\n<p>Combine the <strong>ground cumin</strong>, <strong>ground coriander</strong>, <strong>smoked paprika</strong>, <strong>chilli flakes</strong> (can't handle the heat? Go easy!), 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>sugar</strong> and a pinch of <strong>salt</strong> on a plate</p>\n<p>Mix all the spices together – this is your <strong>fajita seasoning</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1115.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1115.-step-1-x400.jpg",
