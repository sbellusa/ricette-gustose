  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 350&deg;F/ Gas 4, for step 3</p>\r\n<p><strong>Cut</strong> the cucumber in half lengthwise, deseed and slice finely into half moon shapes</p>\r\n<p><strong>Place</strong> the cucumber in a strainer and sprinkle with 1 tsp <span class=\"text-danger\">(2 tsp)</span> of salt and mix well</p>\r\n<p><strong>Cut</strong> the lime<span class=\"text-danger\">(s)</span> into wedges</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the tofu in half lengthways and cut into 3cm cubes</p>\r\n<p><strong>Place</strong> on an oven-proof tray</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Coat</strong> the tofu with the soy sauce and 1-2 tbsp of vegetable oil, mix well and oven bake for 20-25 min, checking often</p>\r\n<p><strong>Once</strong> done, set aside until serving in step 8</p>\r\n<p><strong>Boil</strong> a kettle (used in step 5)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel the garlic and shallots and dice both very finely</p>\r\n<p><strong>Slice</strong> the spring onions thinly &amp; diagonally, discarding the root ends</p>\r\n<p><strong>Crush</strong> the peanuts coarsely for serving</p>\r\n<p><strong>Soak</strong> the rice noodles in plenty of cold water</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 500ml <span class=\"text-danger\">(1L)</span> of boiled water</p>\r\n<p><strong>Add</strong> the tamarind paste, chilli flakes (careful, adjust the amount to your preferred hotness) and 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of sugar to the stock</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 2-3 tbsp of vegetable oil to a large pan over a high heat</p>\r\n<p><strong>Add</strong> the shallots and garlic and cook for 1 min</p>\r\n<p><strong>Add</strong> half the stock to the pan (save the rest for the next step)</p>\r\n<p><strong>Drain</strong> the noodles, add them to the pan and stir</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> well until the stock has almost evaporated</p>\r\n<p><strong>Add</strong> the remaining stock, reduce the heat to medium-low and simmer until the water has mostly evaporated again</p>\r\n<p>Tip: If the noodles are not done, add some water and cook further</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the noodles from the heat and season to your taste with salt and pepper</p>\r\n<p><strong>Serve</strong> them piled with tofu, cucumber, spring onions and peanuts</p>\r\n<p><strong>Garnish</strong> with a wedge of lime</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
