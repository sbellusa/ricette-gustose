  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Transfer your <strong>BBQ pulled pork</strong> and any juices to an <strong>oven-proof dish</strong></p><p>Cover with <strong>tin foil</strong> and put the dish in the oven for an initial 30 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1687534240298-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1687534240298-x400.jpg",
