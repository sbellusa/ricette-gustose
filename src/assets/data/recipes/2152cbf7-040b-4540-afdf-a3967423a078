          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1617029492461-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1617029492461-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1617029492461-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the mushrooms are cooked, slice them finely</p><p>Serve the <strong>sliced peri peri mushrooms</strong> with the <strong>spicy rice</strong> and<strong> lemony salad</strong> to the side</p><p>Garnish with the <strong>remaining</strong> <strong>lemon wedges</strong></p><p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
