  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 4)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the chilli&rsquo;s seeds and peel the ginger. Chop the ginger and chilli<span class=\"text-danger\">(es)</span> very finely (careful, adjust the amount to your preferred hotness)</p>\r\n<p><strong>Slice</strong> the mushrooms and the spring onions finely</p>\r\n<p><strong>Cut</strong> the chicken into thin strips (approx. 1 cm)</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a large pot on a high heat</p>\r\n<p><strong>Add</strong> the ginger and chilli and let them sizzle for less than 1 min, stirring constantly</p>\r\n<p><strong>Add</strong> the chicken and cook for 2-4 min or until cooked through</p>\r\n<p><strong>Add</strong> the shaoxing wine and cook for 1 min or until the wine is mostly evaporated</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice vinegar, mix for 30 sec (don&rsquo;t let it evaporate too much)</p>\r\n<p><strong>Add</strong> 750ml <span class=\"text-danger\">(1.5L)</span> of boiling water from step 1 and add the udon <br />noodles</p>\r\n<p><strong>Reduce</strong> the heat to obtain a gentle simmer and stir</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the noodles have been cooking for 4 min, add the mushrooms</p>\r\n<p><strong>Mix</strong> well and let simmer for 4 min</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the mangetout and soy sauce, mix well and let simmer for further 1 min</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> most of the spring onions (leave the green tips for the end)</p>\r\n<p><strong>Check</strong> the udon noodles to see if they are cooked (they should take about 6 min in total)</p>\r\n<p>Tip: If they are not ready yet, let simmer for a bit longer</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the soup in bowls and decorate with the remaining spring onions</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
