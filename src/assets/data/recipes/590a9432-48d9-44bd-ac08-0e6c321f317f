  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>waxy potatoes</strong> in half lengthways</p><p>Add the<strong> halved potatoes</strong> to a baking tray (or two!) with a drizzle of<strong> vegetable oil</strong> and a pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray[s] in the oven for an initial 30 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1626786162100-x200.jpg",
