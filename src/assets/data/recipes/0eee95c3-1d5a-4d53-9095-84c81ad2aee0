  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil half a kettle</p><p>Put 1 <span class=\"text-danger\">[2]</span> large baking tray<span class=\"text-danger\">[s]</span> in the oven to heat up (this will stop the base of your naan from going soggy!)</p><p>Peel and finely slice the <strong>shallot<span class=\"text-danger\">[s]</span></strong>, then combine with the<strong> red wine vinegar</strong>, 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>sugar</strong> and a pinch of <strong>salt</strong> in a small bowl and set aside – this is your <strong>quick-pickled shallot</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1629808304224-x200.jpg",
