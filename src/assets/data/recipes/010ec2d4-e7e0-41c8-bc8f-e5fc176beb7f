          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1948.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the rice is cooking, cut the <strong>chicken breast portions</strong> into bite-sized pieces</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1948.-step-4-x200.jpg",
            "width": 200
          },
