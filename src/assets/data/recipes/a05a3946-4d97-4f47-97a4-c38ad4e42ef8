          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722006530152-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722006530152-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722006530152-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>giant couscous</strong> to a pot of <strong>boiled water </strong>with a generous pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Cook the <strong>giant couscous</strong> for 8 min or until tender with a slight bite</p><p>Once done, drain the <strong>giant couscous</strong> and reserve the pot</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1722006917582-x200.jpg",
            "width": 200
