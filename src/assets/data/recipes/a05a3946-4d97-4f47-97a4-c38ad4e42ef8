    {
      "instruction": "<p>Dissolve your<strong> vegetable stock mix</strong> and <strong>traditional Italian</strong> <strong>pesto</strong> in 100ml <span class=\"text-purple\">[130ml]</span> <span class=\"text-danger\">[170ml]</span> <strong>boiled water</strong> – this is your<strong> pesto stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1722006977150-x200.jpg",
