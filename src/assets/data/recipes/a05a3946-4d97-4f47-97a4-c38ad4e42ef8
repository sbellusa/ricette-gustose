  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat</p><p>Once hot, add your <strong>pine kernel</strong> <strong>& seed mix</strong> and cook for 2-3 min or until toasted and lightly golden</p><p>Once toasted, transfer to a bowl and set aside until serving, and reserve the pan – these are your <strong>toasted seeds</strong></p><p>Tip: Watch them like a hawk to make sure they don’t burn!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722006530152-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722006530152-x400.jpg",
            "width": 400
