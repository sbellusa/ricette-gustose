  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 5)</p>\r\n<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the coriander roughly</p>\r\n<p><strong>Deseed</strong> the red peppers and cut into squares</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop roughly</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the red peppers on an oven-proof tray</p>\r\n<p><strong>Sprinkle</strong> with the garlic, 2-3 tbsp of olive oil and salt to your taste</p>\r\n<p><strong>Mix</strong> well to ensure that the peppers are well coated</p>\r\n<p><strong>Place</strong> in the oven for 15 min or until the peppers are soft</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, grate the parmesan</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the pasta in a pot of boiling water and salt (optional) for 8 min or until the pasta is cooked to your taste, stirring occasionally, then drain</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> a pan on medium-high heat and dry roast (no oil needed) the hazelnuts for approx. 5 min or until well browned</p>\r\n<p><strong>Keep</strong> stirring and adjust the heat if necessary to prevent burning</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Put</strong> the coriander, red peppers, garlic, hazelnuts, 1/2 of the red chilli flakes, the juice of 1/2 the <span class=\"text-danger\">(whole)</span> lime and 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> of olive oil in a blender or pestle and mortar</p>\r\n<p><strong>Blend</strong> to a rough paste, add the grated parmesan and season to your taste</p>\r\n<p><strong>Add</strong> more chilli flakes if desired, tasting after each addition</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the pesto and the pasta in the pan</p>\r\n<p><strong>Season</strong> with lime juice to your taste and serve</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
