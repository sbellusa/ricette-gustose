  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Slice the <strong>chestnut mushrooms</strong> </p>\n<p>Top, tail and slice the<strong> courgette<span class=\"text-danger\">[s]</span></strong></p>\n<p>Cut the <strong>cherry tomatoes</strong> in half</p>\n<p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1618.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1618.-step-1-x400.jpg",
            "width": 400
