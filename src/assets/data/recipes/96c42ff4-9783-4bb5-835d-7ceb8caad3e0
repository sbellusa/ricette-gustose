      }
    },
    {
      "instruction": "<p>Remove the <strong>browned vegetables</strong> from the oven</p>\n<p>Divide the topping between <strong>naan breads </strong></p>\n<p> </p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1618.-step-5-x200.jpg",
