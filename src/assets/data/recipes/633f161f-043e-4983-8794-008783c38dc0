      }
    },
    {
      "instruction": "<p>Peel the <strong>cooled boiled egg[s]</strong> and cut them in into quarters</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1642010833410-x200.jpg",
