  "cooking_instructions": [
    {
      "instruction": "<p>Zest the <strong>lemon<span class=\"text-danger\">[s]</span></strong> (try to grate lightly with a micro-plane or sharp box grater and avoid grating the white pith, as this is very bitter) and cut into wedges</p><p>Peel and grate the <strong>garlic</strong></p><p>Peel and finely chop the <strong>brown</strong> <strong>onion<span class=\"text-danger\">[s]</span></strong></p><p>Strip the <strong>mint</strong> <strong>leaves</strong> from their stems and chop them roughly, discard the stems</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1687337876333-x200.jpg",
