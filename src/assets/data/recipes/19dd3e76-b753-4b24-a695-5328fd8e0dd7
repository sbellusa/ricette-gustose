          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1632303506970-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1632303506970-x1000.jpg",
