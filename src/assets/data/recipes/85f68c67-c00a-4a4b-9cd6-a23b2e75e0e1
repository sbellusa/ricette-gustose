  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Deseed the <strong>pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Peel and finely slice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 1,
      "media": {
        "images": [
