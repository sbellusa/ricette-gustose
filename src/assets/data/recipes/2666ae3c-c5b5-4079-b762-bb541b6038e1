  "cooking_instructions": [
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) over a high heat</p><p>Once hot, add the<strong> portobello mushrooms</strong> to the pan with a pinch of <strong>salt</strong> and cook for 3 min on each side until starting to brown</p><p>Once the mushrooms are starting to brown, reduce the heat to low, add a couple of splashes of <strong>water</strong> and cook, covered, for 10-12 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1624354714314-x200.jpg",
            "width": 200
