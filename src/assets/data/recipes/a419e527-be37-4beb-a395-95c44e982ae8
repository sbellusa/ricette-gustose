          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the spring onions finely</p>\r\n<p><strong>Peel</strong> and chop (or grate) the ginger finely</p>\r\n<p><strong>Cut</strong> the lemon<span class=\"text-danger\">[s]</span> in half</p>",
      "order": 4,
      "media": {
        "images": [
          {
