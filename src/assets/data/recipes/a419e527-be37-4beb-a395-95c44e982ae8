  "cooking_instructions": [
    {
      "instruction": "<p><strong>Slice</strong> the chicken into thin strips of equal size then season with salt and pepper</p>\r\n<p><strong>Transfer</strong> the chicken strips to a plate with a little flour</p>\r\n<p><strong>Toss</strong> to coat the chicken evenly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice and 350ml <span class=\"text-danger\">[700ml]</span> water to a large pot with a lid and bring to the boil over a high heat</p>\r\n<p><strong>Meanwhile,</strong> cut the broccoli into florets</p>\r\n<p><strong>Once</strong> the rice is boiling, reduce the heat to low and add the broccoli florets on top</p>\r\n<p><strong>Cover</strong> and cook for 10-15 min or until all the water has absorbed and the rice and broccoli are cooked</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, heat a large, wide-based pan (preferably non-stick) with 2-3 tbsp <span class=\"text-danger\">[3-5 tbsp]</span> vegetable oil over a medium-high heat</p>\r\n<p><strong>Once</strong> hot, add the chicken and cook for 3 min or until nicely browned, turning once</p>\r\n<p><strong>Once</strong>&nbsp;browned, transfer the strips to a plate and wipe the pan clean</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-3-x400.jpg",
            "width": 400
          },
          {
