          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cornflour, sweet chilli jam, juice of half the&nbsp;<span class=\"text-danger\">[whole]</span> lemon and 100ml <span class=\"text-danger\">[200ml]</span> cold water to a mixing jug</p>\r\n<p><strong>Stir</strong> to combine - this is your sweet chilli stock</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/632.-step-5-x200.jpg",
            "width": 200
          },
          {
