  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely chop (or grate) the <strong>garlic</strong></p>\n<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium heat</p>\n<p>Once hot, add the <strong>garlic</strong>, <strong>panko breadcrumbs</strong> and a pinch of <strong>salt</strong> and cook for 3-4 min or until they're golden</p>\n<p>Once done, transfer to a bowl and set aside for later</p>",
      "order": 1,
      "media": {
        "images": [
