          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1678967480717-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Moroccan-style lentil stew</strong> in bowls, topped with the <strong>sumac chicken breast strips</strong> and <strong>tomato & sultana salsa</strong></p><p>Garnish with a wedge of<strong> lemon</strong></p><p>Enjoy!</p>",
      "order": 8,
