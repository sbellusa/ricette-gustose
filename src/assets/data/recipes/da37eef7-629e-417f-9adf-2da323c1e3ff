  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle, then peel and finely dice your <strong>brown onion[s]</strong></p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and chop into thin strips</p><p>Top, tail and chop your <strong>courgette[s]</strong> in half lengthways, then slice finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
