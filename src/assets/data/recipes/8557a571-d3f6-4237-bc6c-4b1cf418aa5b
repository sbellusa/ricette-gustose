  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then chop your <strong>pepper[s]<span class=\"text-danger\"> </span></strong>into quarters (scrape the seeds and pith out with a spoon)</p><p>Separate the <strong>white fat</strong> and the <strong>duck</strong> <strong>jelly</strong> from your <strong>duck leg[s]</strong></p><p>Add the <strong>chopped pepper</strong> to a <strong>tin foil</strong>-lined baking tray, top with the <strong>duck leg[s]</strong>, <strong>white fat</strong>, <strong>duck</strong> <strong>jelly</strong>, season with a<strong> </strong>pinch of <strong>salt </strong>and<strong> pepper </strong>then<strong> </strong>put in the oven for 30 min or until golden and crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1644839929909-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1644839929909-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1644839929909-x700.jpg",
            "width": 700
