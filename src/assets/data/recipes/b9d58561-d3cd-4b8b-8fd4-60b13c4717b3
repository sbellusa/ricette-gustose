  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ gas 4</p><p>Boil a kettle</p><p>Add your <strong>tomatoes</strong> to a baking tray with a generous drizzle of <strong>olive oil</strong></p><p>Put the tray in the oven and cook for 35-40 min or until softened – these are your<strong> roasted whole tomatoes</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658226810550-x200.jpg",
            "width": 200
