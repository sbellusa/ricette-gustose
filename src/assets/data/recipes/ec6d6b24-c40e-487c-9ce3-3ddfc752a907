          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1612276463282-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1612276463282-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped tomato</strong> and<strong> onion wedges </strong>to the pan with the <strong>meat-free chick'n</strong> and cook for 4-5 min or until the onion is beginning to soften</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1612276471222-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1612276471222-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1612276471222-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1612276471222-x1000.jpg",
            "width": 1000
