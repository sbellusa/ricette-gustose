  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air, then boil half a kettle</p><p>Slice the<strong> chicken breast portion[s]</strong> lengthways into 2<span class=\"text-danger\"> </span>strips per person</p><p>Chop your <strong>creamed coconut</strong> roughly (if required!) and combine with 200ml <span class=\"text-purple\">[300ml]</span> <span class=\"text-danger\">[400ml]</span> <strong>boiled water</strong> – this is your<strong> coconut stock</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1695044250403-x200.jpg",
            "width": 200
          },
          {
