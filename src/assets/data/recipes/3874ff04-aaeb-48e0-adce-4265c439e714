          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2073.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your<strong> ginger</strong></p><p>Dissolve<strong> </strong>your<strong> vegetable stock mix</strong> in 600ml <span class=\"text-purple\">[800ml]</span> <span class=\"text-danger\">[1L]</span> <strong>boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2073.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2073.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2073.-step-4-x700.jpg",
