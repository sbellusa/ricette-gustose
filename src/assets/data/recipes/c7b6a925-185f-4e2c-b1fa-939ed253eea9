          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2156.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>basa fillets</strong> to a separate baking tray and pat them dry with <strong>kitchen paper</strong></p>\n<p>Top the fish evenly with the<strong> chive crumb </strong>and press it into the fish using the back of a spoon</p>\n<p>Put the tray in the oven for 12-15 min or until golden and cooked through</p>",
      "order": 3,
