  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>steak </strong>out of the fridge, open the packet and let it adjust to room temperature</p><p>Rinse your <strong>quinoa</strong> in a sieve under<strong> cold running water </strong>and add to a pot with a lid with 180ml<span class=\"text-danger\"> <span class=\"text-purple\">[270ml] </span>[360ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to low and cook, covered, for 18-20 min or until all the water has absorbed and the quinoa is tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2278Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/RC2278Step-1-x400.jpg",
