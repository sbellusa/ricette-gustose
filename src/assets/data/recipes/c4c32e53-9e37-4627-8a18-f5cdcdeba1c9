            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the steak is resting, return the reserved pan to a high heat</p><p>Once hot, add the <strong>pepper strips</strong> and cook for 5-6 min or until tender and starting to char</p>",
      "order": 5,
      "media": {
        "images": [
