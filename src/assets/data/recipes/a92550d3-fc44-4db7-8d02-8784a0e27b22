          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1296.-step-5.n-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the cheese has melted, remove the tray from the oven and spread<strong> mayonnaise</strong> over the <strong>ciabatta lids</strong></p>",
      "order": 6,
      "media": {
