            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>cheddar cheese</strong> in quarters lengthways</p>\n<p> </p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1296.-step-4.n-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1296.-step-4.n-x400.jpg",
