  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 395&deg;F/ Gas 6</p>\r\n<p>Preheat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> vegetable oil</strong> over a medium heat&nbsp;</p>\r\n<p>Once hot, add the <strong>bacon lardons</strong> and cook for 5 min or until starting to crisp&nbsp;&nbsp;</p>\r\n<p>Once crisp, remove the pan from the heat and set aside&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
