  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes (skin on) into bite-size pieces</p>\r\n<p><strong>Place</strong> on 1 <span class=\"text-danger\">(2)</span> baking tray<span class=\"text-danger\">(s)</span> with a drizzle of olive oil and salt and pepper</p>\r\n<p><strong>Add</strong> the sausages and oven-roast for 30-35 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, quarter the pear<span class=\"text-danger\">(s)</span> and remove the core</p>\r\n<p><strong>Quarter</strong> the parsnip<span class=\"text-danger\">(s)</span> and remove the root end<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Add</strong> both to a smaller baking tray and drizzle with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span>&nbsp;vegetable oil and season with salt, pepper and half the dried dill</p>\r\n<p><strong>Reserve</strong> the remaining dill for step 6</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Put</strong> the pear and parsnips into the oven for 20-25 min until the pears are caramelised and the parsnips are nice and crisp</p>\r\n<p><strong>Drain</strong>&nbsp;and rinse the beans</p>\r\n<p><strong>Leave</strong> the sausages, potatoes, pears and parsnips in the oven for 10-15 min before moving on to the next step</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-3-x200.jpg",
            "width": 200
