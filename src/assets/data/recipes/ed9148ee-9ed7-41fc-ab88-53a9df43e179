      }
    },
    {
      "instruction": "<p><strong>Wash</strong> and slice the leeks in half lengthways, removing any grit between the leaves and discarding the root ends and woody tops</p>\r\n<p><strong>Slice</strong> the leeks finely</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/441.-step-5-x200.jpg",
