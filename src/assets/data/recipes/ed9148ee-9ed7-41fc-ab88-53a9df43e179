          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 150ml<span class=\"text-danger\"> (300ml)</span>&nbsp;boiled water&nbsp;</p>",
      "order": 4,
      "media": {
