          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, trim the green beans and cut them in half</p>\r\n<p><strong>Add</strong> them to a pot and cover with salted boiling water by 5cm</p>\r\n<p><strong>Bring</strong> to the boil on a high heat and cook for 4-5 min or until tender but with a slight bite</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-6-x1000.jpg",
