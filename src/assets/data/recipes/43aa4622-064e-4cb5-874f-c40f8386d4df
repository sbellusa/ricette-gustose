          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/468.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, return the drained potatoes to the cooking pot</p>\r\n<p><strong>Add</strong> a knob of butter, a splash of milk, the Dijon mustard and season with salt and pepper</p>\r\n<p><strong>Mash</strong> thoroughly until fully combined</p>",
