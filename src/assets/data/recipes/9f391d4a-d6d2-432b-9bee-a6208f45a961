            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1687248456187-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1687248456187-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>chicken breast orzo primavera</strong> topped with the <strong>remaining</strong> <strong>grated Italian hard cheese</strong>, a drizzle of <strong>olive oil</strong>, the <strong>toasted pine kernels</strong> and a grind of <strong>black pepper</strong></p><p>Garnish with a<strong> lemon wedge</strong></p><p>Enjoy!</p>",
      "order": 8,
