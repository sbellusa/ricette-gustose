  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil a kettle</p><p>Peel and finely slice (don't chop!) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1687248439641-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1687248439641-x400.jpg",
