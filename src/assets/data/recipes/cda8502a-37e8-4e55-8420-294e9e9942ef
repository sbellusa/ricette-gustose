            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has softened, add the <strong>sliced garlic</strong> to the pan with the <strong>smoked paprika</strong> and <strong>drained</strong> <strong>cannellini beans</strong> and cook for 1-2 min or until the garlic has softened</p><p>Preheat the grill to high</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1614613133041-x200.jpg",
