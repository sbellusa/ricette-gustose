  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> the potatoes and cut them all to roughly equal size (approx. 5cm chunks)</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 15 min or until you can pierce them easily with a fork</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Season</strong> the pork steaks to your taste on both sides with salt and pepper</p>\r\n<p><strong>Set</strong> aside (cooked in step 3)</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the leek<span class=\"text-danger\">(s)</span> in half lengethwise and wash carefully to remove any dirt from between the leaves</p>\r\n<p><strong>Cut</strong> the leek<span class=\"text-danger\">(s)</span> into slices (approx. 1cm thick)</p>\r\n<p><strong>Chop</strong> the apple<span class=\"text-danger\">(s)</span> into eighths and remove their cores</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1/2-1 tbsp of olive oil to a pan on a medium heat</p>\r\n<p><strong>When</strong> hot, hold the pork upright in the pan using tongs or forks, frying the fatty edges for 3 min or until brown and crisp</p>\r\n<p><strong>Cook</strong> the pork steaks flat for 3 min on each side, or until cooked throughRemove from the pan, cover well and leave to rest</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the apple flesh-side down for 1-2 min per side, until colored oven a medium heat</p>\r\n<p><strong>Add</strong> the leek and garlic for 2-3 min, or until browned</p>\r\n<p><strong>Strip</strong> the thyme's leaves and add to the pan, discarding the stems</p>\r\n<p><strong>Add</strong> 150ml <span class=\"text-danger\">(200ml)</span> of water and stir well to lift off the pan residue</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are done, drain and mash with 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of cr&egrave;me fra&icirc;che</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> any juices the steaks have released while resting to the pan </p>\r\n<p><strong>Reduce</strong> the heat to low and add the mustard and remaining cr&egrave;me fra&icirc;che</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the potato with the pork and the creamy apple, thyme and leek sauce on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
