            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1683884146112-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Squeeze the pouch[es] of cooked<strong> white long grain rice</strong> to separate the grains</p><p>Tear the top corner of the pouch[es] (just a little!) and <strong>microwave</strong> for 2 min or until piping hot</p><p>Tip: If you're cooking two pouches, pop them in together but increase the microwave cook time accordingly</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1683884160111-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1683884160111-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1683884160111-x700.jpg",
