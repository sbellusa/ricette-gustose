          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1651.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your<strong> sriracha</strong> (not a fan of spice? Just add a little!)<strong> </strong>with your<strong> mayo</strong> in a small bowl – this is your <strong>sriracha mayo</strong></p>",
