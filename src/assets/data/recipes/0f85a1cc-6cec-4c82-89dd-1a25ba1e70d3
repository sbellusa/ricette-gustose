  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Boil</strong> a kettle (used in step 3)</p>\r\n<p><strong>Slice</strong> the aubergine<span class=\"text-danger\">(s)</span> into 1/2cm thick discs<br /><br /><strong>Peel</strong> and slice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Chop</strong> the coriander and mint finely and cut the feta into 2cm squares</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the aubergine on an oven tray<br /><br /><strong>Add</strong> 1-2 tbsp of olive oil to the tray and coat well</p>\r\n<p><strong>Season</strong> to your taste with pepper</p>\r\n<p><strong>Put</strong> in the oven for 20 min or until both sides have turned golden brown, turning the aubergine halfway through</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the freekeh to a pot of water and bring it to a boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently for 15 min, or until cooked but still with a slight bite</p>\r\n<p><strong>Drain</strong> the freekeh and set aside (used in step 7)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add 1-2 tbsp of olive oil to a pan over a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, reduce the heat and add the onion to the pan<br /><br /><strong>Cook</strong> for 3-4 min, or until golden brown and set aside</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the harissa and chopped mint to the feta in a bowl</p>\r\n<p><strong>Toss</strong> well to make sure the feta cubes are fully coated in harissa and mint</p>\r\n<p>Tip: If the mixture is too dry to work with, add 1-2 tsp of olive oil to loosen the harissa paste</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the cider vinegar and 1-2 tbsp of olive oil in a small bowl</p>\r\n<p><strong>Whisk</strong> with a fork to form a dressing<br /><br /><strong>Season</strong> to your taste with salt and sugar</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the freekeh, dressing, and coriander (save a pinch to serve) to the onion</p>\r\n<p><strong>Toss</strong> the salad well</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the freekeh salad, topped with the feta and aubergine</p>\r\n<p><strong>Sprinkle</strong> with the remaining coriander</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
