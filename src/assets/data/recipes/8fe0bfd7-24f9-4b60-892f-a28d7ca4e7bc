  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Discard</strong> the top<span class=\"text-danger\">(s)</span> and tail<span class=\"text-danger\">(s)</span> of the parsnip<span class=\"text-danger\">(s)</span> and chop into 3cm pieces</p>\r\n<p><strong>Add</strong> to an oven tray with 1-2 tbsp of olive oil and season with salt and pepper</p>\r\n<p><strong>Roast</strong> for 25-30 min, flipping half-way, until soft and golden, then remove</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, boil a kettle (used in step 4)</p>\r\n<p><strong>Dice</strong> the onion<span class=\"text-danger\">(s)</span> into 1cm cubes</p>\r\n<p><strong>Crush</strong> the garlic cloves with the side of a knife, peel and dice finely</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan with a matching lid and heat on high</p>\r\n<p><strong>When</strong> hot, reduce to a medium heat and add the onion</p>\r\n<p><strong>Saute</strong> the onion for 2-3 min, stirring constantly, until soft and translucent</p>\r\n<p><strong>Add</strong> the garlic and cook for 1 min, until golden</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the dried millet, stirring to coat, and cook for 3-5min, until slightly toasted</p>\r\n<p><strong>Meanwhile</strong>, dissolve the stock in 800ml <span class=\"text-danger\">(1.6L)</span> of boiling water</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the stock to the millet in one go, bring to a boil, and reduce to a rapid simmer</p>\r\n<p><strong>Simmer</strong> with a lid on for 25-35 min, stirring occasionally, until nearly all of the water is <br />absorbed and the millet is tender\"</p>\r\n<p><strong>Once</strong> done, remove from the heat and keep covered</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, discard the tough green top<span class=\"text-danger\">(s)</span> and the root<span class=\"text-danger\">(s)</span> from the leek<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Slice</strong> in half lengthways, and cut into 6cm pieces (roughly quartered)</p>\r\n<p><strong>Chop</strong> the goat's cheese coarsely</p>\r\n<p><strong>Chop</strong> the walnuts coarsely</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the tray from the oven, push the parsnips to one side, and add the walnuts</p>\r\n<p><strong>Roast</strong> for a further 5-10 min, until the walnuts are toasted and set aside</p>\r\n<p><strong>Meanwhile</strong>, add 1-2 tbsp of oil to a pot on a high heat</p>\r\n<p><strong>Brown</strong> the leeks for 1 min, add 75ml <span class=\"text-danger\">(150ml)</span> of water and simmer with a lid on for 3-5 min, or until tender\"</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> the goats' cheese through the millet, until creamy</p>\r\n<p><strong>Spoon</strong> the cheesy millet into bowls and top with the roasted parsnip and walnuts</p>\r\n<p><strong>Add</strong> the braised leeks and drizzle with some leek liquid!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
