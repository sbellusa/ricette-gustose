  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the grill to high</p>\r\n<p><strong>Place</strong> the chicken thighs on an oven tray</p>\r\n<p><strong>Coat</strong> the chicken thighs in the baharat, 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil and season to your taste with salt and pepper</p>\r\n<p><strong>Set</strong> aside for step 3</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the cucumber in half lengthways, scrape out the seeds using a teaspoon and slice finely</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span>, cut in half and slice finely</p>\r\n<p><strong>Put</strong> the onion and cucumber in a bowl, sprinkle with a generous pinch of salt, mix well and set aside</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle (used in step 4)</p>\r\n<p><strong>Grill</strong> the chicken thighs for 12-14 min or until cooked through</p>\r\n<p>Tip: You want the thighs to be slightly charred to accentuate the flavours of the baharat</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, bring a pot of salted water to a boil, add the couscous and cook with the lid on for 6-8 min or until tender, then drain</p>\r\n<p><strong>Peel</strong> and chop the garlic finely</p>\r\n<p><strong>Chop</strong> the mint finely</p>\r\n<p><strong>Grate</strong> the zest of the lime<span class=\"text-danger\">(s)</span></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/220.-step-4-x1000.jpg",
