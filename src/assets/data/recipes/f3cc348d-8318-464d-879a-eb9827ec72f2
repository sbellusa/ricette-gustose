            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and chop the onion<span class=\"text-danger\">[s]</span> roughly</p>\r\n<p><strong>Chop</strong> the celery roughly</p>\r\n<p><strong>Deseed</strong> the pepper<span class=\"text-danger\">[s]</span> (scrape the seeds and pith out with a teaspoon) and cut into bite-size pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan with a matching lid (preferably non-stick) with 1&nbsp;tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil over a high&nbsp;heat</p>\r\n<p><strong>Once</strong> hot, add the onions, celery and green pepper</p>\r\n<p><strong>Cover</strong> and cook for 3-4 min or until beginning to brown and soften</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-3-x700.jpg",
            "width": 700
          },
          {
