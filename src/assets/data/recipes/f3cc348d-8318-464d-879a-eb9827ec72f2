            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the beef mince,&nbsp;paprika and oregano to a bowl</p>\r\n<p><strong>Crumble</strong> in the stock cube<span class=\"text-danger\">[s]</span> and mix very thoroughly with clean hands</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/634.-step-4-x400.jpg",
            "width": 400
