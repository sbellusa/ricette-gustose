            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1735.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a lid, with a large drizzle of <strong>olive oil</strong> over a medium heat</p>\n<p>Once hot, add the <strong>sliced red onion</strong> with a generous pinch of <strong>salt</strong> and reduce the heat to low </p>\n<p>Cover and cook for 6-7 min or until softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1735.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1735.-step-2-x400.jpg",
            "width": 400
