          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1735.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1735.-step-2-x1000.jpg",
            "width": 1000
