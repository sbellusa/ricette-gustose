  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 360ml <span class=\"text-danger\">(720ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to a simmer and cover for 15-20 min or until the water is absorbed</p>\r\n<p><strong>Check</strong> to prevent over-cooking and once done, set aside until step 7</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the diced chicken in a bowl</p>\r\n<p><strong>Add</strong> the five spice and 1/4 tsp <span class=\"text-danger\">(1/2 tsp)</span> of salt and 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> of pepper to taste</p>\r\n<p><strong>Mix</strong> well with a fork and set aside for step 6</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span> and ginger and chop both finely</p>\r\n<p><strong>Remove</strong> the pepper's stem<span class=\"text-danger\">(s)</span> and seeds and slice thinly</p>\r\n<p><strong>Mix</strong> together the soy, sesame oil, tamarind paste, and 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar in a bowl for step 6</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a large pan or wok on a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the chicken and sear for 1-2 min, or until browned all over <br /><br /><strong>Remove</strong> with a slotted spoon, set aside and retain the pan with the oil for step 6</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan to a high heat and cook the onion and ginger for 1 min, stiring to prevent burning</p>\r\n<p><strong>Add</strong> just enough water to the pan to add moisture and to lift the bits off of the bottom</p>\r\n<p><strong>Add</strong> the pepper and cook for 1-2 min, or until browned with a slight bite</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the seared chicken and soy mixture</p>\r\n<p><strong>Add</strong> 100ml <span class=\"text-danger\">(150ml)</span> of water to the pan and cook for 1 min</p>\r\n<p><strong>Reduce</strong> the heat and simmer gently for 3-4 min or until the chicken is cooked through</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Fluff</strong> the rice with a fork and add to the chicken pan<br /><br /><strong>Mix</strong> everything together quicky and remove from the heat</p>\r\n<p>Tip: If the stir-fry is too dry gradually add a few tbsp of water</p>\r\n<p><strong>Roughly</strong> chop the coriander</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the stir-fry steaming hot </p>\r\n<p><strong>Garnish</strong> with coriander</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
