    },
    {
      "instruction": "<p>While the rice is cooking, boil half a kettle</p><p>Chop your<strong> paneer</strong> into bite-sized pieces</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1629717673082-x200.jpg",
