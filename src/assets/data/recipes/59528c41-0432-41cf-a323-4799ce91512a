          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>curry powder</strong> and <strong>red Thai curry paste</strong> to the pan with your <strong>ginger & garlic paste</strong> and cook for 1 min further or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1679410348011-x200.jpg",
