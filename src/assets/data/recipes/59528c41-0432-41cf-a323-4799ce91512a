            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped potato</strong> to a heatproof bowl, cover with <strong>cling film</strong> and pierce a few holes in the top with a fork</p><p>Put the bowl in the <strong>microwave</strong> for 4-6 min or until the potatoes are fork-tender</p>",
      "order": 4,
      "media": {
        "images": [
