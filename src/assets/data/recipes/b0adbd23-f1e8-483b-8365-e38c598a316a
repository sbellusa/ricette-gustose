      }
    },
    {
      "instruction": "<p>Combine your <strong>chopped dates</strong>, <strong>tamarind paste</strong>, <strong>vegetable stock mix</strong> and <strong>chopped creamed coconut</strong> with 400ml <span class=\"text-purple\">[600ml]</span> <span class=\"text-danger\">[800ml]</span> <strong>boiled water</strong> – this is your <strong>date & tamarind stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1627402560216-x200.jpg",
