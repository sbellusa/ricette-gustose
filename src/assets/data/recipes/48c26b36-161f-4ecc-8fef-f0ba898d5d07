            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your<strong> Tenderstem broccoli</strong> in half</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1619192938356-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1619192938356-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1619192938356-x700.jpg",
            "width": 700
