          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1708529244468-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the heated tray[s] from the oven and add your <strong>pizza</strong> <strong>base[s]</strong></p><p>Spread the<strong> tomato base</strong> evenly with the back of a spoon over the <strong>pizza bases[s]</strong></p><p>Top with the <strong>torn</strong> <strong>mozzarella</strong></p>",
      "order": 4,
      "media": {
