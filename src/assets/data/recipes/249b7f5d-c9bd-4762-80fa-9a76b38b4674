  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the peppers in half lengthways and discard the pith and seeds</p>\r\n<p><strong>Add</strong> the halves cut-side up to an oven-proof baking dish</p>\r\n<p><strong>Dice</strong> the tomatoes finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Stuff </strong>the tomatoes inside the peppers&nbsp;</p>\r\n<p><strong>Strip</strong> the rosemary leaves from their stalks and chop the leaves finely, discarding the stalks</p>\r\n<p><strong>Halve</strong> the lemon<span class=\"text-danger\">(s)</span></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Sprinkle</strong> the peppers with rosemary and drizzle with the juice of half the <span class=\"text-danger\">(whole)</span> lemon and 1/2-1 tbsp olive oil</p>\r\n<p><strong>Season</strong> generously with salt and pepper</p>\r\n<p><strong>Put</strong> the dish in the oven for 25 min or until tender</p>\r\n<p>&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the parsley finely, including the stalks</p>\r\n<p><strong>Chop</strong> the capers coarsely</p>\r\n<p><strong>Meanwhile</strong>, peel and chop (or grate) the garlic finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step_4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step_4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step_4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step_4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step_4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the garlic, parsley, chopped capers, remaining lemon juice and 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> olive oil</p>\r\n<p><strong>Season</strong> generously with salt and pepper - this is your salsa verde</p>\r\n<p><strong>Boil</strong> a kettle for your couscous</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and cut the mozzarella into 4 <span class=\"text-danger\">(8)</span> pieces</p>\r\n<p><strong>When</strong> the peppers are nearly tender, add the couscous to a shallow bowl with 200ml <span class=\"text-danger\">(400ml)</span> boiled water, cover and set aside until serving&nbsp;</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/509.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> tender, remove the peppers from the oven and add a chunk of mozzarella</p>\r\n<p><strong>Return</strong> the dish to the oven for 5 min or until the cheese has just melted</p>",
      "order": 7,
      "media": {
