  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and slice thickly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682416382561-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1682416382561-x400.jpg",
            "width": 400
