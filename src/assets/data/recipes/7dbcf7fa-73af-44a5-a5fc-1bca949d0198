            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the meat-free chick'n is browning, pick your <strong>coriander</strong> and <strong>mint</strong> <strong>leaves</strong> from their stems, discard the stems</p><p>Chop the <strong>mint</strong> and <strong>coriander</strong> <strong>leaves</strong> roughly</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-1651599756583-x200.jpg",
