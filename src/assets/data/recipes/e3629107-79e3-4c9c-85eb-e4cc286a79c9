            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1664348023678-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add 50ml <span class=\"text-purple\">[65ml]</span> <span class=\"text-danger\">[75ml]</span> <strong>boiled water</strong> to the pan with your <strong>soy sauce </strong>and 2 tbsp<span class=\"text-purple\"> [3 tbsp]</span> <span class=\"text-danger\">[4 tbsp] </span><strong>pineapple juice </strong>(you'll use the rest later!)</p><p>Cook, covered, for a further 5 min or until the pork is cooked through (no pink meat!) – this is your <strong>Caribbean-style pork</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1664348028216-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1664348028216-x400.jpg",
