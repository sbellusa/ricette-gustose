          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1607347892351-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Divide the <strong>smoky pulled aubergine</strong> evenly between the <strong>warmed tortillas</strong></p><p>Top with the<strong> avo salsa</strong> and<strong> quick-pickled red cabbage</strong></p><p>Garnish with the <strong>remaining</strong> <strong>sliced onion</strong> and <strong>lime wedges</strong></p><p>Enjoy!</p>",
      "order": 8,
