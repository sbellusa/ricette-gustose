  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Place your hand flat onto the <strong>chicken breast<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Slice in half as if you were cutting a burger bun, so you are left with two thinner pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-1-x200.jpg",
            "width": 200
