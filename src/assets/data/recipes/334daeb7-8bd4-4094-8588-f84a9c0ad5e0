            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop the <strong>potatoes</strong> (skins on) roughly into bite-sized pieces</p>\r\n<p>Add the <strong>potatoes</strong> to a pot of<strong> boiled water</strong> with a large pinch of <strong>salt</strong> and cook over a high <span class=\"text-highlight\">heat for</span> 10 min or until almost cooked</p>\r\n<p>Re-boil a kettle</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-3-x400.jpg",
            "width": 400
          },
          {
