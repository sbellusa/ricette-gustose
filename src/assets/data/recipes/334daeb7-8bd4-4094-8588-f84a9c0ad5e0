          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p>\r\n<p>Once hot, add the <strong>sliced chicken breast</strong> and cook for 4-5 min on each side or until cooked through</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1212.-step-2-x400.jpg",
            "width": 400
          },
          {
