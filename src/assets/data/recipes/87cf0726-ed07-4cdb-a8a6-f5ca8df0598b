  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your <strong>potatoes</strong> (skins on) into small cubes</p><p>Zest half your <strong>lemon[s] </strong>(try to grate lightly with a micro-plane or sharp box grater and avoid grating the white pith, as this is very bitter)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1702388409704-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1702388409704-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1702388409704-x700.jpg",
            "width": 700
