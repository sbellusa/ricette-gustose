  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Boil half a kettle</p><p>Chop the <strong>creamed coconut </strong>roughly (if required!)</p><p>Dissolve the <strong>chopped creamed coconut </strong>and <strong>chicken stock mix </strong>in 225ml <span class=\"text-danger\">[450ml</span>] <strong>boiled water </strong>– this is your <strong>coconut stock</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1685114269233-x200.jpg",
            "width": 200
