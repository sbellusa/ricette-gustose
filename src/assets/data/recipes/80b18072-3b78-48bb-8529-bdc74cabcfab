  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7 and boil a kettle (used in step 3)</p>\r\n<p><strong>Peel</strong> the onion(s) and chop into 8 wedges, then chop each beetroot into 6 wedges</p>\r\n<p><strong>Remove</strong> the thyme's leaves and discard the stems</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the onion, beetroot, thyme and walnuts on an oven-proof tray</p>\r\n<p><strong>Coat</strong> well with 1-2 tbsp of olive oil and drizzle with honey</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper </p>\r\n<p><strong>Put</strong> in the oven for 20 min or until caramelised</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the bulgur, half the <span class=\"text-danger\">(whole)</span> stock cube and the bay leaf<span class=\"text-danger\">(ves)</span> to a pot with 180ml <span class=\"text-danger\">(360ml)</span> of boiled water</p>\r\n<p><strong>Cover</strong> with a lid and simmer on a medium-low heat for 5 min, or until almost all the water is absorbed</p>\r\n<p><strong>Remove</strong> from the heat and allow to rest with the lid on for 10 min or until all the water has been absorbed</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> crush the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Cut</strong> the chard into small pieces (approx. 1cm)</p>\r\n<p><strong>Drain</strong> and rinse the black-eyed beans</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the garlic and cook for 1 min, stirring constantly</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the beans to the pan</p>\r\n<p><strong>Cook</strong> for 2 min, stirring regularly</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chard to the pan </p>\r\n<p><strong>Cook</strong> for 3 min or until the chard is wilted and tender, stirring regularly</p>\r\n<p><strong>Once</strong> the bulgur is done, add it to the pan and mix well </p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the roasted nuts and vegetables with the chard bulgur</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
