  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p>\n<p>Peel and chop the <strong>red </strong><span class=\"text-highlight\"><strong>onions</strong></span> into wedges </p>",
      "order": 1,
