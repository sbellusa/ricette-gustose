            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>gnocchi</strong>, <strong>butternut squash cubes</strong>, <strong>chopped red onion</strong> and <strong>Tenderstem broccoli</strong> to a baking tray</p>\n<p>Drizzle everything with <strong>vegetable oil</strong>, season with a pinch of <strong>salt</strong> and give everything a good mix up</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1864.-step-2-x200.jpg",
