  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and slice the onions finely</p>\r\n<p><strong>Heat</strong> 1-2 tbsp of vegetable oil in a pot over a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the onion and cook for 10 min or until starting to caramelise</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> occasionally to prevent over-cooking and once done, set aside until you are ready to serve</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> peel the garlic and chop roughly</p>\r\n<p><strong>Remove</strong> the seeds from cardamom pods and discard the husks</p>\r\n<p><strong>Crush</strong> the cardamom seeds, ground cumin, ground coriander, the garlic, a pinch of salt, 1/2 tbsp <span class=\"text-danger\">(1 tbsp)</span> of water, in a pestle and mortar to form a rough paste</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the paste and the turmeric to the onion</p>\r\n<p><strong>Cook</strong> for a further 5 min or until the spices have released their aromas</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chicken to the onion pot </p>\r\n<p><strong>Cook</strong> for 3-4 min, stirring frequently or until the chicken is sealed all over</p>\r\n<p><strong>Crumble</strong> in the stock cube<span class=\"text-danger\">(s)</span></p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the ground almonds (reserving a little to serve) and the sultanas to the chicken and onion pot </p>\r\n<p><strong>Add</strong> 100ml <span class=\"text-danger\">(200ml)</span> of water to the pot, scraping anything off that might have stuck to the bottom</p>\r\n<p><strong>Reduce</strong> the heat to a gentle simmer and cook with the lid on for 5 min or until the chicken is cooked through</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the coriander coarsely, add half to the cooked rice and mix well (reserve the remaining half to serve)</p>\r\n<p><strong>Once</strong> the chicken is cooked, add the yoghurt and warm through while stirring </p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the creamy curry on a bed of fluffy rice, and sprinkle with remaining chopped coriander and ground almonds</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
