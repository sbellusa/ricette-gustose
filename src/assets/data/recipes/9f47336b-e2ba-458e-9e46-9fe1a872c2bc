  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6</p>\n<p>Peel and chop the <strong>red onion<span class=\"text-danger\">[s]</span></strong> finely</p>\n<p>Chop the<strong> cherry tomatoes</strong> roughly</p>\n<p>Chop the<strong> coriander</strong> finely, including the stalks (save some leaves for garnish!)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2240-Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2240-Step-1-x400.jpg",
            "width": 400
