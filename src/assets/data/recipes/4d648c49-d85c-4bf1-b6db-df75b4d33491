            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add your <strong>meat-free patty[ies]</strong> to a separate <strong>tin foil</strong>-lined baking tray (or two!)</p><p>Put the tray[s] in the oven for 10-12 min or until cooked through</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1-1597747491570-x200.jpg",
