          }
        ]
      }
    },
    {
      "instruction": "<p>Once the feta&nbsp;has browned, remove it from the oven and let cool slightly for 5 min &ndash; this is your <strong>baked honey &amp; sesame feta&nbsp;</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1145.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1145.-step-6-x400.jpg",
