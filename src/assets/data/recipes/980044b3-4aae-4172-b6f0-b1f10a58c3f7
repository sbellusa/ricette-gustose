            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the&nbsp;<strong>radishes</strong> finely</p>\r\n<p>Trim, then slice the<strong> spring onions&nbsp;</strong>finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1145.-step-5-x200.jpg",
            "width": 200
