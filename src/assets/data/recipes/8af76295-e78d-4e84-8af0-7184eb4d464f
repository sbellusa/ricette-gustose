  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle&nbsp;</p>\r\n<p>Cut the<strong> potatoes</strong> (skins on) into large, bite-size pieces</p>\r\n<p>Add the <strong>chopped potatoes</strong> to a pot of<strong> boiled water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 10 min or until fork-tender</p>\r\n<p>Re-boil a kettle</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1026.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1026.-step-1-x400.jpg",
