  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Add your <strong>ground smoked paprika</strong>, <strong>cayenne pepper</strong> (can't handle the heat? Go easy!), <strong>ground coriander</strong>, <strong>dried oregano</strong>, <strong>ground</strong> <strong>cumin</strong>, a pinch of <strong>sugar</strong> and <strong>salt</strong> and a generous grind of <strong>black pepper</strong> to a plate and give it a good mix up – this is your <strong>Cajun-style spice blend</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1608573131455-x200.jpg",
            "width": 200
