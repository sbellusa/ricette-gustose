            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the<strong> </strong>potatoes<strong> </strong>are cooking, slice the <strong>courgette<span class=\"text-danger\">[s]</span></strong> lengthways, then slice on a diagonal into 1cm thick slices</p>",
      "order": 5,
      "media": {
