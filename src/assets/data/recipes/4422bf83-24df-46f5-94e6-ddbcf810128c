            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the heated tray[s] from the oven and add your <strong>pizza base[s]</strong></p><p>Spread the<strong> tomato sauce</strong> evenly between the pizza base[s] with the back of a spoon</p><p>Top with the <strong>spicy chicken & pepper mixture</strong></p>",
      "order": 5,
      "media": {
