            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, grate your <strong>cheddar cheese</strong></p><p>Trim, then slice your <strong>spring onion[s]</strong><span class=\"text-danger\"> </span>finely</p>",
      "order": 5,
      "media": {
        "images": [
