            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-copy-2-1650885894972-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a large knob of <strong>butter</strong> over a medium heat</p><p>Add 1 tbsp <span class=\"text-danger\">[2 tbsp]</span><strong> flour</strong> and stir until sandy paste forms</p><p>Gradually whisk in the <strong>stock </strong>and cook for 2-3 min until the stock has slightly thickened – this is your<strong> sauce</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1649844912436-x200.jpg",
