            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>sugar</strong> in 2 tsp <span class=\"text-danger\">[4 tsp]</span> <strong>boiled water</strong> in a large bowl</p>\r\n<p>Once dissolved, add the <strong>white wine vinegar</strong> and a generous pinch of <strong>salt </strong>&ndash;&nbsp;this is your<strong> pickling liquor</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-3-x700.jpg",
            "width": 700
          },
          {
