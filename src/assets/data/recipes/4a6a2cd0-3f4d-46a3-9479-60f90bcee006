  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p>Cut the <strong>potatoes</strong> (skins on) into <strong>chips</strong>, then add them to a baking tray with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong></p>\r\n<p>Slide the <strong>chips</strong> to one side of the baking tray and add the<strong> Cumberland sausages</strong></p>\r\n<p>Put the tray in the oven for 25-30 min or until the <strong>sausages</strong> are cooked through and the <strong>chips</strong> are golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-1-x400.jpg",
            "width": 400
