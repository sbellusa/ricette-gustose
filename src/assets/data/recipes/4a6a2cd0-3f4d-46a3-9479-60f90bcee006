          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p>\r\n<p>Grate the <strong>carrot<span class=\"text-danger\">[s]</span></strong> (skin on)&nbsp;</p>\r\n<p>Shred (or grate!) the <strong>baby white cabbage<span class=\"text-danger\">[s]</span> </strong>finely</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1215.-step-2-x700.jpg",
            "width": 700
          },
          {
