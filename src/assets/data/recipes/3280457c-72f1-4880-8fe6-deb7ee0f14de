            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the heated tray[s] from the oven and add your <strong>pizza base[s]</strong></p><p>Spread the <strong>pizza sauce </strong>evenly over the pizza base[s], then top with the <strong>tandoori-style chicken & peppers</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1690884540625-x200.jpg",
            "width": 200
