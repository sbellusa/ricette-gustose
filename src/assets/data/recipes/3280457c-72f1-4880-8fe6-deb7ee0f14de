            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top the pizza with the<strong> torn mozzarella</strong> and then put the tray[s] into the oven for 13-15 min or until the cheese has melted and the base is crispy – this is your <strong>tandoori-style chicken pizza</strong></p><p>Tip: Make sure the pizzas don't overlap on the tray to avoid raw dough!</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1690884543764-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1690884543764-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1690884543764-x700.jpg",
