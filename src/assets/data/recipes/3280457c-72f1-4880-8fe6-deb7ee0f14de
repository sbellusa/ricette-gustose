          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1690884535276-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain your <strong>mozzarella</strong>, then pat and squeeze as much liquid out as you can with kitchen paper</p><p>Tear the<strong> drained mozzarella</strong> into rough, bite-sized pieces</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1690884537440-x200.jpg",
