  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and chop the<strong> potatoes</strong> into bite-sized pieces, then peel the <strong>garlic cloves</strong></p><p>Add the<strong> chopped potatoes</strong> and <strong>peeled garlic</strong> to a pot of<strong> boiled water</strong> with a large pinch of<strong> salt</strong>, bring to the boil and cook over a high heat for 10-15 min or until fork-tender</p><p>Once cooked, drain and return them to the pot to steam dry</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1316.-step-1.new-x200.jpg",
