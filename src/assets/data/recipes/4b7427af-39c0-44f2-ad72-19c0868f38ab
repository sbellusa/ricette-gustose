            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>ciabatta[s] </strong>in half</p><p>Spread the <strong>king</strong> <strong>prawn toast mix </strong>onto each <strong>ciabatta base </strong>(save the lid for later!)<strong> </strong>–<strong> </strong>this is your <strong>king</strong> <strong>prawn ciabatta</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1681478908187-x200.jpg",
