            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1661183784778-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your<strong> cherry tomatoes</strong> in half</p><p>Wash your <strong>spinach</strong> and pat it dry with kitchen paper</p>",
      "order": 3,
      "media": {
        "images": [
