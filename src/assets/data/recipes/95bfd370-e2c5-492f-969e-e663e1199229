            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Dice</strong> the tomato<span class=\"text-danger\">(es)</span> finely</p>\r\n<p><strong>Remove</strong> the mint leaves and chop finely, discarding the stalks&nbsp;</p>\r\n<p><strong>Chop</strong> the parsley finely, including the stalks</p>\r\n<p><strong>Combine</strong> the tomato, mint, parsley and remaining red onion in a bowl and set aside until step 8</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-5-x200.jpg",
