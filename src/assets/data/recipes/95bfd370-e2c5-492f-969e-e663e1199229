  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Add</strong> the bulgur wheat to a pot with 180ml <span class=\"text-danger\">(360ml)</span> of boiling water, cover with a lid and place on a medium-low heat</p>\r\n<p><strong>Simmer</strong> for 5 min or until almost all the water is absorbed</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the bulgur from the heat and allow to rest with the lid on for 10 min or until all water has absorbed</p>\r\n<p><strong>Meanwhile</strong>, peel and finely dice the red onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and grate or finely chop the garlic</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the lamb mince, garlic, ground cumin, honey and half the red onion with a generous amount of salt and pepper in a bowl</p>\r\n<p><strong>Add </strong>3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of cooked bulgur</p>\r\n<p><strong>Mix</strong> thoroughly (use your hands for ease)</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Divide</strong> the mixture into 6<span class=\"text-danger\"> (12)</span> balls</p>\r\n<p><strong>Shape</strong> the balls into oval shapes (use wet hands to help the shaping process)</p>\r\n<p><strong>These</strong> are your kofta</p>\r\n<p><strong>Refrigerate</strong> the kofta until step 7 to help them firm up</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/351.-step-4-x700.jpg",
