    {
      "instruction": "<p><strong>Mix</strong> the yoghurt with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil and season generously with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": [
          {
