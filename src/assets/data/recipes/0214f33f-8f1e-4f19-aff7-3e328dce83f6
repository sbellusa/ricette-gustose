            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and chop (or grate) your <strong>garlic</strong></p><p>Strip your <strong>mint leaves</strong> from their stems and chop them roughly, discard the stems</p><p>Tip: Hold the top of the herb sprigs firmly and slide your fingers down their lengths to easily remove the leaves</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1713264482089-x200.jpg",
