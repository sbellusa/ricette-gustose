            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the sausages have browned, transfer them to a plate and set aside</p><p>Return the dish to a medium heat and add the <strong>diced onion</strong> with a pinch of <strong>salt</strong> and cook for 3-4 min or until beginning to soften</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1696243130578-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1696243130578-x400.jpg",
