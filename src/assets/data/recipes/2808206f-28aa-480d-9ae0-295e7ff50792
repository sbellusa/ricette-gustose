            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Drain and rinse your <strong>butter beans</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1696243127255-x200.jpg",
            "width": 200
