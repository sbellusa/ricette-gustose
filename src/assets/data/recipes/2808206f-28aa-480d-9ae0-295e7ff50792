  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Heat a large, wide-based, <strong>hob-safe oven-proof casserole dish</strong> with a small drizzle of <strong>vegetable oil </strong>over a high heat</p><p>Once hot, add your <strong>sausages</strong> to the pan and cook for 2-3 min on each side or until beginning to brown</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1696243123974-x200.jpg",
            "width": 200
