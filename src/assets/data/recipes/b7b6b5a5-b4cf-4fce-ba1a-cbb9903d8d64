          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice the <strong>spring onion[s]</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1614615190676-x200.jpg",
