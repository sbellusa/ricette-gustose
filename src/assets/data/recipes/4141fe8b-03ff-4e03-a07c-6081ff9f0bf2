            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>lettuce</strong>, then pat dry with kitchen paper and shred finely</p><p>Peel and grate your <strong>garlic</strong></p><p>Drain your <strong>sweetcorn</strong></p>",
      "order": 3,
      "media": {
        "images": [
