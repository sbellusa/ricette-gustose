          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1633431039855-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1633431039855-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1633431039855-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the broccoli is cooking, peel and finely chop (or grate) your <strong>garlic</strong></p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your<strong> ginger</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1633431117079-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1633431117079-x400.jpg",
