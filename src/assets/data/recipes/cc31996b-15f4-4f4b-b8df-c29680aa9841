          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1697475465851-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst everything is cooking, chop your<strong> coriander</strong> finely, including the stalks</p><p>Chop your <strong>tomato[es]</strong> finely</p><p>Zest <strong>half</strong> your <strong>lime[s]</strong> (try to grate lightly with a micro-plane or sharp box grater and avoid grating the white pith, as this is very bitter!), then chop the <strong>zested lime[s] </strong>in half</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1697475470335-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1697475470335-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1697475470335-x700.jpg",
