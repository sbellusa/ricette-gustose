  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Tip: This is to warm your tortillas – alternatively, add them to a plate and pop in the microwave!</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>chopped</strong> <strong>pepper & red onion </strong>with a pinch of <strong>salt </strong>and cook for 3-4 min until starting to soften</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1614101556572-x200.jpg",
