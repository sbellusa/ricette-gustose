          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1680278490586-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1680278490586-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>plant-based garlic & coriander butter chickpea burritos </strong>in half and serve</p><p>Tip: Watch out for any cardamom pods!</p><p>Enjoy!</p>",
      "order": 8,
