  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6 and boil a kettle</p>\n<p>Add the <strong>butternut squash cubes</strong> to a bowl with the<strong> red curry paste</strong> and a drizzle of <strong>vegetable oil</strong> and mix it up, then add to a tray</p>\n<p>Put the tray in the oven for 15-20 min or until cooked with a slight bite</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2118.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2118.-step-1-x400.jpg",
            "width": 400
