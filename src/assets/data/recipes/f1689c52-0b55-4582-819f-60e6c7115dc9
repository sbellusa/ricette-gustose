          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/967.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once done, add the<strong> sliced courgette</strong> to the red&nbsp;onion and cook for 3 min, stirring occasionally or until lightly browned and cooked but retaining a slight bite</p>",
