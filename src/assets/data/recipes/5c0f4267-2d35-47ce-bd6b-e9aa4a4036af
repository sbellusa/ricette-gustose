  "cooking_instructions": [
    {
      "instruction": "<p><span class=\"text-highlight\">Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</span></p>\r\n<p><span class=\"text-highlight\">Chop the <strong>cherry tomatoes</strong> in half</span></p>\r\n<p><span class=\"text-highlight\">Add&nbsp;them to a baking tray, drizzle with <strong>olive oil</strong> and season generously with <strong>salt</strong> and <strong>pepper</strong></span></p>\r\n<p><span class=\"text-highlight\">Put&nbsp;them in the oven for 20 min</span></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Meanwhile, place the<strong> rice</strong> in a pot with 350ml <span class=\"text-danger\">[700ml]</span>&nbsp;water, add the<strong> bay leaf<span class=\"text-danger\">[ves]</span>&nbsp;</strong>and bring to the boil over a high heat</span></p>\r\n<p><span class=\"text-highlight\">Once boiling reduce the heat to very low and cook, covered, for 10-15 min or until the rice is cooked</span></p>\r\n<p><span class=\"text-highlight\">Once cooked, place&nbsp;the<strong> smoked basa</strong> fillets over the rice and cook, covered, for a further 3 min or until the fish is cooked through</span></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Meanwhile, boil a kettle</span></p>\r\n<p><span class=\"text-highlight\">Place the<strong> egg<span class=\"text-danger\">[s]</span></strong>&nbsp;in a small pan, cover with boiling water and add a large pinch of <strong>salt</strong></span></p>\r\n<p><span class=\"text-highlight\">Cook&nbsp;over a high heat for 8 min, then drain and cool under cold running water for at least 3 min, alternatively put them in a bowl of ice cold water and set aside&nbsp;</span></p>\r\n<p><span class=\"text-highlight\">Tip: cooling eggs down quickly helps them peel much more easily</span></p>\r\n<p>&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Meanwhile, peel and chop the <strong>onion<span class=\"text-danger\">[s]</span></strong>&nbsp;finely</span></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Add&nbsp;a drizzle of <strong>olive oil</strong> to a large, wide-based pan (preferably non-stick) over a medium-low heat</span></p>\r\n<p><span class=\"text-highlight\">Once hot, add the <strong>onion</strong> and a pinch of <strong>salt</strong></span></p>\r\n<p><span class=\"text-highlight\">Cook for 5-7 min or until softened, then add and stir the <strong>curry powder</strong>&nbsp;through</span></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Peel the cooled <strong>egg<span class=\"text-danger\">[s]</span></strong>&nbsp;and cut into quarters</span></p>\r\n<p><span class=\"text-highlight\">Meanwhile, chop the <strong>parsley</strong> finely, including the stalks</span></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Remove the pan from the heat and add the&nbsp;cooked <strong>rice</strong> and<strong> fish&nbsp;</strong></span></p>\r\n<p><span class=\"text-highlight\">Mix gently, being careful not to break the fish up too much</span></p>\r\n<p><span class=\"text-highlight\">Taste&nbsp;for seasoning, adding more <strong>salt</strong> and <strong>pepper</strong> if needed</span></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/281.-step6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Stir the <strong>parsley</strong> through the kedgeree</span></p>\r\n<p><span class=\"text-highlight\">Garnish with the<strong> tomatoes</strong> and <strong>eggs</strong></span></p>\r\n<p><span class=\"text-highlight\">Enjoy!</span></p>",
