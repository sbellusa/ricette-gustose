  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7 with an oven-proof dish inside</p>\r\n<p><strong>Seperate</strong> the greens from the whites of the pak choi and discard the bases</p>\r\n<p><strong>Trim</strong> any large chunks into bite-size pieces (keep the greens a bit large as they wilt)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the ginger and chop finely</p>\r\n<p><strong>Cut</strong> away the stem<span class=\"text-danger\">(s)</span> from the chilli<span class=\"text-danger\">(es)</span>, deseed and chop finely</p>\r\n<p><strong>Combine</strong> the soy, tamarind, honey, sesame oil, 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar and 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of water</p>\r\n<p><strong>Mix</strong> well and set aside as the sauce for step 8</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a pan on a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, sear the pork for 2 min on each side, or until browned all over</p>\r\n<p><strong>Add</strong> the chilli (careful, adjust the amount to your preferred hotness) and ginger to the pan and cook for 30 sec or until fragrant, stirring frequently</p>\r\n<p><strong>Once</strong> the oil is hot, sear the pork for 2 min on each side, or until browned all over</p>\r\n<p><strong>Place</strong> the pork dish in the oven and cook for 8-10 min, or until cooked through, flipping half way</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the heated dish from the oven</p>\r\n<p><strong>Transfer</strong> the pork, chilli and ginger into the dish</p>\r\n<p><strong>Keep</strong> the pork pan (used in step 7)</p>\r\n<p><strong>Place</strong> the pork dish in the oven and cook for 8-10 min, or until cooked through, flipping half way</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to a boil</p>\r\n<p><strong>Once</strong> boiling, lower the heat and simmer covered for 15-20 min or until the water is absorbed</p>\r\n<p><strong>Check</strong> to prevent over-cooking and once done, set aside until serving</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the pork is done, remove the dish from the oven, cover well and allow to rest until ready to serve</p>\r\n<p><strong>Meanwhile</strong>, return the pork pan to a high heat</p>\r\n<p><strong>Add</strong> the whites of the pak choi and cook for 3 min, or until sweating, stirring occassionally</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 3-4 tbsp of water to the pan, then the green tops, and cook for 2 min, or until tender</p>\r\n<p><strong>Move</strong> the pok choi to a plate and season to taste</p>\r\n<p><strong>Reserve</strong> the pan for step 8</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the tamarind sauce to the pak choi pan and reduce by half on a high heat, or to desired taste and thickness</p>\r\n<p>Tip: the sauce will intensify in flavour the longer it reduces</p>\r\n<p><strong>Slice</strong> the pork thinly and serve with rice, pak choi, and spoonfulls of the sauce (and any leftover pork juices)</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
