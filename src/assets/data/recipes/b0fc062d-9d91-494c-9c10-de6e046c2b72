          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683887427717-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1683887427717-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) over a medium-high heat with a drizzle of <strong>vegetable oil</strong></p><p>Boil a kettle</p><p>Once hot, add the <strong>sliced onion</strong>, <strong>chopped aubergine </strong>and <strong>chopped pepper </strong>with a pinch of <strong>salt</strong></p><p>Cook for 5-7 min or until starting to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1683887516973-x200.jpg",
            "width": 200
