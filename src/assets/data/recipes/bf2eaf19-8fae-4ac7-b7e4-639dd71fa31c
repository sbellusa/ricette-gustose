  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely chop (or grate) your <strong>garlic </strong>and peel and finely dice your <strong>brown onion[s]</strong></p><p>Top, tail, peel and grate your <strong>carrot[s] </strong></p><p>Peel, then dice your <strong>potato[es]</strong> into small bite-sized pieces</p><p>Rinse your <strong>red lentils </strong>in a sieve under <strong>cold running water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674577907304-x200.jpg",
            "width": 200
