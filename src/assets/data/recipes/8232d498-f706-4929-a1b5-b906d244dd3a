  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air, then rinse your <strong>sushi rice </strong>in a sieve under <strong>cold running water</strong> for 30 secs and set aside to drain fully</p><p>Add the <strong>drained rice</strong> with 200ml <span class=\"text-purple\">[300ml] </span><span class=\"text-danger\">[400ml]</span> <strong>cold water</strong> to a pot with a lid and bring to the boil over a high heat, then reduce the heat to low until very gently bubbling and cook, covered, for 15 min, then remove the pot from the heat and keep covered for a further 10 min before serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1687441285256-x200.jpg",
            "width": 200
