  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Zest</strong>&nbsp;the lemon<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Cut</strong>&nbsp;2 <span class=\"text-danger\">[4]</span>&nbsp;thin slices from the centre of the lemon<span class=\"text-danger\">[s]</span>&nbsp;(save for garnish)</p>\r\n<p><strong>Reserve&nbsp;</strong>the lemon halves for later</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong>&nbsp;the fish fillets to a baking tray (use tin foil to avoid mess) and&nbsp;season them lightly with salt and pepper</p>\r\n<p><strong>Combine</strong>&nbsp;the lemon zest in a small bowl with 1 tbsp<span class=\"text-danger\">&nbsp;[2 tbsp]</span>&nbsp;vegetable oil</p>\r\n<p><strong>Spread</strong>&nbsp;the lemon zest evenly over the fish fillets</p>\r\n<p><strong>Put</strong> them in the oven for 10 min or until your fish is cooked through</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a pot of boiled water over&nbsp;a high heat</p>\r\n<p><strong>Cut</strong> the potato<span class=\"text-danger\">[es]</span>&nbsp;(skins on) into bite-size pieces, add them to the pot, cover and bring to the boil</p>\r\n<p><strong>Cook</strong> for 5 min until almost fork-tender</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, drain and rinse the butter beans</p>\r\n<p><strong>Cut</strong> the runner beans into bite-size pieces</p>\r\n<p><strong>Add</strong> the runner beans&nbsp;to the potato pot and boil a further 5 min</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the fish is cooked,&nbsp;remove&nbsp;it&nbsp;from the oven</p>\r\n<p><strong>Tip:</strong> your fish is cooked when it flakes easily and is opaque</p>\r\n<p><strong>Add</strong> a knob of butter to the warm baking tray</p>\r\n<p><strong>Squeeze</strong> the remaining lemon halves over the fish</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the potatoes and runner beans and&nbsp;return them to the pot with the&nbsp;butter&nbsp;beans</p>\r\n<p><strong>Add</strong> the dill, a large knob of butter and season generously with salt and pepper</p>\r\n<p><strong>Smash</strong> the beans and potatoes briefly with a potato masher (smashing is a lighter version of mashing and ensures that a course texture is maintained)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Divide</strong> the smashed-bean potatoes between each plate</p>\r\n<p><strong>Place</strong> the fish over the smashed potatoes</p>\r\n<p><strong>Swirl</strong> the baking tray around to combine the lemon and butter that remains</p>\r\n<p><strong>This</strong> is your lemon butter</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/547.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drizzle</strong> the lemon butter over each piece of fish and garnish with the sliced lemon</p>\r\n<p><strong>Enjoy!</strong></p>",
