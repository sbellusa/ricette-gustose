  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Cut the <strong>tofu</strong> into 3<span class=\"text-danger\"> </span>slices per person</p><p>Add the <strong>tofu slices</strong> to a medium bowl with 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp] </span><strong>sugar</strong> and <strong>half</strong> your <strong>tamari soy sauce</strong> (save the rest for later!) and your <strong>cornflour</strong></p><p>Give everything a good mix up and set aside to marinate</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1670922908334-x200.jpg",
            "width": 200
