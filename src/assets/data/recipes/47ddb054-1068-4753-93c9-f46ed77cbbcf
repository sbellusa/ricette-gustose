            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once starting to soften, push the <strong>sliced onion</strong> to one side of the pan and increase the heat to high, then add your <strong>chicken breast strips</strong></p><p>Cook for 10-12 min or until browned and cooked through (no pink meat!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1886.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1886.-step-4-x400.jpg",
            "width": 400
