          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1605701185407-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1605701185407-x1000.jpg",
