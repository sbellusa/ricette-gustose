  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Chop your<strong> leek[s]</strong> in half lengthways, wash thoroughly to remove any grit then top, tail and slice finely</p><p>Heat a medium-sized pot (with a matching lid) over a medium-high heat with a small drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the <strong>sliced leek </strong>with a pinch of <strong>salt </strong>and cook for 2-3 min or until softened, then transfer the <strong>cooked leek </strong>to a bowl and reserve the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1667303663110-x200.jpg",
            "width": 200
