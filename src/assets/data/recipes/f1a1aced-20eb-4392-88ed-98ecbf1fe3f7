  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Heat a pot (with a matching lid) over a medium-high heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add your <strong>diced chicken breast</strong> and cook for 2-3 min or until starting to brown</p>",
      "order": 1,
      "media": {
