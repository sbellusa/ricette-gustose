            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, drain your <strong>sweetcorn</strong></p><p>Grate your <strong>cheddar cheese</strong> finely</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1723822640510-x200.jpg",
            "width": 200
