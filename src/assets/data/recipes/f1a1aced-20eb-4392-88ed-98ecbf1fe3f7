      }
    },
    {
      "instruction": "<p>Slice <strong>half </strong>your <strong>green chilli[es]</strong> into rounds</p><p>Finely dice the <strong>remaining</strong> <strong>green chilli[es]</strong></p>",
      "order": 2,
