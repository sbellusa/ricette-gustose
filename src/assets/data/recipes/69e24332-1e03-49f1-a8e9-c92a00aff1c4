            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Roll your <strong>lemon[s]</strong> with your hand on a hard surface (to release more juice) and cut in half</p><p>Chop your <strong>parsley</strong> finely, including the stalks</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1720089574915-x200.jpg",
