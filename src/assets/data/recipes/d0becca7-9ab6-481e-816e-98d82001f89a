            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray[s] in the oven and cook for 12-15 min or until the pepper is tender – this is your <strong>roast veg</strong></p>",
      "order": 4,
      "media": {
        "images": [
