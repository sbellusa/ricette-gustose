            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-4-1691484292814-x200.jpg",
            "width": 200
          },
