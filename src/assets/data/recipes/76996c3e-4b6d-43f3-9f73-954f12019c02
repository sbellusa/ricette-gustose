  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely chop your<strong> brown onion[s]</strong></p><p>Top, tail, peel and finely chop your <strong>carrot[s]</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-4-1691484284265-x200.jpg",
