            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-4-1691484292814-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-4-1691484292814-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-4-1691484292814-x1000.jpg",
            "width": 1000
