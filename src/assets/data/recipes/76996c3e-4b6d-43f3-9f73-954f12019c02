          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-4-1691484284265-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>chopped onion</strong> and<strong> carrot</strong> with a pinch of <strong>salt</strong> and cook for 3-4 min or until beginning to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-4-1691484364544-x200.jpg",
