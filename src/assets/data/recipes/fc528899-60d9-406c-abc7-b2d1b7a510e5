  "cooking_instructions": [
    {
      "instruction": "<p>Rinse your <strong>sushi rice</strong> in a sieve under <strong>cold running water</strong> for 30 secs (use your hands to really wash the grains!), then set aside to drain fully</p><p>Add the <strong>drained rice</strong> with 200ml <span class=\"text-purple\">[300ml]<span class=\"text-danger\"> </span>[400ml]<strong> </span>cold water</strong> and a pinch of <strong>salt</strong> to a pot with a lid and bring to the boil over a high heat</p>",
      "order": 1,
      "media": {
