  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice your <strong>sweet potatoes</strong> (skins on) into discs (approx. 0.5cm thick)</p><p>Add the <strong>sweet potato discs</strong> to a baking tray with a drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong></p><p>Put the tray in the oven and cook for 10-12 min until softened slightly</p>",
      "order": 1,
      "media": {
        "images": [
          {
