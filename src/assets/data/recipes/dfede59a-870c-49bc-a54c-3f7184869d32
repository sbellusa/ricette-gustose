  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span>&nbsp;and chop coarsely</p>\r\n<p><strong>Peel</strong> the garlic and chop coarsely&nbsp;</p>\r\n<p><strong>Peel</strong> the ginger (scrape the skin off with a teaspoon) and chop coarsely</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
