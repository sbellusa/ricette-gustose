          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice, 350ml<span class=\"text-danger\"> (700ml)</span> water and salt (optional) to a pot with a lid over a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p><strong>Once</strong> cooked, remove from the heat and keep covered until serving</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/544.-step-2-x200.jpg",
