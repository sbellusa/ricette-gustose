            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1/2 tbsp <span class=\"text-purple\">[3/4 tbsp]</span> <span class=\"text-danger\">[1 tbsp]</span> <strong>vegetable oil</strong> over a medium-high heat</p><p>Drain your <strong>king prawns</strong></p><p>Once hot, add the <strong>drained</strong> <strong>king prawns</strong> and cook for 4-5 min or until cooked through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1581674403423-x200.jpg",
