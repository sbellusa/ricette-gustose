            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and grate (or finely chop) your <strong>garlic</strong></p><p>Cut your <strong>red chilli[es] </strong>in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1581674392408-x200.jpg",
