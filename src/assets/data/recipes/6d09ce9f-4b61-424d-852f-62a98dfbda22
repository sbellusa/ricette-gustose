            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> cucumber matchsticks</strong> and <strong>grated carrot </strong>to a bowl</p><p>Add your<strong> rice vinegar</strong> with a pinch of <strong>salt</strong> and give everything a good mix up – this is your <strong>quick-pickled carrot & cucumber</strong></p><p>Set aside for later</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581674387237-x200.jpg",
            "width": 200
