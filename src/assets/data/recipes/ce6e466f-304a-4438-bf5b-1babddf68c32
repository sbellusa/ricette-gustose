  "cooking_instructions": [
    {
      "instruction": "<p>Top, tail, peel and grate your <strong>carrot[s]</strong>, then peel and finely chop (or grate) your <strong>garlic</strong></p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your<strong> ginger</strong></p><p>Peel and finely chop your <strong>shallot[s]</strong></p><p>Cut your <strong>red chilli[es]</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1628779264543-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1628779264543-x400.jpg",
