            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your<strong> hot dog sausage[s]</strong> to the other side of the baking tray[s] and put the tray[s] in the oven for 20-25 min or until the sausage[s] is cooked through (no pink meat!) and the chips are golden and crispy</p>",
      "order": 2,
      "media": {
        "images": [
