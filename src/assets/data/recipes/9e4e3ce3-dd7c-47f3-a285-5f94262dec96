  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220ºC/ 200ºC (fan)/ gas 7 and boil half a kettle</p><p>Cut your <strong>potatoes</strong> (skins on) into chips</p><p>Add the <strong>chips</strong> to one side of a <strong>baking paper</strong>-lined baking tray (or two!) with a drizzle of <strong>vegetable oil</strong> and a pinch of<strong> salt</strong> and <strong>pepper</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1722267827274-x200.jpg",
            "width": 200
