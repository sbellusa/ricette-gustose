  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil half a kettle</p><p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Peel and roughly chop your <strong>potato[es]</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2478Step-1-1637330089894-x200.jpeg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2478Step-1-1637330089894-x400.jpeg",
