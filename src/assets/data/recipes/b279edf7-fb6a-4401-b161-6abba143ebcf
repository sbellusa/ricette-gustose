  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Peel and finely slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Deseed the <strong>pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p>",
      "order": 1,
      "media": {
        "images": [
