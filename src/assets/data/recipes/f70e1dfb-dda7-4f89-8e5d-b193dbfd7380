          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, top, tail and grate your <strong>carrot[s]</strong></p><p>Trim, then roughly chop your <strong>spring onion[s]</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1657108968749-x200.jpg",
