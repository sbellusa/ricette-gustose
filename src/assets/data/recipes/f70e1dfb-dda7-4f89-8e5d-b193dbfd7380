          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1657108968749-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pork has started to brown, add your <strong>ginger & garlic paste </strong>and <strong>sriracha </strong>(can't handle the heat? Go easy!) and cook for 1 min further until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1657108972323-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1657108972323-x400.jpg",
