  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ gas 4</p><p>Boil a kettle</p><p>Peel and chop the <strong>potatoes</strong> roughly into bite-sized pieces</p><p>Add the <strong>chopped</strong> <strong>potatoes</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong> and cook over a high heat for 15 min or until they're fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-2-1636448520872-x200.jpg",
