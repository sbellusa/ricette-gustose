            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, cover the<strong> chicken breasts</strong> in<strong> cling film</strong> and bash them with a <strong>rolling pin</strong> until evenly flattened and approx. 1cm in thickness</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1636448529059-x200.jpg",
