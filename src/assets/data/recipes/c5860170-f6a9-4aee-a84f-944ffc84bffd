            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Grate your<strong> cheddar flavour block</strong></p><p>Trim, then finely slice your <strong>spring onion[s]</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-1679047463384-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-1679047463384-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-1679047463384-x700.jpg",
            "width": 700
          },
          {
