  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 180°C/ 160°C (fan)/ gas 4</p><p>Boil a full kettle</p><p>Crush the <strong>garlic cloves</strong> open by squashing them with the side of a knife and remove the skins</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1622555693034-x200.jpg",
