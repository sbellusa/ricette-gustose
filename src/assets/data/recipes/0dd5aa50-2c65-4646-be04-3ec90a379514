          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the reserved pan to a medium heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the patties and cook for 3 min on one side only</p>\r\n<p><strong>Meanwhile</strong>, cut the cheese in half&nbsp;</p>\r\n<p><strong>Flip</strong>&nbsp;the patties and add a piece of cheese to each pattie, cover and cook for a further 2-3 min or until the cheese has started to melt</p>\r\n<p>&nbsp;</p>",
      "order": 6,
      "media": {
        "images": [
          {
