  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes lengthways into wedges (skins on)</p>\r\n<p><strong>Add</strong> them to an oven-proof tray, drizzle with 1-2 tbsp vegetable oil - season generously with salt and put them in the oven for 30 min or until crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, remove&nbsp;half <span class=\"text-danger\">[all]</span>&nbsp;of the black garlic cloves from the bulb&nbsp;</p>\r\n<p><strong>Chop</strong> the black garlic as finely as you can (it will be squidgy!)</p>\r\n<p><strong>Combine</strong> the beef mince and black garlic in a bowl and season generously with salt and pepper&nbsp;</p>\r\n<p><strong>Tip:</strong> you want the black garlic to be evenly distributed throughout the mince&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Massage</strong> the mince with clean hands for a minute (this helps them hold their shape whilst cooking)&nbsp;</p>\r\n<p><strong>Divide&nbsp;</strong>and shape the mince into 2 <span class=\"text-danger\">[4]</span>&nbsp;patties (make them slightly larger than the width of the brioche rolls as they shrink when they cook) and put them in the freezer (chilling the meat helps them hold their shape too) until step 7 &nbsp; &nbsp; &nbsp; &nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick with a matching lid) over a high heat</p>\r\n<p><strong>Cut</strong> the brioche rolls in half&nbsp;</p>\r\n<p><strong>Once</strong>&nbsp;hot, add the brioche cut-side down, and cook for 3 min or until lightly toasted&nbsp;</p>\r\n<p><strong>Once</strong> toasted, set aside until serving and reserve the pan&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-4-x1000.jpg",
