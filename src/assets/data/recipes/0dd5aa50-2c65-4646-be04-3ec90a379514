          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the tomato<span class=\"text-danger\">[es]</span>&nbsp;</p>\r\n<p><strong>Wash</strong> the little gem lettuce and remove 2 <span class=\"text-danger\">[4]</span>&nbsp;whole outer leaves and set aside for serving</p>\r\n<p><strong>Cut</strong> the little gem<span class=\"text-danger\">[s]</span>&nbsp;in half, lengthways</p>\r\n<p><strong>Return</strong> the pan to a high heat, add the lettuce, cut-side down and cook&nbsp;for 2 min, then transfer to serving plates, reserving the pan&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/578.-step-5-x400.jpg",
