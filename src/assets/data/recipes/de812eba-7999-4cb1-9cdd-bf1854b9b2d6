  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Chop</strong> the pistachios coarsely</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>\r\n<p><strong>Combine</strong> the lamb mince, garlic, sultanas, cumin and pistachios in a mixing bowl</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-1-x400.jpg",
