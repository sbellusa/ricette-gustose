        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are tender, drain and return them to the cooking pot&nbsp;</p>\r\n<p><strong>Add</strong> a knob of butter and a splash of milk and mash until smooth</p>\r\n<p><strong>Season</strong> generously with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-7-x400.jpg",
            "width": 400
          },
          {
