            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Season</strong> the mixture generously with salt and pepper</p>\r\n<p><strong>Mix</strong> everything with clean hands</p>\r\n<p><strong>Divide</strong> and roll into 6 <span class=\"text-danger\">(12)</span> even balls, then refrigerate until step 5</p>\r\n<p>Tip: Chilling the meat helps it hold its shape when cooking</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-2-x200.jpg",
            "width": 200
          },
          {
