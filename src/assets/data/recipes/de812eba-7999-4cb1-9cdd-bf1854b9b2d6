            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, combine the pomegranate molasses in a large mixing bowl with 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> olive oil and a pinch of salt and pepper</p>\r\n<p><strong>This</strong> is your pomegranate dressing</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-6-x400.jpg",
