            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel the carrot<span class=\"text-danger\">(s)</span>, discarding the root end<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Continue</strong> to peel lengths off the carrot until you have a pile of carrot 'ribbons' and grate the remaining core&nbsp;</p>\r\n<p><strong>Place</strong> the ribbons in a bowl of cold water &nbsp;</p>\r\n<p><strong>Chop</strong> the coriander finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/490.-step-4-x200.jpg",
            "width": 200
          },
          {
