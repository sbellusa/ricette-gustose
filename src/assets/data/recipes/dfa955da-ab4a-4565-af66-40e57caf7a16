  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> and slice the carrot<span class=\"text-danger\">[s]</span> down the centre lengthways, then into bite-sized pieces</p>\r\n<p><strong>Slice</strong> the celery into bite-size pieces</p>\r\n<p><strong>Peel</strong> and slice the onion<span class=\"text-danger\">[s]</span> finely</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
