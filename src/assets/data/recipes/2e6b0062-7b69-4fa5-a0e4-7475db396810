  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ 395°F/ Gas 6 and boil a full kettle</p><p>Cut the <strong>potatoes</strong> (skins on) into large, bite-sized pieces</p><p>Add the <strong>chopped potatoes</strong> to a pot with plenty of<strong> boiled water</strong> and a generous pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 12-15 min or until fork-tender</p><p>Once done, drain and return to the pot to steam dry</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1605707770606-x200.jpg",
            "width": 200
