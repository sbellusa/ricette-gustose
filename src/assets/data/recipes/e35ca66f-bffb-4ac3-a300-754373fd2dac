  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a pot (with a matching lid) with a generous knob of <strong>butter</strong> over a medium heat</p><p>Once melted, add the <strong>bulgur wheat</strong> and cook for 1-2 min or until toasted</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1592297242114-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1592297242114-x400.jpg",
