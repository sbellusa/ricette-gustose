  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, boil a kettle, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Dissolve your <strong>chicken stock mix</strong> in 50ml <span class=\"text-purple\">[65ml]</span> <span class=\"text-danger\">[85ml]</span> <strong>boiled water</strong>, then add your <strong>tomato paste</strong>, <strong>tomato ketchup</strong>, <strong>hoisin sauce</strong>, <strong>Dijon mustard</strong>, <strong>Henderson's Relish</strong>, 1 tbsp<span class=\"text-purple\"> [1 1/2 tbsp]</span> <span class=\"text-danger\">[2 tbsp]</span> <strong>sugar </strong>and a generous grind of <strong>black pepper </strong>and stir it all together – this is your<strong> BBQ hoisin sauce</strong></p>",
      "order": 1,
      "media": {
        "images": [
