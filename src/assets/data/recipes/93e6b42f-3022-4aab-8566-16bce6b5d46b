            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>tomato[es] </strong>into wedges</p><p>Top, tail, peel and grate your <strong>carrot[s]</strong></p><p>Chop your <strong>coriander </strong>finely, including the stalks</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-31-1713259998892-x200.jpg",
