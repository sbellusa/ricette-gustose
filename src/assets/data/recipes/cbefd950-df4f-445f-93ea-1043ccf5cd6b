  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 7, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Cut your<strong> potatoes</strong> (skins on) into chips</p><p>Add the chips to a baking tray with a drizzle of<strong> vegetable oil</strong> and a pinch of<strong> salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599054533737-x200.jpg",
            "width": 200
