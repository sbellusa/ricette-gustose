          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599054533737-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, sprinkle each <strong>chicken breast portion</strong> with your <strong>dried oregano</strong> and a pinch of <strong>salt </strong>– this is your <strong>seasoned chicken</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1599054553149-x200.jpg",
            "width": 200
          },
          {
