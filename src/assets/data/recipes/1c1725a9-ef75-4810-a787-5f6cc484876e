          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1626176890554-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, return the reserved pot to a medium heat with a drizzle of<strong> vegetable oil</strong></p><p>Once hot, add the<strong> sliced spring greens</strong>, <strong>chopped garlic</strong> and a generous pinch of <strong>salt</strong> and cook for 1 min or until starting to wilt</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1626176902606-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1626176902606-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1626176902606-x700.jpg",
