            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1706630984825-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the stew is cooking, wash your <strong>spinach</strong></p><p>Add the<strong> spinach</strong> to the pan and cook, covered, for 1-2 min or until the spinach is wilted</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1706630988549-x200.jpg",
