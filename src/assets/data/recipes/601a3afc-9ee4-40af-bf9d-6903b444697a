  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Boil a full kettle</p><p>Deseed your<strong> pepper[s]</strong><span class=\"text-danger\"> </span>(scrape the seeds and pith out with a teaspoon) and cut into thick strips</p><p>Top, tail then slice your <strong>courgette[s]</strong> into rounds</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1597159462710-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1597159462710-x400.jpg",
            "width": 400
