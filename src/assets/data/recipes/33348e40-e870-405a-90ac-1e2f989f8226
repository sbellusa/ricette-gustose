            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely slice the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Return the pan to a medium heat</p><p>Once hot, add the<strong> sliced onion</strong> and cook for 5-6 min or until beginning to soften</p>",
      "order": 2,
      "media": {
