          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1583491305869-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>one-pot chorizo minestrone</strong> </p><p>Garnish with the <strong>reserved chopped basil</strong></p><p>Enjoy!</p>",
