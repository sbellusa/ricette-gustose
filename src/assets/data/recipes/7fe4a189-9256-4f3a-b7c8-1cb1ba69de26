            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Peel and finely chop your <strong>shallot[s]</strong></p><p>Trim, then chop your<strong> green beans</strong> into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1598263085569-x200.jpg",
