            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the pizza[s] is cooking, heat a large, wide-based pan (preferably non-stick) over a medium heat with 15g <span class=\"text-purple\">[25g]</span> <span class=\"text-danger\">[30g]</span> <strong>butter</strong></p><p>Once melted, add 15g <span class=\"text-purple\">[25g]</span> <span class=\"text-danger\">[30g]</span> <strong>flour</strong> and stir with a wooden spoon for 1-2 min or until a sandy paste forms – this is your <strong>roux</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1606304015590-x200.jpg",
