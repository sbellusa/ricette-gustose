  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then boil a kettle and take your <strong>chicken</strong> out of the fridge, open the packet and let it air </p><p>Add your <strong>bulgur wheat </strong>to a pot with plenty of <strong>boiled water</strong> and a pinch of <strong>salt</strong>,<strong> </strong>bring to the boil over a high heat and cook for 7-9 min or until tender with a slight bite</p><p>Once cooked, drain and return to the pot</p>",
      "order": 1,
      "media": {
        "images": [
