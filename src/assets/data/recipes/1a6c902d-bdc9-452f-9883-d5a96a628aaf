  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut the <strong>potatoes</strong> (skins on) into chips</p><p>Add the<strong> chips</strong> to a baking tray with the <strong>nigella seeds</strong>, a drizzle of <strong>vegetable oil</strong> and a generous pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
