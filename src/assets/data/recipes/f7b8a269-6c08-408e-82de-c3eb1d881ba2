  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6 and boil a kettle</p><p>Chop the <strong>waxy potatoes</strong> (skins on) into large bite-sized pieces</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Peel and chop most of the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into wedges and finely dice the rest</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the<strong> vegetable stock mix</strong> in 300ml <span class=\"text-danger\">[500ml]</span> <strong>boiled water</strong></p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a generous drizzle of <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the<strong> diced red onion</strong>,<strong> black mustard seeds</strong>  with the <strong>ground</strong> <strong>turmeric</strong> and<strong> ground cumin</strong>, <strong>chopped potatoes</strong>, 1/3 of the<strong> chopped garlic </strong>and a generous pinch of <strong>salt</strong>, then cook, covered, for 15-18 min or until almost tender</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2342Step-2-x200.jpg",
