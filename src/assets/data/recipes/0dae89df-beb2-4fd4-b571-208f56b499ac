          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the cherry tomatoes in half</p>\r\n<p><strong>Cut</strong> the lime<span class=\"text-danger\">(s)</span> into quarters</p>\r\n<p><strong>Chop</strong> the coriander finely, including the stalks</p>\r\n<p><strong>Peel</strong> the skin off the mackerel (discard) and tear it up</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the mackerel, cherry tomatoes, juice of half the&nbsp;<span class=\"text-danger\">(whole)</span>&nbsp;lime and half the coriander to the pan and reduce the heat to low</p>\r\n<p><strong>Carefully</strong> stir all the ingredients through the rice</p>\r\n<p><strong>Taste</strong>&nbsp;and tweak for seasoning&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
