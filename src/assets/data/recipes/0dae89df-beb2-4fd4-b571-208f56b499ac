          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cooled rice to the pan and mix in gently&nbsp;</p>\r\n<p>Tip:&nbsp;Cooling the rice stops it clumping together</p>\r\n<p><strong>Cook</strong> for 4 min or until the rice has warmed through</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/419.-step-5-x1000.jpg",
