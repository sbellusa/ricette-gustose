          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1648550294038-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1648550294038-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1648550294038-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1648550294038-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Moroccan-style lamb cottage pie</strong> with the <strong>sumac carrots</strong> to the side</p><p>Sprinkle the <strong>remaining chopped parsley</strong> over the <strong>sumac carrots</strong></p><p>Enjoy!</p>",
      "order": 8,
