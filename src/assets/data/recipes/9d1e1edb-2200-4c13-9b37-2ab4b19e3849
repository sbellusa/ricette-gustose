  "cooking_instructions": [
    {
      "instruction": "<p><strong>Place</strong> the diced chicken in a bowl with half the balsamic vinegar (save the rest for step 6)</p>\r\n<p><strong>Add</strong> 1-2 tbsp olive oil and season generously with salt and pepper</p>\r\n<p><strong>Mix</strong> well and leave to marinate until step 4</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and chop the parsnip<span class=\"text-danger\">(s)</span> into small bite-size pieces, discarding the root end<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Slice</strong> the leek<span class=\"text-danger\">(s)</span> across into thin coins</p>\r\n<p><strong>Set</strong> the coins in a sieve and rinse under cold water to remove any grit</p>\r\n<p><strong>Boil</strong> a kettle</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely chop the shallots</p>\r\n<p><strong>Strip</strong> the rosemary leaves from the stalks</p>\r\n<p><strong>Finely</strong> chop the leaves and discard the stalks</p>\r\n<p><strong>Place</strong> a large, wide-based pan over a medium-high heat</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> hot, add the chicken to the dry pan and cook for 2-3 min or until starting to brown</p>\r\n<p><strong>Meanwhile</strong>, peel and chop (or grate) the garlic</p>\r\n<p><strong>Set</strong> the chicken aside on a plate for later and add 1-2 tbsp olive oil and a knob of butter to the pan</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> hot, add the parsnips and cook for 3-4 min or until lightly caramelised, stirring occasionally</p>\r\n<p><strong>Meanwhile</strong>, dissolve the stock cube<span class=\"text-danger\">(s)</span> in 850ml <span class=\"text-danger\">(1.7L)</span> boiled water</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice, shallots, garlic, leek and rosemary to the pan and stir for 2 min</p>\r\n<p><strong>Add</strong> 200ml <span class=\"text-danger\">(400ml)</span> stock and the remaining balsamic vinegar</p>\r\n<p><strong>Reduce</strong> the heat to medium and stir until nearly all the stock is absorbed</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Continue</strong> to add the stock a quarter at a time, stirring continuously for 15-20 min or until all the stock is absorbed and the rice is tender</p>\r\n<p>Tip: Stirring releases the starch from the rice and makes it creamy</p>\r\n<p><strong>Return</strong> the chicken to the pot and cook for 3-4 min or until cooked through</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/175.-step-7-x400.jpg",
            "width": 400
