            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Prepare your Tenderstem</strong></p>\n<p>Slice the <strong>Tenderstem broccoli</strong> until you reach the heads – keep the tips whole. Set aside.</p>\n<p>Re-boil a kettle.</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1360.-step-2.new1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1360.-step-2.new1-x400.jpg",
