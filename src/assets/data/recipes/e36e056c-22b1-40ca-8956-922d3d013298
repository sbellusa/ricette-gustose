  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat your oven and start preparing your sauce</strong></p>\n<p>Boil a kettle.</p>\n<p>Set the oven to 200°C/ 180°C (fan)/ 400°F/ Gas 6.</p>\n<p>Slice the<strong> lemon<span class=\"text-danger\">[s]</span></strong> into wedges.</p>\n<p>Chop the <strong>chives</strong> and the <strong>dill stalks</strong> finely (reserve the leaves for garnish!). </p>\n<p>Dissolve 1/2 <span class=\"text-danger\">[1]</span> <strong>chicken stock cube</strong> in 250ml <span class=\"text-danger\">[450ml]</span> <strong>boiled water </strong>and set aside.</p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1360.-step-1-x200.jpg",
            "width": 200
