            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/340.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span> <span class=\"text-danger\">[2 tbsp] </span><strong>olive oil</strong> over a medium heat</p><p>Once hot, add the <strong>diced onion</strong> with a pinch of <strong>salt</strong> and cook for 3 min until soft but not coloured</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/340.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/340.-step-3-x400.jpg",
