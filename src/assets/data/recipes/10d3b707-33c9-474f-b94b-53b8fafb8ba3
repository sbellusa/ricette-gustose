  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and finely dice your <strong>shallot[s]</strong></p><p>Deseed your<strong> pepper[s]</strong><span class=\"text-danger\"> </span>(scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Add the <strong>diced shallot </strong>to a small bowl with your <strong>white wine vinegar</strong> and a pinch of <strong>salt </strong>and set aside – this is your <strong>quick-pickled shallot</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1655205347556-x200.jpg",
            "width": 200
