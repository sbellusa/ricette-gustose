          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1893.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the veggie mix is cooking, dissolve <strong>vegetable stock mix </strong>in 150ml <span class=\"text-danger\">[250ml] </span><strong>boiled water</strong></p><p>Drain and rinse the <strong>green lentils</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1893.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1893.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1893.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1893.-step-4-x1000.jpg",
