    },
    {
      "instruction": "<p>Meanwhile, trim, then slice your<strong> spring onion[s]</strong> finely</p><p>Chop<span class=\"text-danger\"> </span>your <strong>capers</strong> finely</p>",
      "order": 2,
      "media": {
        "images": [
          {
