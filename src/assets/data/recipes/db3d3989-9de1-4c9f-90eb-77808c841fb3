  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut your <strong>potatoes</strong> (skins on) into chips</p><p>Add the <strong>chips</strong> to a baking tray (or two!) with a drizzle of <strong>vegetable oil</strong> and a generous pinch of <strong>salt</strong> and give everything a good mix up</p><p>Put the tray[s] in the oven for 20-25 min or until the chips are golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1012.-step-1-x200.jpg",
