            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1670317100319-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your<strong> mayo </strong>with the juice of <strong>half</strong> your<span class=\"text-danger\"> </span><strong>lime[s] </strong>and the<strong> lime zest</strong> in a small bowl – this is your <strong>lime mayo</strong></p>",
      "order": 4,
      "media": {
        "images": [
