            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>pineapple slices</strong> to a bowl with the <strong>Marmite </strong>and give it a good mix up until all of the pineapple is coated – this is your <strong>Marmite pineapple</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1600784934505-x200.jpg",
