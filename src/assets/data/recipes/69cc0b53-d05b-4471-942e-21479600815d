  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Put a large baking tray (or two!) in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p><p>Tip: Cooking for 4? Use 2 trays!</p><p>Drain the<strong> pineapple slices </strong>thoroughly, stack them up and cut them into quarters</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1-1600784924905-x200.jpg",
            "width": 200
