    {
      "instruction": "<p>While the veg is roasting, peel (scrape the skin off with a teaspoon) and finely chop (or grate) your <strong>ginger</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1650362994312-x200.jpg",
