            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the rice is cooked, add your <strong>blanched peas</strong> on top of the rice and put the lid back on for 3 min until the peas are warmed through</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1650363013620-x200.jpg",
