  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p><p>Dissolve the <strong>chicken stock mix</strong> in 500ml <span class=\"text-danger\">[1L]</span> <strong>boiled water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1657548381911-x200.jpg",
            "width": 200
