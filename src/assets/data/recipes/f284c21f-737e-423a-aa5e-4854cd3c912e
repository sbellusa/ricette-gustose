  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Crack the<strong> eggs </strong>into a jug and add 100ml <span class=\"text-danger\">[200ml] </span><strong>milk</strong></p><p>Add 70g <span class=\"text-danger\">[140g]</span><strong> flour</strong>, the <strong>dried sage </strong>and a pinch of<strong> salt </strong>and whisk until smooth – this is your <strong>batter</strong></p><p>Put the <strong>batter</strong> in the fridge to rest</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1635847380805-x200.jpg",
            "width": 200
