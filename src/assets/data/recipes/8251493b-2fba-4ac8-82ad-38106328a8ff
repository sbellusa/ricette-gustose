            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1637677918701-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a full kettle</p><p>Chop the <strong>potatoes</strong> (skins on) into bite-sized pieces</p>",
      "order": 3,
      "media": {
