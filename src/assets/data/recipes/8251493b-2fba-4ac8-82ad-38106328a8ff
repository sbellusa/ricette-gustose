            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>vegetable stock mix</strong> in 350ml <span class=\"text-danger\">[700ml] </span><strong>boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
