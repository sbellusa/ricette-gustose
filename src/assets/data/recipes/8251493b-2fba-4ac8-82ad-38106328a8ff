          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1637677853267-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pot with a drizzle of <strong>olive oil </strong>over a medium heat</p><p>Once hot, add the <strong>diced carrot</strong> and <strong>sliced</strong> <strong>leek</strong> with a pinch of <strong>salt</strong> and cook for 5-6 min or until softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1637677918701-x200.jpg",
