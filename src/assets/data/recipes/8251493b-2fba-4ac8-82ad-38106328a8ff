  "cooking_instructions": [
    {
      "instruction": "<p>Top, tail, peel and finely dice the<strong> carrot<span class=\"text-danger\">[s]</span></strong></p><p>Wash the <strong>leek<span class=\"text-danger\">[s]</span></strong> thoroughly to remove any grit from between the leaves, then top, tail and slice finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1637677853267-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1637677853267-x400.jpg",
