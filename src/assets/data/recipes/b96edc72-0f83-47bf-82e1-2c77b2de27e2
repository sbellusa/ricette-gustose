          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1720527190380-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1720527190380-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1720527190380-x1000.jpg",
            "width": 1000
