            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a full kettle</p><p>Top, tail and chop your <strong>carrot[s]</strong> roughly</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1720527190380-x200.jpg",
            "width": 200
