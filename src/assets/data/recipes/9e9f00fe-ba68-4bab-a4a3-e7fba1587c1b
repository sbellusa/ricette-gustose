          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>sliced leek</strong>,<strong> fennel seeds</strong> and <strong>sliced garlic</strong> to the pan with the sausage meat and cook for 4-5 min or until the leek is beginning to soften</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1692348246049-x200.jpg",
