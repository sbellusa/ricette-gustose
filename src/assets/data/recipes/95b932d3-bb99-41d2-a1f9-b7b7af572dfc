  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the sweet potatoes, with skin on, lengthways into 3cm wedges</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Toss</strong> the wedges in cornflour, 1-2 tbsp of vegetable oil, and salt and pepper to taste</p>\r\n<p><strong>Place</strong> on 1<span class=\"text-danger\">(2)</span> baking tray<span class=\"text-danger\">(s)</span> and leave some space between each wedge</p>\r\n<p><strong>Roast</strong> for 20 min or until starting to turn golden</p>\r\n<p><strong>Once</strong> golden, remove the tray from the oven for step 7</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, roughly chop the parsley (including the stalks)</p>\r\n<p><strong>Peel</strong> and finely chop the garlic cloves</p>\r\n<p><strong>Boil</strong> the kettle with a small amount of water (used in step 5)</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the beef mince to a mixing bowl with the turmeric, ground coriander and half of the chopped garlic (save the rest for step 5)</p>\r\n<p><strong>Season</strong> generously with salt and pepper</p>\r\n<p><strong>Divide</strong> the mixture in 2 <span class=\"text-danger\">(4)</span> and shape into burgers (use wet hands to help)</p>\r\n<p><strong>Pop</strong> the burgers in the fridge until step 6</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chopped parsley, remaining garlic, oregano, chilli flakes, white wine vinegar and 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of olive oil to a food processor with salt, pepper and 50ml <span class=\"text-danger\">(60ml)</span> of boiled water- blitz until smooth </p>\r\n<p>Tip: Alternatively, use a pestle and mortar, and while coarser, it'll still be delicious </p>\r\n<p><strong>This</strong> is your chimichurri sauce</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a non-stick pan on a medium heat</p>\r\n<p><strong>When</strong> hot, add the burgers and cook on each side for 3 min, until browned on each side</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the burgers to the sweet potato tray<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Return</strong> the tray<span class=\"text-danger\">(s)</span> back to the oven for 5-8 min, until the burgers are cooked through and the wedges are crispy</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the burger patties, wedges, and chimichurri sauce to the side </p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
