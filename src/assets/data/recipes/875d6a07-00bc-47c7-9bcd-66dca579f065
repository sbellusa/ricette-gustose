          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1641.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once hot, add the <strong>portobello mushrooms</strong> to the pan with the<strong> baby chestnut mushrooms</strong></p>\n<p>Crumble over the<strong> chestnut mushrooms</strong> and cook for 1 min</p>",
