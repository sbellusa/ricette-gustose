      }
    },
    {
      "instruction": "<p>Whilst the rice is cooking, pierce the<strong> sweet potatoes </strong>with a fork, then cook in the <strong>microwave</strong> for 10-12 min or until fork-tender</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1687534478180-x200.jpg",
