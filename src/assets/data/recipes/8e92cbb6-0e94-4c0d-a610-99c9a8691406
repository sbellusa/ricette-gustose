            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Spread the <strong>creamy base mixture </strong>over the pastry (keep it within the borders!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1614005639259-x200.jpg",
