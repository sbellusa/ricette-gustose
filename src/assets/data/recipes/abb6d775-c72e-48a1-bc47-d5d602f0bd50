          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/499.step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cover the <strong>chicken</strong> with <strong>foil</strong> and put it in the oven for 10-15 min or until cooked through</p>",
      "order": 6,
      "media": {
        "images": [
