  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Place the <strong>Cumberland</strong>&nbsp;<strong>sausages</strong> on a baking tray (lightly oil the tray to prevent sticking!)</p>\r\n<p>Put them in the oven for 30 min or until golden brown and cooked through</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/782_step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/782_step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/782_step-1-x700.jpg",
            "width": 700
          },
