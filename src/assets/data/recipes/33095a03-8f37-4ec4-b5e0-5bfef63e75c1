  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel&nbsp;</strong>the ginger (scrape the skin off with a teaspoon) and finely chop (or grate)</p>\r\n<p><strong>Zest</strong> and juice the lime<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Combine</strong> the ginger, zest and lime juice in a bowl</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the soy sauce, sesame oil, 2 tbsp <span class=\"text-danger\">(4 tbsp)</span>&nbsp;sugar (preferably brown) and the chilli flakes&nbsp;(can't handle the heat? Go easy!)</p>\r\n<p><strong>Mix</strong> well- this is your teryaki sauce</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the tofu from its packaging and pat dry with kitchen paper</p>\r\n<p><strong>Cut</strong>&nbsp;in half and cut each half into 9 cubes</p>\r\n<p><strong>Trim </strong>the beans and slice them finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the sesame seeds and the tofu to a sandwich bag</p>\r\n<p><strong>Shake</strong> the bag so that the sesame seeds stick to the tofu</p>\r\n<p>Tip: If you don't have a sandwich bag, just add them to a bowl and toss with your hands</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the noodles and the beans to a large pot of salted boiling water&nbsp;</p>\r\n<p><strong>Cook</strong>&nbsp;for 7-9 min over a medium-high heat</p>\r\n<p><strong>Once</strong> cooked, drain and rinse under a little cold water (this prevents the noodles sticking together)</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-5-x700.jpg",
