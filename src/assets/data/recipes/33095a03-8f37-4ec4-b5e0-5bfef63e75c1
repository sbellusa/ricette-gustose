            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-6-x1000.jpg",
