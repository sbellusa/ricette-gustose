          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan to a medium heat</p>\r\n<p><strong>Add</strong> the teryaki sauce and whisk for approx. 2-3 min until it's reduced by half into a glaze</p>",
      "order": 7,
      "media": {
