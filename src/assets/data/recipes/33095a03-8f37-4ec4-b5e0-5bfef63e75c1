          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat&nbsp;</strong>a large, wide-based pan (preferably non-stick) with 2-3 tbsp vegetable oil</p>\r\n<p><strong>Once </strong>hot, add the tofu and cook over a medium-high heat for 8-10 min, turning occasionally for even golden colouring</p>\r\n<p><strong>Once </strong>golden, transfer the tofu to kitchen paper and season generously with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/335-step-6-x200.jpg",
            "width": 200
          },
          {
