            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Divide the <strong>merguez-style mix</strong> and roll into small sausage shapes (3 per person!) – these are your <strong>merguez-style koftas</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1716293776491-x200.jpg",
