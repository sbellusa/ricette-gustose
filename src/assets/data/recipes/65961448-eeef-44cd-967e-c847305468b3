  "cooking_instructions": [
    {
      "instruction": "<p>Deseed the<strong> yellow pepper<span class=\"text-danger\">[s]</span></strong> and <strong>red pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and chop into bite-sized pieces</p><p>Peel and slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1641911228901-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1641911228901-x400.jpg",
