    {
      "instruction": "<p><span class=\"text-highlight\">Next, add</span> 1/2 <span class=\"text-danger\">[1]</span> <span class=\"text-highlight\"><strong>Knorr</strong></span> <strong>vegetable stock cube</strong> to the pan with 250ml <span class=\"text-danger\">[400ml]</span> <strong>boiled water </strong>and bring to the boil over a high heat</p>\n<p>Add the <strong>soft cheese</strong> and the <strong>juice</strong> of 1/2<span class=\"text-danger\"> [1]</span><strong> lemon </strong>and give everything a good mix up until fully combined</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1848.-step-5-x200.jpg",
