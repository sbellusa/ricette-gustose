          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your<strong> mayo</strong>, <strong>sriracha</strong> (can't handle the heat? Go easy!) and <strong>red chilli relish</strong> in a bowl – this is your <strong>spicy mayo</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2165.-step-5-x200.jpg",
            "width": 200
          },
