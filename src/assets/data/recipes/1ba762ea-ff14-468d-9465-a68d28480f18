            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the breadcrumbs are cooking, peel and finely chop (or grate) your <strong>garlic</strong></p><p>Roughly chop your <strong>tomato[es]</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1664883455536-x200.jpg",
