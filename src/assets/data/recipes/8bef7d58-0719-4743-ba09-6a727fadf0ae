  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Combine the<strong> egg<span class=\"text-danger\">[s]</span></strong> with 35g <span class=\"text-danger\">[70g]</span><strong> flour</strong> and 50ml <span class=\"text-danger\">[100ml]</span> <strong>milk</strong></p><p>Season with a pinch of<strong> salt</strong> – this is your<strong> batter</strong></p><p>Put the <strong>batter</strong> in the fridge to rest</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1667897167075-x200.jpg",
            "width": 200
