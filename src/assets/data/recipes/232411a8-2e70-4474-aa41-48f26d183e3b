            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reboil a kettle</p><p>Add your <strong>rice</strong> <strong>noodles</strong> to a bowl and cover with <strong>boiled</strong> <strong>water</strong></p><p>Set aside for 12-15 min or until softened</p><p>Once softened, drain the noodles and set aside</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-copy-6-1682418564835-x200.jpg",
