          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-8-1682418578994-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-8-1682418578994-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>rice noodles </strong>in<strong> </strong>bowls<strong> </strong>and pour over the<strong> Thai red veg curry</strong></p><p>Discard the <strong>lemongrass halves</strong></p><p>Sprinkle over the <strong>chilli peanut crumb </strong>and garnish with the<strong> remaining chopped coriander </strong>and a<strong> lime wedge</strong></p><p>Enjoy!</p>",
      "order": 8,
