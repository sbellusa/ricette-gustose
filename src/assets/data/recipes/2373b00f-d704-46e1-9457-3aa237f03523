  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, then take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Cut the <strong>potatoes</strong> (skins on) into fries</p><p>Add the <strong>fries</strong> to a baking tray with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt </strong>and <strong>pepper</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until the fries are golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-22-1697021659229-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-22-1697021659229-x400.jpg",
