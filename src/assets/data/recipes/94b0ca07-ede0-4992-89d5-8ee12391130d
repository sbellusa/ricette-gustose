            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Divide the <strong>pork mixture</strong> into 2 per person and shape into patties<strong> </strong>– these are your <strong>Thai-style lean pork patties</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1660034169132-x200.jpg",
