            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle </p>\n<p>Peel and finely dice the <strong>brown</strong> <strong>onion<span class=\"text-danger\">[</span></strong><span class=\"text-danger\"><strong>s]</strong></span></p>\n<p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/913.-Step-2-x200.jpg",
            "width": 200
