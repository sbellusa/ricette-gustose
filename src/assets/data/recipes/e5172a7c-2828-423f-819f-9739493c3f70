  "cooking_instructions": [
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a matching lid over a high heat</p>\n<p>Once hot, add a drizzle of <strong>vegetable oil</strong> and the <strong>pancetta lardons </strong>and cook for 3-4 min or until crispy</p>",
      "order": 1,
      "media": {
        "images": [
