          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>basil</strong> roughly, including the stalks</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1582891989207-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1582891989207-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1582891989207-x700.jpg",
