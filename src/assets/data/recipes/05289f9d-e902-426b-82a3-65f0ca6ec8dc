  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Heat a large, dry, wide-based pan (preferably non stick with a matching lid) over a medium heat</p><p>Once hot, add your <strong>toasted</strong> <strong>sesame seeds</strong>, <strong>cumin seeds</strong>, <strong>dried</strong> <strong>oregano</strong> and <strong>ground sumac</strong> with a pinch of <strong>salt</strong> and cook for 2-3 min or until toasted and lightly golden</p><p>Once toasted, transfer to a <strong>pestle & mortar</strong>, reserve the pan</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1664189698897-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1664189698897-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1664189698897-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1664189698897-x1000.jpg",
            "width": 1000
