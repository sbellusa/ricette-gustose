            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a high heat</p><p>Once hot, add the<strong> beef patty[ies]</strong>, press down firmly with a spatula and cook for 5 min</p><p>Tip: Cooking for 5? You may need to do this in batches!</p><p>Flip the <strong>patty[ies]</strong> and reduce the heat to medium-high and cook for 5 min further until cooked through and charred (no pink meat!)</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1619713331619-x200.jpg",
