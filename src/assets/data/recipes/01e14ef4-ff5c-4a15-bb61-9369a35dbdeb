          }
        ]
      }
    },
    {
      "instruction": "<p>Add a handful of <strong>flour</strong> to a plate with a generous pinch of <strong>salt</strong></p><p>Crack the <strong>egg<span class=\"text-danger\">[s]</span></strong> into a shallow bowl with a splash of <strong>cold water </strong>and beat with a fork</p><p>Add the <strong>panko breadcrumbs</strong> to another plate</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-1671036320298-x200.jpg",
