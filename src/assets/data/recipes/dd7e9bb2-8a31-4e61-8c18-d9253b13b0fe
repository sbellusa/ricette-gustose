            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the<strong> chives</strong> finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1599559600432-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1599559600432-x400.jpg",
