            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>tomato paste</strong>, <strong>chicken stock mix </strong>and <strong>peanut butter</strong> in 150ml<span class=\"text-danger\"> [300ml] </span><strong>boiling water</strong> – this is your <strong>peanut stock</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1626193750031-x200.jpg",
