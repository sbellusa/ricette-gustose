            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add the <strong>broccoli brown rice</strong> to a large, heatproof bowl and put the bowl in the <strong>microwave</strong> for 3-4 min or until piping hot</p>",
      "order": 2,
      "media": {
