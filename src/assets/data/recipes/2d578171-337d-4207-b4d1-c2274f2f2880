            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>chives </strong>finely</p><p>Combine the <strong>juice </strong>of<strong> 1</strong> <span class=\"text-danger\">[2]</span> <strong>lemon wedge<span class=\"text-danger\">[s]</strong> </span>with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> <strong>olive oil </strong>and a pinch of <strong>salt</strong> and<strong> pepper</strong> –<strong> </strong>this is your <strong>lemony dressing</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
