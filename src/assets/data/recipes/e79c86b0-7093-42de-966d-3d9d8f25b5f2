  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 400&deg;F/ Gas 6&nbsp;</p>\r\n<p><strong>Peel</strong> one whole onion and slice a few rings off it (as finely as you can)</p>\r\n<p><strong>Separate</strong> the onion rings, place them in a bowl of cold water and set aside</p>\r\n<p><strong>Tip:</strong> the cold water removes some of the harsh flavour from the raw onion&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick with a matching lid) with 1 tbsp <span class=\"text-danger\">[2 tbsp]&nbsp;</span>vegetable oil, add the chicken with a pinch of salt and cook for 3 min on each side until golden&nbsp;</p>\r\n<p><strong>Meanwhile</strong>, dice the remaining onion<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Transfer</strong> the coloured chicken to a baking tray, put it in the oven for 7-10 min or until slightly under cooked, then return the pan to a low heat, add a knob of butter and the diced onion with a pinch of salt and sugar and cook until step 5</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the rice, 350ml <span class=\"text-danger\">[700ml]</span>&nbsp;water to a pot with a lid over a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p><strong>Once</strong> cooked, remove from the heat and keep covered until serving</p>\r\n<address>&nbsp;</address>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/565.-step-3-x400.jpg",
