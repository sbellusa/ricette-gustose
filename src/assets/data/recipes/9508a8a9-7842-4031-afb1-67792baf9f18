          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/533.step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>smoky fish</strong> with the <strong>green beans</strong> and <strong>potatoes</strong></p><p>Spoon the <strong>chive butter sauce</strong> over</p><p>Enjoy!</p>",
