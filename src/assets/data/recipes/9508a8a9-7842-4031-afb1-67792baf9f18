  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Cut the <strong>waxy</strong> <strong>potatoes</strong> (skins on) into large, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/533.step-1-x200.jpg",
