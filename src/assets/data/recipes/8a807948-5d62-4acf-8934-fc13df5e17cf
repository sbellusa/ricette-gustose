  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Peel your <strong>potato[es]</strong> and chop them into large, bite-sized pieces</p><p>Add the<strong> chopped potatoes</strong> and to a pot with plenty of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 10 min or until fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-36-1705052319548-x200.jpg",
