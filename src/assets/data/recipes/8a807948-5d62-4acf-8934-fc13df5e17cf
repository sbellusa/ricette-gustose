            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Reboil the kettle</p><p>Peel and slice your <strong>brown onion[s]</strong></p><p>Slice your <strong>apple[s]</strong> finely, discard the core[s]</p><p>Drain and rinse your <strong>butter beans</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-40-1705052324137-x200.jpg",
