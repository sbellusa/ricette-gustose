  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220&ordm;C/ 200&ordm;C (fan)/ 425&ordm;F/ Gas 7</p>\r\n<p>Put a large baking tray in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p>\r\n<p>Combine half the <strong>garlic paste</strong> with the <strong>tomato paste</strong>, a drizzle of <strong>olive oil</strong>, 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> <strong>water</strong> and a generous pinch of <strong>salt</strong>, <strong>pepper</strong> and <strong>sugar</strong>&nbsp;&ndash; this is your <strong>tomato base</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1472.-step-1-x200.jpg",
            "width": 200
