          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1673366611600-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1673366611600-x700.jpg",
