  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to&nbsp;200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) with a matching lid with 1/2 tbsp <span class=\"text-danger\">(1 tbsp) </span>olive oil over a high heat</p>\r\n<p><strong>Pat</strong> the pork dry and season with salt and pepper</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the pan is hot, sear the fatty edges of the pork for 1 min (use tongs to hold them in place), then cook for 2 min on each side or until golden</p>\r\n<p><strong>Meanwhile</strong>, line a baking tray with foil</p>\r\n<p><strong>Transfer</strong> the pork to the tray and set aside to cool down completely, reserving the pan for later</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and slice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Return</strong> the pan to a high heat with a knob of butter</p>\r\n<p><strong>Once</strong> hot, add the onions and cook for 3 min until starting to turn glossy, stirring constantly</p>\r\n<p><strong>Cover</strong> the pan with a lid, reduce the heat to low and cook for 10-15 min or until softened and golden</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-3-x700.jpg",
