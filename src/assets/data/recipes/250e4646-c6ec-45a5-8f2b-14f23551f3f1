          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/537.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the potatoes to a pot of salted boiling water with a matching lid over a high heat</p>\r\n<p><strong>Bring</strong> to the boil and cook, covered, for an initial 7 min or until nearly cooked</p>\r\n<p><strong>Add</strong> the beans and cook, covered, for 3-4 min further or until tender but with a slight bite</p>\r\n<p><strong>Drain</strong> the lot</p>",
      "order": 7,
