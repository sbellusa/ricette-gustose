  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil half a kettle</p><p>Peel and finely slice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Add the <strong>sliced red onion</strong> to a bowl, cover with <strong>boiled water </strong>and set aside for later</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1597161103406-x200.jpg",
            "width": 200
