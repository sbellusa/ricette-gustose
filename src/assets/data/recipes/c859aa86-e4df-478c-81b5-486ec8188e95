          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1587400159862-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1587400159862-x1000.jpg",
