            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the pork loin is cooked, transfer to a plate and set aside</p><p>Return the reserved pan to a medium heat</p><p>Once hot, add the<strong> chopped shallot </strong>and cook for 2 min</p><p>Reboil a kettle</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1587400178267-x200.jpg",
