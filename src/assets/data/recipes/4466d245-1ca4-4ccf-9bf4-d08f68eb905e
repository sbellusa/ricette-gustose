            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the<strong> diced cucumber</strong>,<strong> tomato </strong>and <strong>shallot</strong> in a bowl with 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp] </span><strong>olive oil</strong></p><p>Season with a pinch of <strong>salt</strong> – this is your <strong>kachumber salad</strong></p>",
      "order": 6,
      "media": {
        "images": [
