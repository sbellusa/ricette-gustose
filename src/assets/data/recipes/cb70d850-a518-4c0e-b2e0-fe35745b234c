            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1629199116668-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chips are cooking, trim, then slice your <strong>spring onion[s]</strong> lengthways into thin strips</p><p>Chop your<strong> cucumber</strong> into discs</p><p>Slice each <strong>cucumber disc</strong> into matchsticks</p>",
      "order": 2,
      "media": {
