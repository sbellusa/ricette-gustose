          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1657640556739-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick, with a matching lid) with a drizzle of <strong>vegetable oil </strong>over a medium-high heat</p><p>Once hot, add the <strong>diced onion</strong> and <strong>diced</strong> <strong>pepper </strong>and cook for 2 min or until slightly softened</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1657640566119-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1657640566119-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1657640566119-x700.jpg",
            "width": 700
