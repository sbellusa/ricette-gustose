          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-copy-1657640573862-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the rice is cooked, add your <strong>blanched peas</strong> to the pan and give everything a good mix up</p><p>Cook for a further 1-2 min or until the peas are tender and warmed through</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-copy-1657640584326-x200.jpg",
