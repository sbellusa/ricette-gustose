          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/577.-step--5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the reserved pan to a high heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;vegetable oil</p>\r\n<p><strong>Pat</strong> the salmon dry with kitchen towel and season with salt on both sides</p>\r\n<p><strong>Add</strong> the salmon, skin-side-down and cook for 1 min&nbsp;<br /><br /></p>",
      "order": 6,
      "media": {
        "images": [
