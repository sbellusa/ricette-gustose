            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the veg has softened, add the <strong>chopped garlic</strong> and cook for 1-2 min or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1723202050151-x200.jpg",
