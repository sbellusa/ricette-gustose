  "cooking_instructions": [
    {
      "instruction": "<p>Add the <strong>rice</strong> and 350ml <span class=\"text-danger\">[700ml]</span> water to a pot with a lid and bring to the boil over a high heat</p>\r\n<p>Once boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p>Once cooked, remove from the heat and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/708.-step-1-x200.jpg",
