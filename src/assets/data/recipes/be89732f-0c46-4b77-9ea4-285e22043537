  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Top, tail, peel and dice your <strong>carrot[s] </strong>finely</p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and dice</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1690876681487-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-1690876681487-x400.jpg",
