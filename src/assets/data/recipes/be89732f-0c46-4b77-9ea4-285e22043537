            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the rice is cooked, gently stir in your <strong>blanched peas</strong> and cook for 1 min or until they're warmed through – this is your <strong>West African-style spicy rice</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1690876720142-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-1690876720142-x400.jpg",
