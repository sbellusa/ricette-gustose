          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/516-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> stock</strong> and half the<strong> tarragon</strong> to the pan</p>\r\n<p>Reduce the heat to medium-low, cover with a lid and cook for a further 5 min or until the chicken is cooked through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/516-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/516-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/516-6-x700.jpg",
