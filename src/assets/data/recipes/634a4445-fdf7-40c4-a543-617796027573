  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Cut the<strong>&nbsp;potatoes</strong> (skins on) lengthways into wedges</p>\r\n<p>Add them to a pot (with a matching lid) of <strong>boiled water</strong> with a pinch of <strong>salt</strong> over a high heat</p>\r\n<p>Cook uncovered for 7-9 min or until fork-tender, then drain, return them to the pot and cover to keep warm until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/516-1-x200.jpg",
            "width": 200
          },
          {
