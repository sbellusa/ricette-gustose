  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Peel and chop the <strong>sweet potato<span class=\"text-danger\">[es]</span></strong> into rough bite-sized pieces </p>\n<p>Wrap the <strong>chopped sweet potato</strong> and <strong>garlic</strong> in <strong>tin foil </strong></p>\n<p>Add everything to a baking tray and put the tray in the oven for 30-35 min or until the sweet potato is cooked through and soft </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1680.-step-1-x200.jpg",
            "width": 200
