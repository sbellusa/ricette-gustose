          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1706616034998-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1706616034998-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1706616034998-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>potatoes</strong> (skins on) into chips</p><p>Add the <strong>chips</strong> to a baking tray (or two!) with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong>, give everything a good mix up</p><p>Put the tray[s] in the oven for 25-30 min or until the chips are golden and crisp</p>",
      "order": 4,
