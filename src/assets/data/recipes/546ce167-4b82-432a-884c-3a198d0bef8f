            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>black sesame seeds </strong>to the <strong>basmati</strong> <strong>rice</strong> and fluff with a fork – this is your <strong>sesame rice</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679396979175-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1679396979175-x400.jpg",
            "width": 400
