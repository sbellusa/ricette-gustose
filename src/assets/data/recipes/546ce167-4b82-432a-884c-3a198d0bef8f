            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your <strong>soy sauce</strong>, <strong>hoisin sauce</strong> and <strong>honey</strong> to a bowl and give everything a good mix – this is your <strong>sticky sauce</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1679396967526-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1679396967526-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1679396967526-x700.jpg",
