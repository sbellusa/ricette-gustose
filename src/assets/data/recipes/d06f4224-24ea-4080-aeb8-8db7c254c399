  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6, then take your<strong> chicken</strong> out of the fridge, open the packet and let it air</p><p>Heat a large, wide-based pot (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>diced chicken thigh</strong> with a pinch of <strong>salt</strong> and cook for 2-3 min or until starting to brown</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1657039060232-x200.jpg",
            "width": 200
