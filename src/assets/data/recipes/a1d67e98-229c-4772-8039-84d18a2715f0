            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1-1680536263084-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the veg is starting to soften, add the <strong>hoisin mixture</strong> to the pan and cook, covered, for 7-8 min until the veg is tender</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1-1680536267076-x200.jpg",
