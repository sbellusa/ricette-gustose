          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1604489544998-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> sliced spring onions</strong> to a large bowl with the<strong> pickled cabbage,</strong> <strong>mayo</strong> and a pinch of<strong> salt</strong> and give everything a really good mix up – this is your <strong>creamy winter slaw</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1604489549407-x200.jpg",
