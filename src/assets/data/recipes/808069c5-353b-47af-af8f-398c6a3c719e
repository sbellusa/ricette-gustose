          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1670837820627-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a knob of <strong>butter </strong>over a medium heat</p><p>Once the butter has melted, add the <strong>chopped shallot</strong> and cook for 2-3 min or until softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1670837823514-x200.jpg",
