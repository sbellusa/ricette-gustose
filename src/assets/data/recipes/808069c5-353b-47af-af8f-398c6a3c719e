  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and finely chop your<strong> shallot[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Grate your <strong>cheddar cheese</strong> finely</p><p>Drain your <strong>sweetcorn</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1670837820627-x200.jpg",
            "width": 200
