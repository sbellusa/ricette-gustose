            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cover your <strong>chicken breast portion[s]</strong> in <strong>cling film</strong> and bash with a <strong>rolling pin </strong>until flattened to approx. 1cm thickness</p><p>Season the<strong> flattened chicken </strong>with<strong> half </strong>your <strong>peri-peri seasoning </strong>(can't handle the heat? Go easy!) and a pinch of <strong>salt</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1687507041322-x200.jpg",
