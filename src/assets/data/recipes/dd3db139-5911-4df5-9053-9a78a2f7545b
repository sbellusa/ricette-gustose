          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1595263056296-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>plant-based aubergine pasta bake</strong></p><p>Enjoy!</p>",
      "order": 8,
