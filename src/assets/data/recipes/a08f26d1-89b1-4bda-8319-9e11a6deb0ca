            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, heat a large, wide-based pan (preferably non-stick) over a medium heat</p><p>Once hot, add the <strong>walnuts</strong> and toast for 3-4 min, or until they've darkened in colour slightly</p><p>Tip: Watch them like a hawk to make sure they don't burn!</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1632825237625-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1632825237625-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1632825237625-x700.jpg",
