          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1700585440297-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Put the tray[s] in the oven for 30 min or until the potatoes are golden and the chicken is cooked through (no pink meat!)</p><p>Meanwhile, boil a kettle</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1700585454269-x200.jpg",
