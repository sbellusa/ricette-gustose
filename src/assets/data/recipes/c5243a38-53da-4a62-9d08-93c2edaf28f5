          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1628674748293-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> hoisin</strong> <strong>roasted aubergine</strong> over the<strong> sesame rice</strong> and drizzle with the <strong>hoisin glaze</strong></p><p>Serve the<strong> sesame greens </strong>to the side</p><p>Enjoy!</p>",
