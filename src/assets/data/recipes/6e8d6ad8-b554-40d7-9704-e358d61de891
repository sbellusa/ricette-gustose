            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top, tail and grate the <strong>carrot<span class=\"text-danger\">[s]</span></strong> (no need to peel!)</p><p>Trim, then slice the <strong>green beans</strong> finely on a diagonal</p><p>Trim, then slice the <strong>spring onion<span class=\"text-danger\">[s]</span> </strong>finely</p>",
      "order": 4,
      "media": {
