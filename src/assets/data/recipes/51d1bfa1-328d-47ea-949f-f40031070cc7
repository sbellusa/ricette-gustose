            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the beef is browning, peel and slice (don't chop!) your <strong>garlic</strong></p><p>Dice your <strong>tomato[es]<span class=\"text-danger\"> </span></strong>roughly</p><p>Once starting to brown, add the <strong>sliced garlic </strong>and <strong>diced tomato </strong>to the beef and cook for 2-3 min further</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1684860711985-x200.jpg",
