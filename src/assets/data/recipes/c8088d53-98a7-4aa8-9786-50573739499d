            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and grate (don't chop!) your <strong>garlic</strong></p><p>Add your<strong> mayo</strong> to a bowl with <strong>half</strong> the<strong> grated garlic</strong> (not a big garlic fan? Try using less!) and a splash of <strong>water</strong> – this is your <strong>garlic mayo</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1681376935778-x200.jpg",
