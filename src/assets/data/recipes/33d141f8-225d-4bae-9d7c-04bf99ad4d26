          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-copy-2-1721994271295-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>chicken breast portion[s]</strong> to a clean chopping board, cover with <strong>cling film </strong>and bash with a <strong>rolling pin</strong> until flattened to approx. 1cm thickness</p>",
      "order": 2,
      "media": {
        "images": [
          {
