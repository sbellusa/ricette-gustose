            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p><p>Peel and slice (don't chop!) your <strong>garlic</strong></p><p>Chop your <strong>basil</strong> roughly, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
