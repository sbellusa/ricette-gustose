            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>mayo</strong> and <strong>half</strong> your <strong>white wine vinegar</strong> (save the rest for later!) to the bowl with the <strong>reserved</strong> <strong>spice mix</strong></p><p>Mix until fully combined – this is your <strong>Cajun-style mayo</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1706535863423-x200.jpg",
