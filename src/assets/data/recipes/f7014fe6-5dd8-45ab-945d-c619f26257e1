            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1706535848805-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>ciabatta[s]</strong> to the tray[s] on top of the chips for a final 4-5 min or until hot and crusty</p><p>Once hot, carefully slice the <strong>warmed ciabatta[s]</strong> in half</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1706535857899-x200.jpg",
