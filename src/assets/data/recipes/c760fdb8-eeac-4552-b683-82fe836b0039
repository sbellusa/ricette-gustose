          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1636030525390-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) over a medium heat</p><p>Once hot, add a drizzle of <strong>vegetable oil</strong>, the <strong>smoked paprika</strong> and <strong>cayenne pepper</strong> (can't handle the heat? Go easy!) and cook for 1 min or until fragrant</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1-1636030577063-x200.jpg",
