          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1715248277310-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1715248277310-x1000.jpg",
