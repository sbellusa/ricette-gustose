          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2153-Step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the pan to a medium heat with 1 tbsp<span class=\"text-danger\"> [2 tbsp]</span> <strong>olive oil</strong></p>\n<p>Once hot, add the <strong>chopped cherry tomatoes</strong> and<strong> sliced garlic</strong> with a generous pinch of <strong>salt</strong> and cook, covered, for 8-10 min or until the <strong>tomatoes</strong> are starting to break down</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2153-Step-4-x200.jpg",
            "width": 200
