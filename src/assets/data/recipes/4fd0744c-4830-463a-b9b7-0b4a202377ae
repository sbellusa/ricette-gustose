            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, drain and tear the <strong>mozzarella</strong> into rough bite-sized pieces </p>\n<p>Chop the <strong>basil</strong> roughly, including the stalks </p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2153-Step-5-x200.jpg",
            "width": 200
          },
          {
