            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2153-Step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the<strong> tomatoes</strong> have broken down, add the<strong> tomato paste</strong>, <strong>sundried tomato paste</strong>, 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>sugar</strong> and a pinch of <strong>salt</strong></p>\n<p>Give everything a good mix up – this is your<strong> tomato sauce</strong></p>\n<p> </p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2153-Step-6-x200.jpg",
            "width": 200
