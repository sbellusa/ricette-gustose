  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Top, tail, peel and dice the <strong>carrot<span class=\"text-danger\">[s]</span></strong> finely</p><p>Peel and finely dice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
