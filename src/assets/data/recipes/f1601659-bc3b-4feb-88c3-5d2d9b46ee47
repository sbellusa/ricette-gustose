          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1650382725296-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1650382725296-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Mediterranean-style</strong> <strong>basa stew</strong> with the<strong> toasted ciabatta</strong> to the side</p><p>Garnish with the <strong>remaining</strong> <strong>chopped parsley</strong> and drizzle over the <strong>sunny aioli</strong></p><p>Tip: Don't forget to remove the<strong> </strong>star anise!</p><p>Enjoy!</p>",
      "order": 8,
