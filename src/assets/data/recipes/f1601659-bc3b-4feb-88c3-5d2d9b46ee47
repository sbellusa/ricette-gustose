            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>ciabattas</strong> in half and place in the toaster for 1-2 min or until <strong>toaster</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/431.-step-5.new-x200.jpg",
            "width": 200
          },
