            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Pat the <strong>basa fillets</strong> dry with kitchen paper</p><p>Gently add the <strong>basa</strong> to the pan and cook, covered, for 5 min or until the basa is cooked through</p><p>Tip: Your fish is cooked when it turns opaque and flakes easily</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1650382715602-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1650382715602-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1650382715602-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1650382715602-x1000.jpg",
