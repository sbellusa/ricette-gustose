            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>giant couscous</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Cook the <strong>giant couscous</strong> for 8 min or until tender with a slight bite, then drain and return to the pot</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1695645607087-x200.jpg",
