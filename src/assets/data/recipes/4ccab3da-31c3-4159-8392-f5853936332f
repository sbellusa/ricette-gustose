  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a full kettle</p>\r\n<p><strong>Chop</strong> the pak choi roughly</p>\r\n<p><strong>Chop</strong> the mushrooms finely</p>\r\n<p><strong>Chop</strong> the spring onion<span class=\"text-danger\">[s]</span>&nbsp;finely, keeping the green tops and white stems separate and discarding the root end<span class=\"text-danger\">[s]</span></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick with matching lid) over a medium-high heat with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the pak choi, cover and cook for 3-4 min or until beginning to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the veggie mince, Thai green curry paste and the stock cube<span class=\"text-danger\">[s]</span>&nbsp;to a heat-proof bowl with 200ml <span class=\"text-danger\">[400ml]</span>&nbsp;boiled water</p>\r\n<p><strong>Stir</strong> thoroughly to dissolve then cover and set aside</p>\r\n<p><strong>Cover</strong> the vermicelli noodles with boiled water and set aside to soften</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/573.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the mushrooms and whites of the spring onion to the pan with the pak choi</p>\r\n<p><strong>Peel</strong> and grate the carrot directly into the pan, discarding the root end<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Stir</strong> and continue to cook, covered, for a further 4-5 min</p>",
