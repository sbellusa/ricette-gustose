          }
        ]
      }
    },
    {
      "instruction": "<p>Season with<strong> half </strong>your <strong>dried thyme </strong>(you'll use the rest later!) and a generous pinch of<strong> salt</strong> and give everything a good mix up</p>",
      "order": 5,
      "media": {
        "images": [
