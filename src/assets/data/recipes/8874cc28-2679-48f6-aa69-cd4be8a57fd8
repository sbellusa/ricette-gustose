  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and finely dice half of the onion<span class=\"text-danger\">[s]</span>&nbsp;(save the rest for step 5)</p>\r\n<p><strong>Heat</strong> a medium-sized pot (with matching lid) with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;vegetable oil over a medium heat</p>\r\n<p><strong>Once</strong> hot, add the onions and sultanas with a pinch of salt and cook for 3 min or until the onion is softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> in the basmati rice &amp; saffron, then add 350ml <span class=\"text-danger\">[700ml]</span>&nbsp;water &amp; bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to very low &amp; cook, covered, for 10-15 min or until the water has absorbed &amp; the rice is cooked</p>\r\n<p><strong>Remove</strong> from the heat &amp; keep covered until serving</p>\r\n<p><strong>Drain</strong> &amp; rinse the chickpeas</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely chop (or grate) the garlic&nbsp;</p>\r\n<p><strong>Heat</strong> a large pan with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;vegetable oil over a medium heat</p>\r\n<p><strong>Once</strong> hot, add the chickpeas, half the garlic (reserve the rest for later!), cumin and curry powder with a pinch of salt&nbsp;</p>\r\n<p><strong>Cook</strong> for 5 min or until they're well coated and fragrant, then remove from the heat</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/481.-step-3-x200.jpg",
            "width": 200
