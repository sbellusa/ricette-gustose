          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1670929106512-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the<strong> drained potatoes</strong> to a low heat with a large knob of <strong>butter</strong></p><p>Season with a very generous pinch of <strong>salt</strong> and <strong>pepper</strong> and mash until smooth</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670929116692-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670929116692-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670929116692-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1670929116692-x1000.jpg",
