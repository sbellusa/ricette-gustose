  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and chop your<strong> sweet potato[es]</strong> into bite-sized pieces</p><p>Chop your <strong>potato[es]</strong> (skins on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599138692475-x200.jpg",
