          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1599138747158-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1599138747158-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1599138747158-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>sausage</strong> <strong>tray bake</strong> with the<strong> curried tomato sauce</strong> drizzled all over</p><p>Sprinkle over the <strong>remaining curry powder</strong> – this is your <strong>German-style curried sausage tray bake</strong></p><p>Enjoy!</p>",
      "order": 8,
