    },
    {
      "instruction": "<p>Cut the <strong>remaining lime</strong> into 1 wedge per person</p><p>Fluff the <strong>brown</strong> <strong>rice</strong> with a fork and season with a pinch of<strong> salt</strong></p>",
      "order": 7,
