            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>yakitori sauce</strong> to a pot over a medium heat and cook for 5 min or until thick and sticky – this is your <strong>sticky yakitori sauce</strong></p><p>Tip: Watch this like a hawk to make sure it doesn't burn!</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1627992519611-x200.jpg",
            "width": 200
