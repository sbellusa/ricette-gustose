            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>tofu skewers</strong> to a separate baking tray and put the tray in the oven for an initial 10-12 min or until the tofu is beginning to brown</p><p>Tip: You'll cook these more later!</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1627992467175-x200.jpg",
