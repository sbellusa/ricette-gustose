            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Thread the<strong> chopped tofu pieces </strong>and <strong>spring onion pieces </strong>evenly onto the <strong>soaked skewers </strong>– these are your <strong>tofu skewers</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1627992436060-x200.jpg",
