  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle and wash the spinach in a colander</p>\r\n<p><strong>Peel</strong> and chop the shallots finely</p>\r\n<p><strong>Peel</strong> and grate (or chop) the garlic cloves</p>\r\n<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> with 800ml<span class=\"text-danger\"> (1.4L)</span> of boiled water</p>\r\n<p><strong>Re-boil</strong> the kettle (for step 2)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large wide-based pan (preferably non-stick) on a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil</p>\r\n<p><strong>When</strong> hot, add the shallot with a pinch of salt, then cook on a medium low heat for 2 min, until softened but not coloured</p>\r\n<p><strong>Meanwhile</strong>, pour the boiled water over the spinach in the colander so that it wilts (leaving to cool until step 7)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the rice and 2/3 of the garlic to the shallot pan and mix well</p>\r\n<p><strong>Add</strong> 1/3 of the stock to the rice and stir continuously with a wooden spoon until the stock is absorbed</p>\r\n<p><strong>Continue</strong> to add the stock, a ladle at a time, stirring continuously for 15-20 min, until all the stock is absorbed and the rice is cooked</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, heat another wide-based pan on a medium heat</p>\r\n<p><strong>When</strong> hot, add the pecan nuts and cook for 5 min, or until slightly darkened in colour</p>\r\n<p><strong>Once</strong> toasted, transfer to a pestle and mortar (or processor) and reserve the pan for step 5</p>\r\n<p><strong>Meanwhile</strong>, cut the mushrooms into 1/2cm thick slices</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the reserved pan on a medium high heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil</p>\r\n<p><strong>When</strong> hot, add the mushrooms and a pinch of salt</p>\r\n<p><strong>Cook</strong> them on either side for 3 min, or until golden and caramelised</p>\r\n<p>Tip: Do this in batches as overcrowding prevents proper browning</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the remaining garlic, 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of olive oil (preferably extra virgin) and a large pinch of salt to the pestle and mortar (or processor) with the nuts</p>\r\n<p><strong>Tip:</strong> Omit the raw garlic if you're not keen on that strong flavour</p>\r\n<p><strong>Bash</strong> in a pestle and mortar (or blitz) until you have a coarse nutty oil</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Squeeze</strong> the excess moisture out of the cooled spinach over the sink</p>\r\n<p><strong>Chop</strong> the spinach finely</p>\r\n<p><strong>Add</strong> the wilted spinach to the risotto and stir through thoroughly</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/421.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> in half the pecan oil, reserving the rest for garnish</p>\r\n<p><strong>Season</strong> the risotto with salt and pepper to your taste</p>\r\n<p><strong>Serve</strong> the risotto with the mushrooms on top and the pecan oil drizzled over</p>\r\n<p>Enjoy!</p>",
      "order": 8,
