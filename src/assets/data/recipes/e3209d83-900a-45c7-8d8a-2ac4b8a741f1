            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658226056060-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1658226056060-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped pepper </strong>to one side of a baking tray (or two!)</p><p>Add the <strong>chips </strong>to the other side of the tray[s]</p><p>Drizzle everything with <strong>vegetable oil </strong>and season with a pinch of <strong>salt</strong> and <strong>pepper</strong>,<strong> </strong>then give it a good mix up and put the tray[s] in the oven for an initial 15 min or until the pepper is tender and slightly charred</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1658226059590-x200.jpg",
