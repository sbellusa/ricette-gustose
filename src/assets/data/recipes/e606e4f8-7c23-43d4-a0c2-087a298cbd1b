  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9 and boil a kettle</p><p>Peel the <strong>potatoes</strong> and chop them into thick chips, then add them to a pot with plenty of <strong>boiled water </strong>and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 10 min, then drain (reserve the pot!) and shake them around the colander to fluff up the edges</p>",
      "order": 1,
      "media": {
        "images": [
          {
