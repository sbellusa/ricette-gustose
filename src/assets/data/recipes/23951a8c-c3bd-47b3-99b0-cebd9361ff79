  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut the <strong>potatoes</strong> (skins on) into chips</p><p>Add the <strong>chips</strong> to a baking tray with a generous drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 25-30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1595254320452-x200.jpg",
            "width": 200
