  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Bash your<strong> lemongrass</strong> with a <strong>rolling pin</strong>, remove the<strong> tough outer layers</strong> of the lemongrass and set aside for later</p><p>Chop the <strong>softer inner core[s]</strong> finely</p><p>Strip your <strong>coriander leaves</strong> from their stalks, then chop the <strong>coriander stalks</strong> and <strong>leaves</strong> finely, keeping them separate</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1683891824702-x200.jpg",
            "width": 200
          },
          {
