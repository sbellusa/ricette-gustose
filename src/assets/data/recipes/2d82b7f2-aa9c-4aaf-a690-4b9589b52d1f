            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Thread the <strong>chicken pieces</strong> and<strong> spring onion pieces </strong>evenly onto the <strong>soaked skewers </strong>– these are your <strong>chicken skewers</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2136Step-3-x200.jpg",
