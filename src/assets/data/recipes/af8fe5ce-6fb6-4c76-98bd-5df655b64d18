  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Peel the <strong>potatoes</strong> and chop them into quarters, then add to a pot with plenty of <strong>boiled water </strong>and a pinch of <strong>salt </strong>and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 10-12 min, then drain (save the pot!) and shake them around the colander to fluff up the edges</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1726064867616-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1726064867616-x400.jpg",
            "width": 400
