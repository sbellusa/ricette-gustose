          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1603213160474-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>basa fillets</strong> into strips</p><p>Add the<strong> basa strips</strong> to the cornflour mixture and stir together until they're fully coated in the mixture</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1603213167813-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1603213167813-x400.jpg",
