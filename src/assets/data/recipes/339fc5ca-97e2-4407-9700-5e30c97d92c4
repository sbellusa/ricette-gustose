  "cooking_instructions": [
    {
      "instruction": "<p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Tear the <strong>drained tofu</strong> into large bite-sized pieces</p><p>Combine the<strong> tofu</strong> <strong>pieces</strong> with 2/3 of your <strong>soy sauce</strong> (save the rest for later!) in a large bowl and mix it all together – this is your <strong>marinated tofu</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1670320829019-x200.jpg",
            "width": 200
