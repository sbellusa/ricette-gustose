            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the sauce has reduced, stir the <strong>cooked butternut squash </strong>through the sauce – this is your <strong>chickpea & butternut squash korma</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1632217508198-x200.jpg",
