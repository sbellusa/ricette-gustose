            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and slice (don't chop!) your <strong>garlic</strong></p><p>Dissolve your <strong>vegetable stock mix </strong>in 75ml <span class=\"text-purple\">[100ml]</span> <span class=\"text-danger\">[130ml]</span> <strong>boiled water</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
