            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the courgette has started to soften, add the <strong>sliced garlic </strong>to the pan and cook for 1 min or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1693574224461-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1693574224461-x400.jpg",
