          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1712327974775-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim, then slice your<strong> spring onion[s]</strong> finely</p><p>Chop your<span class=\"text-danger\"> </span><strong>capers</strong> finely</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1712327985213-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1712327985213-x400.jpg",
            "width": 400
          },
          {
