          }
        ]
      }
    },
    {
      "instruction": "<p>Once the meatballs are browned, add the <strong>saag paste</strong> and <strong>tomato paste</strong> to the pan</p><p>Cook for 1 min or until fragrant</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1688112730358-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1688112730358-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1688112730358-x700.jpg",
