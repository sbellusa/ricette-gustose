            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick with a matching lid) over a medium-high heat with a little drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the <strong>meatballs</strong> to the pan and cook for 2 min on each side or until browned</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1688112723242-x200.jpg",
