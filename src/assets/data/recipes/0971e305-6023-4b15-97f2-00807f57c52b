  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and finely slice the red onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Discard</strong> the root end of the aubergine<span class=\"text-danger\">(s)</span> and using a vegetable peeler, peel strips off the aubergine lengthways, leaving a gap between each strip (think zebra stripes)</p>\r\n<p><strong>Cut</strong> the aubergine into chunky rounds approx. 2cm thick</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide-based pan (non-stick is best) with 1-2 tbsp of vegetable oil</p>\r\n<p><strong>When</strong> hot, add the aubergine rounds, red onion, and a pinch of salt</p>\r\n<p><strong>Cook</strong> on a medium-low heat for 5 min, turning the aubergine half way, and once the aubergine is slightly browned, transfer both to a plate</p>\r\n<p><strong>Reserve</strong> the pan for the next step</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle for steps 4 and 6</p>\r\n<p><strong>Add</strong> the ras el hanout to the reserved pan and cook for 20 sec, stirring constantly</p>\r\n<p><strong>Add</strong> the lamb mince and break it up with a wooden spoon</p>\r\n<p><strong>Cook</strong> the lamb in the spice for 5 min, or until starting to colour</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, dissolve the stock cube<span class=\"text-danger\">(s)</span> in 300ml <span class=\"text-danger\">(500ml)</span> of boiled water</p>\r\n<p><strong>Add</strong> the harissa paste and 1 tsp <span class=\"text-danger\">(2 tsp)</span> of sugar to the stock</p>\r\n<p><strong>This</strong> is your harissa stock</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the stock, the cooked aubergine and half of the red onion to the lamb pan, cover with a lid and cook on a rapid simmer for 10 min on a low heat</p>\r\n<p><strong>After</strong> the 10 min, remove the lid, turn the aubergines and cook for a further 5 min, or until most of the water has evaporated</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the couscous to a bowl with 200ml <span class=\"text-danger\">(400ml)</span> of boiling water and cover well</p>\r\n<p><strong>Set</strong> aside for 10 min</p>\r\n<p><strong>Chop</strong> the mint leaves and stalks finely</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Fluff</strong> the couscous with a fork and stir through the remaining red onion and chopped mint</p>\r\n<p><strong>Season</strong> to taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the lamb and aubergines over the jewelled couscous</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
