            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Separate your <strong>duck leg[s]</strong> from the <strong>white duck fat </strong>and <strong>duck jelly </strong>(you'll use these in different parts of the recipe!)</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1698925998946-x200.jpg",
            "width": 200
