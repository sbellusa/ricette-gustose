          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1657625747675-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>crispy chipotle haddock </strong>with the<strong> zingy</strong> <strong>sweet potato salad </strong>to the side</p><p>Garnish with a <strong>lime wedge</strong></p><p>Enjoy!</p>",
