            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chicken is cooking, roughly chop your <strong>tomato[es]</strong></p><p>Chop <strong>half</strong> your <strong>cucumber</strong> (you'll use the rest later!) into small, bite-sized pieces</p><p>Chop your <strong>parsley</strong> roughly, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-2-1681210934297-x200.jpg",
            "width": 200
