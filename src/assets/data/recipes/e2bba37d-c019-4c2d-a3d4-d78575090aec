          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-2-1681210882213-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Sprinkle your <strong>ground smoked paprika</strong> over the chicken and cook for 5-6 min on each side or until cooked through (no pink meat!) – this is your <strong>Mediterranean-style chicken</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-2-1681210890811-x200.jpg",
