          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1709818977000-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1709818977000-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>chicken</strong> <strong>pad Thai noodles </strong>topped with the <strong>chopped peanuts</strong>, <strong>sliced spring onion</strong> and <strong>chopped coriander</strong></p><p>Garnish with a <strong>lime wedge</strong></p><p>Enjoy!</p>",
      "order": 8,
