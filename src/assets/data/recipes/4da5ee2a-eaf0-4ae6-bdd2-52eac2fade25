            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Remove 2 tbsp <span class=\"text-danger\">[4 tbsp]</span><strong> butter alternative</strong> from the fridge to warm up for later</p><p>Drain the<strong> tofu</strong> and pat it dry with kitchen paper</p><p>Slice the <strong>drained tofu</strong> lengthways into 4<span class=\"text-danger\"> [8]</span> flat pieces, then score in a criss-cross pattern, taking care not to cut all the way through</p>",
      "order": 2,
      "media": {
        "images": [
