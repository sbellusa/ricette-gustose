  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Slice the <strong>cucumber</strong> finely</p><p>Add the<strong> sliced cucumber</strong> to a small bowl with the <strong>cider vinegar </strong>and 1 tsp <span class=\"text-danger\">[2 tsp] </span><strong>sugar</strong></p><p>Mix everything together and set aside – this is your <strong>quick-pickled cucumber</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1651056558280-x200.jpg",
