          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1708528748452-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>chicken breast portion[s]</strong> and cook for 3 min on each side or until golden</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1708528753331-x200.jpg",
            "width": 200
