          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1126.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1126.-step-7-x1000.jpg",
