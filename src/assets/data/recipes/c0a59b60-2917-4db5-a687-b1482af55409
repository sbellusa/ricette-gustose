          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-2-17.02.58-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add your <strong>beef mince</strong> and your <strong>five-spice mix</strong> and cook for 4-5 min or until starting to brown, breaking it up with a wooden spoon as you go</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-3-x1000.jpg",
