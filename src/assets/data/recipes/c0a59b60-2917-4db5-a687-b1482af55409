            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of<strong> vegetable oil</strong> over a high heat</p><p>Once hot, add the <strong>chopped garlic, ginger & chilli</strong> and cook for 1-2 min or until fragrant</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-2-17.02.58-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-2-17.02.58-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-2-17.02.58-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-2-17.02.58-x1000.jpg",
            "width": 1000
