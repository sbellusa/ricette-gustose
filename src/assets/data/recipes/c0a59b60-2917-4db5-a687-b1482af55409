          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-7-x1000.jpg",
