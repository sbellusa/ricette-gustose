            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>broccoli</strong> into small florets, discard the stem and leaves</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-v2-2196-v3-2196-v4-Step-5-x200.jpg",
            "width": 200
          },
