  "cooking_instructions": [
    {
      "instruction": "<p>Peel your <strong>garlic</strong> and<strong> ginger</strong>, then slice your <strong>red chilli[es] </strong>in half lengthways and deseed (scrape the seeds out with a teaspoon)</p><p>Chop all of these together as finely as you can</p><p>Tip: If you can't handle the heat, save some of the chilli for another recipe!</p><p>Trim, then slice your <strong>spring onion[s]</strong> finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-2196-v4-Step-1-ver2196-v4-Sion-3-17.03.01-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-2196-v4-Step-1-ver2196-v4-Sion-3-17.03.01-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-2196-v4-Step-1-ver2196-v4-Sion-3-17.03.01-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2196-2196-v4-Step-1-ver2196-v4-Sion-3-17.03.01-x1000.jpg",
            "width": 1000
