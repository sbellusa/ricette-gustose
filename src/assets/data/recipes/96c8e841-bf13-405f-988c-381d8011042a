          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1611576446255-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the<strong> cooked sweetcorn cobettes</strong> and carefully chop them in half with a sharp knife</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1611576451866-x200.jpg",
            "width": 200
