  "cooking_instructions": [
    {
      "instruction": "<p>Rinse the <strong>sushi rice </strong>in a sieve under cold running water for 30 secs (use your hands to really wash the grains!), then set aside to drain fully</p><p>Add the <strong>drained rice</strong> with 200ml <span class=\"text-danger\">[400ml]</span> <strong>cold water</strong> and a generous pinch of <strong>salt</strong> to a pot with a lid and bring to the boil over a high heat</p><p>Tip: Don't let the water fully boil as this will make the rice stick to the pot!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1627979806129-x200.jpg",
            "width": 200
