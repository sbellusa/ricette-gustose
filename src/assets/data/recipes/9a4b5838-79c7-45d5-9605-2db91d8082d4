            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1923.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\">Once the <strong>chicken</strong> is cooked through (no pink meat!), remove the pan from the heat</span></p>\n<p>Roughly tear the <strong>mozzarella</strong> into bite-sized pieces and stir <strong>half</strong> through the <span class=\"text-highlight\"><strong>fusilli</strong></span> (keep the rest aside for serving!)</p>\n<p><span class=\"text-highlight\">This is your <strong>chicken, cherry tomato &amp; mozzarella fusilli</strong></span></p>\n<p> </p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1923.-step-7-x200.jpg",
            "width": 200
