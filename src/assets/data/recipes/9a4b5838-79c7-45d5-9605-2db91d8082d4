            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>drained fusilli</strong> to the<strong> tomato &amp; garlic sauce</strong> and stir to combine</p>\n<p> </p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1923.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1923.-step-6-x400.jpg",
