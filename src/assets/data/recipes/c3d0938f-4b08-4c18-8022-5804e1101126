          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1582890331651-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Snap the <strong>walnuts</strong> in half roughly</p><p>Peel and cut the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into thin wedges, then separate into petals</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1582890337012-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1582890337012-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1582890337012-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1582890337012-x1000.jpg",
