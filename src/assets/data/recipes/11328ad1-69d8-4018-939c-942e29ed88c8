  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, boil half a kettle and take your <strong>chicken </strong>out of the fridge, open the packet and let it air</p><p>Peel and finely dice your<strong> brown onion[s]</strong></p><p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of <strong>vegetable oil </strong>over a medium-high heat, then once hot, add the <strong>diced onion</strong> with a pinch of <strong>salt</strong> and cook for 5-6 min or until softened and lightly browned</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1681316486405-x200.jpg",
            "width": 200
