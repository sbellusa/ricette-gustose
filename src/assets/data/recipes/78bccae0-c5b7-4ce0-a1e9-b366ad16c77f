          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> basa fillets</strong> over the <strong>sauce</strong> <strong>bonne femme</strong> with the <strong>potatoes</strong> <strong>& spring greens</strong> to the side</p><p>Enjoy!</p>",
