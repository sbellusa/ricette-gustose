  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Cut the <strong>potatoes</strong> (skin on) into large bite-sized pieces</p><p>Add the <strong>potatoes</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 15-20 min or until fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-1-x700.jpg",
            "width": 700
          },
