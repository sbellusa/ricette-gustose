          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the potatoes are tender, add the <strong>sliced spring greens</strong> and cook for 2-3 min further</p><p>Drain the <strong>potatoes & spring greens</strong>, drizzle with <strong>olive oil</strong> and season with <strong>salt</strong> and <strong>pepper</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/460__step-5-x1000.jpg",
