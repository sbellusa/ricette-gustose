            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>softer inner lemongrass core</strong> finely</p><p>Peel (scrape the skin off with a teaspoon) and finely chop the <strong>ginger</strong></p><p>Peel and finely chop the <strong>garlic</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1599138054078-x200.jpg",
            "width": 200
