  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Add the <strong>black rice </strong>to a pot of plenty of <strong>boiled water </strong>and cook over a high heat for 30 min or until it's tender (it will still have a slight bite to it when cooked)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1599138034817-x200.jpg",
            "width": 200
