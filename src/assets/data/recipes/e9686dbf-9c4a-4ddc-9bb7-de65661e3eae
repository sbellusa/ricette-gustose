            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Fluff</strong> the cooked couscous with a fork and stir through the red pepper and basil, seasoning generously with black pepper</p>\r\n<p><strong>Serve</strong> the halloumi and any remaining balsamic&nbsp;drizzle&nbsp;over the couscous</p>\r\n<p>Enjoy!</p>",
      "order": 8,
