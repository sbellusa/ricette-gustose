            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> and cut the halloumi into 8 <span class=\"text-danger\">(16)</span> slices</p>\r\n<p><strong>Add</strong> the slices to a heatproof bowl, cover with boiled water (this takes some of the natural saltiness away) and set aside</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) with a matching lid with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> olive oil over a medium heat</p>\r\n<p><strong>Once</strong> hot, add the almonds and garlic with a pinch of salt</p>\r\n<p><strong>Cook</strong> for 1 min, then add the ras el hanout and cook for 1 min further, stirring constantly &nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-538.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-538.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-538.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-538.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-538.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the couscous and sultanas with 200ml <span class=\"text-danger\">(400ml)</span> boiled water</p>\r\n<p><strong>Bring</strong> to the boil, then cover with&nbsp;a lid and remove from the heat</p>\r\n<p><strong>Set</strong> aside, covered, until serving&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-4-x200.jpg",
            "width": 200
