  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a full kettle&nbsp;</p>\r\n<p><strong>Crush</strong> or chop the almonds coarsely</p>\r\n<p>Tip: Bash the nuts in their bag with a rolling pin or use a pestle and mortar</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-2-x200.jpg",
            "width": 200
