    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Remove</strong> the halloumi from the bowl and pat dry to remove any excess water</span></p>\r\n<p>&nbsp;</p>",
      "order": 6,
      "media": {
        "images": [
          {
