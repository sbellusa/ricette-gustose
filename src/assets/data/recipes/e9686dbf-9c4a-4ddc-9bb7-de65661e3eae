    {
      "instruction": "<p><strong>Heat</strong> a pan (preferably non-stick) over a medium-high heat</p>\r\n<p><strong>Once</strong> hot, add the balsamic vinegar and 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> sugar and cook until bubbling</p>\r\n<p><strong>Once</strong> bubbling, add the halloumi slices and cook for 1 min on each side or until the balsamic has thickened into a glaze</p>\r\n<p>&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/538.-step-7-x200.jpg",
