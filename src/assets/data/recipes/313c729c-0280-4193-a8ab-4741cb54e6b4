  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Peel and grate most (approx. 3/4) of the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p><p>Slice the <strong>remaining onion</strong> as finely as you can</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-1-x400.jpg",
            "width": 400
          },
          {
