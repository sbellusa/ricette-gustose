            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>lamb mince</strong>, <strong>grated onion</strong>, <strong>panko breadcrumbs</strong>, <strong>ground cumin</strong>, <strong>garam masala</strong>, <strong>soy sauce</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong> in a large bowl</p><p>Mix thoroughly with clean hands, then divide the mixture into 6 <span class=\"text-danger\">[12]</span> and shape into meatballs</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>meatballs</strong> to a baking tray and put them in the oven for 12-15 min or until cooked through</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1505.-step-3-x200.jpg",
            "width": 200
          },
          {
