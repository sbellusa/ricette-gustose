  "cooking_instructions": [
    {
      "instruction": "<p>Rinse the <strong>white long grain rice</strong> until the water runs clear, then add it to a pot with a lid with 225ml <span class=\"text-danger\">[450ml]</span> <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 12-15 min or until all the water has absorbed and the rice is cooked</p><p>Once done, transfer the rice to a plate and spread it out flat to help it cool down (reserve the pot!)</p>",
      "order": 1,
      "media": {
        "images": [
