  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\n<p>Meanwhile, cut the <strong>waxy potatoes</strong> (skins on) into large, bite-sized pieces</p>\n<p>Add the<strong> potatoes</strong> to a pot of <strong>boiled water </strong>with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 15-20 min or until they're fork-tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-1-x200.jpg",
            "width": 200
