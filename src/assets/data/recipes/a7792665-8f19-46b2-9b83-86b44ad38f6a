            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, place your hand flat onto the<strong> chicken breast<span class=\"text-danger\">[s]</span></strong></p>\n<p>Slice in half as if you were cutting a burger bun, so you are left with two thinner pieces of <strong>chicken</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add a handful of <strong>flour </strong>to a plate with a generous pinch of <strong>salt</strong> and <strong>pepper</strong></p>\n<p>Crack the <strong>egg<span class=\"text-danger\">[s]</span></strong><span class=\"text-danger\"> </span>into a shallow bowl and beat with a fork</p>\n<p>Add the <strong>panko breadcrumbs</strong> to a plate with a pinch of<strong> salt</strong> and <strong>pepper </strong></p>\n<p>Coat the <strong>sliced chicken</strong> in the<strong> flour</strong>, tap off the excess, then into the <strong>beaten egg </strong>and finally press it into the <strong>panko breadcrumbs</strong> firmly to coat everything evenly </p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/976.-step-3-x700.jpg",
