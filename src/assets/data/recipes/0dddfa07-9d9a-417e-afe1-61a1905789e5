  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your<strong> brown onion[s]</strong></p><p>Heat a large pot with a drizzle of <strong>olive oil</strong> over a medium heat</p><p>Once hot, add the <strong>sliced onion</strong> with a pinch of <strong>salt</strong> and cook for 4-5 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1702394672876-x200.jpg",
            "width": 200
