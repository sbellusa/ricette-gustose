            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1619780854979-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1619780854979-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once done, drain and lay the chips flat on a baking tray to steam dry</p><p>Tip: For extra crispy chips, carefully shake them around in the colander to fluff up the edges a little before baking</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1619780868235-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1619780868235-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1619780868235-x700.jpg",
            "width": 700
          },
          {
