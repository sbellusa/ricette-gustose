          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1649782052006-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1649782052006-x700.jpg",
