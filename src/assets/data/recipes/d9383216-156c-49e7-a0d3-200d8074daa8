  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes (skins on) into bite-size pieces</p>\r\n<p><strong>Add</strong> them to a baking tray, drizzle with 1-2 tbsp olive oil and season generously with salt and pepper</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the tray in the oven for 25 min or until golden and crisp</p>\r\n<p><strong>Meanwhile</strong>, peel and finely dice the onion<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Quarter</strong> the cherry tomatoes</p>\r\n<p><strong>Chop</strong> the basil finely, including the stalks</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the capers roughly</p>\r\n<p><strong>Chop</strong> the olives roughly</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> half of the red onion (save the rest for the next step) to a medium sized mixing bowl</p>\r\n<p><strong>Add</strong> the tomatoes, basil, capers, red wine vinegar and 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> olive oil - this is your salsa</p>\r\n<p><strong>Season</strong>&nbsp;with salt and plenty of pepper</p>\r\n<p><strong>Check</strong> on your potatoes before continuing</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the remaining red onion, olives, garlic, turkey mince and dried dill in a large mixing bowl, mixing well</p>\r\n<p><strong>Divide </strong>and shape into&nbsp;2 <span class=\"text-danger\">[4]</span> burgers (approx. 2cm thick)</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide-based pan (preferably non-stick) with 1 tbsp <span class=\"text-danger\">[2 tbsp]&nbsp;</span>vegetable oil over a medium-high heat</p>\r\n<p><strong>Once</strong> hot, add the burgers and cook for 3 min on each side or until browned</p>\r\n<p><strong>Tip:</strong>&nbsp;Try not to fiddle with the burgers too soon, you want to seal them for flipping- this helps them stay together</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/131-step.-6-x400.jpg",
            "width": 400
