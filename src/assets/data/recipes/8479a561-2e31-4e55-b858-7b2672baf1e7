            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) over a medium-high heat with 4 tbsp<span class=\"text-danger\"> [6 tbsp]</span> <strong>vegetable oil</strong></p>\r\n<p>Once hot, add the<strong>&nbsp;halloumi nuggets</strong> and cook for 1-2 min per side or until golden brown and crispy&nbsp;</p>\r\n<p>Once cooked, transfer to kitchen paper&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-4-x400.jpg",
            "width": 400
          },
          {
