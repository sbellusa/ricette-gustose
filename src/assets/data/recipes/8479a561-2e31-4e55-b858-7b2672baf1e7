            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the<strong>&nbsp;pea shoots</strong> roughly</p>\r\n<p>Fluff the <strong>couscous</strong> with a fork</p>\r\n<p>Stir the pea shoots through the couscous with the <strong>dressing</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-6-x200.jpg",
            "width": 200
