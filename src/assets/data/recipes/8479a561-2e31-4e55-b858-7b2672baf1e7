  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Slice the <strong>halloumi</strong> in half lengthways (where the natural crease forms)</p>\r\n<p>Cut each half into 3 even strips (see picture)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add a handful of<strong> flour</strong> to a plate</p>\r\n<p>Crack&nbsp;the <strong>egg<span class=\"text-danger\">[s]</span></strong>&nbsp;into a shallow bowl and beat lightly with a fork&nbsp;</p>\r\n<p>Add&nbsp;the <strong>panko</strong>&nbsp;<strong>breadcrumbs</strong> and<strong> smoked</strong>&nbsp;<strong>paprika</strong> to a separate shallow bowl and mix to combine</p>\r\n<p>Dip the <strong>halloumi</strong>&nbsp;in the <strong>flour</strong>, tap off the excess, then into the <strong>egg</strong> and finally press it into the breadcrumbs</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-2-x700.jpg",
            "width": 700
          },
          {
