            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>couscous</strong> to a heatproof bowl with 200ml <span class=\"text-danger\">[400ml]</span> boiled water, cover and set aside</p>\r\n<p>Strip the <strong>mint</strong> leaves from the stalks and chop them&nbsp;finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/707.-step-3-x700.jpg",
            "width": 700
          },
          {
