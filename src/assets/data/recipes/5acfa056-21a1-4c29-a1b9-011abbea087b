            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1632824661020-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash the <strong>leek<span class=\"text-danger\">[s]</span></strong> carefully to remove any grit from between the leaves, then top, tail and slice finely</p><p>Return the pan to a medium-low heat with a knob of <strong>butter</strong></p><p>Once hot, add the <strong>sliced leek</strong> with a pinch of<strong> salt</strong> and <strong>pepper </strong>and cook for 8-9 min or until softened</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1632824669192-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1632824669192-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1632824669192-x700.jpg",
