  "cooking_instructions": [
    {
      "instruction": "<p><strong>Cut</strong> all the potatoes to roughly equal size (approx. 4cm chunks) </p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 15 min or until you can pierce them easily with a fork</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely slice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and finely chop the garlic cloves</p>\r\n<p><strong>Cut</strong> the bacon up into small bite size pieces</p>\r\n<p><strong>Dissolve</strong> 1/2 <span class=\"text-danger\">(1)</span> of the stock cube<span class=\"text-danger\">(s)</span> in 200ml <span class=\"text-danger\">(400ml)</span> of boiled water</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the bacon and sliced onion to a wide based pan with a matching lid</p>\r\n<p><strong>Cook</strong> on a high heat for 3 min or until the onion is starting to soften and the bacon crisp</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the chicken into strips, approx. 1 cm in width</p>\r\n<p><strong>Coat</strong> the chicken strips evenly in the cornflour</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chicken and chopped garlic to the bacon and onion, and cook for a further 3 min</p>\r\n<p><strong>Add</strong> the chicken stock and cover with a lid</p>\r\n<p><strong>Cook</strong> the chicken on a medium/low heat for 15 - 20 min or until the chicken is tender</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the sugar snap peas in half</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the chicken has had 15 min, remove the lid and reduce the liquid by half </p>\r\n<p><strong>Add</strong> the sugar snap peas and cook for 3 min</p>\r\n<p><strong>Remove</strong> from the heat and stir in half <span class=\"text-danger\">(all)</span> of the creme fraiche </p>\r\n<p><strong>Season</strong> generously with black pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the potatoes </p>\r\n<p><strong>Serve</strong> the chicken with the potatoes to the side </p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
