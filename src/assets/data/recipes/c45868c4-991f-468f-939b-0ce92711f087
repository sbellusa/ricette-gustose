            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion and tomato have softened slightly, add <strong>half </strong>the <strong>chopped garlic</strong> (you'll use the rest later!) to the pan with your <strong>tomato paste</strong></p><p>Cook for 30 secs or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1709224872680-x200.jpg",
            "width": 200
