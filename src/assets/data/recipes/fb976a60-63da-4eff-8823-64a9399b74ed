  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Chop the <strong>waxy potatoes</strong> in half</p><p>Add the <strong>chopped potatoes</strong> to a pot with plenty of <strong>boiled water</strong> and a pinch of <strong>salt</strong> and bring to the boil over a high heat</p><p>Once boiling, cook for 12-15 min or until fork-tender, then drain and return to the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1587400141872-1637683264076-x200.jpeg",
