            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>egg noodles</strong> and <strong>pak choi </strong>to a pot and cover them with<strong> boiled water</strong> until they're fully submerged</p><p>Bring to the boil over a high heat and cook for 5-6 min or until the noodles are cooked with a slight bite</p><p>Once done, drain and set aside</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1723203203237-x200.jpg",
