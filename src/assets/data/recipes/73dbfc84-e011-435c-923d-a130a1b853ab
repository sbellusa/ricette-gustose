  "cooking_instructions": [
    {
      "instruction": "<p>Add the<strong> tilapia fillets</strong> to a plate and drizzle the <strong>soy sauce</strong> all over them, turn the fish several times until all the soy sauce has been absorbed</p><p>Sprinkle the <strong>cornflour </strong>all over and rub it into both sides of the fish until fully coated, then set aside for later – this is your <strong>coated tilapia</strong></p><p>Tip: Coat the fish in the cornflour one side at a time to avoid stickiness!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1649837158642-x200.jpg",
            "width": 200
