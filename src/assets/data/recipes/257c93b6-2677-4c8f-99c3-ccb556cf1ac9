            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp] </span><span class=\"text-danger\">[2 tbsp]</span> <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add the<strong> shredded spring greens</strong> with a pinch of <strong>salt</strong> and cook for 2-3 min or until beginning to wilt</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1634642653807-x200.jpg",
            "width": 200
