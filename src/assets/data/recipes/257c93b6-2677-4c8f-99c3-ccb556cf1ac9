            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, drain, then add your <strong>king prawns </strong>to the pan and cook for an initial 2-3 min</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1634642660511-x200.jpg",
