  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) your <strong>ginger</strong></p><p>Top, tail, peel and chop your<strong> carrot[s]</strong> into thin batons</p><p>Roughly chop your <strong>roasted peanuts</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1684232767852-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1684232767852-x400.jpg",
            "width": 400
