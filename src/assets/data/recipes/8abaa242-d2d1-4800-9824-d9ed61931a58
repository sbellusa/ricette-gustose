      }
    },
    {
      "instruction": "<p>While the butter beans are cooking, chop your <strong>tomato[es]</strong> roughly</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1624609781217-x200.jpg",
