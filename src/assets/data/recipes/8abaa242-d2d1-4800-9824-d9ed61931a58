          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1624609757007-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>drained butter beans </strong>to the pan with a generous crack of <strong>black pepper </strong>and cook for 4-5 min stirring occasionally</p>",
      "order": 2,
      "media": {
