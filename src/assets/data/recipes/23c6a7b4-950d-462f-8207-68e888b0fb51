  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Put a large baking tray (or two) in the oven to heat up (this will stop your pizza bottom[s] from going soggy!)</p><p>Drain and pat your <strong>mozzarella</strong> dry with kitchen paper (squeeze as much liquid out as you can!)</p><p>Tear the <strong>drained</strong> <strong>mozzarella</strong> into rough, bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1712074707925-x200.jpg",
            "width": 200
