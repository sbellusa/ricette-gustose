      }
    },
    {
      "instruction": "<p>Fold the <strong>pastry</strong> over the filling and seal firmly together, then use a fork to crimp along the edge</p><p>Roll the <strong>sealed pastry</strong>, starting at one end, into a spiral</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1658223267964-x200.jpg",
