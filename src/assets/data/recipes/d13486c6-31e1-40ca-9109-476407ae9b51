  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil </strong>a full kettle</p>\r\n<p><strong>Add</strong> the stock cube<span class=\"text-danger\">[s]</span>&nbsp;and 700ml <span class=\"text-danger\">[1.4L]</span>&nbsp;boiled water to a large pot (big enough to fit all the ingredients)</p>\r\n<p><strong>Place</strong> the pot over a high heat and bring to the boil</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely slice the onion<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Peel</strong> and finely slice the garlic</p>\r\n<p><strong>Chop</strong> the cherry tomatoes in half</p>\r\n<p><strong>Grate</strong> the cheese</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the stock is boiling, reduce the heat to medium and add the linguine (you can break the linguine in half if it doesn't fit)</p>\r\n<p><strong>Add</strong>&nbsp;the tomatoes, onion, garlic, dried oregano and the chilli flakes (can't handle the heat? Go easy!)</p>\r\n<p><strong>Add</strong> half the cheese and half the basil</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong>&nbsp;2 tbsp <span class=\"text-danger\">[4 tbsp]</span>&nbsp;olive oil and 1 tsp <span class=\"text-danger\">[2 tsp]</span>&nbsp;of both sugar and pepper</p>\r\n<p><strong>Cover</strong> and cook for 5 min or until half of the water has absorbed</p>\r\n<p>&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/259-step-4-x400.jpg",
