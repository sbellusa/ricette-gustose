  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6 and boil half a kettle</p><p>Cut your <strong>cauliflower[s]</strong> into small florets (discard the stem and leaves), then add the <strong>florets</strong> to a baking tray with your <strong>ground cumin</strong>, a pinch of <strong>salt</strong> and a drizzle of<strong> vegetable oil</strong> and give everything a good mix up</p><p>Put the tray in the oven for 20-25 min or until the cauliflower has softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1612195687147-x200.jpg",
