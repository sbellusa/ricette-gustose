            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely dice<strong> half </strong>your <strong>red onion[s]</strong></p><p>Slice the <strong>remaining red onion</strong></p><p>Dissolve your <strong>chicken stock mix</strong> in 300ml <span class=\"text-purple\">[390ml]</span> <span class=\"text-danger\">[510ml] </span><strong>boiled water</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1683046815098-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1683046815098-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1683046815098-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1683046815098-x1000.jpg",
