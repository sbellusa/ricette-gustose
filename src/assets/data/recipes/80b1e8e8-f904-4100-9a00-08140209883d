          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1618243957090-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your<strong> sausages </strong>to the other side of the tray</p><p>Tip: Cooking for 4? Use 2 trays!</p><p>Put the tray[s] in the oven for 30 min or until the sausages are cooked through and the chips are golden and crisp</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1618243962913-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1618243962913-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1618243962913-x700.jpg",
            "width": 700
          },
