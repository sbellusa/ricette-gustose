  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Boil half a kettle</p><p>Chop your <strong>potatoes </strong>(skins on) into chips</p><p>Add the <strong>chips</strong> to one side of a large baking tray with a drizzle of<strong> vegetable oil </strong>and a pinch of <strong>salt</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1618243957090-x200.jpg",
            "width": 200
