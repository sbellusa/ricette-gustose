          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the heated tray[s] from the oven and add your<strong> pizza base[s]</strong></p><p>Spread the <strong>tomato sauce</strong> evenly over the pizza base[s] with the back of a spoon</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1772.-step-4-x200.jpg",
