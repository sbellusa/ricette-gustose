  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil half a kettle</p><p>Cut narrow slices widthways (about the width of a pound coin) into your<strong> waxy potatoes</strong>, making sure not to cut all the way down to the base – these are your<strong> hasselback potatoes</strong></p><p>Tip: Place chopsticks either side of the potatoes to stop you cutting all the way through!</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1692807002873-x200.jpg",
