            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Whilst the chicken is browning, chop your <strong>creamed coconut</strong> roughly (if required!)</p><p>Dissolve the <strong>chopped creamed coconut</strong>, <strong>fish sauce</strong> and a pinch of <strong>sugar </strong>in 225ml <span class=\"text-purple\">[290ml]</span> <span class=\"text-danger\">[380ml]</span> <strong>boiled water </strong>– this is your<strong> coconut stock</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R1305tep-4-x200.jpg",
