  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice the <strong>brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Deseed the<strong> red pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into large bite-sized pieces</p><p>Heat a large, wide-based pan (preferably non-stick) with 2 tbsp <span class=\"text-danger\">[4 tbsp]</span> <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the <strong>sliced onion</strong> and <strong>chopped</strong> <strong>pepper</strong> with a pinch of <strong>salt</strong> and cook for 6-7 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
