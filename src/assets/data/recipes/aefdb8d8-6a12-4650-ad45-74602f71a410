            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the tofu is cooking, combine your <strong>carrot & cabbage slaw mix</strong> with <strong>half</strong> your <strong>mayo</strong> and <strong>half</strong> your <strong>white wine vinegar </strong>(you'll use the rest later!) – this is your <strong>slaw</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1679407167743-x200.jpg",
