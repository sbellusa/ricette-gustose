    {
      "instruction": "<p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Tear the <strong>tofu</strong> into large chunks</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1679406737201-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1679406737201-x400.jpg",
