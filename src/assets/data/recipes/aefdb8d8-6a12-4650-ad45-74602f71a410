            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine your <strong>white</strong> <strong>miso paste</strong> and the <strong>remaining mayo</strong> in a bowl with the <strong>remaining white wine vinegar</strong>– this is your <strong>miso mayo dip</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1679407068199-x200.jpg",
            "width": 200
