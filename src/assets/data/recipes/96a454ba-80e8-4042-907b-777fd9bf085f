          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1581673633430-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium-high heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the <strong>cooled rice</strong>, your <strong>blanched peas</strong>, <strong>toasted sesame oil</strong> and <strong>soy sauce</strong> and cook for 2-3 min until everything is combined</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1581673637829-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1581673637829-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1581673637829-x700.jpg",
