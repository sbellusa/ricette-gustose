          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-copy-1703174647990-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>chicken stock</strong>,<strong> lime leaf[ves]</strong> and 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp] </span><strong>sugar</strong></p><p>Cook, covered, for 10-15 min or until the sauce has reduced and the chicken is cooked through (no pink meat!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1703174652910-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1703174652910-x400.jpg",
