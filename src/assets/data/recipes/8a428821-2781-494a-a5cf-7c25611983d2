            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1719319962576-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve your <strong>chicken stock mix</strong> in 150ml <span class=\"text-purple\">[200ml]</span> <span class=\"text-danger\">[250ml] </span><strong>boiled water </strong>with the <strong>remaining jerk paste</strong>,<strong> </strong>a pinch of <strong>sugar</strong> and a generous pinch of <strong>salt </strong>and <strong>pepper </strong>– this is your<strong> jerk-spiced stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1719319969421-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1719319969421-x400.jpg",
