    {
      "instruction": "<p>Slice the <strong>halloumi</strong> in half, then each half into 6 <span class=\"text-danger\">[12]</span> sticks</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 4,
