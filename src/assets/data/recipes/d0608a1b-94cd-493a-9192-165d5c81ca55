  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Slice your <strong>red chilli[es]</strong> into rounds</p><p>Combine your <strong>rice vinegar</strong>,<strong> </strong>1/2 tsp <span class=\"text-purple\">[1/4 tsp] </span><span class=\"text-danger\">[1 tsp]</span> <strong>sugar </strong>and 1 tbsp<span class=\"text-purple\"> [1 1 1/2 tsp]</span> <span class=\"text-danger\">[2 tbsp] </span><strong>water </strong>in a bowl and gently stir it all together</p><p>Add the<strong> chilli</strong> <strong>rounds</strong> to the bowl and set aside – this is your <strong>quick-pickled chilli</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1.-1632836897108-x200.jpg",
            "width": 200
