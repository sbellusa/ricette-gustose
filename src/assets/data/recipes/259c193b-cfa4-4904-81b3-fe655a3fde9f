            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the butternut squash has had 10-12 min in the oven, add your <strong>Tenderstem broccoli</strong> to the tray[s]</p><p>Return the tray[s] to the oven for a further 10-15 min or until the butternut squash is tender and the broccoli is crispy</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1717062123914-x200.jpg",
