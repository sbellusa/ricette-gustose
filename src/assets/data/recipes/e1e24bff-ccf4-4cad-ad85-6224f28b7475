  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil a kettle</p><p>Remove the leaves from your <strong>cauliflower</strong>, then chop into rough bite-sized pieces</p><p>Add the<strong> cauliflower </strong>to a<strong> food processor</strong> and blitz until finely chopped – this is your <strong>cauliflower rice</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1711468247819-x200.jpg",
            "width": 200
