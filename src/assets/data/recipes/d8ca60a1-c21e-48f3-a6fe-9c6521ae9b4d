  "cooking_instructions": [
    {
      "instruction": "<p>Add the<strong>&nbsp;rice</strong>, 350ml<span class=\"text-danger\">&nbsp;[700ml]</span>&nbsp;water to a pot with a lid over a high heat and bring to the boil</p>\r\n<p>Once boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/273.step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/273.step1-x400.jpg",
