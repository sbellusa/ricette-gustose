            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Peel and finely chop (or grate) the <strong>garlic</strong></p>\r\n<p>Return&nbsp;the pan to a medium heat</p>\r\n<p>Once&nbsp;hot, add the <strong>turmeric</strong>, <strong>chilli flakes</strong> (can't handle the heat? Go easy!), <strong>curry powder</strong> and <strong>garlic </strong>and cook&nbsp;for 30 sec</p>",
      "order": 3,
      "media": {
        "images": [
          {
