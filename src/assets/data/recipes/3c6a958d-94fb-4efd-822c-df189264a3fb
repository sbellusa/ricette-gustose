            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve your <strong>soft cheese</strong> and <strong>chicken stock mix</strong> in 100ml <span class=\"text-purple\">[130ml] </span><span class=\"text-danger\">[170ml]</span> <strong>boiled water </strong>– this is your <strong>creamy chicken stock</strong></p><p>Grate your <strong>cheddar cheese</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1670340093845-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1670340093845-x400.jpg",
