            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add your<strong> hot dog sausage[s]</strong> to one side of a <strong>tin foil-</strong>lined-baking tray (or two!)</p><p>Put the tray[s] in the oven for 25 min or until the sausage[s] are cooked through</p>",
      "order": 2,
      "media": {
        "images": [
