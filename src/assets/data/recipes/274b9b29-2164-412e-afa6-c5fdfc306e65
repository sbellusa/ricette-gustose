  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce the heat and simmer gently with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> occasionally to prevent over-cooking- once done, set aside (until step 8)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a pan on a medium-high heat</p>\r\n<p><strong>Trim</strong> the fat off the steaks (if desired) and rub them with 1-2 tbsp of vegetable oil and season with salt</p>\r\n<p><strong>When</strong> the pan is hot, add the steaks and cook on each side for 3 min<br />Transfer them to a plate and cover with a clean teatowel or kitchen foil (reserve the pan)</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 450&deg;F/ Gas 6</p>\r\n<p><strong>Peel</strong> and cut the onion<span class=\"text-danger\">(s)</span> in half, cut each half into rough chunks </p>\r\n<p><strong>De-seed</strong> the pepper<span class=\"text-danger\">(s)</span> and cut into bite-sized pieces</p>\r\n<p><strong>Drain</strong> the pineapple reserving the juice, chop all of the pineapple rings into bite-size pieces</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cashew nuts to an oven tray<br /><br /><strong>Put</strong> it in the oven for 8 min, until the nuts are starting to colour and releasing their aroma</p>\r\n<p><strong>Chop</strong> the spring onions finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan (from step 2) to the heat</p>\r\n<p><strong>Add</strong> the onion, pepper and pinepple chunks</p>\r\n<p><strong>Cook</strong> for 5 min on a medium-high heat until starting to colour</p>\r\n<p><strong>Transfer</strong> the vegetables to a bowl (reserve the pan)</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the cornflour to a small mixing bowl</p>\r\n<p><strong>Gradually</strong> add the pineapple juice, whisking with a fork until you have a smooth paste</p>\r\n<p><strong>Add</strong> the rice vinegar, soy sauce and chilli flakes</p>\r\n<p><strong>Slice</strong> the rested pork</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pan to a medium heat</p>\r\n<p><strong>Add</strong> the sauce and 100ml <span class=\"text-danger\">(150ml)</span> water</p>\r\n<p><strong>Cook</strong> for 2 min, or until thickened</p>\r\n<p><strong>Add</strong> the vegetables and sliced pork back to the pan to warm through</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the spring onions to the pan (off the heat) and mix through</p>\r\n<p><strong>Serve</strong> with the rice to the side and the toasted cashews scattered over</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
