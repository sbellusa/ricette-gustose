          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the cooked rice in a sieve</p>\r\n<p><strong>Toss</strong> the drained rice back into the fish pan and stir until the rice is coated in the remaining oil for a little flavour</p>",
      "order": 7,
      "media": {
        "images": [
