          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Bring</strong> the chilli sauce to a rapid boil until the water has evaporated by 2/3rds</p>\r\n<p><strong>Divide</strong> the sauce into bowls for each person</p>\r\n<p><strong>Divide</strong> the chopped cucumber between each bowl</p>\r\n<p><strong>Transfer</strong> the cooked fish cakes to a plate to rest, keeping the pan on a low heat</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--6-x1000.jpg",
