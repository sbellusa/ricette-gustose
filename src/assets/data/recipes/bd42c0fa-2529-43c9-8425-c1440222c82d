  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice to a medium pot with 500ml cold water and a pinch of salt, bring to the boil on a high heat and cook for 20-25 min or until the rice is cooked with a slight bite</p>\r\n<p><strong>Meanwhile</strong>, add 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of sugar and 350ml <span class=\"text-danger\">(600ml)</span> of water to another pot with a lid on a high heat</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the chilli<span class=\"text-danger\">(es)</span> in half lengthways, scrape out the seeds with a teaspoon and chop ﬁnely</p>\r\n<p><strong>Once</strong> the sugar water is boiling, add the chilli and half the white wine vinegar</p>\r\n<p><strong>Return</strong> to a boil, then lower the heat to a gentle simmer without a lid for 15 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, slice the spring onion<span class=\"text-danger\">(s)</span> finely, keeping the whites (step 4) and greens (step 8) separate</p>\r\n<p><strong>Peel</strong> the cucumber lengthways into ribbons with a vegetable peeler, stopping at the seedy interior</p>\r\n<p><strong>Add</strong> the ribbons to a bowl with the remaining white wine vinegar, 1/4 tsp <span class=\"text-danger\">(1/2 tsp)</span> of sugar, 1/4 tsp<span class=\"text-danger\"> (1/2 tsp)</span> of salt and chilli flakes</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Mix</strong> the ribbons and leave until serving</p>\r\n<p><strong>Pat</strong> the fish dry and cut roughly into 2cm chunks</p>\r\n<p><strong>Add</strong> the fish, curry paste, fish sauce, five spice and the whites of the spring onion to a food processor</p>\r\n<p><strong>Blitz</strong> until the mixture comes together into a chunky, sticky ball</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Shape</strong> the mixture into 4<span class=\"text-danger\"> (8)</span> flat patties</p>\r\n<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a pan on a medium heat</p>\r\n<p><strong>Once</strong> hot, cook the patties for 2-3 min each side, or until golden, cooked through and with a slight bounce in the centre</p>\r\n<p><strong>Meanwhile</strong>, finely chop the seedy interior of the cucumber</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/444.-step--5-x1000.jpg",
