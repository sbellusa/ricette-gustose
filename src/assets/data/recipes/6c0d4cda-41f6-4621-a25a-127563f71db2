          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/V2-2221-Step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your<strong> cherry tomatoes</strong> in half</p><p>Remove the base of your <strong>lettuce</strong></p><p>Wash your <strong>lettuce</strong> under <strong>cold running water</strong> and cut away the core, then pat dry with kitchen paper </p><p>Tear the <strong>lettuce leaves</strong> from the stem until you are left with a pile of leaves</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2221-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2221-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2221-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2221-step-6-x1000.jpg",
