            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely chop the<strong> brown onion<span class=\"text-danger\">[s]</span></strong></p><p>Top, tail, peel and finely dice the <strong>carrot<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 2,
      "media": {
        "images": [
