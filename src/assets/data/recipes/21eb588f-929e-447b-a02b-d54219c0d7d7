    },
    {
      "instruction": "<p>Peel <span class=\"text-highlight\"><strong>half</strong> of t</span>he <strong>Italian hard cheese</strong> until you have a pile of shavings <span class=\"text-highlight\">(set these aside for serving!)</span></p>\n<p>Grate the <strong>remaining Italian hard cheese</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1648.-step-3-x200.jpg",
