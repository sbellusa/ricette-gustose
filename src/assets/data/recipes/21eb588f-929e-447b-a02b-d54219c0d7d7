          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1648.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>drained spaghetti</strong> with the <span class=\"text-highlight\"><strong>juice</strong></span> of 1/2 <span class=\"text-danger\">[1]</span> <strong>lemon</strong>, the<strong> grated cheese</strong> and a generous pinch of <strong>salt</strong> and <strong>pepper</strong></p>\n<p>Add a splash of the <strong>starchy pasta water</strong> with a generous drizzle of<strong> olive oil</strong> and give everything a good mix up</p>\n<p>Cook for 30 sec further or until the sauce beings to stick to the pasta</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1648.-step-6-x200.jpg",
