  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Add the&nbsp;<strong>Thai rice noodles</strong>&nbsp;to a shallow bowl and cover them with&nbsp;<strong>cold water</strong></p>\r\n<p>Set them aside to soak</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1324.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1324.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1324.-step-1-x700.jpg",
            "width": 700
          },
