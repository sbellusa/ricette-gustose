  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Heat a large, wide-based pan (preferably non-stick) with a matching lid over a medium heat and once hot, add the <strong>walnuts</strong> and toast for 3-4 min or until they've slightly darkened in colour</p>\r\n<p>Once toasted, transfer the<strong> walnuts</strong> to a chopping board to cool (keep the pan for later!)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/497__step-1-x200.jpg",
            "width": 200
