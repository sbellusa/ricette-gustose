  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely chop the <strong>brown&nbsp;onion<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Peel (scrape the skin off with a teaspoon) and finely chop (or grate) the<strong> ginger</strong></p>\r\n<p>Cut the <strong>chicken breast<span class=\"text-danger\">[s]</span></strong> into bite-sized pieces</p>\r\n<p>Add the<strong>&nbsp;chicken</strong>&nbsp;to a bowl with the&nbsp;<strong>garam masala</strong>&nbsp;and a generous pinch of&nbsp;<strong>salt</strong></p>\r\n<p>Give everything a good old mix up until the&nbsp;<strong>chicken</strong>&nbsp;is coated in the<strong>&nbsp;spices</strong></p>",
      "order": 1,
      "media": {
        "images": [
