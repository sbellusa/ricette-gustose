            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, dry, wide-based pan (preferably non-stick) over a high heat</p><p>Once very hot, add the <strong>sirloin steak[s]</strong> to the pan</p><p>For rare, cook for 2-3 min max on each side; for medium-rare, cook for 3-4 min on each side; for medium, cook for 4-5 min on each side</p><p>Once the steak[s] are cooked, transfer to a plate to rest</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1621.-step-6-x200.jpg",
            "width": 200
