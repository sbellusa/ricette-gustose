            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1530.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped potatoes</strong> to a pot of <strong>boiling water</strong> with a large pinch of <strong>salt</strong> and cook over a high heat for 10-15 min or until fork-tender</p><p>Once cooked, drain and return them to the pot</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1530.-step-2-x200.jpg",
