  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p><p>Boil a kettle</p><p>Chop the<strong> potatoes</strong> (skins on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1530.-step-1-x200.jpg",
            "width": 200
