          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1598262766687-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1598262766687-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the prawns are cooking, cut the <strong>remaining</strong> <strong>lime</strong> into wedges</p><p>Slice the <strong>remaining</strong> <strong>chilli </strong>finely</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1598262786350-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1598262786350-x400.jpg",
