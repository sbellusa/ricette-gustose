            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil half a kettle</p><p>Peel and finely chop your <strong>shallot[s]</strong></p><p>Trim, then chop your<strong> green beans</strong> into bite-sized pieces</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1598262705777-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1598262705777-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1598262705777-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1598262705777-x1000.jpg",
            "width": 1000
