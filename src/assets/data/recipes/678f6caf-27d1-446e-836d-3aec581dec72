          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1602153477369-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>shallot</strong> with a pinch of <strong>salt</strong> and cook for 2 min or until softened</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1598262733940-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1598262733940-x400.jpg",
            "width": 400
