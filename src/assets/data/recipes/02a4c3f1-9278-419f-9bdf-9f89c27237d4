          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, combine the remaining yoghurt with the remaining whites of the spring onions</p>\r\n<p><strong>Mix</strong> well and season with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step7-x1000.jpg",
