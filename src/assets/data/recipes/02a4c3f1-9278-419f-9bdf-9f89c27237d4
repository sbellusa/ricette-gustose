  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step-1-x200.jpg",
