            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the red lentils, ginger, 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;yoghurt, the remaining harissa paste and half the spring onion whites to the pot</p>\r\n<p><strong>Reduce</strong> to a medium-low heat and cook with a lid on for 7 min or until the lentils and potatoes are cooked through and most of the water has been absorbed</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/286.-step6-x1000.jpg",
