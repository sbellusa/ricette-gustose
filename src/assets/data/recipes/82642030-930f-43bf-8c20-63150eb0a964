  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 230&deg;C/ 210&deg;C (fan)/ 450&deg;F/ Gas 8</p>\r\n<p><strong>Cut</strong> the potatoes into wedges (approx. 1cm), place on an oven-proof tray, coat well with 1-2 tbsp of olive oil and season to your taste with salt and pepper </p>\r\n<p><strong>Put</strong> in the oven for 20 min or until golden brown, turning half way through</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, grate the zest of the lime<span class=\"text-danger\">(s)</span> and cut into quarters</p>\r\n<p><strong>Chop</strong> the coriander finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the lime zest, juice of half the <span class=\"text-danger\">(whole)</span> lime, coriander, garlic, chipotle paste (careful, adjust the amount to your preferred hotness) and 2-4 tbsp of olive oil for the spicy sauce</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper and set aside</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the courgette<span class=\"text-danger\">(s)</span> into slices (approx. 1/2-1 cm thick)</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan (use a griddle pan if you have one) on a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the courgettes and cook for 2 min on each side or until slightly charred with a little crunch</p>\r\n<p><strong>Remove</strong> from the pan and set aside</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, season the salmon steaks to your taste on both sides with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to the courgette pan</p>\r\n<p><strong>Once</strong> the oil is hot, add the salmon skin side down</p>\r\n<p><strong>Cook</strong> for 3-4 min on each side or until the skin is crisp and the salmon is cooked through</p>\r\n<p><strong>Remove</strong> the salmon from the pan</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the salmon with the potato wedges and courgette</p>\r\n<p><strong>Pour</strong> the spicy sauce over the salmon and serve with a wedge of lime</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
