  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, the boil a kettle</p><p>Peel and chop <strong>half</strong> your <strong>red onion[s] </strong>into wedges</p><p>Finely slice the <strong>remaining onion</strong></p><p>Add the <strong>sliced onion</strong> to a small bowl with your <strong>red wine vinegar</strong> and a pinch of <strong>salt </strong>and <strong>sugar </strong>and set aside to pickle – this is your <strong>quick-pickled onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680105118858-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680105118858-x400.jpg",
            "width": 400
