      }
    },
    {
      "instruction": "<p>Crush your <strong>roasted</strong> <strong>peanuts</strong> with a <strong>rolling pin</strong></p><p>Tip: If you don’t have a rolling pin, just chop them roughly!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624973682384-x200.jpg",
