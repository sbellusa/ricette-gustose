            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/R2047Step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken is starting to brown, add the <strong>halved</strong> <strong>green beans </strong>and cook for a further 4-5 min or until starting to soften and the chicken is cooked through (no pink meat!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1609328396883-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1609328396883-x400.jpg",
