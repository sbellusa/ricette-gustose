  "cooking_instructions": [
    {
      "instruction": "<p><strong>Heat</strong> a dry wide-based pan (preferably non-stick) on a medium heat</p>\r\n<p><strong>Once</strong> hot, cook the walnuts for 3 min or until lightly toasted, checking frequently</p>\r\n<p><strong>Meanwhile</strong>, cut the aubergine<span class=\"text-danger\">(s)</span> into 1cm pieces, discarding the green stalk<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Once</strong> the walnuts are toasted, set them aside for serving and reserve the pan</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the walnut pan to a high heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil</p>\r\n<p><strong>When</strong> hot, add the aubergine with a large pinch of salt</p>\r\n<p><strong>Cook</strong> for 5 min until the flesh is a deep golden colour, stirring minimally</p>\r\n<p><strong>Meanwhile</strong>, peel and finely slice the onion<span class=\"text-danger\">(s)</span> for step 3 and boil a kettle for step 4</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the darkened aubergine to a food processor, reserving a handful for garnish</p>\r\n<p><strong>Return</strong> the pan to a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil&nbsp;</p>\r\n<p><strong>Once</strong> hot, add the onion with a pinch of salt and cook for 5 min, or until translucent and softened, stirring occasionally</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-3-x1000.jpg",
