          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the pasta to a large pot of boiling water with a large pinch of salt (optional)</p>\r\n<p><strong>Cook</strong> on a high heat for 8-10 min, or until cooked but with a slight bite&nbsp;</p>\r\n<p><strong>Reserve</strong> 200ml <span class=\"text-danger\">(300ml)</span> of pasta water for step 7 and drain thoroughly for serving</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/453.-step-4-x400.jpg",
