  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>red onion[s]</strong></p><p>Peel and finely chop (or grate) your<strong> garlic</strong></p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid), over a medium heat with a drizzle of <strong>vegetable oil</strong> and a large knob of <strong>butter</strong></p><p>Once hot, add the <strong>sliced onion </strong>and <strong>chopped</strong> <strong>garlic</strong> with a pinch of <strong>salt</strong> and cook for 8 min or until softened and browning slightly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1708420771712-x200.jpg",
            "width": 200
