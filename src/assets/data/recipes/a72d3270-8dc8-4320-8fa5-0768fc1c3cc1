            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Spoon over the <strong>remaining chilli paste</strong></p><p>Put the dish in the oven for an initial 18-20 min or until bubbling and golden round the edges – these are your <strong>enchiladas</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1666707395944-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1666707395944-x400.jpg",
