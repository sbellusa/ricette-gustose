  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Peel your <strong>garlic</strong></p><p>Chop <strong>half</strong> of your <strong>tomato[es]</strong> roughly (save the rest for later!)</p><p>Slice <strong>half</strong> your <strong>green chilli[es]</strong> finely and set aside for later, then chop the <strong>remaining green chilli</strong> roughly</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1666707383978-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-copy-1666707383978-x400.jpg",
