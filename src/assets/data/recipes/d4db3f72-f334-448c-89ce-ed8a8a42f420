            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the meat-free chick'n is cooking, roughly dice your<strong> tomato[es]</strong></p><p>Chop <strong>half</strong> your <strong>cucumber</strong> (you'll use the rest later!) into small, bite-sized pieces</p><p>Chop your <strong>parsley</strong> roughly, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1678902528626-x200.jpg",
