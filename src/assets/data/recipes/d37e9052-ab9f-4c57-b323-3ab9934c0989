            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the onion is softening, dice the <strong>tomato<span class=\"text-danger\">[es] </span></strong>finely</p><p>Reserve a few <strong>coriander leaves </strong>for garnish</p><p>Chop the <strong>remaining coriander </strong>finely, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
