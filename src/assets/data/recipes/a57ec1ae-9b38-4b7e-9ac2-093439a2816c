            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Wipe </strong>the reserved pan clean and return&nbsp;it to a medium heat, with a knob of butter</p>\r\n<p><strong>Once</strong> hot, add the green beans with a splash of water and cook, covered, for 5 min or until cooked through&nbsp;</p>",
      "order": 6,
      "media": {
