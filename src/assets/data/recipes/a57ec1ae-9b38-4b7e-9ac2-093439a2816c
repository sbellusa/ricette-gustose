  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Slice</strong> the potatoes into discs and add to&nbsp;a baking tray (use tin foil to avoid mess!)</p>\r\n<p><strong>Drizzle</strong> with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> vegetable oil, season&nbsp;with a pinch of salt and pepper and put them oven for 20-30 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, boil a kettle</p>\r\n<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> olive oil over a high heat</p>\r\n<p><strong>Season</strong> the chicken with a pinch of salt and pepper</p>\r\n<p><strong>Once</strong> hot, add the chicken and cook for 3 min, turning halfway until just golden, then&nbsp;transfer to a plate and reserve the pan</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely chop (or grate) the garlic</p>\r\n<p><strong>Dissolve</strong> half <span class=\"text-danger\">[all]</span> the stock cube in 300ml <span class=\"text-danger\">[600ml]</span> boiled water &nbsp;</p>\r\n<p><strong>Return</strong> the pan to a medium heat, with a drizzle of olive oil&nbsp;</p>\r\n<p><strong>Add</strong>&nbsp;the garlic and cook for 1 min, then add the stock, tomato paste, Henderson's relish and oregano (save a pinch for step 7)</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> for 3-6 min or until the liquid has reduced to a soup-like consistency</p>\r\n<p><strong>Once</strong>&nbsp;reduced, pour the sauce into a casserole dish (or a suitably deep oven-proof dish) and place the chicken thighs on top, reserving the pan for later</p>\r\n<p><strong>Put</strong>&nbsp;the dish in the oven for 15 min&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-4-x200.jpg",
            "width": 200
