            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, pat the mozzarella ball<span class=\"text-danger\">[s]</span> dry and cut into slices&nbsp;</p>\r\n<p><strong>Trim</strong> the green beans and cut them into bite-size pieces (little hands can do this with scissors!)</p>\r\n<p>&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/635.-step-5-x200.jpg",
            "width": 200
          },
          {
