  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 230&deg;C/ 210&deg;C (fan)/ 450&deg;F/ Gas 8</p>\r\n<p><strong>Quarter</strong> the sweet potatoes lengthways (skin on), then halve each quarter lengthways to form thin wedges (approx. 2cm thick)</p>\r\n<p><strong>Quarter</strong> the red onion<span class=\"text-danger\">(s)</span> lengthways with the skin &amp; root intact, then halve each quarter lengthways</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the red onion and sweet potato on a large oven tray (families may need two trays)</p>\r\n<p><strong>Coat</strong> the veg with 2-4 tbsp of olive oil and paprika, then season to taste with salt and pepper</p>\r\n<p>Tip: Arrange the vegetables on a single layer for optimum caramelisation!</p>\r\n<p><strong>Roast</strong> for 30 min, turning halfway, or until browned and softened</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, chop the coriander coarsely and add 2/3 to a mixing bowl (reserve the rest for serving)</p>\r\n<p><strong>Add</strong> the beef and half of the harissa (save the rest for step 7) to the bowl</p>\r\n<p><strong>Mix</strong> well and season to your taste with salt and pepper</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Form</strong> 4 <span class=\"text-danger\">(8)</span> equal shape and size patties</p>\r\n<p><strong>Set</strong> aside on a plate (used in step 5)</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan on a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the meat and cook for 4-5 min each side, or to your preference</p>\r\n<p><strong>Remove</strong> from the pan and allow to rest</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the tray from the oven and allow to cool</p>\r\n<p><strong>Transfer</strong> the sweet potatoes to the serving plates</p>\r\n<p><strong>Once</strong> cooled, carefully pull apart the red onion layers into petals, discarding the skin</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, combine the yoghurt with the remaining harissa in a small bowl</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>\r\n<p><strong>Set</strong> aside for serving</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Pile</strong> the burgers on the serving plates</p>\r\n<p><strong>Top</strong> with the harissa yogurt and scatter the red onion petals, with the remaining coriander on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
