            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1456.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, re-boil a kettle</p>\n<p>Cut the <strong>purple sprouting broccoli</strong> in half </p>\n<p>Dissolve the <strong>vegetable stock cube<span class=\"text-danger\">[s]</span></strong> in 150ml <span class=\"text-danger\">[300ml]</span> <strong>boiled water</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1456.-step-3new-x200.jpg",
            "width": 200
