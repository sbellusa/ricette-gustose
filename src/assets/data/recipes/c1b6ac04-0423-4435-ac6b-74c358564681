            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>linguine</strong> to the reserved pot with a pinch of <strong>salt</strong></p>\n<p>Cover with plenty of <strong>boiled water</strong> and bring to the boil over a high heat</p>\n<p>Cook the<strong> linguine</strong> for an initial 4-5 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1456.-step-2-x200.jpg",
