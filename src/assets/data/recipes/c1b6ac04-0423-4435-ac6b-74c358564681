          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1456.-step-3new-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>linguine</strong> has had 4-5 min, add the<strong> chopped broccoli</strong></p>\n<p>Cook for a further 4-5 min until everything's tender</p>\n<p>Once tender, drain and keep in the sieve</p>\n<p>Reserve the pot for later</p>",
      "order": 4,
      "media": {
