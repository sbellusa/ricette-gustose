  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\n<p>Heat a dry pot over a medium heat</p>\n<p>Once hot, add the <strong>pine nuts </strong>and cook for 2-3 min or until golden and toasted</p>\n<p>Tip: watch the nuts like a hawk to make sure they don't burn!</p>\n<p>Once done, transfer them to a plate and set aside, reserving the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1456.-step-1-x200.jpg",
