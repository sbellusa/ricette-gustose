  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Boil a kettle</p>\n<p>Cut the <strong>potatoes</strong> into chips</p>\n<p>Add the <strong>chips</strong> to a baking tray with a generous drizzle of <strong>vegetable oil</strong></p>\n<p>Season with a pinch of <strong>salt</strong> and put the tray in the oven for 30-35 min or until golden and crisp</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/B.Test.1532.-step-1.2-x200.jpg",
