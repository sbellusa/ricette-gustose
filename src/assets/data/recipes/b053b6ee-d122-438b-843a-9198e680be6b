            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the reserved pan to a medium-high heat</p><p>Once hot, add the <strong>beef patties</strong>, press them down firmly with a spatula and cook for 4-5 min on each side or until cooked through and charred (no pink meat!)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1721286335398-x200.jpg",
