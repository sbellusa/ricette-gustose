          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1593428829393-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and chop your <strong>red onion[s] </strong>into wedges, then separate the wedges into 'petals'</p><p>Chop your <strong>paneer </strong>into bite-sized cubes</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1593428843559-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1593428843559-x400.jpg",
