            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add the <strong>wholewheat noodles</strong> to a pot and cover them with<strong> boiled water</strong> until fully submerged</p><p>Bring to the boil over a high heat and cook for 5 min until tender, then drain and return them to the pot until serving</p>",
      "order": 4,
      "media": {
        "images": [
