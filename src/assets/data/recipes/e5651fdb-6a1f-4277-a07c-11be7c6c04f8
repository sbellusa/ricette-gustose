  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>shallot[s]</strong></p><p>Deseed your<strong> pepper[s]</strong> (scrape the seeds and pith out with a teaspoon) and cut into thin strips</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
