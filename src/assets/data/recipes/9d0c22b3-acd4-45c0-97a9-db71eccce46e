            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Re-boil half a kettle</p><p>Peel and finely slice (don't chop!) the <strong>garlic</strong></p><p>Once the chicken has browned, add the <strong>sliced garlic</strong> to the pan and cook for 1-2 min until fragrant</p>",
      "order": 4,
      "media": {
