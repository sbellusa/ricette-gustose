            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>cornflour</strong> to the bowl with the <strong>marinated basa fillet[s]</strong></p><p>Give everything a good mix up until the basa fillet[s] are coated in the Thai-style batter – this is your <strong>coated basa</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-1647965076863-x200.jpg",
