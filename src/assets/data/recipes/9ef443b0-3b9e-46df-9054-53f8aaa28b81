  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Chop your <strong>potato[es]</strong> (skin on) into small bite-sized pieces</p><p>Top, tail, peel and finely dice your<strong> carrot[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1675766068592-x200.jpg",
            "width": 200
