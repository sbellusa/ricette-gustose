            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>hake fillet[s] </strong>to a bowl with your <strong>curry powder </strong>and a pinch of <strong>salt </strong>and give everything a good mix up until fully coated<strong> </strong>– this is your<strong> coated hake</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1676649005995-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1676649005995-x400.jpg",
