          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1682.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>teriyaki chicken</strong> with the<strong> cooked rice </strong>and<strong> sesame greens </strong>to the side</p><p>Garnish with the <strong>remaining sliced spring onion</strong></p><p>Enjoy!</p>",
      "order": 8,
