            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/984.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, grate your <strong>cheddar cheese</strong></p><p>Strip your <strong>coriander leaves</strong> from their stalks and chop the <strong>stalks</strong> finely (save the<strong> leaves</strong> for garnish!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/984.-step-4-x200.jpg",
