            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Stir the<strong> chopped coriander stalks</strong> through the enchilada filling</p><p>Divide 3/4 of the <strong>enchilada filling</strong> (save some for later!) between your <strong>tortillas</strong>, covering only half of each <strong>tortilla</strong></p><p>Roll up the <strong>tortillas</strong> tightly – these are your <strong>enchiladas</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/984.-step-5-x200.jpg",
