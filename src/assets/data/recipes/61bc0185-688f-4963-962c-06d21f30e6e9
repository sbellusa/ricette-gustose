            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>wholewheat noodles</strong> to a pot, cover them with <strong>boiled water</strong> until fully submerged and stir for 10 secs to separate the noodles</p><p>Set aside to soak for 4 min, then drain the <strong>soaked noodles</strong> and return to the pot</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581514502544-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581514502544-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581514502544-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581514502544-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1581514502544-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>carrot batons</strong>, <strong>onion petals</strong> and <strong>halved mangetout </strong>with a pinch of <strong>salt</strong></p><p>Cook for 5-6 min or until softened</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1581514508750-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1581514508750-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1581514508750-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1581514508750-x1000.jpg",
