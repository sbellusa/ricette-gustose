  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and chop the <strong>red onion<span class=\"text-danger\">[s]</span></strong> into small petals</p><p>Top, tail and chop the <strong>carrot<span class=\"text-danger\">[s]</span></strong> into thin batons</p><p>Slice the <strong>mangetout</strong> in half lengthways</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1581514484422-x200.jpg",
            "width": 200
