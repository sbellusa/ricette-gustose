            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1690280638100-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1690280638100-x400.jpg",
            "width": 400
          },
