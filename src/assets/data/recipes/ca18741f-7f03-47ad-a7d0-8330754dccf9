  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Add</strong> the bulgur wheat to a pot with 275ml <span class=\"text-danger\">(550ml)</span> of boiling water, cover with a lid and place on a medium-low heat and simmer for 5 min or until almost all of the water is absorbed</p>\r\n<p><strong>Remove</strong> from the heat and allow to rest with the lid on for 10 min</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, put the sultanas in a small bowl and add 100ml <span class=\"text-danger\">(200ml)</span> of hot water</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span>, cut them in half and slice finely</p>\r\n<p><strong>Chop</strong> the mint leaves finely, discarding the stems</p>\r\n<p><strong>Grate</strong> the zest of the lemon<span class=\"text-danger\">(s) </span></p>\r\n<p><strong>Cut</strong> the lemon<span class=\"text-danger\">(s) </span>into thin slices</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> half the ras el hanout, 1 tsp (2 tsp) black pepper and a pinch of salt to make a spice mix</p>\r\n<p><strong>Coat</strong> the chicken well with the spice mix</p>\r\n<p><strong>Cut</strong> an incision in one side of each chicken breast to make a pocket</p>\r\n<p><strong>Place</strong> 2 slices of lemon into each pocket</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large pan on a medium-high heat </p>\r\n<p><strong>Once</strong> the oil is hot, add the chicken and onion and cook for 2 min or until the chicken is lightly browned</p>\r\n<p><strong>Add</strong> 100ml <span class=\"text-danger\">(200ml)</span> of water to the pan, stir and cook for 2 min or until it has evaporated</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Turn</strong> the chicken carefully, keeping it together</p>\r\n<p><strong>Add</strong> another 100ml <span class=\"text-danger\">(200ml)</span> of water and cook for 4-5 min or until the chicken is cooked through and the onions are lightly caramelised</p>\r\n<p><strong>Stir</strong> the onion occasionally</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> of the sultana water to the bulgur wheat, drain the sultanas and add them too</p>\r\n<p><strong>Combine</strong> the sultana bulgur with the mint, lemon zest, remaining ras el hanout, pomegranate molasses and 1-2 tbsp of olive oil</p>\r\n<p><strong>Mix</strong> well and season to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the bulgur wheat with the onion and chicken on the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
