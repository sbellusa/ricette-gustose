  "cooking_instructions": [
    {
      "instruction": "<p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air, then heat a large, wide-based pan (preferably non-stick with a matching lid) with a large drizzle of<strong> vegetable oil</strong> over a medium-high heat</p><p>Cut your<strong> chicken breast strips</strong> into bite-sized pieces, then once the pan is hot, add the <strong>diced chicken</strong> and cook for 4-5 min or until browned</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1635258042388-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1635258042388-x400.jpg",
            "width": 400
