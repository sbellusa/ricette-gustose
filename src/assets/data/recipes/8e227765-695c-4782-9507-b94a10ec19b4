          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1621257550328-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1621257550328-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1621257550328-x1000.jpg",
