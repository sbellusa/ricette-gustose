          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1621257529374-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1621257529374-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> sticky chilli sauce </strong>to the pan and cook for 3 min or until the sauce begins to thicken and the pepper has softened</p><p>Once thickened, add the<strong> crispy basa </strong>to the pan and cook for 1 min further until the fish is coated in the sauce – this is your <strong>sticky basa</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1621257542746-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1621257542746-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1621257542746-x700.jpg",
