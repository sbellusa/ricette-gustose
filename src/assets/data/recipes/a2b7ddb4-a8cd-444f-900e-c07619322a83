  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Pour</strong> the water into a pot (for the potatoes) and bring it to a boil (used in step 3)</p>\r\n<p><strong>Meanwhile</strong> cut the mushrooms in half and slice finely, then slice the pork steaks into thin strips (approx. 0.5cm)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan over a high heat</p>\r\n<p><strong>Add</strong> the mushrooms to the pan and cook for 2 min, or until starting to brown</p>\r\n<p><strong>Season</strong> with salt and pepper to your taste</p>\r\n<p><strong>Add</strong> the pork and continue to cook for 3 min or until the pork is brown, stirring frequently</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> cut all the potatoes to roughly equal size (approx. 4cm chunks)</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to the pot and boil for 10 min</p>\r\n<p><strong>Once</strong> the potatoes have been cooking for 10 min, start step 7</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 250ml <span class=\"text-danger\">(400ml)</span> of cold water to the pork pan</p>\r\n<p><strong>Deglaze</strong> the pan by scraping the bottom and stir well</p>\r\n<p><strong>Add</strong> half the <span class=\"text-danger\">(whole)</span> stock cube to the pork pan and stir thoroughly</p>\r\n<p><strong>Cook</strong> for 3-4 min, or until the stock is reduced by half</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> chop the chives finely</p>\r\n<p><strong>Trim</strong> the stem ends of the green beans</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the double cream to the pork pan and mix well</p>\r\n<p><strong>Simmer</strong> for 10 min or until the sauce is reduced by half</p>\r\n<p><strong>Remove</strong> from the heat and sprinkle on the chives</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the green beans to the potato pot</p>\r\n<p><strong>Cook</strong> for a further 5 min or until you can pierce the potatoes easily with a fork, and the beans are tender</p>\r\n<p><strong>Drain</strong>, cover well and set aside until serving</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p>Serve the pork with potatoes and green beans, drizzled with the cream sauce</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
