            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, remove the pan from the heat and add your <strong>soft cheese </strong>with your <strong>chicken stock mix </strong>and <strong>reserved starchy pasta water </strong>and mix it all together</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1706875530608-x200.jpg",
