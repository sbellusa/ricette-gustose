          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add the <strong>chopped garlic</strong>, <strong>drained sweetcorn</strong>, <strong>ground smoked paprika</strong> and <strong>dried oregano</strong> and cook for 1-2 min or until fragrant</p>",
      "order": 5,
      "media": {
