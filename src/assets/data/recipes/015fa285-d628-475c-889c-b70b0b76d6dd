  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Add your <strong>conchiglie</strong> to a pot of<strong> boiled water</strong> with a large pinch of <strong>salt </strong>and bring to the boil over a high heat</p><p>Cook the <strong>conchiglie</strong> for 8-10 min or until cooked with a slight bite</p><p>Once done, drain the <strong>conchiglie</strong>, reserving a cup of the <strong>starchy pasta water</strong></p>",
      "order": 1,
      "media": {
        "images": [
