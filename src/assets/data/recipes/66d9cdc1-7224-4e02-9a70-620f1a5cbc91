          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1719392150520-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1719392150520-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1719392150520-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1719392150520-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> fried free range chicken</strong> with the<strong> sesame fries</strong>, <strong>zingy slaw</strong> and <strong>hoisin mayo</strong> to the side for dipping</p><p>Enjoy!</p>",
      "order": 8,
