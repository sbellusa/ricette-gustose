    {
      "instruction": "<p><strong>Boil</strong> a kettle for the next step</p>\r\n<p><strong>Chop</strong> the dried cranberries finely</p>\r\n<p><strong>Peel</strong> and finely slice 1/2 <span class=\"text-danger\">(1)</span> of the red onion<span class=\"text-danger\">(s)</span></p>",
      "order": 3,
