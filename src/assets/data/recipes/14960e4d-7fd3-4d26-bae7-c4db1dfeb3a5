  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Cut</strong> the potatoes into chips (approx. 1cm thick), keeping the skins on</p>\r\n<p><strong>Place</strong> on an oven-proof tray and coat well with 1-2 tbsp vegetable oil and season generously with salt and pepper</p>\r\n<p><strong>Put</strong> in the oven for 30 min or until they are golden and crisp, turning once</p>",
      "order": 1,
      "media": {
        "images": [
          {
