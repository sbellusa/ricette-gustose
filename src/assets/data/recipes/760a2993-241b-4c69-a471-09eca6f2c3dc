  "cooking_instructions": [
    {
      "instruction": "<p>Peel your<strong> red onion[s]</strong> and slice rings off as finely as you can for per person, then dice the <strong>remaining onion</strong></p><p>Add the<strong> onion rings</strong> and<strong> red wine vinegar </strong>to a shallow bowl and set aside to pickle until serving – these are your <strong>quick-pickled onion rings</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1701944452472-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1701944452472-x400.jpg",
