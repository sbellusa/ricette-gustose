            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>drained noodles</strong> to the pan and give everything a good mix up – these are your <strong>lime & chilli noodles</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624293497380-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1624293497380-x400.jpg",
