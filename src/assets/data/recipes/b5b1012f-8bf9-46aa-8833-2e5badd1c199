            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>lime & chilli sauce</strong> and cook for 1 min or until the green beans have softened slightly</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1624293492520-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1624293492520-x400.jpg",
