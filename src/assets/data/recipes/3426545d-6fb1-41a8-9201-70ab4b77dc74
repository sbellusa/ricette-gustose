            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the mince has started to brown, roughly tear the <strong>chestnut mushrooms</strong> into the pan with a pinch of <strong>salt</strong> and cook for 2-3 min further</p>",
      "order": 4,
      "media": {
        "images": [
