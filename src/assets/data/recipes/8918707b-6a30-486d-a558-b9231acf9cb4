          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Boil-a-Kettle-1631722547322-x200.jpg",
            "width": 200
