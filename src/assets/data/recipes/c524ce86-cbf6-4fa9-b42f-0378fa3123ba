  "cooking_instructions": [
    {
      "instruction": "<p>Cut your <strong>paneer </strong>into bite-sized cubes</p><p>Heat a large, wide-based pan (preferably non-stick) adding a large drizzle of <strong>vegetable oil </strong>over a medium heat</p><p>Once hot, add the <strong>cubed paneer</strong> and cook for 3-5 min until golden, turning occasionally for even colouring</p><p>Once cooked, transfer the <strong>golden paneer</strong> to a plate and reserve the pan</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1630422048091-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1630422048091-x400.jpg",
            "width": 400
