            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Use this time to clear up, set the table, have a cup of tea or simply chill!</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-copy-13-1693312633883-x200.jpg",
