          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1649422185551-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1649422185551-x1000.jpg",
            "width": 1000
          },
          {
