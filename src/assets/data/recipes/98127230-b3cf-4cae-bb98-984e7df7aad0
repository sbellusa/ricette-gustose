  "cooking_instructions": [
    {
      "instruction": "<p>Before you start cooking, take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Boil a kettle</p><p>Dissolve the<strong> vegetable stock mix</strong> in 400ml <span class=\"text-danger\">[800ml]</span><strong> boiled water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1582199871523-x200.jpg",
            "width": 200
