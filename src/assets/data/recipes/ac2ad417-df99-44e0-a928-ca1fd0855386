            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add the <strong>sliced pepper</strong> to the pan<strong> </strong>with the <strong>chopped</strong> <strong>garlic </strong>and <strong>ginger</strong> and cook for 1-2 min until slightly softened and fragrant</p><p>Once fragrant, add your <strong>Chinese rice wine</strong> and cook for 30 secs or until evaporated</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1656241212210-x200.jpg",
