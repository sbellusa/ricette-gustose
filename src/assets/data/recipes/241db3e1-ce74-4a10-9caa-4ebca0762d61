          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1622551626419-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the<strong> chopped pepper </strong>to the pan with the chicken</p><p>Add your <strong>ginger paste</strong> and <strong>chopped garlic</strong> and cook for 6-7 min further or until the chicken is cooked through (no pink meat!) and the pepper is beginning to soften</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1622551654680-x200.jpg",
