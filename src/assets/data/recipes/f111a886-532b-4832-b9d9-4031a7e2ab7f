        ]
      }
    },
    {
      "instruction": "<p><strong>Place</strong> your hand flat on the chicken breast on a chopping board</p>\r\n<p><strong>Slice</strong> in half as if you were cutting a burger bun, so you are left with two thinner pieces</p>\r\n<p><strong>Add</strong> the chicken to the foil</p>",
      "order": 3,
