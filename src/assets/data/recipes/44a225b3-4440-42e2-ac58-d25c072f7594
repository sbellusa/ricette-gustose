            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1671546796864-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the lardons are crisp, add 1 tsp <span class=\"text-purple\">[1 1/2 tsp]</span> <span class=\"text-danger\">[2 tsp]</span> <strong>butter </strong>to the pot</p><p>Once melted, add the <strong>sliced</strong> <strong>leek </strong>with a pinch of <strong>salt</strong> and cook for 4-5 min further or until softened</p>",
      "order": 3,
      "media": {
        "images": [
