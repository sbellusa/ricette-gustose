  "cooking_instructions": [
    {
      "instruction": "<p>Chop your <strong>leek[s]</strong> in half lengthways, wash thoroughly to remove any grit then top, tail and slice finely</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Top, tail, peel and slice your <strong>carrot[s] </strong>in half lengthways, then chop into bite-sized pieces</p><p>Chop your <strong>potatoes</strong> (skins on) into bite-sized pieces</p>",
      "order": 1,
      "media": {
        "images": [
