            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>butternut squash cubes</strong> to the<strong> ras el hanout</strong> and cook for 1-2 min further</p>",
      "order": 4,
      "media": {
        "images": [
          {
