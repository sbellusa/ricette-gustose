  "cooking_instructions": [
    {
      "instruction": "<p>Rinse your <strong>sushi rice </strong>in a sieve under <strong>cold running water</strong> for 30 secs (use your hands to wash the grains!) and set aside to drain</p><p>Add the <strong>drained rice </strong>and 200ml <span class=\"text-purple\">[300ml]</span> <span class=\"text-danger\">[400ml] </span><strong>cold water</strong> to a pot with a lid and bring to the boil over a high heat</p><p>Tip: Don't let the water fully boil as this will make the rice stick to the pot!</p>",
      "order": 1,
      "media": {
