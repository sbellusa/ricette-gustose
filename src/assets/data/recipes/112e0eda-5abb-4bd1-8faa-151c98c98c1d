  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Pierce the <strong>Maris piper potatoes</strong> a few times with a fork </p>\n<p>Rub the <strong>potatoes</strong> with <strong>salt</strong> then add them to a baking tray</p>\n<p>Put the tray in the oven and cook for 60 min or until cooked through and crisp </p>\n<p>Tip: If you're in a hurry, microwave your potatoes for 10-15 mins or until cooked through!</p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Use the next 20 min to set the table, have a cup of tea or simply chill!</p>\n<p> </p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1835.-step-2-x200.jpg",
            "width": 200
          },
          {
