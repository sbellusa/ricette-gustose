  "cooking_instructions": [
    {
      "instruction": "<p>Take your<strong> chicken</strong> out of the fridge, open the packet and let it air</p><p>Add your <strong>basmati rice</strong> and 300ml <span class=\"text-purple\">[390ml]</span> <span class=\"text-danger\">[600ml]</span> <strong>cold water</strong> to a pot with a lid and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 10-12 min or until all the water has absorbed and the rice is cooked</p><p>Once cooked, remove from the heat and keep covered</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1700644812787-x200.jpg",
            "width": 200
