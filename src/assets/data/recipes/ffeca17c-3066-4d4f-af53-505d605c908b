  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the freekeh in a sieve under cold running water</p>\r\n<p><strong>Place</strong> the washed freekeh in a pot with plenty of water</p>\r\n<p><strong>Bring</strong> to the boil over a high heat and cook for 20-25 min or until the freekeh is tender with a slight bite</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Peel</strong> and finely slice the red onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Chop</strong> the plums into rough pieces, discarding the stones</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a separate pot with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span>&nbsp;olive oil over a low heat</p>\r\n<p><strong>Once</strong> hot, add the onion and plums with a pinch of salt</p>\r\n<p><strong>Cook</strong>&nbsp;for 6-8 min or until the onions have softened and the plums are tender, stirring occasionally</p>\r\n<p><strong>Add</strong> the almonds to a baking tray and oven roast until browned, approx. 7-13 min</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the balsamic vinegar, 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> sugar and 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> water to the plums</p>\r\n<p><strong>Increase</strong> the heat to medium and cook for 10-15 min or until jammy, then set aside</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, drain the halloumi and pat dry with kitchen roll</p>\r\n<p><strong>Slice</strong> the halloumi in half widthways to make 2 <span class=\"text-danger\">(4)</span> steaks</p>\r\n<p><strong>Strip</strong>&nbsp;the mint leaves from the stems, save a few for garnish, and chop the rest finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the cooled, toasted almonds coarsely (or bash them in a bowl with a rolling pin)</p>\r\n<p><strong>Drain</strong> the cooked freekeh and return it to its pot</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a separate pan (preferably non-stick) over a high heat</p>\r\n<p><strong>Once</strong> hot, add the halloumi steaks and cook on each side for 3-4 min or until browned on the outside</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/425.-step7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Mix</strong>&nbsp;the chopped mint and half the almonds through the cooked freekeh and season with pepper</p>\r\n<p><strong>Serve</strong> the halloumi over the freekeh with the plum chutney to the side</p>\r\n<p><strong>Garnish</strong> with mint leaves and the remaining almonds</p>\r\n<p>Enjoy!</p>",
      "order": 8,
