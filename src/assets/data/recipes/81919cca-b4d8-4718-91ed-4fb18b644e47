  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Drain your <strong>tofu</strong> and pat it dry with kitchen paper</p><p>Cut the <strong>drained tofu </strong>into cubes</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1586949459950-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1586949459950-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1586949459950-x700.jpg",
