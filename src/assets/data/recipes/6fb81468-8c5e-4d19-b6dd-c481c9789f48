  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Cut</strong> the potatoes to roughly equal size (approx. 4cm)</p>\r\n<p><strong>Add</strong> them to a pot of boiling water with a pinch of salt and boil for 15 min or until you can pierce them easily with a fork </p>\r\n<p><strong>Add</strong> 200ml <span class=\"text-danger\">(350ml)</span> boiling water to the chicken stock cube and whisk to combine</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the pork mince, breadcrumbs, allspice and half of the dried dill in a bowl</p>\r\n<p><strong>Season</strong> and mix together (use your hands)</p>\r\n<p><strong>Divide</strong> the mixture into 12 <span class=\"text-danger\">(24)</span> walnut sized pieces</p>\r\n<p><strong>Using</strong> wet hands, shape into balls</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a pan (that has a lid) with 1 tbsp vegetable oil</p>\r\n<p><strong>When</strong> hot, add the meatballs</p>\r\n<p><strong>Cook</strong> until coloured, moving them around the pan so they colour evenly</p>\r\n<p><strong>After</strong> about 4 mins transfer them to a plate and reserve the pan</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Chop</strong> the cranberries up finely</p>\r\n<p><strong>Top</strong> and tail the green beans</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> to the pork meatball pan</p>\r\n<p><strong>Add</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of butter and melt over a medium heat</p>\r\n<p><strong>Add</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> of flour and stir into the butter</p>\r\n<p><strong>Cook</strong> for 1 min, stirring constantly with a wooden spoon</p>\r\n<p><strong>This</strong> is your roux</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chicken stock, whisk to combine and simmer on a low heat for 3 min</p>\r\n<p><strong>Add</strong> the chopped cranberries and dijon to the pan</p>\r\n<p><strong>Add</strong> the meatballs back to the pan and cover with a lid </p>\r\n<p><strong>Cook</strong> for a further 5 min, or until the meatballs are cooked through</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the green beans to a pot with 100ml <span class=\"text-danger\">(200ml)</span> boiling water</p>\r\n<p><strong>Add</strong> a lid and boil for 4 mins, then drain</p>\r\n<p><strong>Remove</strong> the meatballs from the heat and stir through the remaining dried dill and 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> sour cream</p>\r\n<p>Tip: Add more sour cream if you like it creamy!</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the potatoes, add a knob of butter, a splash of milk and mash them with a potato masher until creamy</p>\r\n<p>Smaklig m&aring;ltid (bon appetit!)</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
