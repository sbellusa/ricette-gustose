  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Add your <strong>basmati rice</strong> and 250ml <span class=\"text-purple\">[320ml] </span><span class=\"text-danger\">[500ml]</span> <strong>cold water</strong> to a pot with a lid and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to very low and cook, covered, for 10-12 min or until all the water has been absorbed and the rice is cooked, then remove from the heat and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1653387606763-x200.jpg",
            "width": 200
