            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>remaining</strong> <strong>chilli</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1653387617416-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1653387617416-x400.jpg",
