  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely slice (don't chop!) <strong>half</strong> the <strong>garlic</strong></p><p>Peel and finely chop (or grate) the <strong>remaining</strong> <strong>garlic</strong></p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>olive oil </strong>over a high heat</p>",
      "order": 1,
      "media": {
        "images": [
