  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and dice the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Peel</strong> and chop the carrots into bite-size pieces</p>\r\n<p><strong>Peel</strong> (scrape the skin off with a teaspoon) and finely grate or chop the ginger</p>\r\n<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--1-x200.jpg",
            "width": 200
