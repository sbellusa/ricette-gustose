          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the tomato paste and stir for 1 min</p>\r\n<p><strong>Add</strong> the rice and 375ml <span class=\"text-danger\">(750ml)</span> water to the pan</p>\r\n<p><strong>Stir</strong> in the softened coconut cream and a pinch of sugar (optional)</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--5-x200.jpg",
            "width": 200
          },
