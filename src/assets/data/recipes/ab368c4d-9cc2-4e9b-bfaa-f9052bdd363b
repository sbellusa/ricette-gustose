            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> half a kettle</p>\r\n<p><strong>Cut</strong> the chicken into bite-size pieces</p>\r\n<p><strong>Submerge</strong> the coconut cream sachets in a bowl of boiling water and set aside to soften</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--2-x200.jpg",
            "width": 200
          },
          {
