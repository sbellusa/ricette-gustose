          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large wide-based pan (with a matching lid) with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil over a medium-high heat</p>\r\n<p><strong>When</strong> hot, add the chicken and a large pinch of salt</p>\r\n<p><strong>Cook</strong> for 3-4 min or until golden</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the chicken to a plate and return the pan to a medium-high heat</p>\r\n<p><strong>Add</strong> the onion, carrot and curry powder (adding more oil if needed)</p>\r\n<p><strong>Cook</strong> for 4 min or until the onion has softened</p>\r\n<p><strong>Add</strong> the garlic and ginger and cook for a further 2 min</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/488.-step--4-x200.jpg",
            "width": 200
