  "cooking_instructions": [
    {
      "instruction": "<p>Boil half a kettle</p><p>Peel and finely slice 1/2<span class=\"text-danger\"> [1]</span> <strong>red onion</strong></p>",
      "order": 1,
      "media": {
        "images": [
