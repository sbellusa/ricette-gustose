            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/724.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>vegetable</strong>&nbsp;<strong>stock cub<strong>e</strong></strong><span class=\"text-danger\"><strong>[s]</strong></span> in 700ml<span class=\"text-danger\"> [1.4L]</span> <strong>boiled water</strong></p>\r\n<p>Peel and finely dice the <strong>brown&nbsp;onion</strong><span class=\"text-danger\"><strong>[s]</strong></span></p>\r\n<p>Return the pan to a medium-high heat with a drizzle of <strong>vegetable oil</strong> and a knob of<strong> butter</strong></p>\r\n<p>Once the pan is hot and the butter is bubbling, add the <strong>onion</strong>&nbsp;and cook for 3-5 min or until softened but not coloured</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/724.-step-2-x200.jpg",
            "width": 200
          },
          {
