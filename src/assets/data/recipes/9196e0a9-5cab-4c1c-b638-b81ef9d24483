  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely dice your <strong>brown onion[s]</strong></p><p>Heat a large, wide-based pan (preferably non-stick) with a generous drizzle of<strong> olive oil </strong>over a medium-low heat</p><p>Once hot, add the <strong>diced onion</strong> with a pinch of <strong>salt</strong> and cook for 6-7 min or until softened but not coloured</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1724395905473-x200.jpg",
            "width": 200
