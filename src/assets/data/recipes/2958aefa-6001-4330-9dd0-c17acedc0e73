  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil half a kettle</p><p>Cut the<strong> potatoes</strong> (skins on) into chips</p><p>Add the <strong>chips</strong> to a baking tray with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for an initial 20 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1632300872323-x200.jpg",
            "width": 200
