        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>pitta bread</strong> in half and carefully peel the pockets open</p>\r\n<p>Tip: don't worry if you tear the bread a little</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1209.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1209.-step-2-x400.jpg",
