            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Divide the <strong>beef mince</strong> into 8 <span class=\"text-danger\">[16]&nbsp;</span>and carefully fill each <strong>pitta pocket</strong></p>\r\n<p>Close the pitta pocket and press down firmly <span class=\"text-highlight\">&ndash; these</span> are your <strong>beef arayes</strong></p>\r\n<p>&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1209.-step-3-x200.jpg",
            "width": 200
          },
          {
