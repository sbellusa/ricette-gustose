            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>potatoes</strong> into bite-sized cubes</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1674831613850-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1674831613850-x400.jpg",
