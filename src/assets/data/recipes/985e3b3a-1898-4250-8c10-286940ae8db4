    {
      "instruction": "<p>Dissolve your <strong>chicken stock mix</strong> and<strong> tomato paste</strong> in 300ml <span class=\"text-purple\">[390ml]</span><span class=\"text-danger\"> [510ml] </span><strong>boiled water</strong> – this is your <strong>tomato</strong> <strong>stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1674831624234-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1674831624234-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1674831624234-x700.jpg",
