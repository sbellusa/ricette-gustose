          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2050.-step-3.2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Rip the <strong>green leaves</strong> from the<strong> pak choi </strong>and set them aside</p>\n<p>Chop the <strong>white bases</strong> into rough, small pieces</p>\n<p>Discard the tough stalks</p>\n<p>Cut the <strong>lime<span class=\"text-danger\">[s]</span></strong> into wedges</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2050.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2050.-step-4-x400.jpg",
