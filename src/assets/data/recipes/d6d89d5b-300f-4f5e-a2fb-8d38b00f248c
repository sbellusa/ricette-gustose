            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>soy sauce</strong>, <strong>curry powder</strong>, <strong>chilli flakes</strong> (can't handle the heat? Go easy!),<strong> garlic &amp; ginger paste</strong> and<strong> tomato paste</strong> to the pan and cook for 30 sec or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2050.-step-5-x200.jpg",
            "width": 200
