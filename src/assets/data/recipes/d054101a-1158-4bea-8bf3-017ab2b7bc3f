            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash, then shred your<strong> lettuce</strong> finely and pat dry with kitchen paper</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-7-1657642007221-x200.jpg",
            "width": 200
