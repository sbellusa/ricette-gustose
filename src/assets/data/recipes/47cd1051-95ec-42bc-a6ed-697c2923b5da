            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>eggs</strong> to a pot of <strong>boiled salted water</strong> (the salt prevents them from cracking) bring to the boil over a high heat</p>\r\n<p>Cook for 7 min for perfect mid-boiled eggs</p>\r\n<p>Once boiled, transfer&nbsp;the <strong>eggs</strong> to the <strong>ice bath</strong> and set aside</p>\r\n<p>Re-boil the kettle&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-2-x1000.jpg",
