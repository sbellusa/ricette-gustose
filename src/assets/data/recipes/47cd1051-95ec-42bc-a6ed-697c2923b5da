  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Preheat the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p>Meanwhile, peel and finely slice the <strong>brown&nbsp;onion<span class=\"text-danger\">[s]</span></strong></p>\r\n<p>Place an ice pack (Gousto's are perfect) or loose ice cubes into a bowl of <strong>cold water</strong> and set aside &ndash; this is your <strong>ice bath</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/413_step-1-x200.jpg",
            "width": 200
