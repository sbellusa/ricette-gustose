  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil half a kettle</p><p>Peel and finely chop your <strong>brown onion[s]</strong></p><p>Top, tail, peel and finely dice your <strong>carrot[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1694531481038-x200.jpg",
