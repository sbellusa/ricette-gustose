  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Chop your<strong> tomato[es]</strong> roughly</p><p>Deseed your <strong>pepper[s] </strong>(scrape the seeds and pith out with a teaspoon) and dice</p><p>Peel and finely dice your <strong>red onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1708525489638-x200.jpg",
