  "cooking_instructions": [
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Peel</strong> the potatoes and cut them into chunks (approx. 5cm)</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 15 min or until you can just pierce them with a fork (finish cooking in step 6)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong> add the breadcrumbs to a bowl and cover with milk </p>\r\n<p><strong>Peel</strong> the onion and chop very finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Remove</strong> the rosemary's leaves and chop finely, discarding the stems</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Drain</strong> the breadcrumbs and squeeze to get rid of excess liquid </p>\r\n<p><strong>Combine</strong> the breadcrumbs, beef mince, tomato paste, oregano, garlic, half the Dijon mustard and a handful of onion to make the patty mix</p>\r\n<p><strong>Crack</strong> the egg<span class=\"text-danger\">(s)</span> on top and mix well</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Make</strong> 6 <span class=\"text-danger\">(12)</span> patties of equal size from the mix using your hands, flattening them so they are approx. 2-3cm thick discs</p>\r\n<p>Tip: Wet your hands first to prevent the meat from sticking</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of butter or oil to a pan on a high heat</p>\r\n<p><strong>Once</strong> hot, add the patties and cook for 1 min on each side</p>\r\n<p><strong>Reduce</strong> the heat to prevent burning and cook the patties for a further 4-5 min on each side or until they are just cooked through</p>\r\n<p><strong>Set</strong> the pan aside for serving</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the potatoes are done, drain them and cut into quarters</p>\r\n<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the potatoes and cook for 10 min or until browned on all sides</p>\r\n<p><strong>Sprinkle</strong> with rosemary and season to your taste with salt and pepper</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the lettuce in a bowl and add 1-2 tbsp of olive oil</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Arrange</strong> the patties and potatoes on plates</p>\r\n<p><strong>Serve</strong> with the lettuce and remaining Dijon mustard</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
