  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) over a high heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the<strong> portobello mushrooms</strong> and cook for 2-3 min on each side or until starting to soften and brown</p><p>Meanwhile, drain and rinse the <strong>black beans</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1626951088014-x200.jpg",
            "width": 200
