  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6, then top, tail and dice your <strong>carrot[s]</strong> finely and finely chop your <strong>chestnut mushrooms</strong></p><p>Heat a large wide-based pan (preferably non-stick) over a medium-high heat with a knob of <strong>butter</strong></p><p>Once hot, add the <strong>diced carrot </strong>and cook for 2-3 min, then add the <strong>chopped</strong> <strong>mushrooms</strong> and cook for a further 5-7 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1703063217959-x200.jpg",
            "width": 200
