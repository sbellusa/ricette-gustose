  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p><strong>Boil</strong> a kettle (used in steps 3 &amp; 5)</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan on a high heat</p>\r\n<p><strong>Once</strong> the oil is hot, sear the pork tenderloin for 2 min on each side, or until browned all over (keep the pan for step 6)</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the pork on an oven-proof tray and put in the oven for 8-10 min, or until cooked through&nbsp;</p>\r\n<p><strong>Once</strong> done, remove from the oven, cover well and allow to rest until step 7</p>\r\n<p><strong>Dissolve</strong> half the <span class=\"text-danger\">(whole)</span> beef stock cube in 100ml <span class=\"text-danger\">(200ml)</span> of boiling water</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the mushrooms into quarters</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span> and chop finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Chop</strong> the parsley finely</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cook</strong> the pasta in a pot of boiling water and salt (optional) for 8-10 min or until the pasta is cooked to your taste, stirring occasionally, then drain&nbsp;</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the pork pan to a medium-high heat, add the garlic and onion and cook for 1 min</p>\r\n<p><strong>Add</strong> the mushrooms and cook for 1 min</p>\r\n<p><strong>Reduce</strong> the heat, add the stock and 50ml <span class=\"text-danger\">(100ml)</span> of cream and simmer for 5 min</p>\r\n<p><strong>Add</strong> the parsley</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Grate</strong> the parmesan</p>\r\n<p><strong>Cut</strong> the pork into slices (approx. 2cm)</p>\r\n<p><strong>Season</strong> the mushroom sauce to your taste with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the pasta to the sauce and mix well&nbsp;</p>\r\n<p><strong>Serve</strong> the pasta with the pork on top and sprinkle with parmesan</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
