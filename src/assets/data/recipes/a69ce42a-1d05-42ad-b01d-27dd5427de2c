          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1658224175401-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely chop (or grate) your <strong>garlic</strong></p><p>Finely slice <strong>half</strong> your <strong>red chilli[es]</strong> into rounds and set aside for garnish</p><p>Cut the <strong>remaining</strong> <strong>chilli</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1658224177889-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1658224177889-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1658224177889-x700.jpg",
