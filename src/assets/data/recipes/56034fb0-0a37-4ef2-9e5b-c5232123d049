          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/476.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the noodles to a pot of salted boiling water (enough to cover them) on a high heat</p>\r\n<p><strong>Boil</strong> for 5-7 min or until cooked through but with a slight bite</p>\r\n<p><strong>Once</strong> cooked, drain and briefly rinse them under cold, running water until cooled slightly, then return them to the pot off the heat</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/476.-step--5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/476.-step--5-x400.jpg",
