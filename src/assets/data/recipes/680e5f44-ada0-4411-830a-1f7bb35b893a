  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Cut</strong> the potatoes (skin on) into 2cm wedges and place on a baking tray with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil and a large pinch of salt</p>\r\n<p><strong>Toss</strong> to coat well and place them in the oven for 30 min or until golden brown&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, pat the steaks dry with kitchen towel and coat evenly on both sides with 1 tsp <span class=\"text-danger\">(2 tsp)</span> vegetable oil and plenty of salt</p>\r\n<p><strong>Heat</strong> a large, wide-based pan (preferably non-stick) over a high heat</p>\r\n<p><strong>Once</strong> very hot, add the steaks and cook for 1 min on each side</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Transfer</strong> the cooked steaks to a chopping board and cover with a tea towel to rest</p>\r\n<p><strong>Peel</strong> and finely slice the onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Return</strong> the same pan to a medium heat with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> vegetable oil</p>\r\n<p><strong>Add</strong> the onion with a pinch of salt (to draw out the moisture)</p>\r\n<p><strong>Cook</strong> for 5 min or until translucent and softened, stirring occasionally</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and grate (or very finely chop) the garlic</p>\r\n<p><strong>Combine</strong> 1 tsp <span class=\"text-danger\">(2 tsp)</span> red wine vinegar (save the rest for step 5) with the mayonnaise and garlic in a large mixing bowl</p>\r\n<p><strong>Mix</strong> with 3 tbsp <span class=\"text-danger\">(6 tbsp)</span> olive oil and 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> hot water, then season generously with salt and pepper - this is your aioli</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/494.-step-4-x200.jpg",
            "width": 200
