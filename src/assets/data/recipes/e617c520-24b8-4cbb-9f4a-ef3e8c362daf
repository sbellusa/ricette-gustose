          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1581614538289-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1581614538289-x700.jpg",
            "width": 700
