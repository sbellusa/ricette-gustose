      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp vegetable oil to a large pan over a medium heat</p>\r\n<p><strong>Once&nbsp;</strong>hot, add the sausages and cook for 6 min or until browned all over</p>\r\n<p><strong>Transfer</strong> the sausages to a plate and reserve the pan for the next step</p>",
      "order": 3,
