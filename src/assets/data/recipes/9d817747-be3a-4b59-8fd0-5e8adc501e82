          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1691060753252-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your<strong> cornflour</strong> to the marinated chicken and mix it all together until the chicken is completed coated – this is your <strong>coated chicken</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1691060755823-x200.jpg",
            "width": 200
