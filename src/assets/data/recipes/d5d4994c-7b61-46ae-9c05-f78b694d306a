          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1671010100386-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1671010100386-x1000.jpg",
