          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1671010100386-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Peel and finely slice your <strong>shallot[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p><p>Chop your <strong>basil</strong> finely, including the stalks</p><p>Roughly chop your <strong>sun-dried tomatoes</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1671010104825-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1671010104825-x400.jpg",
            "width": 400
          },
          {
