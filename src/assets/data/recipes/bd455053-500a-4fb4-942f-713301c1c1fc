            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-35-1715608365353-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain your <strong>mozzarella</strong>, then pat it dry with kitchen paper (squeeze as much liquid out as you can!)</p><p>Tear the drained mozzarella into rough, bite-sized pieces</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-36-copy-1715608386358-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-36-copy-1715608386358-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-36-copy-1715608386358-x700.jpg",
