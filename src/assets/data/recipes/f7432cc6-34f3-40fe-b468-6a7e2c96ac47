  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Cut the <strong>sugar snap peas</strong> and <strong>Tenderstem broccoli </strong>in half lengthways</p><p>Slice <strong>half</strong> of the <strong>red chilli<span class=\"text-danger\">[es]</span></strong> finely into rounds</p><p>Chop the <strong>remaining</strong> <strong>red chilli</strong> in half lengthways, deseed and chop finely</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1612879639714-x200.jpg",
            "width": 200
