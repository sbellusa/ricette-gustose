            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>cornflour </strong>in a small bowl with 3 tbsp<span class=\"text-danger\"> [5 tbsp] </span><strong>cold water</strong></p><p>Stir in the <strong>soy sauce</strong>, <strong>mirin </strong>and <strong>honey </strong>– this is your <strong>teriyaki sauce</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1612879670389-x200.jpg",
