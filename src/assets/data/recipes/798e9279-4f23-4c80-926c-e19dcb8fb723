          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1700569335814-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1700569335814-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1700569335814-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the<strong> puttanesca-style sauce with fresh orecchiette </strong>topped with the <strong>remaining chopped parsley</strong> and a generous grind of <strong>black pepper</strong></p><p>Enjoy!</p>",
