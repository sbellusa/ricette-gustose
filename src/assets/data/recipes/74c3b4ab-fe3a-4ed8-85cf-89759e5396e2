  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 7</p><p>Boil a kettle</p><p>Add the <strong>bulgur wheat</strong> to a pot with plenty of <strong>boiled water</strong> and cook over a high heat for 10-15 min or until tender with a slight bite, then drain and return to the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1610.-step-1-x200.jpg",
            "width": 200
