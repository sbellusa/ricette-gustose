          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the mackerel from the oven, carefully peel off the skin and tear the flesh up into bite-size pieces, directly into the&nbsp;salad bowl</p>\r\n<p><strong>Add</strong> the lentils and gently toss the whole lot together</p>\r\n<p><strong>Taste</strong> for seasoning, adding more salt and pepper if desired&nbsp;</p>",
      "order": 7,
      "media": {
        "images": [
