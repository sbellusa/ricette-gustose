  "cooking_instructions": [
    {
      "instruction": "<p><strong>Rinse</strong> the lentils in a sieve under cold running water</p>\r\n<p><strong>Once</strong> rinsed, add them to a medium pot with 500ml <span class=\"text-danger\">(1L)</span> water</p>\r\n<p><strong>Bring</strong> to the boil on a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to medium and continue to cook for 20-25 min or until tender, checking occasionally&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, preheat the oven to 180&deg;C/ 160&deg;C (fan)/ 350&deg;F/ Gas 4&nbsp;</p>\r\n<p><strong>Add</strong> the vinegar, Dijon mustard and 1 tsp<span class=\"text-danger\"> (2 tsp)</span>&nbsp;sugar to a large mixing bowl with 3 tbsp <span class=\"text-danger\">(6 tbsp)</span>&nbsp;olive oil (preferably extra virgin)</p>\r\n<p><strong>Chop</strong> the dill finely, including the stalks, and coarsely grate the apple</p>\r\n<p><strong>Add</strong>&nbsp;half the dill and apple to the bowl&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the mackerel to a baking tray, skin-side up (use tin foil to avoid mess)</p>\r\n<p><strong>Put</strong> it in the oven for 10-15 min or until warmed through</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the cucumber in half lengthways, scraping out the seeds with a teaspoon and discarding</p>\r\n<p><strong>Finely</strong> chop the cucumber</p>\r\n<p><strong>Slice</strong> the spring onions finely, discarding the root ends&nbsp;</p>\r\n<p><strong>Add</strong> the cucumber and spring onions to the mixing bowl&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-4-x1000.jpg",
