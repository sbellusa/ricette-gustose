            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the remaining dill with the&nbsp;yoghurt and season generously with pepper and a small pinch of salt (remember that the mackerel is already a salty fish) in a small bowl</p>\r\n<p><strong>Set</strong> aside until serving&nbsp;</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/462.-step-5-x200.jpg",
            "width": 200
