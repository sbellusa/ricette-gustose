          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1674037608692-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the chips are cooking, trim, then slice the <strong>spring onion<span class=\"text-danger\">[s]</span></strong></p><p>Cut the <strong>red chilli<span class=\"text-danger\">[es]</span></strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p><p>Chop the <strong>coriander </strong>finely, including the stalks</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1674037621863-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1674037621863-x400.jpg",
            "width": 400
          },
          {
