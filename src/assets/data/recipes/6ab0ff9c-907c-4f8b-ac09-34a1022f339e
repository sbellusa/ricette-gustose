        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your<strong> tomato[es]</strong> roughly</p><p>Wash your <strong>spinach</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-13.56.52-1688043615949-x200.jpg",
