  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 7</p><p>Cut the <strong>potatoes</strong> (skins on) into wedges</p><p>Add them to a baking tray with the <strong>dried oregano</strong>, a generous drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 20-25 min or until crisp – these are your <strong>herby wedges</strong></p>",
      "order": 1,
      "media": {
        "images": [
