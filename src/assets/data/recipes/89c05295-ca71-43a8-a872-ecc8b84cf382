  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Heat a large, wide-based pan (preferably non-stick with a matching lid) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>sliced</strong> <strong>onion</strong> with a pinch of <strong>salt</strong> and <strong>sugar </strong>and cook for 3 min, or until starting to soften, then add your <strong>lean beef mince</strong> and cook for a further 3 min, breaking it up with a wooden spoon as you go</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1615544297947-x200.jpg",
            "width": 200
