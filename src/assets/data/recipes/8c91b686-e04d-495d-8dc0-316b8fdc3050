  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7, boil a kettle, then take your <strong>steak</strong> out of the fridge, open the packet and let it adjust to room temperature</p><p>Peel your <strong>potatoes</strong> and chop them into quarters, then add to a pot with plenty of <strong>boiled water </strong>and a pinch of <strong>salt </strong>and bring to the boil over a high heat, once boiling, reduce the heat to medium and cook for 12 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1648543093821-x200.jpg",
            "width": 200
