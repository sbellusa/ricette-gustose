  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Cut 2 <span class=\"text-danger\">[4] </span>thick steaks from the centre of the <strong>cauliflower<span class=\"text-danger\">[s] </span></strong>(keep any leftovers, chop them into florets, then roast for a tasty snack!)</p><p>Add the <strong>cauliflower steaks </strong>to a baking tray, then drizzle the <strong>tamari soy sauce</strong> all over and put the tray in the oven for 30-35 min or until golden and tender, turning once halfway</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1626786579418-x200.jpg",
