            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, trim then slice your <strong>spring onion[s]</strong></p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1690477265026-x200.jpg",
