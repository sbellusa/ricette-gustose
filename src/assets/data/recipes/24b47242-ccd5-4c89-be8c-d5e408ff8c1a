            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the mince is starting to brown, reduce the heat to medium-high, then add the <strong>chopped garlic </strong>to the pan and cook for 1-2 min or until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
