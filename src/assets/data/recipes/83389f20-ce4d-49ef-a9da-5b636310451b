            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once softened, add the <strong>remaining ground turmeric</strong>, <strong>curry powder</strong>, <strong>tomato paste</strong> and 2 tsp <span class=\"text-purple\">[3 tsp]<span class=\"text-danger\"> </span>[4 tsp]</span> <strong>flour</strong> to the onion and cook for 1 min or until fragrant</p><p>Drain the <strong>quick-pickled chilli cucumber</strong>, reserving the pickling liquid and bay leaf[ves]</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1671543623422-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1671543623422-x400.jpg",
            "width": 400
