        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>basa fillet[s]</strong> into large, bite-sized pieces</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1671543612994-x200.jpg",
