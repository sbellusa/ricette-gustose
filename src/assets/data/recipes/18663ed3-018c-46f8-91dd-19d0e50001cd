  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Put a large baking tray (or two!) in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
