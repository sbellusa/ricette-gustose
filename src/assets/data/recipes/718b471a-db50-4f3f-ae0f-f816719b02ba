  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Add your <strong>macaroni</strong> to a pot of <strong>boiled water</strong> and bring to the boil over a high heat</p><p>Cook the <strong>macaroni</strong> for 6-7 min or until cooked with a bite</p><p>Once done, drain the <strong>macaroni</strong> and set aside until later, reserving 150ml <span class=\"text-purple\">[195ml]</span> <span class=\"text-danger\">[200ml]</span> <strong>starchy pasta water</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1686133777328-x200.jpg",
