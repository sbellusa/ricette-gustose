            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a knob of <strong>butter</strong> over a medium-high heat</p><p>Once melted, add 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span> <span class=\"text-danger\">[2 tbsp]</span> <strong>flour</strong> and <strong>half</strong> the <strong>chopped garlic </strong>(you'll use the rest later!) and stir with a wooden spoon for 1-2 min or until a sandy paste forms – this is your <strong>roux</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1686133783380-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1686133783380-x400.jpg",
