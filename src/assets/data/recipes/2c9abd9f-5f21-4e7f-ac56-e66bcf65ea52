            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add <strong>half</strong> of the <strong>peri peri sauce</strong> (you'll use the rest later!) to a separate bowl with your <strong>meat-free chick'n</strong> and mix well until they're fully coated</p><p>Set aside to marinate</p>",
      "order": 4,
      "media": {
        "images": [
