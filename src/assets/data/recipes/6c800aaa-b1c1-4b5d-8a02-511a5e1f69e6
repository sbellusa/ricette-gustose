  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>diced chorizo</strong> and cook for 5-6 min or until golden and crispy</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1492-v2-Step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1492-v2-Step-1-x400.jpg",
