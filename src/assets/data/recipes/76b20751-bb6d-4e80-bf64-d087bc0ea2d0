          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1650388176697-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then add your <strong>green beans</strong> to a pot with a pinch of <strong>salt </strong>and cover them with <strong>boiled water</strong></p><p>Bring to the boil over a high heat and cook for 3-4 min or until tender</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1650388183192-x200.jpg",
            "width": 200
