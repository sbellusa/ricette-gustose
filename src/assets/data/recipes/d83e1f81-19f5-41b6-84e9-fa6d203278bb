          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1629302713871-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1629302713871-x1000.jpg",
