            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>sliced courgette </strong>and <strong>sliced garlic </strong>to the pan with your <strong>ras el hanout</strong>, <strong>ground cumin</strong> and a pinch of <strong>salt</strong> and cook for 2 min further or until fragrant</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1657039015790-x200.jpg",
