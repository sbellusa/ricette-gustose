    },
    {
      "instruction": "<p>While the mixture is cooking, slice your <strong>tomatoes</strong> into rounds</p><p>Preheat the grill to very high</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1685457671949-x200.jpg",
