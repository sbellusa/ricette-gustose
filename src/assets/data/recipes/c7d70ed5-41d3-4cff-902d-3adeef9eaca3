  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Remove 15g <span class=\"text-purple\">[25g]</span><span class=\"text-danger\"> [30g]</span> <strong>butter</strong> from the fridge and set aside to soften slightly</p><p>Peel and cut your <strong>sweet potato[es]</strong> into fries</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624268417341-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1624268417341-x400.jpg",
            "width": 400
