  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the pears in half lengthwise and remove the cores</p>\r\n<p><strong>Cut</strong> each half into quarters lengthwise</p>\r\n<p><strong>Peel</strong> the onion<span class=\"text-danger\">(s)</span>, quarter, and quarter them again into wedges</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> the cheese into cubes (approx. 1cm) </p>\r\n<p><strong>Crush</strong> the pecan nuts into small pieces using a pestle and mortar or a knife</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the pear and onion on an oven-proof tray</p>\r\n<p><strong>Sprinkle</strong> with pecan nuts and coat well with 1-2 tbsp of olive oil</p>\r\n<p><strong>Put</strong> in the oven for 15 min</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Cut</strong> all the potatoes to roughly equal size (approx. 3cm chunks)</p>\r\n<p><strong>Add</strong> the potatoes and salt (optional) to a pot of boiling water and boil for 15 min or until you can pierce them easily with a fork</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a pan on a medium heat</p>\r\n<p><strong>Once</strong> the oil is hot, hold the pork steaks upright in the pan and sear the fatty edge of the steak for 1 min </p>\r\n<p><strong>Cook</strong> the pork steaks flat for 1 min on each side</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the pear and onion from the oven and place the pork steaks on top</p>\r\n<p><strong>Mix</strong> all the ingredients well, then sprinkle with the cheese and oregano</p>\r\n<p><strong>Return</strong> to the oven and cook for 10 min or until the pork steaks are cooked through</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the pork steaks and potatoes with the trimmings</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
