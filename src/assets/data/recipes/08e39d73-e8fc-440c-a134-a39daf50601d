            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2022.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Squeeze the pouch<span class=\"text-danger\">[es]</span> of <strong>cooked</strong> <strong>brown long grain rice </strong>to separate the grains</p><p>Tear the top corner of the pouch<span class=\"text-danger\">[es]</span> (just a little!) and put the pouch in the <strong>microwave</strong> for 2 min or until piping hot</p><p>Tip: If you're cooking two packets, pop them in together but increase the microwave cook time accordingly</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/v2-x-2022-Step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/v2-x-2022-Step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/v2-x-2022-Step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/v2-x-2022-Step-5-x1000.jpg",
