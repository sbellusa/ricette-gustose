          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/v2-x-2022-Step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>hoisin sauce </strong>to the pan and cook for 2-3 min or until the sauce has thickened and the chicken is cooked through (no pink meat!) - this is your <strong>hoisin chicken</strong></p>",
      "order": 6,
      "media": {
