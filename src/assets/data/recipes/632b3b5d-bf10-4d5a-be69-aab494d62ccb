            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, roughly chop your <strong>walnuts</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-copy-1722596578206-x200.jpg",
