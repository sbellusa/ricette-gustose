          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1722596594736-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-copy-1722596594736-x1000.jpg",
            "width": 1000
