        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Boil a full kettle</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of<strong> olive oil</strong> over a medium-high heat</p><p>Chop the<strong> cherry tomatoes </strong>in half</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2296-Step-2-x200.jpg",
