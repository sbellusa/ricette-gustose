  "cooking_instructions": [
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add your <strong>salmon fillet[s]</strong>, season with a pinch of <strong>salt</strong> and <strong>pepper </strong>and cook for 9-10 min, or until cooked through, turning once halfway</p><p>Tip: Your fish is cooked once it turns opaque and flakes easily</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1588587260208-x200.jpg",
            "width": 200
