            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain and rinse your <strong>cannellini beans</strong></p><p>Dissolve your <strong>vegetable stock mix</strong> in 150ml <span class=\"text-purple\">[200ml]</span> <span class=\"text-danger\">[250ml]</span> <strong>boiled water</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1720094054722-x200.jpg",
