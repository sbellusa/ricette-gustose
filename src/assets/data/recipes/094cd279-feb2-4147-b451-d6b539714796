            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1687517898635-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p><p>Add your <strong>butternut squash cubes</strong> to a heatproof bowl</p><p>Cover the bowl with <strong>cling film</strong> and pierce a few holes in the top</p><p>Put the bowl in the <strong>microwave</strong> and cook for 3-4 min or until the squash is fork-tender</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1687517902357-x200.jpg",
