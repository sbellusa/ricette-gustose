          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1687517906151-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1687517906151-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>spinach</strong> then add to a colander and pour <strong>boiled water</strong> all over it so that it starts to wilt</p><p>Rinse the <strong>wilted spinach</strong> under <strong>cold running water</strong> until it's cool</p><p>Once cool, squeeze as much water out of the spinach as you can</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687517909510-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687517909510-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687517909510-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687517909510-x1000.jpg",
