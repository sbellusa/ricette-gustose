    },
    {
      "instruction": "<p>Boil half a kettle</p><p>Chop your <strong>creamed coconut</strong> roughly (if required!)</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1691481681119-x200.jpg",
