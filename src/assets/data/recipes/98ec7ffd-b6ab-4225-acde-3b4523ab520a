            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>free range chicken breast portion[s]</strong> into small bite-sized pieces</p><p>Once the pepper and onion have softened, increase the heat to high, then add the <strong>chopped chicken</strong> and your <strong>red Thai curry paste</strong> to the pan and cook for 3-4 min or until fragrant</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1691481521906-x200.jpg",
