        ]
      }
    },
    {
      "instruction": "<p>Squeeze your pouch[es] of <strong>cooked white</strong> <strong>long grain rice</strong> to separate the grains</p><p>Tear the top corner of the pouch[es] (just a little!) and <strong>microwave</strong> for 2 min or until piping hot</p><p>Tip: If you're cooking two or more pouches, pop them in together but increase the microwave cook time accordingly</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1581614165693-x200.jpg",
