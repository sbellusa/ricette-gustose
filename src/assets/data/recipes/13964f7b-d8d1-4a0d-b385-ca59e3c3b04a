          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1627380512004-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the vegetables have softened, drain your<strong> jumbo prawns</strong>, then add them to the pan and cook for an initial 5-6 min</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1627380523446-x200.jpg",
