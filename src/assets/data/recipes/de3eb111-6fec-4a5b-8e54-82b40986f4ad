  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely chop your <strong>brown onion[s]</strong></p><p>Peel and finely chop (or grate) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
