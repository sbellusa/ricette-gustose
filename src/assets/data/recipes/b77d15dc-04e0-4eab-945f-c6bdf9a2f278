  "cooking_instructions": [
    {
      "instruction": "<p>Boil a full kettle</p><p>Chop the<strong> waxy potatoes</strong> in half</p><p>Add the <strong>chopped potatoes</strong> to a pot of <strong>boiled water</strong>, bring to the boil over a high heat and cook for 12-15 min or until fork-tender, then drain and return to the pot</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1666093888472-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1666093888472-x400.jpg",
