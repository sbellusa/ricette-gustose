      }
    },
    {
      "instruction": "<p>Add the <strong>sliced courgette </strong>to the garlic and onion and cook for 3-4 min or until the courgette has started to soften</p><p>Drain and rinse your <strong>green lentils</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1628675782705-x200.jpg",
