  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 6</p><p>Cut your <strong>potatoes</strong> (skins on) into bite-sized cubes</p><p>Add the <strong>potato cubes</strong> to a baking tray (or two!) with a drizzle of <strong>vegetable oil</strong> and a pinch of <strong>salt</strong> and <strong>pepper</strong></p><p>Put the tray[s] in the oven for 25-30 min or until the potatoes are golden and crispy – these are your <strong>crispy potatoes</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1636392606605-x200.jpg",
            "width": 200
