  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Chop</strong> the cranberries finely</p>\r\n<p><strong>Crumble</strong> the blue cheese into small pieces</p>\r\n<p><strong>Reserve</strong> 2 tbsp <span class=\"text-danger\">(4 tbsp)</span> of crumbled blue cheese for stuffing the patties (step 3)</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Set</strong> aside a clean board or plate for shaping the patties later</p>\r\n<p><strong>Add</strong> the turkey mince and chopped cranberries to a mixing bowl</p>\r\n<p><strong>Season</strong> with 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> of salt and 1/4 tsp <span class=\"text-danger\">(1/2 tsp)</span> of pepper</p>\r\n<p><strong>Wet</strong> your hands, mix thoroughly and shape into 2 <span class=\"text-danger\">(4)</span> balls</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Make</strong> a shallow indent with your fingers into the centre of each ball and stuff with 1 tbsp of the reserved blue cheese</p>\r\n<p><strong>Cover</strong> the indent with the mince by folding it over</p>\r\n<p><strong>Pat</strong> and shape the stuffed patties into 2cm thick burgers -- covering the cheese completely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide pan (preferably non stick) with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil over a medium heat</p>\r\n<p><strong>Once</strong> hot, add the burgers and cook for 3 min on each side, or until coloured, then reserve the pan</p>\r\n<p><strong>Transfer</strong> them to an oven tray and cook in the oven for an additional 8 min, or until cooked through</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, add the remaining crumbled blue cheese and vinegar to a small bowl then mash together with a spoon into a rough paste</p>\r\n<p><strong>Mix</strong> in the mayonnaise, 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of milk and a pinch of pepper - this is your blue cheese dressing</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Wash</strong> and dry the corn salad thoroughly</p>\r\n<p><strong>Once</strong> cooked through, remove the burgers from the oven to rest until serving</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-6--x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-6--x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-6--x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-6--x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-6--x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, wipe down the burger pan and return to a medium-high heat</p>\r\n<p><strong>Slice</strong> the brioche in half widthways</p>\r\n<p><strong>Add</strong> the halves cut-side-down in the pan and cook for 2-3 min, until toasted</p>\r\n<p>Tip: Do this in batches if needed!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/451.-step-7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the burger in the toasted brioche with the salad and dressing to the side</p>\r\n<p>Enjoy!</p>",
      "order": 8,
