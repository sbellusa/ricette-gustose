            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>white miso paste</strong>, <strong>honey</strong>, <strong>ginger & garlic paste </strong>and <strong>mirin</strong> to a bowl with 1/2 tbsp <span class=\"text-purple\">[3/4 tbsp] </span><span class=\"text-danger\">[1 tbsp] </span><strong>boiled water </strong>and stir it all together – this is your <strong>miso glaze</strong></p>",
      "order": 5,
      "media": {
        "images": [
