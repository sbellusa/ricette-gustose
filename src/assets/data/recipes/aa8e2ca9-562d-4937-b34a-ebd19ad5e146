        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>basil</strong> finely, including the stalks</p><p>Slice the<strong> ciabatta roll<span class=\"text-danger\">[s]</span></strong> into 6 <span class=\"text-danger\">[12] </span>slices</p>",
      "order": 5,
      "media": {
