  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6 and take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Chop your <strong>waxy potatoes</strong> in half, lengthways</p><p>Add the <strong>chopped potatoes</strong> to a baking tray with a drizzle of <strong>vegetable oil</strong> and a generous pinch of <strong>salt</strong> and <strong>pepper</strong> and give everything a good mix up</p><p>Put the tray in the oven for an initial 20-25 minutes or until golden</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684228298661-x200.jpg",
            "width": 200
