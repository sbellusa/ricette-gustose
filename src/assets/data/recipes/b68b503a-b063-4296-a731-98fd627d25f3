  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Add</strong> 1-2 tbsp of olive oil to an ovenproof tray</p>\r\n<p><strong>Add</strong> the sausages and move them about in the oil to prevent them from sticking <br />Place the tray in the oven for 30 min until golden and brown</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and finely dice the red onion<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Peel</strong> and grate (or dice) the garlic clove<span class=\"text-danger\">(s)</span></p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of olive oil to a pot on a medium heat</p>\r\n<p><strong>When</strong> hot, add the onion and a pinch of salt and cook on a medium-low heat for 6 - 10 min or until softened and caramelised</p>\r\n<p><strong>Once</strong> caramelised, add the garlic and cook for a further 1 min, stirring constantly</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the tin<span class=\"text-danger\">(s)</span> of chopped tomatoes</p>\r\n<p><strong>Reduce</strong> on a very low heat for 5 min, or until reduced by half</p>\r\n<p><strong>Once</strong> reduced, cover and set aside until step 6</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> sausages have been in the oven for 15 min and are starting to brown, add the gnocchi to the same tray, sprinkle with the dried oregano, cook for 15-20 min or until starting to crisp and hot inside and the sausages are cooked through </p>\r\n<p>Tip: You may have to use 2 trays if you don't have enough space!</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the gnocchi is cooked, return the tomato sauce to a medium heat for a couple of mins to warm through, add the balsamic and 0.5 tsp <span class=\"text-danger\">(1tsp)</span> of sugar and salt and pepper to your taste</p>\r\n<p><strong>Add</strong> the spinach, stirring constantly until it has wilted down in the heat, then remove from the heat</p>\r\n<p>Tip: Add a little water to the tomato sauce if it's too thick</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the sausages are cooked, carefully transfer them to a clean board and slice them up into bite-size pieces</p>\r\n<p>Tip: Use a knife and fork to help cut them up!</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the spinach and tomato sauce with the crispy sausage pieces and gnocchi on top</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
