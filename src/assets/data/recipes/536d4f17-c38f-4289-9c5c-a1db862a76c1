          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1721219944296-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then finely slice your<strong> spring onion[s]</strong></p><p>Grate your <strong>cheddar cheese</strong></p><p>Wash your<strong> spinach</strong>, pat dry with kitchen paper</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1721219948422-x200.jpg",
