          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2157.-step-3-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the tomatoes are in the oven, peel the <strong>garlic</strong> and chop it roughly</p>\n<p>Grate the <strong>cheddar cheese</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2157.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2157.-step-4-x400.jpg",
            "width": 400
