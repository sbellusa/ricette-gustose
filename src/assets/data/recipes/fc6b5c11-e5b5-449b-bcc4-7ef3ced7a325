          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1606304211524-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Return the pan to a medium-low heat with a drizzle of <strong>vegetable oil</strong></p><p>Crack the <strong>eggs </strong>into the pan, cover with a lid and cook for 2 min or until done to your liking</p><p>Once the <strong>sausages </strong>are cool enough to touch, slice them in half lengthways</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1606304223038-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1606304223038-x400.jpg",
            "width": 400
