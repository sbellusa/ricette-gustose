            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, add the <strong>soft cheese </strong>and<strong> pesto</strong> to a measuring jug with 50ml <span class=\"text-danger\">[80ml]</span> <strong>boiled water</strong></p><p>Give it a good mix up until smooth<strong> </strong>– this is your <strong>creamy</strong> <strong>pesto sauce</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1588590754122-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1588590754122-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1588590754122-x700.jpg",
