            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>basil </strong>finely, including the stalks</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1588590762200-x200.jpg",
