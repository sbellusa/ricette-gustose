  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</p>\r\n<p><strong>Rinse</strong> the lentils in a sieve under cold water</p>\r\n<p><strong>Add</strong> them to a medium pot with the bay leaves and cover with plenty of cold water</p>\r\n<p><strong>Bring</strong> to the boil on a high heat</p>\r\n<p><strong>Cook</strong> for 20 min or until tender</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and cut the carrots into batons, discarding the ends</p>\r\n<p><strong>Reserve</strong> the juice from the beetroot packet<span class=\"text-danger\">(s)</span> straight into a small saucepan, ready for step 6</p>\r\n<p><strong>Cut</strong> each beetroot into 6 wedges</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Place</strong> the beetroot and carrot batons on a baking tray (use tin foil to avoid mess)</p>\r\n<p><strong>Drizzle</strong> with olive oil and season with salt and pepper</p>\r\n<p><strong>Put</strong> the tray in the oven for 20 min or until the carrots are tender</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel and finely chop the garlic cloves</p>\r\n<p><strong>Strip</strong> the mint leaves off their stalks and chop them roughly</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Tear</strong> the ciabatta roll<span class=\"text-danger\">(s)</span> into bite sized chunks</p>\r\n<p><strong>Add</strong> them to a bowl with the chopped garlic and drizzle them with olive oil, salt and pepper and mix well</p>\r\n<p><strong>Add</strong> them to a baking tray (use tin foil to avoid mess)</p>\r\n<p><strong>Put</strong> the tray in the oven for 5-8 min or until the bread is starting to brown</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the balsamic to the beetroot juice pan (from step 2)</p>\r\n<p><strong>Add</strong> 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of sugar to the pan</p>\r\n<p><strong>Bring</strong> the liquid to the boil on a medium low heat</p>\r\n<p><strong>Once</strong> the liquid starts to foam, cook for approx. 1-2 min, then remove from the heat</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Once</strong> the lentils are tender, drain them and return them to the pot, discarding the bay leaves</p>\r\n<p><strong>Add</strong> half the goats' cheese to the lentils and mix through until it's melted</p>\r\n<p><strong>Add</strong> the roasted beetroot and carrots and mix to combine</p>\r\n<p><strong>Season</strong> with salt and pepper</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Plate</strong> the lentils, then use your hands to break the croutons over them</p>\r\n<p><strong>Add</strong> the remaining goats' cheese and drizzle with the balsamic glaze</p>\r\n<p><strong>Scatter</strong> the mint over</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
