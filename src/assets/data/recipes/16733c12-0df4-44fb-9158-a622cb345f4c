  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ 425°F/ Gas 7</p>\n<p>Peel and finely chop (or grate) the <strong>ginger </strong></p>\n<p>Chop the <strong>cauliflower</strong> into 6 <span class=\"text-danger\">[12]</span> wedges</p>\n<p> </p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
