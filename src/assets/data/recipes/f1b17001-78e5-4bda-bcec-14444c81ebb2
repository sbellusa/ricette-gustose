        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>oyster mushrooms </strong>to the <strong>beaten egg </strong>and then coat in the <strong>seasoned flour</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1681818843322-x200.jpg",
