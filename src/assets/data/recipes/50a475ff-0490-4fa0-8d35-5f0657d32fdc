            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1607610753861-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>sweet pointed pepper[s]</strong><span class=\"text-danger\"> </span>finely into rings</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1607610759529-x200.jpg",
