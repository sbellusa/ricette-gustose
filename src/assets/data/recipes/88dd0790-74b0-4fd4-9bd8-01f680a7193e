  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, a pinch of salt and pepper and 350ml <span class=\"text-danger\">[700m]</span> water to a pot with a lid and bring to the boil over a high heat</p>\r\n<p><strong>Once</strong> boiling, reduce the heat to low and cook, covered, for 10-15 min or until all the water has absorbed and the rice is cooked</p>\r\n<p><strong>Once</strong> cooked, remove from the heat and keep covered until serving&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
