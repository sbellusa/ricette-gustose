          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1585753137749-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Line a baking tray with <strong>tin foil</strong></p><p>Add the <strong>breaded chicken strips</strong> to the tray and top them with any <strong>remaining cheesy breadcrumbs</strong></p><p>Put the tray in the oven for 18-20 min or until cooked through (no pink meat!) and golden – these are your<strong> crispy chicken strips</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1585753213896-x200.jpg",
