  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 240&deg;C/ 220&deg;C (fan)/ 475&deg;F/ Gas 9</p>\r\n<p><strong>Boil</strong> a kettle</p>\r\n<p><strong>Drain</strong> and quarter the artichoke hearts</p>\r\n<p><strong>Line</strong> 1 <span class=\"text-danger\">(2)</span> oven-proof tray<span class=\"text-danger\">(s)</span> with parchment and place the artichoke quarters on top</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/86.-step-1-x200.jpg",
