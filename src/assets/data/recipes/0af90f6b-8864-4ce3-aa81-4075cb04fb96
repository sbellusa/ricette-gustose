  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Cut the <strong>waxy potatoes</strong> (skins on) in half</p><p>Add the<strong> halved potatoes</strong> to a pot of <strong>boiled water</strong> with a pinch of <strong>salt</strong>, bring to the boil over a high heat and cook for 10-15 min or until fork-tender</p><p>Once cooked, drain and leave them to steam dry (save the pot!)</p>",
      "order": 1,
      "media": {
