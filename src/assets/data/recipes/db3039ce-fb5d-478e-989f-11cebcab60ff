            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>blanched peas </strong>and cook for 2 min further or until everything's tender</p><p>Once done, drain the <strong>vegetables</strong> and return them to the pot with a knob of <strong>butter</strong></p><p>Keep covered until serving</p>",
      "order": 6,
      "media": {
        "images": [
