          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1649838186606-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut a large piece of <strong>tin foil</strong> per person approx. the size of A4 sheets of paper</p><p>Add 2 <strong>chicken thighs</strong> to each piece of foil</p><p>Spoon the <strong>spicy green chutney</strong> over the chicken evenly</p><p>Scrunch the edges of the <strong>tin foil</strong> together around the <strong>chicken</strong> to form 1 sealed parcel per person</p>",
