  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice to a medium pot with plenty of water (approx. 4 times) and a pinch of salt</p>\r\n<p><strong>Bring</strong> to the boil on a high heat</p>\r\n<p><strong>Cook</strong> for 20-25 min or until the rice is cooked with a slight bite</p>\r\n<p><strong>Once</strong> cooked, continue to step 6</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, zest and juice the orange<span class=\"text-danger\">(s)</span>, discarding the pips</p>\r\n<p><strong>Peel</strong> the ginger (scrape the skin off with a teaspoon) and grate it or chop it finely</p>\r\n<p><strong>Peel</strong> and grate (or finely chop) the garlic</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Combine</strong> the orange juice, zest, ginger, garlic and the rice vinegar with 2 <span class=\"text-danger\">(4)</span> of the soy sauce sachets, 1 tsp of the cornflour, and 1 tbsp <span class=\"text-danger\">(1 1/2 tbsp)</span> of sugar - mix well for step 6</p>\r\n<p><strong>Reserve</strong> the remaining cornflour and soy sauce for steps 4 and 7, respectively</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the chicken into strips (approx. 2cm) </p>\r\n<p><strong>Transfer</strong> the chicken to a medium-sized bowl</p>\r\n<p><strong>Add</strong> the remaining cornflour and toss to coat evenly</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a large wide-based pan (preferably non-stick with a matching lid) with 1 tbsp <span class=\"text-danger\">(2 tbsp)</span> of vegetable oil </p>\r\n<p><strong>When</strong> hot, add the chicken, leaving space between the pieces, and cook on a medium heat for 5 min, or until starting to brown</p>\r\n<p>Tip: Don't overcrowd the pan, so do this in batches if using a smaller pan</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the orange juice mix to the chicken</p>\r\n<p><strong>Turn</strong> the heat down to medium low and add a lid</p>\r\n<p><strong>Cook</strong> for 8-10 min or until the chicken is cooked through</p>\r\n<p><strong>Add</strong> the mangetout to the brown rice for a final 2 min, then drain and season</p>\r\n<p><strong>Meanwhile</strong>, finely slice the spring onions, discarding the root ends</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the lid from the chicken and reduce the sauce to a thick syrup on a low heat (this should only take about 30 secs)</p>\r\n<p><strong>Once</strong> reduced, remove the pan from the heat and add the sesame oil and final soy sauce sachet<span class=\"text-danger\">(s)</span></p>\r\n<p><strong>Fold</strong> in the chopped spring onions</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the brown rice and mangetout with the sticky chicken spooned over</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
