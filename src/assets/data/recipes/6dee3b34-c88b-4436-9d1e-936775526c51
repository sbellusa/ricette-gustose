            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) over a medium-high heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add the<strong> chicken breast strips </strong>with a generous pinch of <strong>salt </strong>and cook for an initial 4-5 min or until starting to brown</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1692111823206-x200.jpg",
