            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once brown, add the <strong>sliced shallot</strong> to the pan and cook for 1-2 min or until starting to soften</p><p>Once softened, add your <strong>ground turmeric</strong> and <strong>ginger & garlic paste</strong> and cook for 30 secs or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1692111827897-x200.jpg",
