          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1684491722849-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1684491722849-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1684491722849-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1684491722849-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Korean-style fried chicken bao buns </strong>with the <strong>chips</strong>, <strong>remaining quick-pickled sesame slaw </strong>and<strong> remaining spicy mayo </strong>to the side</p><p>Enjoy!</p>",
