            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the veg is cooking, dice your <strong>tomato[es]</strong> finely</p><p>Cut your <strong>red chilli[es]</strong> in half lengthways, deseed (scrape the seeds out with a teaspoon) and chop finely</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1684831022453-x200.jpg",
