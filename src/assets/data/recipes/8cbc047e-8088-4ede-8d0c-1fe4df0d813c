            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>chopped tomatoes</strong> and <strong>mint</strong> to a bowl with a generous drizzle of <strong>olive oil</strong> and the <strong>juice</strong> of 1/4 <span class=\"text-danger\">[1/2]</span> a<strong> lemon</strong></p>\n<p>Season with a pinch of<strong> salt</strong> and give everything a good mix up – this is your<strong> tomato salad</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2106.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2106.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/2106.-step-5-x700.jpg",
