    },
    {
      "instruction": "<p>When everything's nearly ready, put your <strong>ciabatta[s]</strong> in the oven for 5 min or until warmed and crusty</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1713881587945-x200.jpg",
