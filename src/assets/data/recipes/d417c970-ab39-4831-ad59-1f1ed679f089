          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1660648115844-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1660648115844-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1660648115844-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>coconutty tamarind aubergine & green bean curry</strong> and top with the <strong>crushed</strong> <strong>cashew nuts</strong> and <strong>sliced green chilli </strong>(not a fan of spice? Just add a little!)</p><p>Enjoy!</p>",
