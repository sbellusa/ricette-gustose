            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drain and rinse your <strong>chickpeas</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1621861080086-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1621861080086-x400.jpg",
            "width": 400
