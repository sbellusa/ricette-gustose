  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Chop the<strong> cherry tomatoes</strong> in half, then peel and finely slice (don't chop) the<strong> garlic</strong></p><p>Add the<strong> fennel seeds</strong> to a<strong> pestle & mortar</strong> and grind (or chop if you don't have a pestle and mortar!) to a fine powder</p>",
      "order": 1,
      "media": {
        "images": [
