          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1388.-step-3.2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, dissolve the 1/2 <span class=\"text-danger\">[1] </span><strong>vegetable stock cube</strong> in the reserved <strong>pasta water</strong></p>",
      "order": 4,
      "media": {
