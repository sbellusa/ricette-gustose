            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the tomatoes have broken up, add the<strong> chopped garlic</strong> to the pan with your <strong>garam masala</strong>,<strong> ground fenugreek</strong> and <strong>ground</strong> <strong>paprika</strong> and cook for 1 min further or until fragrant</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1694421981867-x200.jpg",
