            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1624295223259-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>honey</strong> and continue to cook for 1 min further before removing the pan from the heat to cool slightly – these are your <strong>honey chickpeas</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1624295226576-x200.jpg",
            "width": 200
