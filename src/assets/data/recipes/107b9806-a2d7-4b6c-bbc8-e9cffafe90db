          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1624295223259-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1624295223259-x1000.jpg",
