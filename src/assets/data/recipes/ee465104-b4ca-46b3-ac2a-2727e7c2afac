            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>fine egg noodles</strong> to a large bowl, cover them with <strong>boiled water</strong> and stir for 10 secs to separate the noodles</p><p>Set aside to soak for 5-6 min</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1667300424615-x200.jpg",
