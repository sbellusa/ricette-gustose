            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>gnocchi</strong> to an <strong>oven-proof dish</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1628681804988-x200.jpg",
            "width": 200
