            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the leek has softened, add 1 tbsp <span class=\"text-danger\">[2 tbsp]</span> <strong>flour </strong>to the pan and cook for 1 min, then gradually add the <strong>stock</strong> and cook for 1-2 min further or until a creamy consistency – this is your <strong>creamy mushroom mixture</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1628681809520-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1628681809520-x400.jpg",
            "width": 400
          },
          {
