          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1675159040851-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1675159040851-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-7-1675159040851-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Serve the <strong>Cajun-style meat-free chick'n & pepper linguine</strong> and season with a crack of <strong>black pepper</strong></p><p>Enjoy!</p>",
      "order": 8,
