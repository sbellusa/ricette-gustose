          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1657612350261-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the aubergine is tender, drain the <strong>king prawns</strong>, then add them to the pan and cook for 3-4 min or until almost cooked through</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1657612354092-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1657612354092-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1657612354092-x700.jpg",
