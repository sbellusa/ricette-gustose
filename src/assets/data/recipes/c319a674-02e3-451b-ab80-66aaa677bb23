            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has softened, add the <strong>chopped pepper</strong> and <strong>chorizo</strong> and cook for 5-6 min further or until the <strong>chorizo</strong> has turned golden</p>",
      "order": 3,
