  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\n<p>Peel and dice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p>\n<p>Heat a large, wide-based pan (preferably non-stick) with a matching lid with a drizzle of <strong>olive oil</strong> over a medium heat</p>\n<p>Once hot, add the <strong>diced onion</strong> and cook for 4-5 min or until softened</p>\n<p> </p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1552.-step-1-x200.jpg",
            "width": 200
