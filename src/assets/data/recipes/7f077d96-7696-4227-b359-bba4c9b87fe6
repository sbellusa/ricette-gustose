            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the tofu strips are cooking, add your <strong>tortillas</strong> to a baking tray</p><p>Put the tray in the oven for 2-3 min or until they're warmed through (alternatively, add them to a plate and microwave for 1-2 min!)</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Plain-wraps-on-a-bakin-tray-1677587614207-x200.jpg",
