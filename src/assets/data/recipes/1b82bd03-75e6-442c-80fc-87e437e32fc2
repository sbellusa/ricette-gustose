          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1636047399525-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>dates </strong>roughly</p><p>Slice your <strong>cheddar cheese </strong>into 5 thin slices per person</p><p>Wash your <strong>salad</strong>, then pat it dry with kitchen paper</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1636047402391-x200.jpg",
            "width": 200
