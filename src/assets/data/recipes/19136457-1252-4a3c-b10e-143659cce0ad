  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Peel and finely slice (don't chop!) your <strong>garlic</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1692024534394-x200.jpg",
            "width": 200
