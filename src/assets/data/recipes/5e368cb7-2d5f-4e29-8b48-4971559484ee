    {
      "instruction": "<p>Combine your <strong>black bean paste</strong> and <strong>Chinese rice wine</strong> with 100ml <span class=\"text-purple\">[130ml]</span> <span class=\"text-danger\">[150ml] </span><strong>boiled water</strong> and 1/2 tsp<span class=\"text-purple\"> [3/4 tsp]</span><span class=\"text-danger\"> [1 tsp] </span><strong>sugar </strong>– this is your<strong> black bean stock</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1643201502243-x200.jpg",
