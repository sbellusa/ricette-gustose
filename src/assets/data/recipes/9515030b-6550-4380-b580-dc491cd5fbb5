            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>green beans </strong>in half</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1650386576942-x200.jpg",
