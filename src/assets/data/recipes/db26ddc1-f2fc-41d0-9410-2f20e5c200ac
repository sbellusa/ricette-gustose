  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Trim the green stalks off the <strong>aubergine<span class=\"text-danger\">[s]</span></strong> and cut in half lengthways then slice into half moons</p><p>Deseed the <strong>red pepper<span class=\"text-danger\">[s]</span></strong> (scrape the seeds and pith out with a teaspoon) and cut into thick strips</p>",
      "order": 1,
      "media": {
        "images": [
