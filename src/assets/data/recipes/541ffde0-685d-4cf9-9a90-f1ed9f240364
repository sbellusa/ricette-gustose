  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200&deg;C/ 180&deg;C (fan)/ 400&deg;F/ Gas 6</p>\r\n<p>Pat the <strong>pork belly</strong> dry with kitchen paper</p>\r\n<p>Score the <strong>fatty side</strong> of the<strong> pork belly</strong> in a criss-cross pattern by drawing a sharp knife through the skin, deep enough to reach the meat below</p>\r\n<p>Season with a very generous pinch of <strong>salt</strong> and rub it deep into the criss-cross pattern</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) over a very high heat</p>\r\n<p>Once very hot, add the <strong>pork belly</strong>, fat side down and cook for 4 min or until coloured and crispy, then flip and cook for 2 min on the other side&nbsp;</p>\r\n<p>Once done, transfer the <strong>pork</strong> to a <strong>tin foil</strong> lined baking tray and put the tray in the oven for 40 min</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1084.-step-2-x200.jpg",
            "width": 200
