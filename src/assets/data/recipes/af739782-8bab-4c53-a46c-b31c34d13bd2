    {
      "instruction": "<p>Peel your <strong>red onion[s]</strong> and slice finely into rounds</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/03-08-21_17h10m26s-APIC-1628083252549-x200.jpg",
