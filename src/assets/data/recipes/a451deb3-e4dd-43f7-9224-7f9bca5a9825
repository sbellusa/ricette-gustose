  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Deseed the <strong>red pepper<span class=\"text-danger\">[s]</span> </strong>(scrape the seeds and pith out with a teaspoon) and cut into thin strips (as finely as you can!)</p><p>Peel and finely slice the <strong>red onion<span class=\"text-danger\">[s]</span></strong></p>",
      "order": 1,
      "media": {
