      }
    },
    {
      "instruction": "<p>Slice the <strong>chicken breasts</strong> into thin strips</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1590578004746-x200.jpg",
            "width": 200
