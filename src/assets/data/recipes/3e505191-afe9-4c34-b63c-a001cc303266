            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Boil a kettle</p><p>Dissolve your <strong>chicken stock mix</strong> and <strong>tomato paste</strong> in 300ml<span class=\"text-purple\"> [390ml] </span><span class=\"text-danger\">[500ml]</span> <strong>boiled water</strong> – this is your<strong> tomato stock</strong></p><p>Chop your<strong> black olives</strong> roughly</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-6-1691492780215-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-copy-6-1691492780215-x400.jpg",
