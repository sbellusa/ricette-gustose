          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-10-1691492788141-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-copy-10-1691492788141-x1000.jpg",
            "width": 1000
