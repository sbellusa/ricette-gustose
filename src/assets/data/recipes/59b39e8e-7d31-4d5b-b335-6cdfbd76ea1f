          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the drained noodles and cream to the pan and cook for 1 min or until warmed through, then remove from the heat</p>\r\n<p><strong>Taste</strong> for seasoning, adding salt and pepper if needed,&nbsp;</p>\r\n<p><span class=\"text-highlight\"><strong>Tip:</strong></span> cut the noodles up whilst in the pan for easy eating!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-7-x200.jpg",
