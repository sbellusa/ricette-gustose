  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and finely chop (or grate) the garlic</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-1-x400.jpg",
            "width": 400
          },
          {
