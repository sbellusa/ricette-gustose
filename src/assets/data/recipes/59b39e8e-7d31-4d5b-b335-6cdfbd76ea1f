          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the chicken, garlic, cayenne, oregano and 1 tbsp <span class=\"text-danger\">[2tbsp]</span>&nbsp;vegetable oil to a bowl and crumble in the chicken stock cube<span class=\"text-danger\">[s]</span></p>\r\n<p><strong>Season</strong> with a big pinch of pepper</p>\r\n<p><strong>Mix</strong> thoroughly&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Heat</strong> a wide-based pan&nbsp;(preferably non-stick) with a matching lid over a high heat with 1 tbsp <span class=\"text-danger\">[2 tbsp]</span>&nbsp;vegetable oil</p>\r\n<p><strong>Once</strong> hot, add the chicken spreading each piece flat</p>\r\n<p><strong>Cook</strong>, covered, for 5 min</p>\r\n<p><strong>Meanwhile</strong>, slice the mushrooms finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Boil</strong> a kettle</span>&nbsp;</p>\r\n<p><strong>Remove</strong> the lid from the pan and flip each piece of chicken</p>\r\n<p><strong>Add</strong> the mushrooms around the chicken</p>\r\n<p><strong>Cook</strong>, covered, for a further 5 min or until the chicken is cooked through</p>\r\n<p><strong>Stir</strong> the mushrooms occasionally</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/557.-step-4-x1000.jpg",
