            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop your <strong>parsley </strong>roughly, including the stalks</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-5-1688643842298-x200.jpg",
            "width": 200
