  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9 and boil a kettle</p><p>Take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Add your <strong>basmati rice</strong> to an <strong>oven-proof dish</strong> with 300ml <span class=\"text-purple\">[390ml]</span> <span class=\"text-danger\">[600ml]</span> <strong>boiled water</strong></p><p>Cover tightly with<strong> tin foil</strong> and put the dish in the oven for an initial 10 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
