            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>spring onion[s] </strong>on the diagonal</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687528271281-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687528271281-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687528271281-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687528271281-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1687528271281-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the veg has softened, add your <strong>ginger & garlic paste </strong>to the pan and cook for 30 secs or until fragrant</p><p>Once fragrant, add your <strong>teriyaki</strong> <strong>sauce</strong> and cook for a further 30 secs or until the veg is well coated in the sauce – this is your <strong>Fable mushroom teriyaki</strong></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1687528275584-x200.jpg",
            "width": 200
