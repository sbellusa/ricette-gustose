          }
        ]
      }
    },
    {
      "instruction": "<p>Remove the heated tray<span class=\"text-danger\">[s]</span> from the oven and add the<strong> pizza bases</strong></p><p>Divide the <strong>tomato sauce</strong> between the<strong> </strong>pizza<strong> </strong>bases<strong> </strong>and spread it evenly all over them with the back of a spoon</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1782.-step-5-x200.jpg",
            "width": 200
