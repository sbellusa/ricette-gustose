            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1782.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Top the<strong> pizzas</strong> with the <strong>torn mozzarella </strong>and <strong>softened pepper</strong></p><p>Sprinkle over the <strong>dried oregano</strong></p><p>Put the tray<span class=\"text-danger\">[s]</span> in the oven for 13-15 min or until the cheese has melted and the base is crispy</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1782.-step-6-x200.jpg",
            "width": 200
