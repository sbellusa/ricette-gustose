  "cooking_instructions": [
    {
      "instruction": "<p>Peel and finely slice your <strong>brown onion[s]</strong></p><p>Chop your <strong>portobello mushroom[s]</strong> finely</p><p>Heat a large, wide-based pan (preferably non-stick) over a medium-low heat with a drizzle of <strong>vegetable oil</strong></p><p>Once hot, add <strong>half</strong> the <strong>sliced onion</strong> with a pinch of<strong> salt </strong>and cook for 5-6 min, then increase the heat to medium-high, add the <strong>chopped</strong> <strong>mushrooms</strong> and cook for a further 5-7 min</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1665139832429-x200.jpg",
            "width": 200
