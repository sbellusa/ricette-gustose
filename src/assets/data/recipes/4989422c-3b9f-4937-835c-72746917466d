            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Wash your <strong>lettuce</strong>, then pat dry with kitchen paper and shred finely</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1619786372662-x200.jpg",
