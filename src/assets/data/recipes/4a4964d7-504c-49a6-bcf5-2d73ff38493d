            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, chop your <strong>basil</strong> finely, including the stalks</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1640106806367-x200.jpg",
