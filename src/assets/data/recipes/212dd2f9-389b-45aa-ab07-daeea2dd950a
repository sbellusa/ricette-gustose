  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Trim the green stalks<strong> </strong>off your<strong> aubergine[s]</strong><span class=\"text-danger\"> </span>and cut into bite-sized pieces</p><p>Transfer the <strong>aubergine pieces</strong> to a baking tray with a generous drizzle of <strong>vegetable oil </strong>and a pinch of <strong>salt</strong></p><p>Give everything a good mix up and put the tray in the oven for 20 min or until softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1626683327782-x200.jpg",
            "width": 200
