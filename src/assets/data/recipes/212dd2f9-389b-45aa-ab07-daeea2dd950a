        ]
      }
    },
    {
      "instruction": "<p>Whilst the rice is cooking, boil a kettle</p><p>Peel and finely slice your <strong>red onion[s]</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1626683335297-x200.jpg",
