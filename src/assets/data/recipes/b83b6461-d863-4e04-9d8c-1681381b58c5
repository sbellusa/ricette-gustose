          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-1715605160630-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut your <strong>ciabatta[s] </strong>in half, then add the <strong>ciabatta halves</strong> to a baking tray, cut-side up</p><p>Put the tray in the oven for 3-4 min or until warmed through and slightly crispy</p><p>Tip: Cooking for 4 or more? You may need to use 2 trays!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1715605164679-x200.jpg",
