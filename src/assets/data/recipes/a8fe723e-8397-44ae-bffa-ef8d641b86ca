  "cooking_instructions": [
    {
      "instruction": "<p>Add the <strong>basmati rice</strong> and 175ml <span class=\"text-danger\">[350ml]</span> <strong>cold water</strong> to a pot with a lid and bring to the boil over&nbsp;a high heat</p>\r\n<p>Once boiling, reduce the heat to very low and cook, covered, for 10-15 min or until all the water has absorbed and the <strong>rice</strong> is cooked</p>\r\n<p>Once cooked, remove from the heat and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
