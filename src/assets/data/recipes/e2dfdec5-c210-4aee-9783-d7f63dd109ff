            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Chop the <strong>parsley </strong>finely, including the stalks</p><p>Zest 1/2 <span class=\"text-danger\">[1]</span> <strong>lemon </strong>(try to grate lightly with a micro-plane or sharp box grater) and cut in half</p><p>Peel and finely chop (or grate) the <strong>garlic</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1641914789487-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1641914789487-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1641914789487-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-copy-1641914789487-x1000.jpg",
