            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a dry, large, wide-based pan (preferably non-stick) over a high heat</p><p>Once hot, add the <strong>marinated chicken thighs</strong>, skin-side down, and cook for an initial 10 min or until the skin has started to crisp and char slightly</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1595941913429-x200.jpg",
