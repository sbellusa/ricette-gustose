            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Slice the <strong>brioche bun[s] </strong>in half</p><p>Heat a large, dry, wide-based pan (preferably non-stick) over a medium heat and add the <strong>brioche halves</strong>, cut-side down, and cook for 2-3 min or until toasted and charred</p><p>Tip: Cooking for 3 or more? You might need to do this in batches!</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1615910521577-x200.jpg",
