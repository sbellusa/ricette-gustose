  "cooking_instructions": [
    {
      "instruction": "<p><strong>Peel</strong> and chop the onion<span class=\"text-danger\">(s)</span> finely</p>\r\n<p><strong>Crush</strong> the garlic with the side of a knife, peel it and chop finely</p>\r\n<p><strong>Chop</strong> the parsley finely</p>\r\n<p><strong>Cut</strong> away the chilli<span class=\"text-danger\">(es)</span> stem, deseed it and chop very finely</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the stem<span class=\"text-danger\">(s)</span> of the pepper<span class=\"text-danger\">(s)</span>, deseed and chop into small pieces (approx. 1cm thick)</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of olive oil to a large deep pan (ideally one with a lid) to a medium-high heat</p>\r\n<p><strong>Once</strong> the oil is hot, add the chilli (careful, adjust the amount to your preferred hotness), onion and pepper to the pan</p>\r\n<p><strong>Cook</strong> and stir occasionally for 5-7 min or until soft</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the garlic, cumin and paprika</p>\r\n<p><strong>Cook</strong> for 2 min, stirring frequently</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Stir</strong> the millet into the pan</p>\r\n<p><strong>Add</strong> the chopped tomatoes and 320ml <span class=\"text-danger\">(640ml)</span> of water</p>\r\n<p><strong>Reduce</strong> the heat to medium low and cook for 10 min with a lid on, or until the millet has absorbed most of the liquid</p>\r\n<p><strong>Season</strong> to your taste with salt and pepper</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the lid and turn the heat to medium-high for a further 5 min, or until slightly thickened</p>\r\n<p><strong>Make</strong> space for the eggs by making two <span class=\"text-danger\">(four)</span> wells in the thickened sauce</p>\r\n<p><strong>Crack</strong> the eggs into the wells</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cover</strong> the pan and cook for a further 3-5 min or until the eggs are done to your preference</p>\r\n<p><strong>Crumble</strong> 100g <span class=\"text-danger\">(200g)</span> of feta cheese into small bite size pieces</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Serve</strong> the baked eggs and sprinkle with parsley and feta</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
