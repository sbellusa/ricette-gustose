          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the pasta to a pot of boiling water with salt (optional) for 7-9 min, until the pasta is nearly cooked with a slight bite, stirring occasionally</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/358.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/358.-step-2-x400.jpg",
