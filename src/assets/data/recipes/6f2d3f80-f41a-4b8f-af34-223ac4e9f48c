  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce to a simmer and cook with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> often to prevent over-cooking and once done, set aside until serving</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the coriander seeds, five spice, pinch of salt, and 1/2 tsp <span class=\"text-danger\">(1 tsp)</span> of black pepper to a mortar and pestle</p>\r\n<p><strong>Grind</strong> the spices finely, breaking up all of the seeds </p>\r\n<p><strong>Slice</strong> the pork steaks into 1cm thick strips, against the grain</p>\r\n<p><strong>Rub</strong> the ground spices over the strips, and set aside until step 6</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Peel</strong> and slice half of the ginger and all of the garlic into discs the thickness of a pound coin</p>\r\n<p><strong>Grate</strong> the remaining ginger for step 7</p>\r\n<p><strong>Peel</strong> and slice the onion<span class=\"text-danger\">(s)</span> finely</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Top</strong> and tail the green beens and cut into 2cm pieces for step 7</p>\r\n<p><strong>Slice</strong> the spring onions thinly on a diagonal for garnish, discarding the roots</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a pan/wok over a high heat</p>\r\n<p><strong>Once</strong> hot, add the ginger and garlic discs and cook for 1 min, stirring constantly</p>\r\n<p><strong>Discard</strong> them with a slotted spoon once fragrant and golden </p>\r\n<p>Tip: This method adds flavour to oil without the chunks</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the onion (not the spring onion) to the pan and coat well</p>\r\n<p><strong>Cook</strong> the onion for 1 min or until browned and softened, stirring frequently</p>\r\n<p><strong>Add</strong> the marinated pork strips to the pan</p>\r\n<p><strong>Sear</strong> on all sides for 2-4 min and then reduce the heat to medium low</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 100ml <span class=\"text-danger\">(175ml)</span> of water to the pan, dissolving all the tasty bits </p>\r\n<p><strong>Add</strong> the green beans to the pan and cook for 3-4 min</p>\r\n<p><strong>Add</strong> the soy sauce and grated ginger to the pan and cook for 1 min</p>\r\n<p><strong>Remove</strong> the pan from heat</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> both the shaoxing wine and sesame oil to the pan, coating everything until glossy</p>\r\n<p><strong>Serve</strong> the pork on a bed of rice and spoon over the sauce</p>\r\n<p><strong>Sprinkle</strong> with spring onions and enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
  ],
