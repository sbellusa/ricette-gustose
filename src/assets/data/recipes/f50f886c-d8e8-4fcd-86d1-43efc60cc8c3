            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the sauce is thickening, grate the <strong>cheddar flavour block</strong></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1607954902851-x200.jpg",
            "width": 200
