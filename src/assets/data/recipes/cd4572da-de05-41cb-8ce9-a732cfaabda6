            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Cut the <strong>lemon</strong><span class=\"text-danger\"><strong>[s] </strong></span>in half</p>\r\n<p>Peel and chop the <strong>garlic</strong> roughly</p>\r\n<p>Meanwhile, drain and rinse the <strong>chickpeas</strong> and add them to a <strong>food processor</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the&nbsp;<strong>tahini paste, chopped garlic</strong>,<span style=\"background-color: #ffffff;\">&nbsp;</span>50ml <span class=\"text-danger\">[100ml]</span><strong> olive oil</strong>,&nbsp;a big splash of&nbsp;<strong>water</strong> and 1 tsp <span class=\"text-danger\">[2 tsp]</span><strong> salt</strong> to your <strong>food processor</strong></p>\r\n<p>Juice half of the <strong>lemon<strong><span class=\"text-danger\">[s]</span></strong></strong> into the <strong>food processor</strong></p>\r\n<p>Blitz until smooth and creamy then set aside - this is your<strong> homemade</strong>&nbsp;<strong>hummus</strong>&nbsp;</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-3-x700.jpg",
