  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p>\r\n<p>Add the <strong>bulgur wheat</strong> to a pot with plenty of <strong>boiled water</strong>&nbsp;and a pinch of <strong>salt</strong> (the same as you would for pasta) and cook over a high heat for 7-10 min or until tender with a slight bite</p>\r\n<p>Once tender, drain and set aside in a sieve to cool</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/964.-step-1-x200.jpg",
            "width": 200
          },
          {
