            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Strip the <strong>mint leaves</strong> from their stems and chop them roughly, discard the stems</p><p>Tip: Hold the top of the herb sprigs firmly and slide your fingers down their lengths to easily remove the leaves</p>",
      "order": 6,
      "media": {
        "images": [
