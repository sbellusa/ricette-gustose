            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the onion has softened, add the <strong>tomato sauce</strong> to the dish and cook for 25-30 min or until the meatballs are cooked through and the sauce has thickened to a ragù-like consistency</p>",
      "order": 5,
      "media": {
        "images": [
