  "cooking_instructions": [
    {
      "instruction": "<p>Combine the<strong> rice vinegar </strong>with 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>sugar</strong> in a medium sized bowl</p><p>Peel the <strong>carrots</strong>, then continue to peel lengths until you end up with a pile of carrot ribbons</p><p>Add the <strong>carrot ribbons</strong> to the vinegar mixture and give it all a good mix up</p><p>Set aside - this is your <strong>quick-pickled carrot salad</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/796.-step-1-x200.jpg",
            "width": 200
