  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 160&deg;C/ 140&deg;C (fan)/ 325&deg;F/ Gas 3</p>\r\n<p>Keep your&nbsp;<strong>goats' cheese</strong>&nbsp;refrigerated until step 5</p>\r\n<p>Add the <span class=\"text-highlight\"><strong>puy-style</strong></span>&nbsp;<strong>lentils</strong> to a pot with 400ml <span class=\"text-danger\">[800ml]</span>&nbsp;<strong>water </strong>and bring to the boil over a high heat</p>\r\n<p>Once boiling, reduce the heat to medium and cook for 20-25 min or until tender</p>\r\n<p>Once tender, drain in a sieve and return to the pot to cool&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/810.-step-1-x200.jpg",
            "width": 200
