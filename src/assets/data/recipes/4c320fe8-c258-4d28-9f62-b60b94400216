          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1688123383381-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1688123383381-x1000.jpg",
            "width": 1000
