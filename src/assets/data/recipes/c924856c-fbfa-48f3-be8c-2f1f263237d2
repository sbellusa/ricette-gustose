            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1645551074151-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the chicken is golden, turn the heat down to medium-high and add the <strong>sliced pepper</strong> with 1 tsp <span class=\"text-danger\">[2 tsp]</span> <strong>flour</strong> and cook for 1-2 min further or until the pepper is beginning to soften</p><p>Wash the <strong>spinach</strong>, then pat it dry with kitchen paper</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1645551084223-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1645551084223-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1645551084223-x700.jpg",
