          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1645551057907-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine the <strong>remaining soy sauce</strong>, <strong>honey</strong> and <strong>mirin </strong>with 80ml <span class=\"text-danger\">[120ml]</span> <strong>boiled water </strong>– this is your <strong>honey mirin sauce</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1645551074151-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1645551074151-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1645551074151-x700.jpg",
