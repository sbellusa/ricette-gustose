  "cooking_instructions": [
    {
      "instruction": "<p>Rinse your <strong>brown rice</strong>, add it to a pot with plenty of <strong>cold water</strong> and bring to the boil over a high heat</p><p>Once boiling, reduce the heat to medium and cook for 20-25 min or until it's tender with a slight bite</p><p>Once cooked, drain, return it to the pot and keep covered until serving</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1660650720328-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1660650720328-x400.jpg",
            "width": 400
