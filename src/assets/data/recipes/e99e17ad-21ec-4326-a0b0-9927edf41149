            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1626718165248-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the mushrooms have browned, add the <strong>tomato stock</strong> and cook, covered, for 12-13 min or until the liquid has reduced and the mushrooms have softened</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1626718169384-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-5-1626718169384-x400.jpg",
