            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Combine most of the <strong>chopped chives</strong> (save some for garnish!) with the<strong> mayo</strong></p><p>Add a little splash of <strong>cold water</strong> to loosen and season with a crack of <strong>black pepper </strong>– this is your <strong>chive mayo</strong></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1607345462841-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1607345462841-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1607345462841-x700.jpg",
