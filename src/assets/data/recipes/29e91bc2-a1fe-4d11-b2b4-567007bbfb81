          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1607345453427-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the fritters are cooking, chop the <strong>chives</strong> finely</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-copy-1637942976271-x200.jpg",
