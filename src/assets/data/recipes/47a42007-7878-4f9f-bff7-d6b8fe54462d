            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, top, tail, peel and grate your<strong> carrot[s]</strong></p><p>Top, tail and grate your <strong>courgette[s]</strong></p><p>Trim, then slice your <strong>spring onion[s]</strong> finely</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1684853052667-x200.jpg",
