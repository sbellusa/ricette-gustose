            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, boil a kettle</p>\r\n<p>Peel the <strong>onion</strong><strong><span class=\"text-danger\">[s]</span></strong>, <strong>carrot</strong><strong><span class=\"text-danger\">[s]</span></strong> and <strong>garlic</strong></p>\r\n<p>Grate the <strong>onion</strong><strong><span class=\"text-danger\">[s]</span></strong>, <strong>carrot</strong><span class=\"text-danger\"><strong>[s]</strong></span>, <strong>garlic</strong> and <strong>mushrooms</strong></p>\r\n<p>Tip: alternatively bung everything in a food processor for speedier results!</p>\r\n<p>&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-1-x700.jpg",
            "width": 700
          },
