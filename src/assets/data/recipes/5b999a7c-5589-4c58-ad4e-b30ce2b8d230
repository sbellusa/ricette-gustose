            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add all of the <strong>grated</strong> <strong>vegetables</strong> to the pan</p>\r\n<p>Season with a generous pinch of <strong>salt</strong></p>\r\n<p>Cook for 4 min until soft and caramelised</p>",
      "order": 3,
      "media": {
        "images": [
