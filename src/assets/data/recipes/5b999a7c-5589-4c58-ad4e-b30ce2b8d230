  "cooking_instructions": [
    {
      "instruction": "<p>Heat a large, wide-based pan with a drizzle of <strong>olive</strong> <strong>oil</strong> over a medium-high heat</p>\r\n<p>Squeeze the <strong>sausage</strong><strong>meat</strong> out of their casings directly into the pan</p>\r\n<p>Cook for 5 min until the <strong>sausagemeat</strong> is brown and crispy, breaking it up into small pieces with a wooden spoon as you go&nbsp;</p>\r\n<p>&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/777.-step-2-x400.jpg",
            "width": 400
