            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, top, tail and chop your <strong>courgette[s] </strong>into quarters lengthways, then slice finely</p><p>Slice your<strong> spring onion[s]</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1692954653825-x200.jpg",
