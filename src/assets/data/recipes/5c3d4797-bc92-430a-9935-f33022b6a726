            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the hake and rice are cooking, cut your <strong>cucumber </strong>in half lengthways, then slice finely</p><p>Peel and slice the<strong> remaining onion </strong>finely</p><p>Cut your <strong>tomato[es]</strong> into wedges</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1682405529959-x200.jpg",
