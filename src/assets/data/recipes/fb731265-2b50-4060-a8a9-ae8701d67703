            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dust your work surface with a generous sprinkling of <strong>flour</strong></p><p>Unwrap the <strong>puff pastry</strong> and roll it out with a <strong>rolling pin</strong> until it is large enough to cover the <strong>oven proof dish<span class=\"text-danger\">[es]</span></strong></p>",
      "order": 3,
      "media": {
