  "cooking_instructions": [
    {
      "instruction": "<p>Boil a kettle</p><p>Cut the <strong>waxy</strong> <strong>potatoes</strong> in half and add them to a pot of <strong>boiled water</strong> with a large pinch of <strong>salt</strong></p><p>Bring to the boil and cook over a high heat for 12-15 min or until fork-tender</p><p>Once cooked, drain and return them to the pot</p>",
      "order": 1,
      "media": {
        "images": [
