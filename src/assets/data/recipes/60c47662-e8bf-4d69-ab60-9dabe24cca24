          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add the <strong>chopped potatoes</strong> and <strong>creamy stock</strong></p>\n<p>Cook, covered for 15-20 min or until the potatoes are cooked through</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-7-x200.jpg",
