          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-4.new-x1500.png",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>chicken stock cube<span class=\"text-danger\">[s]</span></strong> in 300ml <span class=\"text-danger\">[600ml]</span> <strong>boiled water</strong></p>\n<p>Add the <strong>soft cheese</strong> to the stock – this is your <strong>creamy stock</strong></p>\n<p>Chop the <strong>potatoes</strong> into small bite-sized pieces</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Once the <strong>leek</strong> and <strong>mushroom</strong> have softened, add the <strong>chopped thyme</strong> and <strong>garlic</strong> and cook for 1 min or until fragrant</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1851.-step-6-x1000.jpg",
