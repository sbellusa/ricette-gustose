          }
        ]
      }
    },
    {
      "instruction": "<p>Once fragrant, add 1 tbsp <span class=\"text-purple\">[1 1/2 tbsp]</span><span class=\"text-danger\"> [2 tbsp] </span><strong>flour</strong> to the pan and cook for 30 secs until a sandy paste has formed</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1676374681912-x200.jpg",
            "width": 200
