        ]
      }
    },
    {
      "instruction": "<p><strong>Now, let's get started!</strong></p><p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil a kettle</p><p>Heat a large, wide-based <strong>oven-proof casserole dish </strong>with a matching lid with a drizzle of <strong>olive oil</strong> over a medium-high heat</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1606305200419-x200.jpg",
