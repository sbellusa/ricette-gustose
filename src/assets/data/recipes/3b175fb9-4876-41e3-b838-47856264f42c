          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-6-1722349380390-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Use this time to clear up, set the table, have a cup of tea or simply chill!</p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1722349388488-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1722349388488-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1722349388488-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1722349388488-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-7-1722349388488-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Drizzle your <strong>natural</strong> <strong>yoghurt</strong> over the <strong>Fable mushroom aloo gosht </strong>and dollop on your <strong>mango chutney</strong></p><p>Scatter over the <strong>remaining sliced chilli </strong>(not a fan of spice? Just add a little!)</p><p>Serve the <strong>basmati rice</strong> to the side</p><p>Dig in!</p>",
      "order": 8,
