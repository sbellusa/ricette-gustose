          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1651596361660-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Once hot, add the <strong>pepper strips</strong> and <strong>sliced onion</strong> with a pinch of <strong>salt</strong> and cook for 7-8 min or until softened</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1651596367556-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1651596367556-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1651596367556-x700.jpg",
