            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280__-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely chop (or grate) the<strong> garlic&nbsp;</strong></p>\r\n<p>Peel and chop the<strong> carrot<span class=\"text-danger\">[s]</span></strong> finely</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-2-x200.jpg",
            "width": 200
          },
          {
