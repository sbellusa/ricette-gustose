          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Crumble the<strong>&nbsp;beef stock cube<span class=\"text-danger\">[s]</span></strong>&nbsp;into the <strong>beef mince</strong></p>\r\n<p>Add the <strong>tomato paste</strong>, 1/2 tsp&nbsp;<span class=\"text-danger\">[1&nbsp;tsp]</span><strong>&nbsp;sugar</strong> and the <strong>balsamic vinegar</strong></p>\r\n<p>Reduce the heat to medium and cook for a further 4 min&nbsp;</p>\r\n<p>Meanwhile, chop the <strong>chestnut&nbsp;mushrooms</strong> into quarters</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-4-x200.jpg",
            "width": 200
