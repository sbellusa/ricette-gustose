          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat&nbsp;a large, wide-based pan (preferably non-stick) with 1-2 tbsp <strong>olive oil</strong> over a high heat</p>\r\n<p>Once&nbsp;hot, add the<strong> chopped&nbsp;carrot</strong> and cook for 30 sec&nbsp;</p>\r\n<p>Add the <strong>beef mince</strong>, break it up with a wooden spoon and cook for a further 30 sec</p>\r\n<p>Add the <strong>chopped&nbsp;garlic</strong> and cook for a further 3 min, or until the meat is no longer pink</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/280.step-3-x400.jpg",
            "width": 400
