  "cooking_instructions": [
    {
      "instruction": "<p><strong>Add</strong> the rice, 375ml <span class=\"text-danger\">(750ml)</span> of water and salt (optional) to a pot with a lid on a high heat and bring to the boil</p>\r\n<p><strong>Once</strong> boiling, reduce to a simmer and cook with the lid on for 15-20 min or until all the water is absorbed</p>\r\n<p><strong>Check</strong> often to prevent over-cooking and once done, set aside until serving</p>",
      "order": 1,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Slice</strong> the steaks into very thin strips, against the grain</p>\r\n<p><strong>Bash</strong> the coriander seeds and rub onto the steak strips</p>\r\n<p><strong>Set</strong> aside to marinate</p>\r\n<p>Tip: You can use pestle or mortar, or bash the coriander seeds in a bag with a rolling pin</p>",
      "order": 2,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Cut</strong> each mangetout in half lengthways</p>\r\n<p><strong>Slice</strong> the ginger into round discs the thickness of a pound coin</p>\r\n<p><strong>Peel</strong> and slice the onion finely</p>\r\n<p><strong>Chop</strong> the spring onions coarsely,discarding the roots</p>",
      "order": 3,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> 1-2 tbsp of vegetable oil to a pan/ wok over a high heat<br />wok over a high heat</p>\r\n<p><strong>Add</strong> the ginger and cook for 1 min, stirring it once or twice</p>\r\n<p>Tip: Make sure the wok/pan is red hot before adding in the ginger</p>",
      "order": 4,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the onion (not the spring onion) to the pan</p>\r\n<p><strong>Add</strong> 70ml <span class=\"text-danger\">(100ml)</span> of water to the pan</p>\r\n<p><strong>Cook</strong> the onion for 1 min or until soft</p>",
      "order": 5,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the marinated beef strips to the pan</p>\r\n<p><strong>Cook</strong> for 1 min or until the beef is almost cooked</p>",
      "order": 6,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Add</strong> the mangetout to the pan and cook for 1 min</p>\r\n<p><strong>Add</strong> the soy sauce to the pan and cook for 2 min</p>\r\n<p><strong>Remove</strong> the pan from heat</p>\r\n<p><strong>Pour</strong> both the shaoxing wine and sesame oil to the pan, glossing the dish</p>",
      "order": 7,
      "media": {
        "images": []
      }
    },
    {
      "instruction": "<p><strong>Remove</strong> the ginger slices from the pan before serving</p>\r\n<p><strong>Serve</strong> the beef on a bed of rice and&nbsp;sprinkle with spring onions</p>\r\n<p>Enjoy!</p>",
      "order": 8,
      "media": {
        "images": []
      }
    }
