            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>conchiglie</strong> to a pot of <strong>boiled water </strong>with a pinch of <strong>salt </strong>and bring to the boil over a high heat</p><p>Cook the <strong>conchiglie</strong> for 8-10 min or until cooked with a slight bite</p><p>Once done, drain the <strong>conchiglie</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1688730083855-x200.jpg",
