          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1643797432970-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>While the beef is browning, dice the <strong>tomato<span class=\"text-danger\">[es]</span> </strong>roughly</p><p>Once starting to brown, add the <strong>sliced garlic </strong>and <strong>diced tomato </strong>to the beef and cook for 2-3 min further</p>",
      "order": 3,
      "media": {
        "images": [
