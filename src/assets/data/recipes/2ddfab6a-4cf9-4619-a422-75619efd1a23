            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Heat a pot with a drizzle of <strong>vegetable oil</strong> over a medium heat</p><p>Once hot, add the <strong>chopped garlic</strong> with a pinch of <strong>salt</strong> and cook for 1-2 min or until fragrant</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-2-1678376282376-x200.jpg",
