          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-3-1590499773075-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve 1/2 <span class=\"text-danger\">[1]</span> <strong>Knorr</strong> <strong>chicken stock cube</strong> in 100ml <span class=\"text-danger\">[150ml]<strong> </span>boiled water </strong>– this is your <strong>chicken stock</strong></p><p>Add the <strong>chicken stock</strong> to the pan with the <strong>chopped tomatoes</strong> and <strong>drained potatoes</strong></p><p>Stir through <strong>half</strong> the <strong>chopped basil </strong>– this is your <strong>tomato sauce</strong></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-4-1590499778999-x200.jpg",
