  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7</p><p>Heat a large, wide-based pan (preferably non-stick) with a drizzle of <strong>vegetable oil</strong> over a medium-high heat</p><p>Peel and finely chop the <strong>shallot<span class=\"text-danger\">[s]</span></strong></p><p>One hot, add the <strong>chopped shallot</strong> and <strong>lean beef mince</strong> to the pan and cook for 2-3 min or until the mince is browned, breaking it up with a wooden spoon as you go</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1614619678798-x200.jpg",
            "width": 200
