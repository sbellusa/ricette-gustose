            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Trim, then slice your <strong>spring onion[s]</strong> finely</p><p>Chop your <strong>coriander</strong> finely, including the stalks</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/353.-.step-5-x200.jpg",
