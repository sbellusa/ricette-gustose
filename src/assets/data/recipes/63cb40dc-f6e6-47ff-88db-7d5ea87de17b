          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679661321094-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679661321094-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Transfer the <strong>marinated chicken skewer[s]</strong> to a<strong> tin foil</strong>-lined baking tray (or two!)</p><p>Put the tray[s] in the oven for 22-25 min or until the chicken is slightly charred and cooked through (no pink meat!) – this is your <strong>chicken thigh souvlaki skewer</strong></p><p>Once cooked through, slide and slice <strong>half</strong> of the <strong>chicken thigh souvlaki</strong> off each skewer on a clean board</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1679661324739-x200.jpg",
            "width": 200
