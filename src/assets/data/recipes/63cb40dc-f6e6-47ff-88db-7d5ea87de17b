          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1679661324739-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, slice <strong>half</strong> of your <strong>cucumber</strong><span class=\"text-danger\"> </span>into discs</p><p>Cut the <strong>remaining cucumber</strong> in half lengthways, scrape out the inner seeds with a teaspoon and discard</p><p>Grate the <strong>deseeded cucumber</strong> and squeeze out any excess water</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1710494249510-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-5-1710494249510-x400.jpg",
