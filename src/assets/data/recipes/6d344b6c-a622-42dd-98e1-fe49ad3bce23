            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680018730628-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1680018730628-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Meanwhile, peel and finely slice (don't chop!) your <strong>garlic</strong></p><p>Chop your <strong>creamed coconut</strong> roughly (if required!)</p><p>Trim, then slice your <strong>spring onion[s]</strong></p>",
      "order": 2,
      "media": {
