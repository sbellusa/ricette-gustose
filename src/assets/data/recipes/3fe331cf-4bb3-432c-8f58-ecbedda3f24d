  "cooking_instructions": [
    {
      "instruction": "<p><strong>Preheat</strong> the oven to 180&deg;C/ 160&deg;C (fan)/ 355&deg;F/ Gas 4</p>\r\n<p><strong>Rinse</strong> the lentils in a sieve under the cold tap and place them in a large pot that's big enough to fit all the ingredients in (with a lid) with 500ml <span class=\"text-danger\">(800ml)</span> of cold water</p>\r\n<p><strong>Bring</strong> to the boil on a high heat, when boiling, add the lid and cook for 20-25 min&nbsp;</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, peel the onion<span class=\"text-danger\">(s)</span> and cut them into 2cm wedges</p>\r\n<p><strong>Set</strong> 2 <span class=\"text-danger\">(4)</span> of the wedges aside for step 3</p>\r\n<p><strong>Roughly</strong> seperate the leaves of the remaining wedges and place them on a non-stick baking tray (or use foil to avoid mess)&nbsp;</p>\r\n<p><strong>Drizzle</strong> them with 1-2 tbsp of olive oil and season generously with salt - put them in the oven for 12-15 min or until cooked and starting to caramelise</p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Meanwhile</strong>, dice the reserved red onion finely</p>\r\n<p><strong>Add</strong> it to a small bowl and pour the balsamic vinegar over</p>\r\n<p><strong>Leave</strong> the onion to marinade in the vinegar until step 8</p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Boil</strong> a kettle for your stock in the next step</p>\r\n<p><strong>Top</strong> and tail the green beans and slice them in half widthways</p>\r\n<p><strong>Cut</strong> the cherry tomatoes in half</p>\r\n<p><strong>Chop</strong> the black olives roughly&nbsp;</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Dissolve</strong> the stock cube<span class=\"text-danger\">(s)</span> in 100ml <span class=\"text-danger\">(120ml)</span> of boiled water and whisk to combine</p>\r\n<p><strong>Drain</strong> and rinse the cannellini beans&nbsp;</p>\r\n<p><strong>Once</strong> the lentils are nearly tender drain them for the next step</p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/341.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><strong>Return</strong> the drained lentils to their cooking pot and add the stock and green beans</p>\r\n<p><strong>Add</strong> a lid to the pan and cook for a further 5 min or until the beans are tender</p>\r\n<p><strong>Remove</strong> the lid, and add the cannellini beans, stirring to warm through for 3-4 min</p>",
