  "cooking_instructions": [
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Boil</strong> a kettle</span></p>\r\n<p><span class=\"text-highlight\"><strong>Preheat</strong> the oven to 220&deg;C/ 200&deg;C (fan)/ 425&deg;F/ Gas 7</span></p>\r\n<p><span class=\"text-highlight\"><strong>Cut</strong> the potatoes&nbsp;(skin on) into large bite-size pieces</span></p>\r\n<p><span class=\"text-highlight\"><strong>Slice</strong> the spring onion[s] finely, discarding the root ends</span></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-1-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-1-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-1-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-1-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-1-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Add</strong> the potatoes to a pot of salted boiling water over a high heat and cook for 15-20 min or until fork tender&nbsp;</span></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-2-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-2-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-2-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-2-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-2-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Add</strong> the sausages to a baking tray (use tin foil to avoid mess!) and place in the oven for 20 min or until cooked through and nicely browned</span></p>\r\n<p><span class=\"text-highlight\"><strong>Meanwhile</strong>, separate the spring greens leaves, discarding any tough stalks&nbsp;</span></p>\r\n<p><span style=\"background-color: #ffff00;\"><strong>Layer</strong> the leaves over each other then roll them up and slice them into thin strips&nbsp;</span></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step3-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step3-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step3-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step3-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step3-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Heat</strong> a large wide-based pan (preferably non-stick with a matching lid) with 1 tbsp [2 tbsp] vegetable oil over a high heat</span></p>\r\n<p><span class=\"text-highlight\"><strong>Once</strong> hot, add the&nbsp;spring greens,&nbsp;spring onion&nbsp;and a generous pinch of salt and pepper</span></p>\r\n<p><span class=\"text-highlight\"><strong>Cook</strong> for 4-5 min, then add a splash of water, cover and cook for a further 2 min</span></p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-4-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-4-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-4-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-4-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-4-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span style=\"background-color: #ffff00;\"><strong>Drain</strong> the cooked potatoes and return them to the pan</span></p>\r\n<p><span class=\"text-highlight\"><strong>Add</strong> the spring greens (reserve the pan for the next step), a large knob of butter, a splash of milk and a pinch of salt and pepper </span></p>\r\n<p><span class=\"text-highlight\"><strong>Mash</strong> thoroughly until smooth - this is your colcannon</span></p>",
      "order": 5,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step5-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step5-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step5-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step5-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Meanwhile</strong>, finely dice (or grate) the apples (skin on), discarding the cores</span></p>\r\n<p><span class=\"text-highlight\"><strong>Chop</strong> the chives finely</span></p>\r\n<p><span class=\"text-highlight\"><strong>Return</strong> the reserved pan to a low heat with a small knob of butter and add the apples and chives</span></p>\r\n<p><span class=\"text-highlight\"><strong>Cover</strong> and cook for 4-5 min or until the apples are soft&nbsp;</span></p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-6-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-6-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-6-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-6-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step-6-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Once</strong> softened, add a pinch of sugar and a very small splash of water to the apples</span></p>\r\n<p><span class=\"text-highlight\"><strong>Taste</strong> for seasoning, adding salt and pepper if needed - this is your apple compote&nbsp;</span></p>",
      "order": 7,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step7-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step7-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step7-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step7-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/558.-step7-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p><span class=\"text-highlight\"><strong>Serve</strong> the cooked sausages over the colcannon and top with the apple compote</span></p>\r\n<p><strong><span class=\"text-highlight\">Enjoy!</span></strong></p>",
      "order": 8,
