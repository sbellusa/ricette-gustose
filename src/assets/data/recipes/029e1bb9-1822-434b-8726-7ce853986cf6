  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle</p><p>Slice your <strong>aubergine[s]</strong> in half lengthways, keeping the green stalk on, then score the<strong> </strong>flesh in a criss-cross pattern and add the <strong>aubergine halves</strong> to a baking tray (or two!) with a drizzle of <strong>olive oil</strong> and a pinch of<strong> salt</strong></p><p>Put the tray[s] in the oven for 20-25 min or until the flesh has softened</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684229663212-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684229663212-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-1-1684229663212-x700.jpg",
            "width": 700
