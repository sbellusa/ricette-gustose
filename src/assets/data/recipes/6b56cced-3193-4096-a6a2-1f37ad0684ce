  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 240ºC/ 220ºC (fan)/ gas 9</p><p>Put a large baking tray <span class=\"text-danger\">[or 2]</span> in the oven to heat up (this will stop the pizza bottoms from going soggy!)</p><p>Add the <strong>dried</strong> <strong>yeast</strong><span class=\"text-danger\"> </span>to a large bowl with 100ml <span class=\"text-danger\">[200ml]</span> <strong>warm water </strong>and 1 tsp<span class=\"text-danger\"> [2 tsp]</span> <strong>sugar</strong></p><p>Give it a good mix up and set aside for 5-10 min for the yeast to develop</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1597748235213-x200.jpg",
