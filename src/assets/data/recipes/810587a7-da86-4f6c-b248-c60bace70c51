          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679590648279-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add your <strong>seasoned chicken</strong> and <strong>crushed garlic</strong> to the dish with your <strong>cherry tomatoes</strong>, a generous drizzle of <strong>olive oil</strong> and a pinch of <strong>salt</strong></p><p>Give everything a good mix up, leaving the chicken at the top and put the dish in the oven for an initial 10-15 min</p>",
      "order": 4,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-4-1679590652436-x200.jpg",
            "width": 200
          },
          {
