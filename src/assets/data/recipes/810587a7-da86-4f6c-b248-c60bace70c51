          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1679590644133-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Crush your<strong> garlic cloves </strong>by squashing them with the side of a knife and discard the skins</p><p>Pat the <strong>chicken breast portion[s]</strong> dry with kitchen paper and season them with a generous pinch of <strong>salt</strong></p>",
      "order": 3,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679590648279-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679590648279-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679590648279-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-3-1679590648279-x1000.jpg",
