            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/1402.-step-5-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Add the <strong>fragrant sauce </strong>to the pan and cook for 30 secs</p>",
      "order": 6,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-1705677629269-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-1705677629269-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/step-6-copy-1705677629269-x700.jpg",
            "width": 700
