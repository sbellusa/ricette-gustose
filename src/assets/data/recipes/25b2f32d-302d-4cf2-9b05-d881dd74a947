  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 220°C/ 200°C (fan)/ gas 7 and boil a kettle, then take your <strong>chicken</strong> out of the fridge, open the packet and let it air</p><p>Peel the <strong>garlic</strong> and roughly tear the<strong> basil</strong>, including the stalks (reserve a couple of leaves for garnish!)</p><p>Add the <strong>peeled</strong> <strong>garlic</strong>,<strong> torn</strong> <strong>basil</strong> and a large knob of<strong> butter </strong>to a <strong>food processor </strong>and pulse until blitzed but not smooth – this is your <strong>basil butter</strong></p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1696323224892-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1696323224892-x400.jpg",
            "width": 400
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1696323224892-x700.jpg",
            "width": 700
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1696323224892-x1000.jpg",
            "width": 1000
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1696323224892-x1500.jpg",
            "width": 1500
          }
        ]
      }
    },
    {
      "instruction": "<p>Dissolve the <strong>chicken stock mix</strong> in 350ml <span class=\"text-danger\">[650ml] </span><strong>boiled water</strong></p>",
      "order": 2,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-2-1696323233557-x200.jpg",
            "width": 200
