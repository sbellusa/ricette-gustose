  "cooking_instructions": [
    {
      "instruction": "<p>Preheat the oven to 200°C/ 180°C (fan)/ gas 6</p><p>Boil half a kettle</p><p>Add the <strong>portobello mushrooms</strong> to a tray and drizzle over the <strong>soy sauce</strong></p><p>Put the tray in the oven for 15-20 min or until the mushrooms are cooked through and tender</p>",
      "order": 1,
      "media": {
        "images": [
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1626787001767-x200.jpg",
            "width": 200
          },
          {
            "image": "https://production-media.gousto.co.uk/cms/recipe-step-image/Step-1-1626787001767-x400.jpg",
